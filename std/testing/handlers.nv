// std/testing/handlers.nv — детерминированные handler-фабрики для
// `Random` и `Time` эффектов. Главный инструмент для тестов, которые
// зависят от случайности или времени.
//
// AI-first идея: вместо mock-библиотек и monkey-patching — handler
// substitution через `with` (D11/D61). Та же функция `Bcrypt.hash` в
// production видит CSPRNG, в тестах — детерминированный PRNG, без
// какого-либо изменения сигнатуры.
//
// API:
//
//   // PRNG с фиксированным seed — xoshiro256++ quality.
//   fn seeded(seed u64) -> Handler[Random]
//
//   // Time зафиксирован на одном моменте; sleep — no-op.
//   fn fixed_ms(ms u64) -> Handler[Time]
//
//   // Mutable test clock: sleep(d) продвигает время на d.
//   // Полезно для rate_limiter/retry/cron тестов где нужно advance.
//   fn mut_clock(start_ms u64) -> Handler[Time]
//
// Использование:
//
//   import std.testing.handlers as th
//
//   test "uuid v4 детерминирован под seeded" {
//       let u1 = with Random = th.seeded(42) { Uuid.v4() }
//       let u2 = with Random = th.seeded(42) { Uuid.v4() }
//       assert(u1 == u2)
//   }
//
//   test "rate_limiter: refill после 1s" {
//       with Time = th.mut_clock(0), Random = th.seeded(7) {
//           let bucket = TokenBucket.new(10, 1.0)
//           bucket.try_acquire()         // 9 tokens left
//           Time.sleep(1.second())       // virtual clock advance
//           bucket.try_acquire()         // refilled to 10, теперь 9
//       }
//   }
//
// Composability:
//   with Random = th.seeded(42), Time = th.fixed_ms(0) { ... }
//
// PRNG: xoshiro256++ by Sebastiano Vigna (public domain, CC0).
//   https://prng.di.unimi.it/xoshiro256plusplus.c
// State init: splitmix64 для расширения 64-bit seed → 4×u64 state.
//   https://prng.di.unimi.it/splitmix64.c
//
// Не для production: `seeded` — НЕ криптографически стойкий.
// Для production используется встроенный `Random` handler (CSPRNG via
// runtime), который и активен по-умолчанию. См. spec/open-questions.md
// → `secure()` будущая фабрика для CSPRNG.

module testing.handlers


// Random — effect-тип для PRNG. Объявлен здесь же, в handlers.nv:
// codegen генерирует NovaVtable_Random + thread-local handler при первом
// `type Random effect` декларации, и все импортирующие модули видят
// определение через инлайн-import (resolve_imports_inline).
/// Random effect — ambient PRNG. Replace в тестах через `with Random = th.seeded(...)`
/// для детерминированности.
#stable(since = "0.1")
export type Random effect {
    u64() -> u64                        // 64 случайных бита
    bytes(n int) -> []byte              // массовая генерация
}


// ──────────────────────────────────────────────────────────────────────────
// Random — xoshiro256++ handler-фабрика
// ──────────────────────────────────────────────────────────────────────────
//
// xoshiro256++ — современный PRNG с отличной statistical quality
// (passes BigCrush и PractRand), периодом 2^256 - 1 и быстрой
// генерацией (≈ 1.36ns/operation на современных x86).
//
// State — 4×u64 = 256 bits. Init через splitmix64: 64-bit seed
// расширяется до 4 хороших начальных u64 без correlation между ними.
//
// Алгоритм:
//   result = rotl(s[0] + s[3], 23) + s[0]
//   t = s[1] << 17
//   s[2] ^= s[0]
//   s[3] ^= s[1]
//   s[1] ^= s[2]
//   s[0] ^= s[3]
//   s[2] ^= t
//   s[3] = rotl(s[3], 45)
//   return result

// splitmix64 для seed init — гарантирует non-zero state даже при seed=0.
// Note: `mut`-параметр не поддержан парсером (Plan 34 Ф.2), поэтому
// явная локальная mut переменная.
fn splitmix64_step(seed u64) -> u64 {
    let mut z = seed + 0x9E3779B97F4A7C15
    z = (z ^ (z >> 30)) * 0xBF58476D1CE4E5B9
    z = (z ^ (z >> 27)) * 0x94D049BB133111EB
    z ^ (z >> 31)
}

fn rotl64(x u64, k int) -> u64 =>
    (x << k) | (x >> (64 - k))


/// xoshiro256++ Random handler, детерминированный по `seed`. Same seed → same sequence.
/// Works for seed=0 (splitmix64 гарантирует non-zero state).
///
/// # Examples
/// ```nova
/// with Random = th.seeded(42) {
///     let u = Uuid.v4()  // deterministic
/// }
/// ```
#stable(since = "0.1")
export fn seeded(seed u64) -> Handler[Random] {
    // Расширяем 64-bit seed → 4×u64 state через splitmix64.
    let mut z = seed
    z = splitmix64_step(z); let mut s0 = z
    z = splitmix64_step(z); let mut s1 = z
    z = splitmix64_step(z); let mut s2 = z
    z = splitmix64_step(z); let mut s3 = z

    // Cached extra bytes из последнего u64() — для bytes(n) perf.
    let mut buf_remaining = 0
    let mut buf u64 = 0

    handler Random {
        u64() {
            // xoshiro256++ step.
            let result = rotl64(s0 + s3, 23) + s0
            let t = s1 << 17
            s2 = s2 ^ s0
            s3 = s3 ^ s1
            s1 = s1 ^ s2
            s0 = s0 ^ s3
            s2 = s2 ^ t
            s3 = rotl64(s3, 45)
            // Invalidate byte cache — следующий bytes() возьмёт fresh state.
            buf_remaining = 0
            return result
        }
        bytes(n) {
            // Production: 8 байт за один advance state.
            let mut out []byte = []
            let mut i = 0
            while i < n {
                if buf_remaining == 0 {
                    // Direct xoshiro256++ step (inlined, без invalidate).
                    let result = rotl64(s0 + s3, 23) + s0
                    let t = s1 << 17
                    s2 = s2 ^ s0
                    s3 = s3 ^ s1
                    s1 = s1 ^ s2
                    s0 = s0 ^ s3
                    s2 = s2 ^ t
                    s3 = rotl64(s3, 45)
                    buf = result
                    buf_remaining = 8
                }
                out.push((buf & 0xFF) as byte)
                buf = buf >> 8
                buf_remaining = buf_remaining - 1
                i = i + 1
            }
            out
        }
    }
}


// ──────────────────────────────────────────────────────────────────────────
// Time — handler-фабрики
// ──────────────────────────────────────────────────────────────────────────


/// `Time` handler с fixed timestamp. `sleep(d)` — no-op. Для тестов где
/// продвижение времени не нужно (uuid v7, jwt exp checks).
#stable(since = "0.1")
export fn fixed_ms(ms u64) -> Handler[Time] {
    handler Time {
        now_ms() => ms
        now_ns() => ms * 1_000_000
        now() => Timestamp.from_unix_millis(ms as i64)
        sleep(d) => ()
    }
}


/// `Time` handler с virtual mutable clock. `sleep(d)` продвигает время на d (no real wait).
/// Для rate_limiter/retry/cron тестов — точная имитация прошедшего времени.
///
/// Sub-ms durations округляются floor.
#stable(since = "0.1")
export fn mut_clock(start_ms u64) -> Handler[Time] {
    let mut current_ms = start_ms
    handler Time {
        now_ms() => current_ms
        now_ns() => current_ms * 1_000_000
        now() => Timestamp.from_unix_millis(current_ms as i64)
        sleep(d Duration) {
            // Duration внутри — i64 nanos (см. std/time/duration.nv).
            // Конверсия в ms через целочисленное деление.
            //
            // Plan 65 Ф.1: explicit `Duration` annotation forces handler-body
            // codegen to use `Nova_Duration*` instead of the schema-derived
            // `nova_int` param type. Without this, importing this module
            // from any test causes invalid C `(nova_int).nanos`. The fix is
            // codegen-side (emit_handler_lit honours annotation when present),
            // see [M-handler-duration-schema-mismatch] in docs/simplifications.md
            // for the broader Time-effect schema mismatch issue.
            let nanos = d.nanos
            let delta_ms = if nanos > 0 {
                (nanos / 1_000_000) as u64
            } else {
                0 as u64
            }
            current_ms = current_ms + delta_ms
        }
    }
}


// ──────────────────────────────────────────────────────────────────────────
// Self-tests
// ──────────────────────────────────────────────────────────────────────────

// ── Sanity ────────────────────────────────────────────────────────────────

test "seeded даёт детерминированную последовательность" {
    let (a, b) = with Random = seeded(42 as u64) {
        (Random.u64(), Random.u64())
    }
    let (a2, b2) = with Random = seeded(42 as u64) {
        (Random.u64(), Random.u64())
    }
    assert(a == a2)
    assert(b == b2)
    assert(a != b)
}

test "seeded — разные seed дают разные последовательности" {
    let v1 = with Random = seeded(1 as u64) { Random.u64() }
    let v2 = with Random = seeded(2 as u64) { Random.u64() }
    assert(v1 != v2)
}

test "seeded(0) работает (splitmix64 init гарантирует non-zero state)" {
    let v = with Random = seeded(0 as u64) { Random.u64() }
    // xoshiro256++ из splitmix64-инициализированного state не даёт 0
    // на первом шаге для seed=0.
    assert(v != 0 as u64)
}

test "seeded.bytes возвращает запрошенную длину" {
    let bs = with Random = seeded(0 as u64) { Random.bytes(16) }
    assert(bs.len() == 16)
}

test "seeded.bytes — детерминизм между запусками" {
    let bs1 = with Random = seeded(99 as u64) { Random.bytes(32) }
    let bs2 = with Random = seeded(99 as u64) { Random.bytes(32) }
    assert(bs1.len() == bs2.len())
    let mut all_eq = true
    for i in 0..bs1.len() {
        if bs1[i] != bs2[i] { all_eq = false }
    }
    assert(all_eq)
}

// ── Distribution quality smoke tests ──────────────────────────────────────

test "PRNG: 1000 значений — non-trivial period (> 2^32)" {
    // xoshiro256++ имеет period 2^256-1. На 1000 итерациях не должно
    // быть повторений. Проверяем через простой check: первое и
    // последнее значение не равны, и среднее значение не близко к 0
    // или u64::MAX.
    with Random = seeded(12345 as u64) {
        let first = Random.u64()
        let mut last u64 = 0
        for _ in 0..999 {
            last = Random.u64()
        }
        assert(first != last)
    }
}

test "PRNG: uniform-byte distribution (no obvious bias)" {
    // Генерируем 256 байт, смотрим что нет очевидного bias:
    // каждый bucket [0..32, 32..64, ...] получил хотя бы 1 значение.
    // Это не строгий chi-square, но catches LCG-style low-bit bias.
    with Random = seeded(7 as u64) {
        let bs = Random.bytes(256)
        let mut buckets [8]int = [0, 0, 0, 0, 0, 0, 0, 0]
        for i in 0..bs.len() {
            let b = bs[i] as int
            let bucket = b / 32                 // 0..7
            buckets[bucket] = buckets[bucket] + 1
        }
        // Все 8 buckets должны иметь хотя бы 1 hit на 256 sample'ах.
        // LCG обычно проваливает этот тест из-за low-bit pattern.
        let mut filled = 0
        for i in 0..8 {
            if buckets[i] > 0 { filled = filled + 1 }
        }
        assert(filled == 8)
    }
}

test "PRNG: non-correlation между последовательными вызовами" {
    // Простой sanity — последовательные значения не должны быть
    // равны или отличаться на константу (что было бы у broken LCG).
    with Random = seeded(31337 as u64) {
        let a = Random.u64()
        let b = Random.u64()
        let c = Random.u64()
        assert(a != b)
        assert(b != c)
        // Разница a→b и b→c не должна быть равна (linear-recurrence).
        let d1 = if a > b { a - b } else { b - a }
        let d2 = if b > c { b - c } else { c - b }
        assert(d1 != d2)
    }
}

// ── Time handlers ─────────────────────────────────────────────────────────

test "fixed_ms.now_ms возвращает заданное значение" {
    let ms = with Time = fixed_ms(12345 as u64) { Time.now_ms() }
    assert(ms == 12345 as u64)
}

test "fixed_ms.sleep — no-op (время не двигается)" {
    with Time = fixed_ms(1000 as u64) {
        Time.sleep(100.millis())
        Time.sleep(1.second())
        assert(Time.now_ms() == 1000 as u64)
    }
}

test "mut_clock — sleep продвигает виртуальное время" {
    with Time = mut_clock(0 as u64) {
        assert(Time.now_ms() == 0 as u64)
        Time.sleep(500.millis())
        assert(Time.now_ms() == 500 as u64)
        Time.sleep(2.seconds())
        assert(Time.now_ms() == 2500 as u64)
    }
}

test "mut_clock — independent instances между with-блоками" {
    let m1 = with Time = mut_clock(1000 as u64) {
        Time.sleep(1.second())
        Time.now_ms()
    }
    let m2 = with Time = mut_clock(1000 as u64) {
        Time.sleep(5.seconds())
        Time.now_ms()
    }
    assert(m1 == 2000 as u64)
    assert(m2 == 6000 as u64)
}

test "seeded + fixed_ms композируются" {
    let r = with Random = seeded(42 as u64), Time = fixed_ms(5000 as u64) {
        Random.u64() + Time.now_ms()
    }
    assert(r != 0 as u64)
}

test "seeded + mut_clock композируются" {
    with Random = seeded(99 as u64), Time = mut_clock(0 as u64) {
        let v1 = Random.u64()
        Time.sleep(1.second())
        let v2 = Random.u64()
        assert(v1 != v2)
        assert(Time.now_ms() == 1000 as u64)
    }
}
