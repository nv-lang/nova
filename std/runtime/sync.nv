// ─── Mutex ───────────────────────────────────────────────────────

/// Fair FIFO fiber-aware mutex.
///
/// Park/wake через `nova_sched` — заблокированный fiber не потребляет CPU.
/// NOT reentrant: повторный `lock()` из того же fiber'а приведёт к deadlock.
///
/// # Examples
///
/// ```nova
/// let mu = Mutex.new()
/// mu.lock()
/// // critical section
/// mu.unlock()
/// ```
///
/// # See Also
///
/// - `[WaitGroup]` — ожидание завершения нескольких fiber'ов
/// - `[Once]` — exactly-once execution barrier
#stable(since = "0.1")
export external fn Mutex.new() -> Self

/// Захватить mutex. Паркует вызывающий fiber до освобождения.
///
/// NOT reentrant — повторный вызов из того же fiber'а deadlock.
#stable(since = "0.1")
export external fn Mutex mut @lock()

/// Освободить mutex. Будит следующий ожидающий fiber, если есть.
///
/// Должен вызываться только когда mutex захвачен данным fiber'ом.
#stable(since = "0.1")
export external fn Mutex mut @unlock()

/// Попытаться захватить mutex без блокировки.
///
/// Возвращает `true` если lock успешно захвачен, `false` если занят.
#stable(since = "0.1")
export external fn Mutex mut @try_lock() -> bool

// ─── WaitGroup ───────────────────────────────────────────────────

/// Counter-based rendezvous — ожидание завершения группы fiber'ов.
///
/// Паттерн использования: `add(n)` перед spawn, `done()` в каждом fiber'е,
/// `wait()` в координирующем fiber'е.
///
/// # Examples
///
/// ```nova
/// let wg = WaitGroup.new()
/// wg.add(3)
/// spawn { work1(); wg.done() }
/// spawn { work2(); wg.done() }
/// spawn { work3(); wg.done() }
/// wg.wait()
/// ```
///
/// # See Also
///
/// - `[Mutex]` — взаимное исключение
/// - `[Once]` — exactly-once barrier
#stable(since = "0.1")
export external fn WaitGroup.new() -> Self

/// Увеличить счётчик на `delta`. Вызывать перед spawn'ом workers.
#stable(since = "0.1")
export external fn WaitGroup mut @add(delta int)

/// Уменьшить счётчик на 1. Будит все `wait()` если счётчик достиг 0.
///
/// Не должен вызываться больше раз, чем суммарно было передано в `add()`.
#stable(since = "0.1")
export external fn WaitGroup mut @done()

/// Парковать вызывающий fiber до достижения счётчиком нуля.
#stable(since = "0.1")
export external fn WaitGroup @wait()

// ─── OnceState ───────────────────────────────────────────────────

/// State of a `Once` execution barrier.
///
/// Variants: `Fresh` (not started), `Running` (init in progress),
/// `Done` (completed successfully), `Poisoned` (init panicked).
///
/// C representation pre-declared in sync_primitives.h.
#stable(since = "0.1")
export type OnceState
    | Fresh
    | Running
    | Done
    | Poisoned

// ─── Once (hardened, Plan 103.5) ─────────────────────────────────

/// Exactly-once execution barrier with panic-safe closure API.
///
/// `call_once(fn)` is the primary API: executes the closure exactly
/// once across all concurrent callers. If the closure panics, Once
/// transitions to `Poisoned` state; subsequent `call_once` calls also
/// panic. Use `is_completed()` / `state()` for observability.
///
/// Legacy `run()`/`done()` pair is deprecated — use `call_once` instead.
///
/// # Examples
///
/// ```nova
/// let init = Once.new()
/// init.call_once { || setup() }
/// assert(init.is_completed() == true)
/// ```
///
/// # See Also
///
/// - `[OnceCell]` — value-capturing one-time init
/// - `[Lazy]` — auto-init on first access
#stable(since = "0.1")
export external fn Once.new() -> Self

/// Execute `body` exactly once across all concurrent callers.
///
/// If `body` panics, Once transitions to `Poisoned` state.
/// Subsequent `call_once` calls re-panic (OncePoisoned).
/// All waiters are woken on completion or panic.
#stable(since = "0.1")
export external fn Once mut @call_once(body fn() -> ())

/// Returns `true` if Once has successfully completed (state == Done).
#stable(since = "0.1")
export external fn Once @is_completed() -> bool

/// Returns the current state of the Once barrier.
#stable(since = "0.1")
export external fn Once @state() -> OnceState

/// (Deprecated) Attempt to begin once execution.
///
/// Returns `true` if this fiber should execute the once-body.
/// Deprecated: use `call_once(fn)` instead (panic-safe primary API).
#deprecated(since = "0.1", note = "use call_once(fn) instead (panic-safe primary API)")
#stable(since = "0.1")
export external fn Once mut @run() -> bool

/// (Deprecated) Mark once body as complete.
///
/// Must be called exactly once by the fiber whose `run()` returned `true`.
/// Deprecated: use `call_once(fn)` instead (panic-safe primary API).
#deprecated(since = "0.1", note = "use call_once(fn) instead (panic-safe primary API)")
#stable(since = "0.1")
export external fn Once mut @done()

// ─── OnceCell[T] ─────────────────────────────────────────────────

/// A cell which can be written to at most once.
///
/// Supports reading before initialization (returns `None`), setting
/// once, and get-or-init with exactly-once semantics. After `take()`,
/// the cell is empty again and can be set once more.
///
/// Panic in `get_or_init` closure leaves cell empty (retry allowed),
/// unlike `Lazy` which poisons on panic.
///
/// # See Also
///
/// - `[Once]` — once-only execution without a value
/// - `[Lazy]` — auto-init wrapper (poisons on panic)
#stable(since = "0.1")
export external type OnceCell[T]

/// Create an empty OnceCell.
#stable(since = "0.1")
export external fn OnceCell[T].new() -> Self

/// Get the value if initialized, or `None` if empty.
#stable(since = "0.1")
export external fn OnceCell[T] @get() -> Option[T]

/// Set the value if the cell is empty.
///
/// Returns `true` on success, `false` if already initialized.
#stable(since = "0.1")
export external fn OnceCell[T] mut @set(v T) -> bool

/// Get the value, initializing with `init` if empty.
///
/// `init` runs at most once; concurrent callers park until init
/// completes. On panic in `init`, cell stays empty (retry allowed).
#stable(since = "0.1")
export external fn OnceCell[T] mut @get_or_init(init fn() -> T) -> T

/// Take the value out, leaving the cell empty.
///
/// Returns `Some(v)` if initialized, `None` if already empty.
/// After take(), the cell can be set or initialized again.
#stable(since = "0.1")
export external fn OnceCell[T] mut @take() -> Option[T]

/// Returns `true` if the cell has been initialized.
#stable(since = "0.1")
export external fn OnceCell[T] @is_initialized() -> bool

// ─── Lazy[T] ─────────────────────────────────────────────────────

/// A value that is lazily initialized on first `force()`.
///
/// The init closure runs exactly once; all concurrent callers of
/// `force()` receive the same value. If the init closure panics,
/// `Lazy` is poisoned — subsequent `force()` calls re-panic
/// (unlike `OnceCell.get_or_init` which allows retry).
///
/// # Examples
///
/// ```nova
/// let lazy = Lazy[int].new() { expensive_computation() }
/// let v = lazy.force()  // runs init if first call
/// ```
///
/// # See Also
///
/// - `[OnceCell]` — finer-grained control (set/take/retry)
/// - `[Once]` — once-only execution without a value
#stable(since = "0.1")
export external type Lazy[T]

/// Create a Lazy[T] with the given initializer closure.
#stable(since = "0.1")
export external fn Lazy[T].new(init fn() -> T) -> Self

/// Force initialization and return the value.
///
/// If already initialized, returns the cached value without running init.
/// On panic in init, Lazy is poisoned; subsequent calls re-panic.
#stable(since = "0.1")
export external fn Lazy[T] mut @force() -> T

/// Returns `true` if the value has been successfully initialized.
#stable(since = "0.1")
export external fn Lazy[T] @is_forced() -> bool

