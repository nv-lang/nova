// ─── AtomicInt ───────────────────────────────────────────────────

/// Lock-free атомарный целочисленный счётчик.
///
/// Использует acquire/release ordering для всех операций.
/// Ширина соответствует `nova_int` (platform word size).
///
/// # Examples
///
/// ```nova
/// let counter = AtomicInt.new(0)
/// counter.fetch_add(1)
/// assert(counter.load() == 1)
/// ```
///
/// # See Also
///
/// - `[AtomicBool]` — атомарный boolean
/// - `[Mutex]` — fiber-aware mutex для non-atomic критических секций
#stable(since = "0.1")
export external fn AtomicInt.new(v int) -> Self

/// Загрузить текущее значение (acquire ordering).
#stable(since = "0.1")
export external fn AtomicInt @load() -> int

/// Записать новое значение (release ordering).
#stable(since = "0.1")
export external fn AtomicInt mut @store(v int)

/// Атомарно добавить `delta`, вернуть предыдущее значение (acq_rel).
#stable(since = "0.1")
export external fn AtomicInt mut @fetch_add(delta int) -> int

/// Атомарно вычесть `delta`, вернуть предыдущее значение (acq_rel).
#stable(since = "0.1")
export external fn AtomicInt mut @fetch_sub(delta int) -> int

/// Compare-and-swap: если значение == `expected`, записать `desired`.
///
/// Возвращает `true` при успехе. Использует acq_rel ordering.
#stable(since = "0.1")
export external fn AtomicInt mut @compare_exchange(expected int, desired int) -> bool

// ─── AtomicBool ──────────────────────────────────────────────────

/// Lock-free атомарный булев флаг.
///
/// `swap()` полезен для one-shot ownership паттерна:
/// `if !flag.swap(true) { /* только первый caller выполняет */ }`.
///
/// Ordering-aware overloads добавлены в Plan 103.2.
/// Methods без `MemOrdering` используют `SeqCst` (M1) — safest default.
///
/// # See Also
///
/// - `[AtomicInt]` — deprecated integer atomic
/// - `[AtomicI64]` — preferred integer atomic
/// - `[Once]` — barrier для exactly-once execution
/// - `[MemOrdering]` — ordering parameter enum
#stable(since = "0.1")
export external fn AtomicBool.new(v bool) -> Self

/// Загрузить текущее значение с explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool @load(ord MemOrdering) -> bool
/// Загрузить текущее значение (SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool @load() -> bool

/// Записать новое значение с explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool mut @store(v bool, ord MemOrdering)
/// Записать новое значение (SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool mut @store(v bool)

/// Compare-and-swap с explicit orderings.
/// Возвращает `true` при успехе.
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange(expected bool, desired bool, success MemOrdering, failure MemOrdering) -> bool
/// Compare-and-swap (SeqCst/SeqCst ordering).
/// Возвращает `true` при успехе.
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange(expected bool, desired bool) -> bool

/// Compare-and-swap weak с explicit orderings. Может spuriously fail на ARM.
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange_weak(expected bool, desired bool, success MemOrdering, failure MemOrdering) -> bool
/// Compare-and-swap weak (SeqCst/SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange_weak(expected bool, desired bool) -> bool

/// Атомарно установить `v`, вернуть предыдущее значение с explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool mut @swap(v bool, ord MemOrdering) -> bool
/// Атомарно установить `v`, вернуть предыдущее значение (SeqCst ordering).
///
/// Полезен для one-shot ownership: `if !flag.swap(true) { /* first */ }`.
#stable(since = "0.1")
export external fn AtomicBool mut @swap(v bool) -> bool

/// Атомарный bitwise-OR, returns previous value. With explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_or(v bool, ord MemOrdering) -> bool
/// Атомарный bitwise-OR, returns previous value (SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_or(v bool) -> bool

/// Атомарный bitwise-AND, returns previous value. With explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_and(v bool, ord MemOrdering) -> bool
/// Атомарный bitwise-AND, returns previous value (SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_and(v bool) -> bool

/// Атомарный bitwise-XOR, returns previous value. With explicit ordering.
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_xor(v bool, ord MemOrdering) -> bool
/// Атомарный bitwise-XOR, returns previous value (SeqCst ordering).
#stable(since = "0.1")
export external fn AtomicBool mut @fetch_xor(v bool) -> bool

// ─── AtomicPtr ───────────────────────────────────────────────────

/// Lock-free atomic pointer (GC-managed reference).
