/// Загрузить текущее значение (SeqCst ordering).
#realtime
#stable(since = "0.1")
export external fn AtomicBool @load() -> bool

/// Записать новое значение с explicit ordering.
#realtime
#stable(since = "0.1")
export external fn AtomicBool mut @store(v bool, ord MemOrdering)
/// Записать новое значение (SeqCst ordering).
#realtime
#stable(since = "0.1")
export external fn AtomicBool mut @store(v bool)

/// Compare-and-swap с explicit orderings.
/// Возвращает `true` при успехе.
#realtime
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange(expected bool, desired bool, success MemOrdering, failure MemOrdering) -> bool
/// Compare-and-swap (SeqCst/SeqCst ordering).
/// Возвращает `true` при успехе.
#realtime
#stable(since = "0.1")
export external fn AtomicBool mut @compare_exchange(expected bool, desired bool) -> bool

/// Compare-and-swap weak с explicit orderings. Может spuriously fail на ARM.
