export fn str.new() -> Self => ""

// Convert a known-valid codepoint int ŌåÆ char. Return type `char` drives the
// Ok-arm coercion (mirrors std/encoding/base64.nv encode_char). Invalid cp
// cannot occur here ŌĆö ą║ą░ąČą┤čŗą╣ cp ą┐ąŠą╗čāčćąĄąĮ ąĖąĘ UTF-8 decode ą▓ą░ą╗ąĖą┤ąĮąŠą╣ čüčéčĆąŠą║ąĖ.
fn cp_to_char(cp int) -> char {
    match char.try_from(cp) {
        Ok(c)  => c,
        Err(_) => '\u{FFFD}',
    }
}

