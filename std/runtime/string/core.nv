// UTF-8 bytes ą║ą░ą║ []u8 (allocating copy). D178: renamed from @bytes().
// Plan 139 ąż.2: Nova-body ŌĆö ą║ąŠą┐ąĖčĆčāąĄčé ą▒ą░ą╣čéčŗ ąĖąĘ @as_bytes() (zero-copy view)
// ą▓ ąĮąŠą▓čŗą╣ []u8. ąĪąĄą╝ą░ąĮčéąĖą║ą░ ąĖą┤ąĄąĮčéąĖčćąĮą░ nova_str_to_bytes (ą┐ąŠą╗ąĮą░čÅ ą║ąŠą┐ąĖčÅ, owned).
export fn str @to_bytes() -> []u8 {
    // Plan 152.0 ąż.3: bulk copy via Vec.@append (RawMem.copy memmove) ŌĆö zero
    // push-loop. Owned []u8 copy of the bytes (identical to nova_str_to_bytes).
    mut out = []u8.with_capacity(@byte_len())
    out.append(@as_bytes())
