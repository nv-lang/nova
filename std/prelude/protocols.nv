//   `StringBuilder` (opaque runtime type, hardcoded РІ type-checker
//   builtins). Р”Рѕ 62.D.bis (РѕРїР°РєРѕРІС‹Рµ С‚РёРїС‹ в†’ `external type`) Display
//   declaration РЅРµ РјРѕР¶РµС‚ СЃСЃС‹Р»Р°С‚СЊСЃСЏ РЅР° StringBuilder С‡РµСЂРµР· cross-file
//   resolve. РЎРј. DEFER comment РЅРёР¶Рµ.
//
// **NOT modified (Plan 62.E explicit non-goals):**
//
// - Auto-derive Р»РѕРіРёРєР° D73 (From/Into) РІ compiler-codegen вЂ” РѕСЃС‚Р°С‘С‚СЃСЏ.
// - Built-in dispatch Hash/Eq/Ord РґР»СЏ РїСЂРёРјРёС‚РёРІРѕРІ (`int.hash()`,
//   `str.eq()`, etc.) РІ codegen вЂ” РѕСЃС‚Р°С‘С‚СЃСЏ.
// - `lints.rs:565` `collect_protocol_names` HashSet вЂ” РёРґРµРјРїРѕС‚РµРЅС‚РЅРѕ
//   СЃ СЌС‚РёРјРё declarations (HashSet de-dups; protocol resolution
//   РЅРµ Р»РѕРјР°РµС‚СЃСЏ).

module prelude.protocols

// Plan 91.8a (D183): Ordering sum-type СѓРґР°Р»С‘РЅ; Compare.compare РІРѕР·РІСЂР°С‰Р°РµС‚ int
// (memcmp-style: < 0 / 0 / > 0). РќРёРєР°РєРёС… imports РёР· core РЅРµ С‚СЂРµР±СѓРµС‚СЃСЏ.


// ──────────────────────────────────────────────────────────────────────────
// Conversion protocols (D73, D77)
// ──────────────────────────────────────────────────────────────────────────

/// РљРѕРЅРІРµСЂСЃРёСЏ `T в†’ Self` (D73, spec/decisions/08-runtime.md#d73).
///
/// `from` вЂ” **СЃС‚Р°С‚РёС‡РµСЃРєРёР№** РјРµС‚РѕРґ (D35: `fn Type.from(...)`); РІ
/// protocol-С‚РµР»Рµ РїРѕРјРµС‡Р°РµС‚СЃСЏ leading-С‚РѕС‡РєРѕР№ (Plan 97, СЂРµР·РѕР»РІ
/// `Q-static-method-protocol`). Р РµР°Р»РёР·Р°С†РёСЏ: `fn Foo.from(t T) -> Foo => ...`.
/// Auto-derive `Into[Self]` РґР»СЏ `T` РµСЃР»Рё `From[T]` РѕР±СЉСЏРІР»РµРЅ РЅР° `Self`.
///
/// # Examples
///
/// ```nova
/// type Celsius { value f64 }
/// fn Celsius.from(f Fahrenheit) -> Celsius =>
///     Celsius { value: (f.value - 32.0) * 5.0 / 9.0 }
/// // РђРІС‚Рѕ-РґРѕСЃС‚СѓРїРЅРѕ: Fahrenheit.into() -> Celsius
/// ```
#stable(since = "0.1")
export type From[T] protocol {
    .from(t T) -> Self
}

/// Plan 91.8a.2 (D183 amendment): blanket identity From вЂ” РєР°Р¶РґС‹Р№ С‚РёРї T
/// РјРѕР¶РЅРѕ СЃРєРѕРЅСЃС‚СЂСѓРёСЂРѕРІР°С‚СЊ РёР· СЃРµР±СЏ С‡РµСЂРµР· `T.from(t T) -> T`. РђРЅР°Р»РѕРі Rust
/// `impl<T> From<T> for T`.
///
/// Override Р·Р°РїСЂРµС‰С‘РЅ (Q4 strict, E_BLANKET_IDENTITY_OVERRIDE): identity
/// is identity (D9 single canonical path). Р РµР°Р»РёР·Р°С†РёСЏ вЂ” СЃРёРЅС‚РµР·РёСЂРѕРІР°РЅР°
/// codegen'РѕРј per concrete T РїСЂРё mono.
///
/// Resolution order РґР»СЏ `T.from(value)`:
/// 1. Explicit `fn T.from(value_type)` вЂ” user impl wins
/// 2. Blanket identity вЂ” matches С‚РѕР»СЊРєРѕ РµСЃР»Рё value_type == T
/// 3. D77 auto-derive РёР· From[value_type] chain
/// 4. Error E_NO_FROM_IMPL
///
/// Identity Into auto-derived (D77): `t.into()` РґР»СЏ `t: T` в†’ `t`.
///
/// # Examples
///
/// ```nova
/// let x int = int.from(42)             // identity blanket
/// let m Money = Money.from(other_money) // identity blanket
/// fn copy[T](x T) -> T => T.from(x)    // works РґР»СЏ Р»СЋР±РѕРіРѕ T
/// ```
#stable(since = "0.1")
export fn[T] T.from(t T) -> T => t

/// РљРѕРЅРІРµСЂСЃРёСЏ `Self в†’ U` вЂ” instance method (D73).
///
/// Auto-derived РёР· `From[Self]` РµСЃР»Рё `From[U]` РґР»СЏ `T=Self` СЃСѓС‰РµСЃС‚РІСѓРµС‚
/// (compiler СЃРёРЅС‚РµР·РёСЂСѓРµС‚ `into()` body РєР°Рє `U.from(self)`).
///
/// # Examples
///
/// ```nova
/// let c Celsius = f.into()  // РІС‹Р·С‹РІР°РµС‚ Celsius.from(f) Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё
/// ```
#stable(since = "0.1")
export type Into[U] protocol {
    @into() -> U
}

// TryFrom / TryInto вЂ” Result-С„РѕСЂРјР° РїРѕ `try_`-prefix convention.
//
// РљРѕРЅРІРµРЅС†РёСЏ Nova: `try_X` в†” `Result[T, E]`, `X` в†” `Fail[E]`-СЌС„С„РµРєС‚ (СЃРј.
// std/runtime/read_buffer.nv вЂ” РїР°СЂС‹ `read_byte`/`try_read_byte` Рё С‚.Рґ.).
// `try_from`/`try_into` РёРјРµРЅРѕРІР°РЅС‹ РїРѕРґ СЌС‚Сѓ РєРѕРЅРІРµРЅС†РёСЋ в†’ РІРѕР·РІСЂР°С‰Р°СЋС‚ Result.
// Fail-С„РѕСЂРјР° (`from`/`into` СЃ `Fail[E]`) вЂ” auto-derived РёР· Result-С„РѕСЂРјС‹
// РјРµС…Р°РЅРёР·РјРѕРј **D77 4-way auto-derive** (`compiler-codegen/src/codegen/emit_c.rs`
// вЂ” `try_from_targets` / `from_targets`); СЃРј. С‚Р°РєР¶Рµ spec D77.
//
// Note: Plan 56 Р¤.2.7 (Р·Р°РїСЂРµС‚ СЌС„С„РµРєС‚РѕРІ РІ protocol-РјРµС‚РѕРґР°С…) **СЃРЅСЏС‚**
// 2026-05-20 (D122 amended) вЂ” СЌС„С„РµРєС‚С‹ РІ protocol-РјРµС‚РѕРґР°С… С‚РµРїРµСЂСЊ
// СЂР°Р·СЂРµС€РµРЅС‹. Result-С„РѕСЂРјР° Сѓ `TryFrom`/`TryInto` РѕСЃС‚Р°С‘С‚СЃСЏ РЅРµ РєР°Рє
// workaround, Р° РєР°Рє РµСЃС‚РµСЃС‚РІРµРЅРЅР°СЏ СЃРµРјР°РЅС‚РёРєР° `try_`-prefix convention.

/// Fallible РєРѕРЅРІРµСЂСЃРёСЏ `T в†’ Self`, РІРѕР·РІСЂР°С‰Р°РµС‚ `Result[Self, E]`.
///
/// РРјРїР»РµРјРµРЅС‚РёСЂСѓР№С‚Рµ РЅР° С‚РёРїР°С…, РєРѕС‚РѕСЂС‹Рµ РјРѕРіСѓС‚ Р±С‹С‚СЊ РїРѕСЃС‚СЂРѕРµРЅС‹ РёР· `T` СЃ
/// РІРѕР·РјРѕР¶РЅРѕСЃС‚СЊСЋ РѕС€РёР±РєРё. РђРІС‚РѕРјР°С‚РёС‡РµСЃРєРё РґР°С‘С‚ `T.try_from(v)` (D77).
/// `try_from` вЂ” **СЃС‚Р°С‚РёС‡РµСЃРєРёР№** РјРµС‚РѕРґ (D35: `fn Type.try_from(...)`),
/// РІ protocol-С‚РµР»Рµ РїРѕРјРµС‡Р°РµС‚СЃСЏ leading-С‚РѕС‡РєРѕР№ (Plan 97).
///
/// `Result[Self, E]`-РІРѕР·РІСЂР°С‚ вЂ” РїРѕ `try_`-prefix convention; Fail-С„РѕСЂРјР°
/// (`fn Type.from(t T) Fail[E] -> Self`) auto-derive'РёС‚СЃСЏ С‡РµСЂРµР· D77.
///
/// # Examples
///
/// ```nova
/// let r = MyNum.try_from("42")
/// match r {
///     Ok(n) => println("got " + str.from(n.val))
///     Err(e) => println("error: " + e)
/// }
/// ```
#stable(since = "0.1")
export type TryFrom[T, E] protocol {
    .try_from(t T) -> Result[Self, E]
}

/// Fallible РєРѕРЅРІРµСЂСЃРёСЏ `Self в†’ U`, РІРѕР·РІСЂР°С‰Р°РµС‚ `Result[U, E]`.
///
/// `try_into` вЂ” instance-РјРµС‚РѕРґ (Р±РµР· leading-С‚РѕС‡РєРё). РђРІС‚РѕРјР°С‚РёС‡РµСЃРєРё
/// СЂРµР°Р»РёР·СѓРµС‚СЃСЏ С‡РµСЂРµР· `TryFrom`: РµСЃР»Рё `U TryFrom[Self, E]`, С‚Рѕ
/// `v.try_into()` СЌРєРІРёРІР°Р»РµРЅС‚РµРЅ `U.try_from(v)` (D77).
#stable(since = "0.1")
export type TryInto[U, E] protocol {
    @try_into() -> Result[U, E]
}


// ──────────────────────────────────────────────────────────────────────────
// Equality / Hashing / Ordering protocols (D109)
// ──────────────────────────────────────────────────────────────────────────

/// РҐСЌС€РёСЂСѓРµРјС‹Рµ С‚РёРїС‹ вЂ” РґР»СЏ `HashMap[K, ...]` / `HashSet[K]` (D109,
/// spec/decisions/04-effects.md; D237 rename Hash в†’ Hash).
///
/// **Split policy (D109):** `Hash` РѕРїСЂРµРґРµР»СЏРµС‚ С‚РѕР»СЊРєРѕ `hash() -> u64`,
/// equality РІС‹РЅРµСЃРµРЅР° РІ РѕС‚РґРµР»СЊРЅС‹Р№ `Equal`. Р­С‚Рѕ СѓРїСЂРѕС‰Р°РµС‚ СЃС‚СЂСѓРєС‚СѓСЂРЅСѓСЋ
/// РїСЂРѕРІРµСЂРєСѓ: `[K Hash]` РѕР·РЅР°С‡Р°РµС‚ "РґРѕСЃС‚Р°С‚РѕС‡РЅРѕ РґР»СЏ С…СЌС€-С‚Р°Р±Р»РёС†С‹ lookup'Р°
/// **РґРѕ** collision check", `[K Hash + Equal]` вЂ” РїРѕР»РЅС‹Р№ contract.
///
/// **Bootstrap:** РїСЂРёРјРёС‚РёРІС‹ (`int`/`str`/`bool`/`char`/С‡РёСЃР»РѕРІС‹Рµ) вЂ” auto-
/// hashable per type-checker special-case (emit_c.rs:5817). РРјРµРЅРѕРІР°РЅРЅС‹Рµ
/// С‚РёРїС‹ РґРѕР»Р¶РЅС‹ СЏРІРЅРѕ СЂРµР°Р»РёР·РѕРІР°С‚СЊ `fn T @hash() -> u64`.
///
/// # Examples
///
/// ```nova
/// type UserId { value u64 }
/// fn UserId @hash() -> u64 => @value
/// // UserId С‚РµРїРµСЂСЊ СѓРґРѕРІР»РµС‚РІРѕСЂСЏРµС‚ Hash structurally.
/// ```
#stable(since = "0.1")
export type Hash protocol {
    @hash() -> u64
}

/// Р Р°РІРµРЅСЃС‚РІРѕ (D109; D237 rename Equal в†’ Equal, @equal в†’ @equal).
///
/// `Self == Self` С‡РµСЂРµР· СЏРІРЅС‹Р№ РјРµС‚РѕРґ. Plan 91.8a.2 (D183 amendment):
/// Р•СЃР»Рё С‚РёРї satisfies Compare, @equal auto-synthesized С‡РµСЂРµР· compare;
/// РёРЅР°С‡Рµ implementer РїРёС€РµС‚ @equal СЏРІРЅРѕ (e.g. Vector3, Complex Р±РµР· linear
/// order). Operators ==/!= synthesized Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё.
///
/// # Examples
///
/// ```nova
/// // Type only Equal (no order):
/// type Vector3 { x f64, y f64, z f64 }
/// fn Vector3 @equal(other Vector3) -> bool =>
///     @x == other.x && @y == other.y && @z == other.z
///
/// // Type with Compare вЂ” equal auto-derived from @compare:
/// type Money { cents int }
/// fn Money @compare(other Money) -> int => @cents - other.cents
/// // @equal synthesized via Equal.equal default body
/// ```
#stable(since = "0.1")
export type Equal protocol {
    @equal(other Self) -> bool => @compare(other) == 0
}

/// РџРѕР»РЅС‹Р№ РїРѕСЂСЏРґРѕРє (D109, D183 amendment Plan 91.8a.2; D237 rename Compare в†’ Compare).
/// Orthogonal СЃ Equal (no embed); Equal РїРѕР»СѓС‡Р°РµС‚ default body С‡РµСЂРµР·
/// coercion Рє Compare. Р’РѕР·РІСЂР°С‰Р°РµС‚ `int` (memcmp-style: < 0, 0, > 0).
///
/// РўСЂР°РЅР·РёС‚РёРІРЅРѕСЃС‚СЊ Рё antisymmetry вЂ” РїСЂРѕРіСЂР°РјРјРёСЃС‚СЃРєР°СЏ РѕР±СЏР·Р°РЅРЅРѕСЃС‚СЊ (compiler
/// РЅРµ РІРµСЂРёС„РёС†РёСЂСѓРµС‚). Р”Р»СЏ partial order вЂ” РѕС‚РґРµР»СЊРЅС‹Р№ protocol (Plan 62.E+).
///
/// # Examples
///
/// ```nova
/// fn Money @compare(other Money) -> int =>
///     if @cents < other.cents { -1 }
///     else if @cents > other.cents { 1 }
///     else { 0 }
/// ```
#stable(since = "0.1")
export type Compare protocol {
    @compare(other Self) -> int
}


// ──────────────────────────────────────────────────────────────────────────
// Plan 137 (D237) вЂ” Clone protocol (renamed from Clone)
// ──────────────────────────────────────────────────────────────────────────

/// Deep recursive copy (Plan 126, D230; D237 rename Clone в†’ Clone).
///
/// Single-method protocol РґР»СЏ РіР»СѓР±РѕРєРѕР№ РєРѕРїРёРё value-record / heap-record /
/// named tuple / sum-type. Auto-derive С‡РµСЂРµР· `#impl(Clone)` РЅР° С‚РёРїРµ:
/// compiler synthesize'РёС‚ memberwise СЂРµРєСѓСЂСЃРёРІРЅСѓСЋ РєРѕРїРёСЋ РєР°Р¶РґРѕРіРѕ РїРѕР»СЏ.
///
/// **Auto-derive rules:**
/// - Primitive types (int/f64/bool/char/byte/str): copy semantics built-in;
///   `str` clone = РЅРѕРІР°СЏ Р°Р»Р»РѕРєР°С†РёСЏ СЃ С‚РµРј Р¶Рµ РєРѕРЅС‚РµРЅС‚РѕРј.
/// - `[]T`: new array СЃ recursive clone СЌР»РµРјРµРЅС‚РѕРІ.
/// - Record/NamedTuple: memberwise `field.clone()` chain.
/// - Sum-type: match-arms, payload СЂРµРєСѓСЂСЃРёРІРЅРѕ clone'РёС‚СЃСЏ.
/// - Reference fields РІ value-record: clone underlying (`[]T` deep copy).
///
/// **Cycle detection:** type `A` СЃСЃС‹Р»Р°СЋС‰РёР№СЃСЏ РЅР° `A` СЃР°Рј (С‡РµСЂРµР· embed) в†’
/// `E_AUTO_DERIVE_CYCLE` РїСЂРё РїРѕРїС‹С‚РєРµ synthesize.
///
/// **Field eligibility:** РєР°Р¶РґРѕРµ РїРѕР»Рµ type'Р° РґРѕР»Р¶РЅРѕ implement Clone
/// (Р»РёР±Рѕ primitive, Р»РёР±Рѕ `#impl(Clone)`). РРЅР°С‡Рµ в†’
/// `E_AUTO_DERIVE_FIELD_LACKS_PROTOCOL`.
///
/// # Examples
///
/// ```nova
/// #impl(Clone)
/// type Vec3 value {
///     x f64
///     y f64
///     z f64
/// }
///
/// ro a = Vec3 { x: 1.0, y: 2.0, z: 3.0 }
/// ro b = a.clone()  // synthesized: Vec3 { x: @x.clone(), y: @y.clone(), z: @z.clone() }
/// ```
///
/// Manual impl (override default):
///
/// ```nova
/// fn Vec3 @clone() -> Vec3 =>
///     Vec3 { x: @x, y: @y, z: @z }   // shallow copy (primitives)
/// ```
#stable(since = "0.1")
export type Clone protocol {
    @clone() -> Self
}


// ──────────────────────────────────────────────────────────────────────────
// Plan 137 (D237) вЂ” Display + Debug protocols (renamed from Display/Debug)
// ──────────────────────────────────────────────────────────────────────────

/// Р¤РѕСЂРјР°С‚РёСЂРѕРІР°РЅРёРµ РІ СЃС‚СЂРѕРєСѓ (РґР»СЏ println, str.from, etc).
/// D237 rename: Display в†’ Display, @display в†’ @display.
///
/// РњРµС‚РѕРґ `@display(sb)` РїРёС€РµС‚ representation РІ `StringBuilder` (opaque runtime
/// type вЂ” hardcoded РІ type-checker builtins HashSet РґРѕ Plan 62.D.bis
/// РєР°РЅРѕРЅРёР·Р°С†РёРё С‡РµСЂРµР· `external type` D-block). Р’РѕР·РІСЂР°С‰Р°РµС‚ `()`; РІСЃСЏ
/// СЂР°Р±РѕС‚Р° вЂ” РїРѕР±РѕС‡РЅС‹Р№ effect РЅР° `sb`.
///
/// # Examples
///
/// ```nova
/// type Point { x int, y int }
/// fn Point @display(mut sb StringBuilder) -> () {
///     sb.append("Point(")
///     sb.append_int(@x)
///     sb.append(", ")
///     sb.append_int(@y)
///     sb.append(")")
/// }
/// ```
/// Plan 91.8a.2 (D183 amendment): default body РёСЃРїРѕР»СЊР·СѓРµС‚ `str.from(@)`
/// вЂ” primitive C function РґР»СЏ primitives, РёР»Рё user-declared overload РґР»СЏ
/// custom types. Implementer РїРёС€РµС‚ @display СЏРІРЅРѕ РґР»СЏ perf (no intermediate
/// string), Р»РёР±Рѕ РїСЂРµРґРѕСЃС‚Р°РІР»СЏРµС‚ `fn str.from(MyType) -> str` overload.
#stable(since = "0.1")
export type Display protocol {
    @display(mut sb StringBuilder) {
        sb.append(str.from(@))
    }
}


/// Protocol РґР»СЏ РѕС‚Р»Р°РґРѕС‡РЅРѕРіРѕ РїСЂРµРґСЃС‚Р°РІР»РµРЅРёСЏ вЂ” sibling Рє Display (D229; D237 rename).
/// D237 rename: Debug в†’ Debug, @debug в†’ @debug.
///
/// **Distinction РѕС‚ Display:**
/// - `Display.@display` вЂ” user-facing display (e.g., `Point(1, 2)`, `"hello"`).
/// - `Debug.@debug` вЂ” diagnostic representation (e.g.,
///   `Point { x: 1, y: 2 }`, `"\"hello\\n\""` СЃ quote-escape), matches
///   Rust `#[derive(Debug)]` shape.
///
/// **Trigger:** `${expr:?}` syntax inside Nova interp-strings (Plan 91.14 Р¤.2).
/// Bare `${expr}` (no `:?`) routes Рє Display.@display (unchanged).
///
/// **Auto-derive:** synthesized on-demand РїСЂРё РїРµСЂРІРѕРј encounter `${x:?}`.
/// Future explicit form `#impl(Debug)` вЂ” [M-91.14-derive-debug].
///
/// # Examples
///
/// ```nova
/// type Point { x int, y int }
/// // Auto-synthesized:
/// //   @debug(sb) := sb.append("Point { x: ${@x:?}, y: ${@y:?} }")
///
/// ro p = Point { x: 1, y: 2 }
/// println("p = ${p:?}")  // "p = Point { x: 1, y: 2 }"
/// ```
///
/// Manual impl (override default):
///
/// ```nova
/// fn Point @debug(mut sb StringBuilder) -> () {
///     sb.append("Point(")
///     sb.append_int(@x)
///     sb.append(", ")
///     sb.append_int(@y)
///     sb.append(")")
/// }
/// ```
#stable(since = "0.1")
export type Debug protocol {
    @debug(mut sb StringBuilder) {
        sb.append(str.from_debug(@))
    }
}


// ──────────────────────────────────────────────────────────────────────────
// Plan 110 (D188 / D192 / D194) вЂ” Consumable[E] + WithExitTimeout
// ──────────────────────────────────────────────────────────────────────────

/// Plan 110 (D188): РєРѕРЅС‚СЂР°РєС‚ СЂРµСЃСѓСЂСЃР° РґР»СЏ `consume X = expr { body }`
/// scope-block'Р°. **РћРґРёРЅ** РјРµС‚РѕРґ `on_exit` РІС‹Р·С‹РІР°РµС‚СЃСЏ СЂРѕРІРЅРѕ РѕРґРёРЅ СЂР°Р·
/// РїСЂРё РІС‹С…РѕРґРµ РёР· body (success/throw/panic/cancel).
///
/// **`E`** вЂ” С‚РёРї РѕС€РёР±РѕРє, РєРѕС‚РѕСЂС‹Рµ `on_exit` СЃР°Рј РјРѕР¶РµС‚ throw (commit
/// failure, flush failure). Р•СЃР»Рё СЂРµСЃСѓСЂСЃ infallible вЂ” РёСЃРїРѕР»СЊР·СѓР№С‚Рµ
/// `Consumable[never]` (D194), СЌС‚Рѕ РґР°С‘С‚ caller'Сѓ РїСЂР°РІРѕ РЅРµ РѕР±СЉСЏРІР»СЏС‚СЊ
/// `Fail[E]` + codegen hot-path elision.
///
/// **R-rules (D188):**
/// - R1: РµСЃР»Рё `init` throws вЂ” `on_exit` РЅРµ РІС‹Р·С‹РІР°РµС‚СЃСЏ (partial-construction).
/// - R2: exactly-once invariant (runtime counter).
/// - R3: cancel-shield by default РІРЅСѓС‚СЂРё `on_exit` body.
/// - R4: timeout resolution at scope-entry (3-level, D192).
/// - R5: LIFO composition РґР»СЏ РІР»РѕР¶РµРЅРЅС‹С… consume{}.
/// - R6: release-acquire memory ordering РјРµР¶РґСѓ body Рё on_exit.
///
/// # Examples
///
/// ```nova
/// type Transaction { /* ... */ }
///
/// fn Transaction consume @on_exit(outcome ScopeOutcome) Fail[DbError] -> () {
///     match outcome {
///         Success      => @commit()?
///         Failure(_)   => @rollback()?
///         Panic(_)     => @rollback_emergency()
///     }
/// }
///
/// fn process() Fail[DbError] -> () {
///     consume tx = Db.begin() {
///         do_work()?
///     }
///     // tx.on_exit РІС‹Р·РІР°РЅ СЂРѕРІРЅРѕ РѕРґРёРЅ СЂР°Р·; commit/rollback РїРѕ outcome.
/// }
/// ```
#stable(since = "0.1")
export type Consumable[E] protocol {
    consume @on_exit(outcome ScopeOutcome) Fail[E] -> ()
}

/// Plan 110 (D192): РѕРїС†РёРѕРЅР°Р»СЊРЅС‹Р№ protocol РґР»СЏ СЂРµСЃСѓСЂСЃРѕРІ СЃ custom
/// `exit_timeout`. **РќРµ** С‡Р°СЃС‚СЊ Consumable вЂ” structural-match: Р»СЋР±РѕР№
/// С‚РёРї СЃ РјРµС‚РѕРґРѕРј `exit_timeout_ms() -> int` Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё satisfies.
///
/// РСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ codegen'РѕРј `nv_resolve_exit_timeout` (3-level resolution):
/// 1. WithExitTimeout impl (СЌС‚РѕС‚ protocol) вЂ” РµСЃР»Рё РµСЃС‚СЊ;
/// 2. Application effect handler вЂ” `default_exit_timeout_ms()`;
/// 3. Hardcoded fallback вЂ” 5000 ms.
///
/// `Mutex` / `Sem` / `Lock` РЅР°РјРµСЂРµРЅРЅРѕ **РЅРµ** implement вЂ” РґР»СЏ РЅРёС…
/// hardcoded 5s РґРѕСЃС‚Р°С‚РѕС‡РµРЅ (releases instant).
///
/// **Bootstrap:** `int` РјРёР»РёСЃРµРєСѓРЅРґ РІРјРµСЃС‚Рѕ `Duration` (РїРѕСЃР»РµРґРЅРёР№ РІ std/time/,
/// РЅРµ prelude вЂ” РёР·Р±РµРіР°РµРј cross-module import).
///
/// # Examples
///
/// ```nova
/// fn Transaction @exit_timeout_ms() -> int => 30_000   // 30 СЃРµРєСѓРЅРґ
/// ```
#stable(since = "0.1")
export type WithExitTimeout protocol {
    @exit_timeout_ms() -> int
}


// ──────────────────────────────────────────────────────────────────────────
// Plan 138 (D238 / D240) — Index[K, V] + MutIndex[K, V] protocols
// ──────────────────────────────────────────────────────────────────────────

/// Индексный доступ `a[key]` — magic-метод `@index` для `a[key]` выражений
/// на user-типах. Паникует при invalid key (OOB, missing key etc).
///
/// Встроенные `[]T` и `str` удовлетворяют через built-in codegen path;
/// user-типы (`Vec[T]`, `HashMap[K,V]` и т.д.) реализуют явно.
///
/// # D238 (spec/decisions/03-syntax.md)
///
/// `a[key]` десугаринг в `a.index(key)` для любого типа реализующего
/// `Index[K, V]`. `K` — тип ключа, `V` — тип возвращаемого значения.
///
/// # Examples
///
/// ```nova
/// // Vec[T] implements Index[int, T]:
/// mut v = Vec[int].new()
/// v.push(10); v.push(20)
/// assert(v[0] == 10)  // v.index(0)
///
/// // Custom map implementing Index[str, int]:
/// type MyMap { ... }
/// fn MyMap @index(key str) -> int { ... }
/// ```
#stable(since = "0.1")
export type Index[K, V] protocol {
    @index(key K) -> V
}

/// Индексная запись `a[key] = val` — magic-метод `mut @index` для assignment
/// lhs. Read-only типы реализуют только `Index`. Мутабельные — оба.
///
/// # D240 (spec/decisions/03-syntax.md)
///
/// `a[key] = val` десугаринг в `a.@index(key, val)` (write-overload `@index`
/// с `mut`-receiver) для типов реализующих `MutIndex[K, V]`.
///
/// # Examples
///
/// ```nova
/// // Vec[T] implements MutIndex[int, T]:
/// mut v = Vec[int].new()
/// v.push(10)
/// v[0] = 99  // v.@index(0, 99)
/// assert(v[0] == 99)
/// ```
#stable(since = "0.1")
export type MutIndex[K, V] protocol {
    mut @index(key K, val V)
}
