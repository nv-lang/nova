// with_tests.nv — тесты прямо в файле.

module effects.with_tests

fn double(x int) -> int => x * 2

fn factorial(n int) -> int {
    if n <= 1 { return 1 }
    n * factorial(n - 1)
}

test "double works" {
    assert(double(5) == 10)
    assert(double(0) == 0)
    assert(double(-3) == -6)
}

test "factorial base case" {
    assert(factorial(0) == 1)
    assert(factorial(1) == 1)
}

test "factorial recursive" {
    assert(factorial(5) == 120)
    assert(factorial(6) == 720)
}

test "this one fails on purpose" {
    assert(1 == 2)
}
