// Plan 152.5b (D254): collation is OPT-IN — `str` NEVER collates silently.
// Without `import std.unicode`, `collate_compare` is not in scope: the program
// must not silently compile (the default `str` Ord stays byte-lexicographic).
// Negative test pins the opt-in boundary (mirrors plan152_4 n_unicode_opt_in).
//
// EXPECT_COMPILE_ERROR undefined identifier
module neg.n_collation_opt_in

test "collate_compare is undefined without import std.unicode" {
    ro x = collate_compare("a", "b")
    assert(x < 0)
}
