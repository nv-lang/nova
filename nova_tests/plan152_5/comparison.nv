// Plan 152.5a (D254): comparison core — byte-Ord (@compare) + eq_ignore_ascii_case.
module plan152_5.comparison

test "str eq_ignore_ascii_case (ASCII only)" {
    assert("Foo".eq_ignore_ascii_case("foo"))
    assert("FOO".eq_ignore_ascii_case("foo"))
    assert("HeLLo".eq_ignore_ascii_case("hello"))
    assert(!"Foo".eq_ignore_ascii_case("bar"))
    assert(!"Foo".eq_ignore_ascii_case("foobar"))   // length differs
    assert("".eq_ignore_ascii_case(""))
}

test "str eq_ignore_ascii_case does NOT fold non-ASCII" {
    assert(!"é".eq_ignore_ascii_case("É"))          // non-ASCII: byte-distinct
    assert("café".eq_ignore_ascii_case("CAFé"))     // ASCII part folds, é matches
    assert(!"café".eq_ignore_ascii_case("CAFÉ"))    // É != é
}

test "char eq_ignore_ascii_case" {
    assert('A'.eq_ignore_ascii_case('a'))
    assert('Z'.eq_ignore_ascii_case('z'))
    assert(!'A'.eq_ignore_ascii_case('b'))
    assert('5'.eq_ignore_ascii_case('5'))
}

test "byte-lexicographic Ord (@compare) — deterministic, locale-independent" {
    assert("abc".compare("abc") == 0)
    assert("abc".compare("abd") < 0)
    assert("abd".compare("abc") > 0)
    assert("ab".compare("abc") < 0)                 // prefix < longer
    assert("Z".compare("a") < 0)                    // 'Z'(90) < 'a'(97) — byte order, not case-insensitive
}
