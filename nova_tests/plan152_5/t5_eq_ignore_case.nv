// Plan 152.5b (D254): eq_ignore_case — Unicode full-case-fold equality for str and char.
// Opt-in: requires `import std.unicode`.
module nova_tests.plan152_5

import std.unicode.{eq_ignore_case}

test "str eq_ignore_case handles multi-codepoint folds (ß)" {
    // German sharp-s: "straße".fold_case() == "strasse"; "STRASSE".fold_case() == "strasse"
    assert("STRASSE".eq_ignore_case("straße"))
    assert("straße".eq_ignore_case("STRASSE"))
}

test "str eq_ignore_case basic ASCII" {
    assert("Hello".eq_ignore_case("HELLO"))
    assert("hello".eq_ignore_case("Hello"))
    assert(!"Hello".eq_ignore_case("World"))
}

test "str eq_ignore_case non-ASCII accented letters" {
    assert("café".eq_ignore_case("CAFÉ"))
    assert("CAFÉ".eq_ignore_case("café"))
}

test "str eq_ignore_case empty strings" {
    assert("".eq_ignore_case(""))
}

test "str eq_ignore_case length mismatch returns false" {
    assert(!"hello".eq_ignore_case("hell"))
    assert(!"hello".eq_ignore_case("helloo"))
}

test "char eq_ignore_case" {
    assert('A'.eq_ignore_case('a'))
    assert('z'.eq_ignore_case('Z'))
    assert('é'.eq_ignore_case('É'))
    assert(!'a'.eq_ignore_case('b'))
}
