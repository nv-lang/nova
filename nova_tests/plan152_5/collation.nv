// Plan 152.5b (D254): Unicode collation (UCA / DUCET, UTS #10) — hand cases.
//
// Opt-in `std.unicode` collator (Shifted variable weighting). These pin the
// human-meaningful ordering properties that the (sampled) CollationTest oracle
// also covers, plus a few that are easy to read. collate_compare returns int
// (-1/0/+1, D183), NOT an Ordering sum-type.
module plan152_5.collation

import std.unicode.{collate_compare, collate_sort_key, collate_eq, Collator}

test "primary ordering: letters by base letter" {
    assert(collate_compare("a", "b") < 0)
    assert(collate_compare("b", "a") > 0)
    assert(collate_compare("a", "a") == 0)
    assert(collate_compare("apple", "banana") < 0)
    assert(collate_compare("abc", "abd") < 0)
    assert(collate_compare("ab", "abc") < 0)            // prefix collates first
}

test "case is tertiary, not primary: 'a' and 'A' share a primary" {
    // Unlike byte-Ord (where 'Z'(0x5A) < 'a'(0x61)), collation groups by base
    // letter first: lowercase 'a' sorts before uppercase 'A' (tertiary weight),
    // and both sort before 'b'.
    assert(collate_compare("a", "A") < 0)               // a < A (tertiary)
    assert(collate_compare("A", "b") < 0)               // A < b (A's primary < b's)
    assert(collate_compare("a", "b") < 0)
    // Whole-word case difference: "apple" < "Apple" (differs only at tertiary).
    assert(collate_compare("apple", "Apple") < 0)
}

test "byte-Ord vs collation diverge on case (Z vs a)" {
    // The contrast that motivates collation: byte order puts 'Z'(0x5A) before
    // 'a'(0x61); collation puts 'a' before 'Z' because base 'a' < base 'z'.
    assert("Z".compare("a") < 0)                        // byte-Ord: Z < a
    assert(collate_compare("Z", "a") > 0)               // collation: a < Z (z-base > a-base)
}

test "accents are secondary: 'cafe' < 'café', e < é < everything-after" {
    // NFD-first: 'é' = e + combining acute; the acute adds a secondary weight,
    // so "cafe" (no accent) sorts before "café" (accented e), and both sort
    // before "caff" (primary difference dominates secondary).
    assert(collate_compare("cafe", "café") < 0)
    assert(collate_compare("café", "cafz") < 0)         // primary (e<z) beats secondary
    assert(collate_compare("résumé", "resume") > 0)     // accented sorts after plain
}

test "precomposed and decomposed accents collate equal (NFD)" {
    // U+00E9 (é precomposed) vs 'e' + U+0301 (combining acute) — canonically
    // equivalent, so they MUST collate equal (NFD normalization step).
    assert(collate_eq("caf\u{e9}", "cafe\u{301}"))
    assert(collate_compare("caf\u{e9}", "cafe\u{301}") == 0)
}

test "variable (punctuation) is shifted below letters" {
    // Under Shifted, punctuation/symbols are demoted to level 4: a hyphen does
    // not outrank letters. "black-bird" and "blackbird" differ only by a
    // variable, which only breaks ties at the quaternary level.
    assert(collate_compare("blackbird", "black-bird") != 0) // distinct at L4
    // The hyphenated form is NOT pushed before/after a different base letter:
    assert(collate_compare("black-bird", "blackcird") < 0)  // 'b' < 'c' dominates
    // A leading space (variable) does not reorder relative to letters at L1-3:
    assert(collate_compare(" a", "a") != 0)                 // differ only at L4
    assert(collate_compare(" a", "b") < 0)                  // 'a' base < 'b' base
}

test "digits and length tiebreak" {
    assert(collate_compare("1", "2") < 0)
    assert(collate_compare("a1", "a2") < 0)
    assert(collate_compare("", "a") < 0)                 // empty collates first
    assert(collate_compare("", "") == 0)
}

test "CJK implicit weights order by codepoint within a block" {
    // U+4E00 (一) and U+4E8C (二) are not in DUCET; implicit Han weights order
    // them by codepoint. Both core-Han, so 4E00 < 4E8C.
    assert(collate_compare("\u{4e00}", "\u{4e8c}") < 0)
    // A Latin letter (primary ~0x2380) sorts before any Han ideograph
    // (implicit primary base 0xFB40+), so "a" < "一".
    assert(collate_compare("a", "\u{4e00}") < 0)
}

test "sort_key is consistent with compare" {
    // compare(a,b) sign must match lexicographic order of the sort keys.
    ro ka = collate_sort_key("apple")
    ro kb = collate_sort_key("Apple")
    // apple < Apple, so ka < kb lexicographically — first differing weight smaller.
    mut differ = false
    mut i = 0
    ro n = if ka.len() < kb.len() { ka.len() } else { kb.len() }
    while i < n && !differ {
        if ka[i] != kb[i] {
            assert(ka[i] < kb[i])
            differ = true
        }
        i = i + 1
    }
    assert(differ)
}

test "Collator object delegates to the free functions" {
    ro c = Collator.root()
    assert(c.order("a", "b") < 0)
    assert(c.same("caf\u{e9}", "cafe\u{301}"))
    assert(c.key("a").len() > 0)
}
