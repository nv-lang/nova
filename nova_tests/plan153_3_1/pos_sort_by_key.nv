// Plan 153.3.1: pdqsort — sort_unstable_by_key
module nova_tests.plan153_3_1
fn main() -> () {
    mut xs = Vec[int].new()
    xs.push(-5)
    xs.push(3)
    xs.push(-1)
    xs.push(4)
    xs.push(-9)
    xs.sort_unstable_by_key(|x| if x < 0 { -x } else { x })
    // verify keys (absolute values) are sorted ascending
    mut i = 0
    while i < 4 {
        ro ka = if xs[i] < 0 { -xs[i] } else { xs[i] }
        ro kb = if xs[i + 1] < 0 { -xs[i + 1] } else { xs[i + 1] }
        assert(ka <= kb)
        i = i + 1
    }
    assert(xs.len == 5)
}
