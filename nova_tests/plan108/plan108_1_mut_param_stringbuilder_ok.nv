// Plan 108.1 (D176 amend): `mut` параметр позволяет вызов mut-методов
// на user-defined consume-типе (StringBuilder).

module nova_tests.plan108

fn append_world(mut sb StringBuilder) -> int {
    sb.append(" world")
    sb.len()
}

test "mut param + StringBuilder append" {
    consume sb = StringBuilder.from("hello")
    ro n = append_world(sb)
    assert(n == 11)         // "hello world" = 11 bytes
    ro final = sb.into_str()
    assert(final == "hello world")
}
