// Plan 108 Ф.3: str.as_bytes() zero-copy readonly []u8 view.

module plan108.str_as_bytes_test

test "str.as_bytes: basic byte values" {
    ro s = "hello"
    ro view = s.as_bytes()
    assert(view[0] == 104)  // 'h'
    assert(view[1] == 101)  // 'e'
    assert(view[2] == 108)  // 'l'
    assert(view[3] == 108)  // 'l'
    assert(view[4] == 111)  // 'o'
}

test "str.as_bytes: length matches str.len" {
    ro s = "Nova"
    ro view = s.as_bytes()
    assert(view.len() == s.len())
}

test "str.as_bytes: iterate over bytes" {
    ro s = "abc"
    ro view = s.as_bytes()
    mut sum = 0
    for b in view {
        sum = sum + b
    }
    // 'a'=97 + 'b'=98 + 'c'=99 = 294
    assert(sum == 294)
}

test "str.as_bytes: empty string gives empty slice" {
    ro s = ""
    ro view = s.as_bytes()
    assert(view.len() == 0)
}

test "str.as_bytes: auto-coerce to ro []u8 param" {
    ro s = "test"
    ro view ro []u8 = s.as_bytes()
    assert(view.len() == 4)
}
