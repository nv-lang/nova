// EXPECT_COMPILE_ERROR E_READONLY_COERCE
// Plan 108 Ф.2: D176 readonly T → non-readonly T coerce is forbidden.

module plan108.readonly_coerce_neg_test

fn get_readonly() -> ro []u8 {
    ro arr []u8 = [1, 2, 3]
    arr  // auto-coerce []u8 → ro []u8
}

test "cannot coerce ro to non-ro" {
    ro r ro []u8 = get_readonly()
    ro mutable []u8 = r  // E_READONLY_COERCE
    assert(mutable[0] == 1)
}
