// Plan 108.1 (D176 amend): `mut` параметр для user-defined record-типа
// с `mut @method` методом.

module nova_tests.plan108

type Counter_plan1081mutparamuserrecordok {
    mut value int
}

fn Counter_plan1081mutparamuserrecordok.new() -> Counter_plan1081mutparamuserrecordok => { value: 0 }

fn Counter_plan1081mutparamuserrecordok mut @inc(n int) -> () {
    @value = @value + n
}

fn Counter_plan1081mutparamuserrecordok @get() -> int => @value

fn bump_by_5(mut c Counter_plan1081mutparamuserrecordok) -> int {
    c.inc(5)
    c.get()
}

test "mut param + user-defined mut @method" {
    ro c = Counter_plan1081mutparamuserrecordok.new()
    ro v = bump_by_5(c)
    assert(v == 5)
    assert(c.get() == 5)
}
