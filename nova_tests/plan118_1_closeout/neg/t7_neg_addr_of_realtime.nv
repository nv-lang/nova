// Plan 118.6 T7 NEG — addr_of() removed → E_ADDR_OF_REMOVED.
// EXPECT_COMPILE_ERROR E_ADDR_OF_REMOVED
module neg.t7_neg_addr_of_realtime
#realtime fn handler() -> () {
    ro x = 42
    unsafe {
        ro p = addr_of(x)
    }
}
test "addr_of removed — realtime case also gives E_ADDR_OF_REMOVED" {
    handler()
}
