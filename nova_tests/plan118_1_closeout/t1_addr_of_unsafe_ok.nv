// Plan 118.1 closeout T1 — &local int inside unsafe.
//
// Per design: `&x` takes address of x. Inside unsafe context.
// (addr_of removed in Plan 118.6 — use & syntax directly.)

module nova_tests.plan118_1_closeout

test "addr_of(int) inside unsafe" {
    ro x = 42
    unsafe {
        ro p = &x
        assert(p.read() == 42)
    }
}
