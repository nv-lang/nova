// Plan 118.1 closeout T1 — addr_of(local int) inside unsafe.
//
// Per design: addr_of[T](x ro T) -> *T builtin, desugars к UnOp::AddrOf
// (`&x`). Read-only — no mut binding required. Inside unsafe context.

module plan118_1_closeout.t1_addr_of_unsafe_ok

test "addr_of(int) inside unsafe" {
    ro x = 42
    unsafe {
        ro p = addr_of(x)
        assert(p.read() == 42)
    }
}
