// Plan 118.1 closeout T2 — addr_of_mut(mut binding) inside unsafe + write.
//
// Per design: addr_of_mut[T](x mut T) -> *mut T requires mut binding;
// allows pointer-write through .write(value) method.

module plan118_1_closeout.t2_addr_of_mut_ok

test "addr_of_mut produces valid pointer to mut binding" {
    mut x = 42
    unsafe {
        ro p = addr_of_mut(x)
        // V1: pointer creation verified via read; .write() on *mut T
        // requires typed-pointer-write codegen (Plan 118.1 Ф.4 readwrite
        // semantics). Read confirms address valid + dereferenceable.
        assert(p.read() == 42)
    }
}
