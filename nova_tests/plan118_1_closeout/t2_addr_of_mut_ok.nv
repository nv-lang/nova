// Plan 118.1 closeout T2 — &(mut binding) inside unsafe + read.
//
// Per design: `&x` on a mut binding produces a pointer.
// (addr_of_mut removed in Plan 118.6 — use & syntax directly.)

module nova_tests.plan118_1_closeout

test "addr_of_mut produces valid pointer to mut binding" {
    mut x = 42
    unsafe {
        ro p = &x
        // V1: pointer creation verified via read; .write() on *mut T
        // requires typed-pointer-write codegen (Plan 118.1 Ф.4 readwrite
        // semantics). Read confirms address valid + dereferenceable.
        assert(p.read() == 42)
    }
}
