// Plan 118.1 closeout T11 POS — str.as_cstr() returns CStr (zero-copy).
//
// Per D26 invariant: full Nova str ALWAYS has ptr[len]=='\0'. as_cstr()
// returns CStr wrapping bytes.as_ptr() — direct buffer reference.

module plan118_1_closeout.t11_pos_cstr_as_cstr_method

import std.ffi.cstr.{CStr}

test "str.as_cstr() returns CStr" {
    ro s = "hello"
    ro c = s.as_cstr()
    // C-side strlen would see "hello\0" (5 bytes + terminator). Verify
    // только that method compiles + returns CStr type (.0 field test).
    assert(s.len() == 5)
}

test "str.to_cstr() returns CStr (V1: alias к as_cstr)" {
    ro s = "world"
    ro c = s.to_cstr()
    assert(s.len() == 5)
}

test "str.as_cstr_unchecked() returns CStr (V1: alias)" {
    ro s = "test"
    ro c = s.as_cstr_unchecked()
    assert(s.len() == 4)
}

test "empty str.as_cstr() works" {
    ro s = ""
    ro c = s.as_cstr()
    assert(s.len() == 0)
}
