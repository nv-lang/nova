// EXPECT_COMPILE_ERROR D133
//
// Plan 100.1 (D133): consume-var, не закрытая до scope exit'а — ошибка.
// `consume tx = begin()` без consume-метода и без передачи наверх →
// E (D133-not-consumed).

module plan100_1.consume_err_forget

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => { id: 1 }

test "забыли consume — должна быть ошибка" {
    consume tx = begin()
    // ОШИБКА D133-not-consumed: tx Live на exit'е scope'а.
    // Compiler suggest: call .commit() or .rollback().
}
