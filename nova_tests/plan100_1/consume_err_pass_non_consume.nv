// Plan 100.1 → Plan 100.3 (D157): передача consume-var в view-param (non-consume
// fn-параметр типа consume-type) — РАЗРЕШЕНО как view-borrow.
//
// `fn log(tx Transaction)` — параметр без `consume` qualifier = view-param (D157).
// Caller передаёт consume-var как view-borrow; tx остаётся Live у caller.
//
// NOTE: До Plan 100.3 (D133 bootstrap) этот паттерн давал ошибку
// D133-move-to-non-consume. После D157 — разрешён: view-borrow.

module plan100_1.consume_err_pass_non_consume

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => { id: 1 }

// `log` — view-param (non-consume param of consume type). Read-only borrow (D157).
fn log(tx Transaction) -> () {
    println(tx.id)
}

test "log(tx) — view-borrow; caller's tx остаётся Live" {
    consume tx = begin()
    // D157: view-borrow — log видит tx read-only, не consume'нет.
    log(tx)
    // tx остаётся Live после view-use.
    tx.commit()
}
