// EXPECT_COMPILE_ERROR D133
//
// Plan 100.1 (D133): на 2-й итерации loop'а tx предыдущей итерации
// Live → use-after-consume / not-consumed. Pessimistic loop-handling:
// переменная, потреблённая в теле, становится MaybeConsumed.
//
// Pattern: `loop { consume tx = begin() }` — каждая iteration создаёт
// новый tx, никогда не consume'ит → forget на каждой iteration.

module nova_tests.plan100_1.consume_err_loop_forget

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => { id: 1 }

test "loop без consume — каждая iteration teryает tx" {
    ro n = 3
    mut i = 0
    while i < n {
        consume tx = begin()
        // ОШИБКА D133-not-consumed: tx Live на exit'е iteration body.
        // (loop-scope exit на каждой iteration требует consume.)
        i = i + 1
    }
}
