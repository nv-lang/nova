// Plan 125.2 Ф.3 [M-125-stmt-position-divergence]:
// `Stmt::Continue` at last-stmt position in if-else arm → divergent.
// If-expr type inferred from non-divergent branch (int).

module nova_tests.plan125_2

fn sum_positive(xs []int) -> int {
    mut total = 0
    mut i = 0
    loop {
        if i >= xs.len() {
            break
        }
        ro v = xs[i]
        i = i + 1
        ro adj = if v > 0 {
            v
        } else {
            continue
        }
        total = total + adj
    }
    total
}

test "if-else-continue — type infers as int from non-divergent then arm" {
    ro xs = [1, -2, 3, -4, 5]
    ro s = sum_positive(xs)
    // Positive values: 1 + 3 + 5 = 9
    assert(s == 9)
}

test "if-else-continue — all negatives → 0" {
    ro xs = [-1, -2, -3]
    ro s = sum_positive(xs)
    assert(s == 0)
}
