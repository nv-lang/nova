// Plan 125.2 [M-125-loop-no-break-divergence]: `loop {}` без break — divergent.
// if c { loop {} } else { 42 } — then-arm divergent, тип if-expr = int
// по else-arm. Mechanical CFA expansion в expr_diverges_125.

module plan125_2.loop_inf_in_then_else_value

fn pick(c bool) -> int {
    if c {
        loop {}
    } else {
        42
    }
}

test "loop-inf in then, int in else — returns int" {
    ro n = pick(false)
    assert(n == 42)
}
