// EXPECT_COMPILE_ERROR [E_INFINITE_TYPE]
//
// Q-infinite-value-type (D280 В§4) вЂ” NEGATIVE: Av MUTUAL value-containment cycle.
//
//     type Av value { Bv Bv }
//     type Bv value { Av Av }
//
// Neither field carries indirection вЂ” `Av` inlines Av `Bv`, `Bv` inlines an `Av`, so
// the combined layout recurses `Av в†’ Bv: Bv в†’ Av: Av в†’ вЂ¦` without bound. The cycle
// passes through two distinct value records (mutual recursion), not Av single
// self-reference, and the detector's DFS-with-on-path-set catches it the same
// way: starting at `Av`, it follows the inline edge into `Bv`, then `Bv`'s inline
// edge back into `Av` (already on the path) в†’ cycle.
//
// Both decls live in ONE file so Av single-file `nova check` resolves the peer
// type. At least one of `Av`/`Bv` MUST report `E_INFINITE_TYPE`.
//
// INTENT: `nova check` EXITS NONZERO with `E_INFINITE_TYPE`.

module plan144_inftype.neg_mutual_cycle

type Av value { Bv Bv }

type Bv value { Av Av }
