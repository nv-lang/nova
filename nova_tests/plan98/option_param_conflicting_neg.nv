// EXPECT_COMPILE_ERROR plan98_undef_helper
//
// Plan 98 Ф.2.2 (negative): Nova-body method, обращающийся к
// несуществующему символу — должен падать loud (Plan 79 invariant
// «no silent fallback»). Параллель Plan 95.bis negative — убеждаемся,
// что Plan 98 inference не вводит silent fallback path.

module nova_tests.plan98.option_param_conflicting_neg

fn bad[T](o Option[T]) -> bool => plan98_undef_helper(o)

test "Plan 98: free-fn с undefined-symbol — loud-fail" {
    ro a Option[int] = Some(1)
    assert(bad(a))
}
