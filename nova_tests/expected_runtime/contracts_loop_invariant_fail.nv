// EXPECT_RUNTIME_PANIC contract requires failed in `<assert_static>`
//
// Plan 33.3 Ф.9.3: loop invariant violated → runtime panic в debug.

module expected_runtime.contracts_loop_invariant_fail

fn bad_loop(n int) -> int {
    let mut i = 0
    while i < n
        invariant i < 0   // явно ложно (i стартует с 0)
    {
        i = i + 1
    }
    i
}

fn main() Io -> () {
    let _ = bad_loop(5)
    println("UNREACHABLE")
}
