// EXPECT_RUNTIME_PANIC nova: unhandled Fail: deep
// EXPECT_STDOUT OUTER_ERRDEFER
// EXPECT_STDOUT INNER_ERRDEFER
//
// nv_panic fix: вложенные errdefer на main flow — оба срабатывают.
// Внутренний scope errdefer первым (LIFO по блокам).

module nova_tests.expected_runtime.errdefer_panic_nested_mainflow


fn main() Io -> () {
    let _ = {
        errdefer { println("OUTER_ERRDEFER") }
        let _ = {
            errdefer { println("INNER_ERRDEFER") }
            panic("deep")
            0
        }
        0
    }
}
