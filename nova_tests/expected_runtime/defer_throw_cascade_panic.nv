// EXPECT_RUNTIME_PANIC nova: unhandled Fail: deep
//
// Plan 20 gap-check (3): multi-level throw путь без user handler.
// Throw unhandled — runtime nova_throw идёт через _defer_BID_ff
// chain (LIFO defer/errdefer cleanup на каждом scope), потом до
// test-runner panic-frame, которому говорит "unhandled Fail".
//
// Тест проверяет:
//   - throw из глубокого scope проходит через все enclosing
//     defer/errdefer scopes в LIFO order.
//   - На каждом уровне ВСЕ defers (defer + errdefer) fire on
//     throw-path в LIFO регистрации.
//   - Throw корректно re-thrown на каждом уровне, доходит до
//     unhandled → test-runner panic.

module expected_runtime.defer_throw_cascade_panic


fn main() Io -> () {
    // Note: переменные не используются для проверки (test'у важен
    // только runtime panic с правильным message). Production-grade
    // тестирование cleanup-cascade требует other-way (через
    // observable side effects, fs/stdout).
    ro _ = {
        defer { println("L1 defer") }
        errdefer { println("L1 errdefer") }
        ro _ = {
            defer { println("L2 defer") }
            errdefer { println("L2 errdefer") }
            ro _ = {
                defer { println("L3 defer") }
                errdefer { println("L3 errdefer") }
                throw "deep"
                0
            }
            0
        }
        0
    }
}
