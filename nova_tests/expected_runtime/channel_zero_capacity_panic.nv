// EXPECT_RUNTIME_PANIC Channel.new: capacity must be >= 1
//
// Plan 40 Ф.3 B9: Channel.new(0) should panic.  Prior to B9 ordering
// fix the allocation happened first and only then the check fired,
// so the buffer leaked through GC pressure until the next collect.
// Functional behaviour is identical; this test pins the contract.

module expected_runtime.channel_zero_capacity_panic

fn main() {
    let _ = Channel.new(0)
}
