// EXPECT_RUNTIME_PANIC contract requires failed in `<assert_static>`
//
// Plan 33.3 Ф.9.8: loop body не decrement'ит decreases-измеритель →
// runtime assert_static panic в debug.

module expected_runtime.f9_loop_decreases_fail

fn bad_loop(n int) -> int {
    mut i = n
    mut iter = 0
    while iter < 1
        decreases i
    {
        // i не меняется → decreases не уменьшается → violation.
        iter = iter + 1
    }
    i
}

fn main() Io -> () {
    ro _ = bad_loop(5)
    println("UNREACHABLE")
}
