// EXPECT_RUNTIME_PANIC invariant failed: balance >= 0
//
// Plan 33.3 Ф.9.2: record invariant violation на конструкции →
// runtime contract violation в debug.

module expected_runtime.contracts_record_invariant_fail

type Account {
    balance int
}
    invariant balance >= 0

fn main() Io -> () {
    ro bad = Account { balance: -100 }
    println("UNREACHABLE")
    ro _ = bad
}
