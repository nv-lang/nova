// EXPECT_RUNTIME_PANIC nova: unhandled Fail: boom
// EXPECT_STDOUT C
// EXPECT_STDOUT B
// EXPECT_STDOUT A
//
// nv_panic fix: несколько errdefer на main flow — LIFO порядок.
// Регистрация: A, B, C. Ожидаемый порядок срабатывания: C, B, A.

module expected_runtime.errdefer_panic_lifo


fn main() Io -> () {
    ro _ = {
        errdefer { println("A") }
        errdefer { println("B") }
        errdefer { println("C") }
        panic("boom")
        0
    }
}
