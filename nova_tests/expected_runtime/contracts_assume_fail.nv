// EXPECT_RUNTIME_PANIC contract requires failed in `<assume>`
//
// Plan 33.3: `assume false` в debug-сборке → runtime contract violation.
// (В release с full SMT это была бы compile error, но в bootstrap-форме —
// runtime fallback.)

module nova_tests.expected_runtime.contracts_assume_fail

fn bad_assume(x int) -> int {
    assume x < 0      // программист утверждает x < 0
    x
}

fn main() Io -> () {
    let _ = bad_assume(5)   // 5 < 0 → false → contract violation
    println("UNREACHABLE")
}
