    let c19 = Channel.new(1); let r19 = c19.rx
    let c20 = Channel.new(1); let r20 = c20.rx
    let c21 = Channel.new(1); let r21 = c21.rx
    let c22 = Channel.new(1); let r22 = c22.rx
    let c23 = Channel.new(1); let r23 = c23.rx
