// EXPECT_COMPILE_ERROR select: too many channel arms (33); maximum is 32.
//
// Plan 40 Ф.3 B5: select с >32 arms раньше silently возвращал из set_recv
// и select висел вечно ожидая non-registered arm.  Теперь codegen
// эмитит compile-error с line:col на overflow.
//
// 33 arms (max+1) — минимальный triggering case.

module nova_tests.expected_runtime.select_overflow_compile_error

fn main() {
    let c0  = Channel.new(1); let r0  = c0.rx
    let c1  = Channel.new(1); let r1  = c1.rx
