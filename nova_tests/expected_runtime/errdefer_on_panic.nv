// EXPECT_RUNTIME_PANIC nova: unhandled Fail: PANIC_MSG
// EXPECT_STDOUT ERRDEFER_FIRED
//
// Plan 20 gap-check (4): errdefer fires на panic-path.
// По D90 п.7: errdefer запускается на panic(msg) пока fiber жив.
// panic в Nova dispatch'ится через nova_throw → fail-frame → cleanup.
// Реализационно panic ≡ throw без user handler — ловится _defer_BID_ff
// аналогично unhandled throw.

module expected_runtime.errdefer_on_panic


fn main() Io -> () {
    let _ = {
        errdefer { println("ERRDEFER_FIRED") }
        panic("PANIC_MSG")
        0
    }
}
