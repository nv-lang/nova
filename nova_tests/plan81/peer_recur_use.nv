// Plan 81 Ф.5: взаимная рекурсия между peer-файлами folder-модуля.
// `peer_recur` — folder-module из двух peer'ов (even.nv, odd.nv), чьи
// функции вызывают друг друга. Verify: компилируется и работает
// независимо от порядка peer'ов (order-independent, как Go package).

module plan81.peer_recur_use

import nova_tests.plan81.peer_recur.{is_even, is_odd}

test "Ф.5 — cross-peer mutual recursion resolves" {
    assert(is_even(10))
    assert(is_odd(7))
    assert(!is_even(3))
    assert(!is_odd(4))
}
