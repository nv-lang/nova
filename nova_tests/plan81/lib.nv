// Plan 81 Ф.1: тестовый модуль с exported и private функциями.
// `hidden` — не `export`, не должна быть видна импортирующему модулю.
// `public_value` — `export`, видна. Вызывает `hidden` внутри (codegen completeness).

module nova_tests.plan81.lib

fn hidden() -> int {
    42
}

export fn public_value() -> int {
    hidden() + 1
}

export const ANSWER int = 43
