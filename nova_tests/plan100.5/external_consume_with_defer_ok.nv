// Plan 100.5 (D163): external consume FFI + defer cleanup pattern.
// File через FFI, defer закрывает на всех exit-paths (D158 D90).

module nova_tests.plan100_5.external_consume_with_defer_ok

type IoErr { msg str }

external type File consume

external consume fn nova_file_open(path str) -> Result[File, IoErr] needs Fs
external fn nova_file_close(consume f File) Fail[IoErr] -> () needs Fs

fn File consume @close() Fail[IoErr] -> () {
    nova_file_close(@)
}

fn process(path str) Fail -> () {
    let r = nova_file_open(path)?
    consume file = r
    defer { file.close() }                      // failable cleanup (D158)
    // do_io(view file) — use without consume (D157)
}

test "FFI consume File + defer cleanup" {
    process("test.txt")
}
