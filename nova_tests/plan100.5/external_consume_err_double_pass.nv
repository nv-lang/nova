// EXPECT_COMPILE_ERROR D133
//
// Plan 100.5 (D152 + D133): передача consume-var дважды в external
// consume-param = use-after-consume.

module nova_tests.plan100_5.external_consume_err_double_pass

external type File consume

external consume fn nova_file_open(path str) -> File needs Fs
external fn nova_file_close(consume f File) -> () needs Fs

test "double pass в external consume-param — use-after-consume" {
    consume f = nova_file_open("x")
    nova_file_close(f)                          // ✅ first close
    // ОШИБКА D133-use-after-consume: f уже Consumed.
    nova_file_close(f)                          // ❌ second close
}
