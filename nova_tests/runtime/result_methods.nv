// result_methods.nv — D26 prelude методы на Result[T, E].
//
// Spec: spec/decisions/08-runtime.md:235.
// Bootstrap эмитит inline-dispatch: (Nova_Result*) с tag-check'ом
// на NOVA_TAG_Result_Ok / Err и closure-call'ом для f-аргумента.
// Bootstrap-ограничение: Result hardcoded на (nova_int Ok, nova_str Err).
//
// Покрываем:
//   - is_ok / is_err
//   - ok() → Option[T]
//   - err() → Option[E] (новое в этой задаче)
//   - unwrap_or(default)
//   - unwrap_or_else(f)
//   - map(f)
//   - map_err(f) — основная цель
//   - unwrap() (Fail handler)

module runtime.result_methods


// ───── is_ok / is_err ─────

test "Result.is_ok / is_err" {
    ro ok Result[int, str] = Ok(42)
    ro err Result[int, str] = Err("boom")
    assert(ok.is_ok())
    assert(!ok.is_err())
    assert(err.is_err())
    assert(!err.is_ok())
}


// ───── unwrap_or ─────

test "Result.unwrap_or — Ok(v) → v" {
    ro r Result[int, str] = Ok(99)
    assert(r.unwrap_or(0) == 99)
}


test "Result.unwrap_or — Err(_) → default" {
    ro r Result[int, str] = Err("oops")
    assert(r.unwrap_or(7) == 7)
}


// ───── unwrap_or_else ─────

test "Result.unwrap_or_else — Ok(v) skips closure" {
    ro r Result[int, str] = Ok(123)
    ro v = r.unwrap_or_else(fn(e str) -> int => 0)
    assert(v == 123)
}


test "Result.unwrap_or_else — Err(e) calls closure" {
    ro r Result[int, str] = Err("e1")
    // (Использование e.len ломает bootstrap-inference для closure-param,
    // см. Q-closure-param-inference; покрытие — interp-only.)
    ro v = r.unwrap_or_else(fn(e str) -> int => 42)
    assert(v == 42)
}


// ───── map ─────

test "Result.map — Ok(v) → Ok(f(v))" {
    ro r Result[int, str] = Ok(10)
    ro r2 = r.map(|x| x * 2)
    assert(r2.is_ok())
    assert(r2.unwrap_or(0) == 20)
}


test "Result.map — Err(e) passes through" {
    ro r Result[int, str] = Err("E")
    ro r2 = r.map(|x| x + 1)
    assert(r2.is_err())
    // Err-payload не извлекаем числовой path'ом (nova_str через NovaOpt
    // боксируется); проверяем only is_err.
}


// ───── map_err ─────

test "Result.map_err — Err(e) → Err(f(e))" {
    ro r Result[int, str] = Err("boom")
    // Closure-arg type должен быть аннотирован явно — bootstrap-codegen
    // не делает inference для closure-параметра по сигнатуре method'а
    // (Q-closure-param-inference).
    ro r2 = r.map_err(fn(e str) -> str => "wrapped: " + e)
    assert(r2.is_err())
    // Полная проверка содержимого Err — через chain ?, см. ниже тест
    // "chain через ?" (Fail-handler ловит и возвращает строку).
}


test "Result.map_err — Ok(v) passes through" {
    ro r Result[int, str] = Ok(42)
    ro r2 = r.map_err(fn(e str) -> str => "X")
    assert(r2.is_ok())
    assert(r2.unwrap_or(0) == 42)
}


// Chain через `?` — это идиома `let _ = parse(s).map_err(...)?` в
// fn возвращающей Result. В test-fn (unit return) `?` не работает —
// этот test покрывается через examples/, не через nova_tests.


// ───── ok / err Option-конверсия ─────

test "Result.ok — Ok(v) → Some(v)" {
    ro r Result[int, str] = Ok(7)
    ro o = r.ok()
    assert(o.is_some())
    assert(o.unwrap_or(0) == 7)
}


test "Result.ok — Err(_) → None" {
    ro r Result[int, str] = Err("x")
    ro o = r.ok()
    assert(o.is_none())
    assert(o.unwrap_or(99) == 99)
}


// ───── Result.unwrap (Fail на Err) ─────

test "Result.unwrap — Ok(v) → v" {
    ro r Result[int, str] = Ok(123)
    ro v = r.unwrap()
    assert(v == 123)
}


test "Result.unwrap — Err(e) бросает Fail с msg" {
    // Fail-handler ловит msg из Err.
    mut caught = ""
    with Fail = effect Fail {
        fail(msg) {
            caught = msg
            interrupt ()
        }
    } {
        ro r Result[int, str] = Err("boom")
        ro _ = r.unwrap()
    }
    assert(caught == "boom")
}


// ───── Result.err — Option[E] ─────

test "Result.err — Err(e) → Some(e), Ok → None" {
    ro err Result[int, str] = Err("E1")
    ro ok Result[int, str] = Ok(42)
    assert(err.err().is_some())
    assert(ok.err().is_none())
}


// ───── Option.unwrap_or_else ─────

test "Option.unwrap_or_else — Some(v) skips closure" {
    ro s Option[int] = Some(7)
    ro v = s.unwrap_or_else(|| 0)
    assert(v == 7)
}


test "Option.unwrap_or_else — None calls closure" {
    ro n Option[int] = None
    ro v = n.unwrap_or_else(|| 99)
    assert(v == 99)
}


// ───── Option.map ─────

test "Option.map — Some(v) → Some(f(v))" {
    ro s Option[int] = Some(5)
    ro s2 = s.map(fn(x int) -> int => x * 2)
    assert(s2.is_some())
    assert(s2.unwrap_or(0) == 10)
}


test "Option.map — None → None" {
    ro n Option[int] = None
    ro n2 = n.map(fn(x int) -> int => x + 1)
    assert(n2.is_none())
}


// ───── Option.ok_or — конверсия в Result ─────

test "Option.ok_or — Some(v) → Ok(v)" {
    ro s Option[int] = Some(42)
    ro r = s.ok_or("missing")
    assert(r.is_ok())
    assert(r.unwrap_or(0) == 42)
}


test "Option.ok_or — None → Err(e)" {
    ro n Option[int] = None
    ro r = n.ok_or("missing value")
    assert(r.is_err())
}
