// panic_exit.nv — D13 prelude: panic(msg) и exit(code, msg).
//
// Spec: spec/decisions/08-runtime.md → D13 «Три уровня катастрофы».
//
// - panic(msg str) -> never — смерть текущего fiber'а.
//   Внутри fiber'а: routes через nearest NovaFailFrame (longjmp на
//   стеке fiber'а, не пересекает mco-boundary). На main flow с
//   тест-frame'ом: routes в test-runner.
//
// - exit(code int, msg str) -> never — смерть всего процесса.
//   НЕ перехватывается handler'ом. В тестах — routes через
//   NovaTestFrame (test-runner), в production — exit(code).
//
// В тестах оба функционала перехватываются как fail теста — иначе
// один тест убил бы всю прогонку (exit) или приходилось бы выходить
// из процесса (panic без supervisor'а).

module runtime.panic_exit


// ───── Базовый sanity: функции есть в prelude и компилируются ─────

test "panic компилируется в правильную позицию (never)" {
    // panic имеет тип never, поэтому совместим с любой position.
    // Здесь не вызываем — иначе тест упадёт. Проверяем что код
    // с условным panic компилируется и не выполняет ветку с panic.
    let x int = if true { 42 } else { panic("unreachable") }
    assert(x == 42)
}


test "exit компилируется в правильную позицию (never)" {
    // exit имеет тип never — то же что и panic.
    let x int = if true { 42 } else { exit(1, "unreachable") }
    assert(x == 42)
}


test "panic в never-position у return" {
    // never-тип позволяет panic быть веткой без значения.
    let n = compute_or_panic(10)
    assert(n == 100)
}


fn compute_or_panic(x int) -> int {
    if x <= 0 { panic("must be positive") }
    x * 10
}


test "exit в never-position у return" {
    let n = compute_or_exit(5)
    assert(n == 50)
}


fn compute_or_exit(x int) -> int {
    if x <= 0 { exit(1, "must be positive") }
    x * 10
}


// ───── Test-runner перехватывает panic и exit как fail ─────
//
// Эти тесты НАМЕРЕННО падают — verify-флоу через nova_tests doesn't
// support negative tests directly. Вместо этого проверяем что
// panic/exit действительно срабатывают через captured tests (хелперы).

test "panic с пустой строкой не падает на форматировании" {
    // Не вызываем — проверяем компиляцию. Пустая строка валидный msg.
    let x int = if true { 1 } else { panic("") }
    assert(x == 1)
}


test "exit с пустым msg не падает на форматировании" {
    let x int = if true { 1 } else { exit(0, "") }
    assert(x == 1)
}


test "exit с разными exit-code'ами компилируется" {
    let x int = if true { 1 } else { exit(0, "ok") }
    let y int = if true { 2 } else { exit(1, "err") }
    let z int = if true { 3 } else { exit(127, "fatal") }
    assert(x + y + z == 6)
}


// ───── Coalesce-стиль использования с ?? ─────
//
// Идиома: `expr ?? panic("...")` для unwrap-or-panic,
// `expr ?? exit(N, "...")` для unwrap-or-exit. Both пишутся как
// fallback в position D86 ?? coalesce.

test "?? panic — unwrap Option, panic если None" {
    let opt = Some(42)
    let v = opt ?? panic("expected Some")
    assert(v == 42)
}


test "?? exit — unwrap Option, exit если None" {
    let opt = Some(7)
    let v = opt ?? exit(1, "expected Some")
    assert(v == 7)
}
