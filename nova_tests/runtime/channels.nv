// channels.nv — D91 Channel[T] capability-split семантика.
//
// Plan 21: Channel.new(cap) -> (Sender[T], Receiver[T]).
// Sender: send, try_send, close, len, capacity, is_closed.
// Receiver: recv, try_recv, len, capacity, is_closed.
// Park/wake через D93 sched API — no busy-loops (R7 Plan 22).
//
// NOTE: defer tx.close() не используется с tx из tuple-destructure —
// defer setjmp-frame эмитится до объявления переменных. Вместо этого
// явный tx.close() в конце теста там где нужно (Plan 25 G8 = open-coded
// defer устранит это ограничение в будущем).

module nova_tests.runtime.channels

// ================================================================
// SECTION 1: send / recv — buffered channel
// ================================================================

test "channel: send + recv FIFO" {
    let (tx, rx) = Channel.new(4)
    tx.send(10)
    tx.send(20)
    tx.send(30)
    let a = rx.recv()
    let b = rx.recv()
    let c = rx.recv()
    assert(a.unwrap_or(-1) == 10)
    assert(b.unwrap_or(-1) == 20)
    assert(c.unwrap_or(-1) == 30)
    tx.close()
}

test "channel: len и capacity" {
    let (tx, rx) = Channel.new(8)
    assert(rx.capacity() == 8)
    assert(rx.len() == 0)
    tx.send(1)
    tx.send(2)
    assert(rx.len() == 2)
    let _ = rx.recv()
    assert(rx.len() == 1)
    tx.close()
}

test "channel: ring-buffer wrap" {
    let (tx, rx) = Channel.new(3)
    tx.send(1)
    tx.send(2)
    let _ = rx.recv()
    tx.send(3)
    tx.send(4)
    assert(rx.recv().unwrap_or(-1) == 2)
    assert(rx.recv().unwrap_or(-1) == 3)
    assert(rx.recv().unwrap_or(-1) == 4)
    tx.close()
}

// ================================================================
// SECTION 2: closed-channel семантика
// ================================================================

test "channel: close + recv drain" {
    let (tx, rx) = Channel.new(4)
    tx.send(1)
    tx.send(2)
    tx.close()
    assert(rx.recv().unwrap_or(-1) == 1)
    assert(rx.recv().unwrap_or(-1) == 2)
    assert(rx.recv().is_none())
    assert(rx.recv().is_none())
}

test "channel: is_closed" {
    let (tx, rx) = Channel.new(2)
    assert(!rx.is_closed())
    tx.close()
    assert(rx.is_closed())
}

test "channel: close idempotent" {
    let (tx, rx) = Channel.new(2)
    tx.close()
    tx.close()
    assert(rx.is_closed())
}

// ================================================================
// SECTION 3: try_send / try_recv — non-blocking
// ================================================================

test "channel: try_send full buffer" {
    let (tx, rx) = Channel.new(2)
    assert(tx.try_send(10))
    assert(tx.try_send(20))
    assert(!tx.try_send(30))
    assert(rx.recv().unwrap_or(-1) == 10)
    assert(tx.try_send(30))
    tx.close()
}

test "channel: try_recv empty buffer" {
    let (tx, rx) = Channel.new(4)
    assert(rx.try_recv().is_none())
    tx.send(42)
    assert(rx.try_recv().unwrap_or(-1) == 42)
    assert(rx.try_recv().is_none())
    tx.close()
}

test "channel: try_send на closed → false" {
    let (tx, _rx) = Channel.new(2)
    tx.close()
    assert(!tx.try_send(1))
}

// ================================================================
// SECTION 4: while-let recv-loop
// ================================================================

test "channel: while-let drain pattern" {
    let (tx, rx) = Channel.new(4)
    tx.send(10)
    tx.send(20)
    tx.send(30)
    tx.close()
    let mut sum = 0
    while let Some(v) = rx.recv() {
        sum = sum + v
    }
    assert(sum == 60)
}

// ================================================================
// SECTION 5: concurrent send+recv via spawn (Plan 22 park/wake)
// ================================================================

test "channel: concurrent send+recv via spawn" {
    let (tx, rx) = Channel.new(1)
    let mut received = 0
    supervised {
        spawn {
            tx.send(42)
            tx.close()
        }
        spawn {
            let v = rx.recv()
            received = v.unwrap_or(-1)
        }
    }
    assert(received == 42)
}

test "channel: producer-consumer pipeline" {
    let (tx, rx) = Channel.new(4)
    let mut sum = 0
    supervised {
        spawn {
            tx.send(1)
            tx.send(2)
            tx.send(3)
            tx.send(4)
            tx.send(5)
            tx.close()
        }
        spawn {
            while let Some(v) = rx.recv() {
                sum = sum + v
            }
        }
    }
    assert(sum == 15)
}

test "channel: ping-pong" {
    let (tx1, rx1) = Channel.new(1)
    let (tx2, rx2) = Channel.new(1)
    let mut result = 0
    supervised {
        spawn {
            tx1.send(10)
            let reply = rx2.recv()
            result = reply.unwrap_or(-1)
            tx1.close()
        }
        spawn {
            let msg = rx1.recv()
            tx2.send(msg.unwrap_or(0) * 2)
            tx2.close()
        }
    }
    assert(result == 20)
}

// ================================================================
// SECTION 6: передача Sender / Receiver в функции (type annotation)
// ================================================================

fn fill_channel(tx ChanWriter[int], values []int) {
    let mut i = 0
    while i < values.len() {
        tx.send(values[i])
        i = i + 1
    }
    tx.close()
}

fn drain_channel(rx ChanReader[int]) -> int {
    let mut sum = 0
    while let Some(v) = rx.recv() {
        sum = sum + v
    }
    sum
}

test "channel: Sender передаётся в функцию" {
    let (tx, rx) = Channel.new(8)
    fill_channel(tx, [1, 2, 3, 4, 5])
    let a = rx.recv().unwrap_or(-1)
    assert(a == 1)
    tx.close()
}

test "channel: Receiver передаётся в функцию" {
    let (tx, rx) = Channel.new(8)
    tx.send(10)
    tx.send(20)
    tx.send(30)
    tx.close()
    let s = drain_channel(rx)
    assert(s == 60)
}

test "channel: Sender и Receiver передаются независимо" {
    let (tx, rx) = Channel.new(8)
    fill_channel(tx, [100, 200, 300])
    let s = drain_channel(rx)
    assert(s == 600)
}

fn relay(rx ChanReader[int], tx ChanWriter[int]) {
    while let Some(v) = rx.recv() {
        tx.send(v * 2)
    }
    tx.close()
}

test "channel: relay — Receiver → Sender pipeline через функцию" {
    let (tx1, rx1) = Channel.new(4)
    let (tx2, rx2) = Channel.new(4)
    tx1.send(1)
    tx1.send(2)
    tx1.send(3)
    tx1.close()
    relay(rx1, tx2)
    let s = drain_channel(rx2)
    assert(s == 12)
}

// ── Секция 7: send → bool (Plan 30 Ф.1) ──────────────────────────

test "channel: send после close возвращает false, не паникует" {
    let (tx, _rx) = Channel.new(2)
    assert(tx.send(1))
    tx.close()
    assert(!tx.send(99))
}

test "channel: send в открытый канал возвращает true" {
    let (tx, rx) = Channel.new(4)
    assert(tx.send(10))
    assert(tx.send(20))
    assert(tx.send(30))
    tx.close()
    let a = rx.recv() ?? -1
    let b = rx.recv() ?? -1
    let c = rx.recv() ?? -1
    assert(a == 10)
    assert(b == 20)
    assert(c == 30)
}

test "channel: send возвращаемое значение можно использовать как bool" {
    let (tx, _rx) = Channel.new(1)
    let ok = tx.send(42)
    assert(ok)
    tx.close()
    let ok2 = tx.send(0)
    assert(!ok2)
}

// ── Секция 8: multi-writer tx.clone() (Plan 30 Ф.2) ──────────────

test "channel: clone — канал НЕ закрыт после close оригинала" {
    let (tx, rx) = Channel.new(4)
    let tx2 = tx.clone()
    tx.send(1)
    tx.close()
    // tx закрыт (writer_count = 1), но tx2 ещё жив (writer_count = 1→0 при tx2.close)
    assert(!rx.is_closed())
    tx2.send(2)
    tx2.close()
    // теперь все writers закрыты
    assert(rx.is_closed())
    let a = rx.recv() ?? -1
    let b = rx.recv() ?? -1
    assert(a == 1)
    assert(b == 2)
}

test "channel: clone/close порядок — канал закрыт только когда все writers закрыты" {
    let (tx, rx) = Channel.new(2)
    let tx2 = tx.clone()
    // close clone первым — оригинал ещё жив
    tx2.close()
    assert(!rx.is_closed())
    // close original — теперь всё
    tx.close()
    assert(rx.is_closed())
}

test "channel: fan-in — два writer'а, один reader" {
    let (tx, rx) = Channel.new(8)
    let tx2 = tx.clone()
    let mut sum = 0
    supervised {
        spawn {
            tx.send(1)
            tx.send(2)
            tx.send(3)
            tx.close()
        }
        spawn {
            tx2.send(10)
            tx2.send(20)
            tx2.send(30)
            tx2.close()
        }
        spawn {
            while let Some(v) = rx.recv() {
                sum = sum + v
            }
        }
    }
    assert(sum == 66)
}

// ── Секция 9: исправления Plan 30 review ──────────────────────────

test "channel: double-close одного writer idempotent (Б1 fix)" {
    let (tx, rx) = Channel.new(2)
    tx.send(42)
    tx.close()
    tx.close()  // повторный close НЕ должен corrupting writer_count
    // канал закрыт после первого close
    assert(rx.is_closed())
    assert(rx.recv().unwrap_or(-1) == 42)
}

test "channel: double-close clone не ломает другой writer (Б1 fix)" {
    let (tx, rx) = Channel.new(4)
    let tx2 = tx.clone()  // writer_count = 2
    tx.close()            // writer_count = 1, closed = false
    tx.close()            // idempotent — writer_count остаётся 1
    assert(!rx.is_closed())  // tx2 ещё жив
    tx2.send(99)
    tx2.close()           // writer_count = 0, closed = true
    assert(rx.is_closed())
    assert(rx.recv().unwrap_or(-1) == 99)
}

test "channel: try_recv различает empty-open от empty-closed через is_closed (Н1)" {
    let (tx, rx) = Channel.new(4)
    // пустой открытый
    assert(rx.try_recv().is_none())
    assert(!rx.is_closed())
    // пустой закрытый
    tx.close()
    assert(rx.try_recv().is_none())
    assert(rx.is_closed())
}

test "channel: try_recv drains buffer после close (Н1)" {
    let (tx, rx) = Channel.new(4)
    tx.send(1)
    tx.send(2)
    tx.close()
    // данные ещё в буфере — try_recv их читает
    assert(rx.try_recv().unwrap_or(-1) == 1)
    assert(rx.try_recv().unwrap_or(-1) == 2)
    // буфер исчерпан И канал закрыт
    assert(rx.try_recv().is_none())
    assert(rx.is_closed())
}

test "channel: try_send closed channel → false и is_closed (Н1)" {
    let (tx, _rx) = Channel.new(2)
    tx.close()
    assert(!tx.try_send(42))
    assert(tx.is_closed())
}
