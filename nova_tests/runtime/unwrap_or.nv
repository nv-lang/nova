// 57_unwrap_or.nv — D26 prelude: базовые методы Option/Result.
//
// Option[T]: is_some / is_none / unwrap / unwrap_or
// Result[T,E]: is_ok / is_err / ok / unwrap / unwrap_or

module runtime.unwrap_or

// ================================================================
// SECTION 1: Option<int>
// ================================================================

test "Some.is_some / is_none" {
    ro s = Some(42)
    assert(s.is_some())
    assert(!s.is_none())
}

test "None.is_some / is_none" {
    ro n = None
    assert(!n.is_some())
    assert(n.is_none())
}

test "Some.unwrap_or" {
    ro s = Some(42)
    assert(s.unwrap_or(0) == 42)
}

test "None.unwrap_or" {
    ro n = None
    assert(n.unwrap_or(99) == 99)
}

test "Some.unwrap" {
    ro s = Some(7)
    assert(s.unwrap() == 7)
}

test "None.unwrap throws Fail (caught)" {
    mut caught = false
    with Fail = effect Fail {
        fail(_msg) {
            caught = true
            interrupt ()
        }
    } {
        ro n = None
        ro _ = n.unwrap()
    }
    assert(caught)
}

// ================================================================
// SECTION 2: Result<int, str>
// ================================================================

test "Ok.is_ok / is_err" {
    ro r = Ok(42)
    assert(r.is_ok())
    assert(!r.is_err())
}

test "Err.is_ok / is_err" {
    ro r = Err("oops")
    assert(!r.is_ok())
    assert(r.is_err())
}

test "Ok.unwrap_or" {
    ro r = Ok(42)
    assert(r.unwrap_or(0) == 42)
}

test "Err.unwrap_or" {
    ro r = Err("bad")
    assert(r.unwrap_or(99) == 99)
}

test "Ok.ok() returns Some" {
    ro r = Ok(5)
    ro o = r.ok()
    assert(o.unwrap_or(-1) == 5)
}

test "Err.ok() returns None" {
    ro r = Err("err")
    ro o = r.ok()
    assert(o.is_none())
    assert(o.unwrap_or(99) == 99)
}

test "Ok.unwrap" {
    ro r = Ok(123)
    assert(r.unwrap() == 123)
}

test "Err.unwrap throws Fail with err message" {
    mut caught_msg = ""
    with Fail = effect Fail {
        fail(msg) {
            caught_msg = msg
            interrupt ()
        }
    } {
        ro r = Err("custom error")
        ro _ = r.unwrap()
    }
    assert(caught_msg == "custom error")
}

// ================================================================
// SECTION 3: chained unwrap_or pattern
// ================================================================

fn try_parse(s str) -> Option {
    if s == "42" { Some(42) } else { None }
}

test "chained: try_parse(s).unwrap_or(default)" {
    assert(try_parse("42").unwrap_or(0) == 42)
    assert(try_parse("bad").unwrap_or(0) == 0)
    assert(try_parse("nope").unwrap_or(-1) == -1)
}
