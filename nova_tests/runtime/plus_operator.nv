// plus_operator.nv — Plan 13 Ф.9.2: оператор `+` через @plus method
// (D46 operator overload). Plan 91 followup: StringBuilder.@plus убран
// (используйте .append() напрямую); этот файл покрывает только str + str.
//
// Семантика:
//   s1 + s2   → s1.@plus(s2)   → @concat(s2)  (str + str)
//
// Decls в std/runtime/string.nv. Routing — общее правило в codegen для BinOp::Add (D46).

module runtime.plus_operator


// ================================================================
// SECTION 1: str + str через @plus → @concat
// ================================================================

test "str + str — пустые" {
    assert("" + "" == "")
    assert("" + "x" == "x")
    assert("y" + "" == "y")
}

test "str + str — ASCII" {
    assert("foo" + "bar" == "foobar")
    ro result = "alpha" + "-" + "beta"
    assert(result == "alpha-beta")
}

test "str + str — Unicode len/char_len (Plan 108 D26 rev)" {
    ro a = "Привет"      // 6 codepoints, 12 bytes
    ro b = ", "          // 2 codepoints, 2 bytes
    ro c = "мир"         // 3 codepoints, 6 bytes
    ro s = a + b + c
    assert(s.len() == 20)             // 12 + 2 + 6 bytes (len = bytes now)
    assert(s.char_len() == 11)        // 6 + 2 + 3 codepoints
}
