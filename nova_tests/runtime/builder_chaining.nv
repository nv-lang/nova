// builder_chaining.nv — Plan 13 Ф.9.1: Self-return chaining для
// StringBuilder и WriteBuffer.
//
// Mut-методы возвращают `Self` чтобы вызовы можно было сцеплять:
//   sb.append(a).append(b).append(c)
//   wb.write_u32_be(magic).write_u16_be(version).write_bytes(payload)
//
// Также static creation методы возвращают Self (унификация).

module nova_tests.runtime.builder_chaining


// ================================================================
// SECTION 1: StringBuilder.@append chaining
// ================================================================

test "StringBuilder: chained append str" {
    let mut sb = StringBuilder.new()
    sb.append("hello").append(" ").append("world")
    let s = sb.into()
    assert(s == "hello world")
}

test "StringBuilder: chained append str + char" {
    let mut sb = StringBuilder.new()
    sb.append("=").append('>').append(" ").append("ok")
    let s = sb.into()
    assert(s == "=> ok")
}

test "StringBuilder: chain produces same buffer (Self semantics)" {
    let mut sb = StringBuilder.new()
    let r = sb.append("a").append("b")
    // r и sb — один и тот же буфер. Проверка через @len + into.
    assert(sb.len() == 2)
    let s = sb.into()
    assert(s == "ab")
}


// ================================================================
// SECTION 2: WriteBuffer chained writes
// ================================================================

test "WriteBuffer: chained write_byte" {
    let mut wb = WriteBuffer.new()
    wb.write_byte(0x01).write_byte(0x02).write_byte(0x03)
    assert(wb.len() == 3)
    let bs = wb.into()
    assert(bs.len == 3)
    assert(bs[0] == 0x01)
    assert(bs[1] == 0x02)
    assert(bs[2] == 0x03)
}

test "WriteBuffer: chained mixed writes (numeric + bytes)" {
    let mut wb = WriteBuffer.new()
    wb.write_u32_be(0xDEADBEEF as u32).write_u16_be(0x1234 as u16).write_byte(0xFF)
    assert(wb.len() == 7)         // 4 + 2 + 1
    let bs = wb.into()
    // Big-endian u32: DE AD BE EF
    assert(bs[0] == 0xDE)
    assert(bs[1] == 0xAD)
    assert(bs[2] == 0xBE)
    assert(bs[3] == 0xEF)
    // Big-endian u16: 12 34
    assert(bs[4] == 0x12)
    assert(bs[5] == 0x34)
    // Single byte
    assert(bs[6] == 0xFF)
}

test "WriteBuffer: chained text writes" {
    let mut wb = WriteBuffer.new()
    wb.write_str("nova").write_char('-').write_str("lang")
    let bs = wb.into()
    let mut rb = ReadBuffer.from(bs)
    let s = rb.read_str(9)         // 4 + 1 + 4 codepoints
    assert(s == "nova-lang")
}


// ================================================================
// SECTION 3: Round-trip — chaining работает совместно с read_*
// ================================================================

test "round-trip: builder chain → read_str codepoints" {
    let mut wb = WriteBuffer.new()
    wb.write_str("Hello, ").write_str("Привет!")
    let bs = wb.into()
    let mut rb = ReadBuffer.from(bs)

    let part1 = rb.read_str(7)     // "Hello, " — 7 codepoints
    assert(part1 == "Hello, ")
    let part2 = rb.read_str(7)     // "Привет!" — 7 codepoints
    assert(part2 == "Привет!")
    assert(rb.remaining() == 0)
}
