// read_text.nv — Plan 13 Ф.9.4: codepoint-уровневые reads на ReadBuffer.
//
// API (из std/runtime/read_buffer.nv):
//   rb.read_char()      Fail[ReadBufferError] -> char    (1 codepoint, 1-4 байта)
//   rb.try_read_char()  -> Result[char, ReadBufferError]
//   rb.read_str(n int)  Fail[ReadBufferError] -> str     (n codepoint'ов)
//   rb.try_read_str(n)  -> Result[str, ReadBufferError]
//
// Errors: UnexpectedEnd (буфер пуст / неполная UTF-8 sequence на хвосте)
//   либо InvalidUtf8 { position int } (мусорный байт в середине sequence).

module runtime.read_text


// ================================================================
// SECTION 1: read_char — happy path
// ================================================================

test "read_char ASCII (1 u8)" {
    mut wb = WriteBuffer.new()
    wb.write_char('H')
    wb.write_char('i')
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)
    ro c1 = rb.read_char()
    ro c2 = rb.read_char()
    assert(c1 == 'H')
    assert(c2 == 'i')
    assert(rb.remaining() == 0)
}

test "read_char Cyrillic (2 bytes UTF-8)" {
    // 'П' = U+041F → 0xD0 0x9F (2 bytes)
    mut wb = WriteBuffer.new()
    wb.write_char('П')
    ro bs = wb.into()
    assert(bs.len() == 2)            // 2 байта
    mut rb = ReadBuffer.from(bs)
    ro c = rb.read_char()
    assert(c == 'П')
    assert(rb.remaining() == 0)
}

test "read_char emoji (4 bytes UTF-8)" {
    // '😀' = U+1F600 → 4-byte UTF-8 sequence
    mut wb = WriteBuffer.new()
    wb.write_char('😀')
    ro bs = wb.into()
    assert(bs.len() == 4)
    mut rb = ReadBuffer.from(bs)
    ro c = rb.read_char()
    assert(c == '😀')
    assert(rb.remaining() == 0)
}

test "read_char advances by codepoint width, not byte" {
    mut wb = WriteBuffer.new()
    wb.write_char('A')   // 1 u8
    wb.write_char('П')   // 2 bytes
    wb.write_char('B')   // 1 u8
    ro bs = wb.into()
    assert(bs.len() == 4)            // 1+2+1
    mut rb = ReadBuffer.from(bs)

    ro c1 = rb.read_char()
    assert(c1 == 'A')
    assert(rb.position() == 1)     // advanced 1 u8

    ro c2 = rb.read_char()
    assert(c2 == 'П')
    assert(rb.position() == 3)     // advanced 2 bytes

    ro c3 = rb.read_char()
    assert(c3 == 'B')
    assert(rb.position() == 4)     // advanced 1 u8
}


// ================================================================
// SECTION 2: read_str(n) — happy path
// ================================================================

test "read_str ASCII (n codepoints == n bytes)" {
    mut wb = WriteBuffer.new()
    wb.write_str("hello world")
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)

    ro s = rb.read_str(5)
    assert(s == "hello")
    assert(rb.position() == 5)
    assert(rb.remaining() == 6)    // " world"
}

test "read_str mixed ASCII + Cyrillic (n codepoints != n bytes)" {
    mut wb = WriteBuffer.new()
    wb.write_str("a Привет")        // 1 + 1 + 6*2 = 14 bytes, 8 codepoints
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)

    ro s = rb.read_str(2)         // "a "
    assert(s == "a ")
    assert(rb.position() == 2)     // 2 bytes для 2 ASCII codepoints

    ro cyr = rb.read_str(6)        // "Привет"
    assert(cyr == "Привет")
    assert(rb.position() == 14)    // 2 + 12 bytes
    assert(rb.remaining() == 0)
}


// ================================================================
// SECTION 3: try_read_char / try_read_str — Result-форма
// ================================================================

test "try_read_char Ok happy path" {
    mut wb = WriteBuffer.new()
    wb.write_char('X')
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)

    ro r = rb.try_read_char()
    assert(r.is_ok())
    ro c = r.unwrap_or(0)
    assert(c == 'X')
}

test "try_read_char Err when buffer empty" {
    // Empty buffer.
    mut wb = WriteBuffer.new()
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)

    ro r = rb.try_read_char()
    assert(r.is_err())
}

test "try_read_str Err when too few codepoints" {
    mut wb = WriteBuffer.new()
    wb.write_str("hi")              // 2 codepoints
    ro bs = wb.into()
    mut rb = ReadBuffer.from(bs)

    // Просим больше codepoint'ов чем доступно.
    ro r = rb.try_read_str(5)
    assert(r.is_err())
}
