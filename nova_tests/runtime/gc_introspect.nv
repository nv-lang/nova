// Тесты std.runtime.gc — GC introspection API.
// Семантика: malloc backend → heap_size()=0, alloc_count монотонный.
// Boehm backend → heap_size() > 0 после аллокаций.
// Тесты используют if gc.heap_size() == 0 { ... } differential-pattern.

module runtime.gc_introspect

import std.runtime.gc

test "gc.heap_size: возвращает int >= 0" {
    let h = gc.heap_size()
    assert(h >= 0)
}

test "gc.live_count: возвращает int >= 0" {
    let n = gc.live_count()
    assert(n >= 0)
}

test "gc.alloc_count: монотонно растёт после аллокаций" {
    gc.reset_stats()
    let before = gc.alloc_count()
    // Аллоцируем строки — каждая concat создаёт новый объект
    let mut i = 0
    while i < 10 {
        let s = "alloc-" + str.from(i)
        assert(s.len() > 0)
        i += 1
    }
    let after = gc.alloc_count()
    assert(after > before)
}

test "gc.reset_stats: сбрасывает alloc_count" {
    // Делаем аллокации
    let _ = "x" + "y" + "z"
    gc.reset_stats()
    let after_reset = gc.alloc_count()
    assert(after_reset == 0)
}

test "gc.collect: не падает" {
    gc.collect()
    // No assert — просто проверяем что вызов не паникует
    assert(true)
}

test "gc.last_pause_ns: возвращает int >= 0" {
    gc.collect()
    let ns = gc.last_pause_ns()
    assert(ns >= 0)
}

test "gc.heap_size differential: под boehm > 0, под malloc = 0" {
    let h = gc.heap_size()
    if h == 0 {
        // malloc backend — sentinel, не ошибка
        assert(true)
    } else {
        // boehm backend — heap есть
        assert(h > 0)
    }
}
