// Plan 34 follow-up: gc.alloc_count behavior — после аллокаций счётчик
// должен расти. Это differential test: показывает что counter реально
// инкрементируется на real allocation.

module nova_tests.plan34.gc_alloc_monotonic


type Obj { a int, b int }


test "gc.alloc_count растёт после аллокаций" {
    gc.reset_stats()
    let before = gc.alloc_count()
    // Создаём 100 короткоживущих объектов.
    let mut sink = 0
    for i in 0..100 {
        let o = Obj { a: i, b: i * 2 }
        sink = sink + o.a
    }
    let after = gc.alloc_count()
    assert(after >= before)
    assert(sink == 4950)        // sum(0..99) = 4950
}


test "gc.collect после reset_stats — heap_size не падает в инвалидное" {
    gc.reset_stats()
    gc.collect()
    let h = gc.heap_size()
    assert(h >= 0)
}
