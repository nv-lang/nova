module nova_tests.plan61

// Plan 61 / D65 правило 1: `Fail` ≡ `Fail[any]` — alias / catch-all.
// `with Fail = |e| ...` (без [E]) ловит **любой** throw.

export type ParseError | Bad

fn raise1() Fail[ParseError] -> int {
    throw Bad
}

test "Fail без [E] ловит любой typed throw" {
    ro n = with Fail = |_e| interrupt 42 {
        ro _ = raise1()
        0
    }
    assert(n == 42, "Fail catch-all interrupts to 42")
}
