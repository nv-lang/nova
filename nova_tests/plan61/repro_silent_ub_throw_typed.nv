module nova_tests.plan61

// Plan 61 Ф.0 repro: Silent UB #1 — throw user-error становится garbage.
//
// Текущий codegen (emit_c.rs:8503-8517): для не-nova_str value делает
// `nova_int_to_str((nova_int)(val))` — кастует pointer к int и форматирует
// как число. Handler получает строку типа "140726384521232".
//
// После Plan 61 Ф.3 (per-E specialization): handler arm видит typed
// `e: ParseError_reprosilentubthrowtyped`, может прочитать `e.detail`.

export type ParseError_reprosilentubthrowtyped | Bad(str) | EOF

fn raise2() Fail[ParseError_reprosilentubthrowtyped] -> int {
    throw Bad("expected digit")
}

test "throw ParseError_reprosilentubthrowtyped carries typed payload" {
    ro result = with Fail[ParseError_reprosilentubthrowtyped] = |e| interrupt (match e {
        Bad(detail) => detail
        EOF         => "eof"
    }) {
        ro _ = raise2()
        "unreachable"
    }
    // До Plan 61 — silent garbage. После Plan 61 — passes.
    assert(result == "expected digit", "handler should receive typed payload")
}
