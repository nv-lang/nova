// Plan 108.1 (D176 amend): `mut readonly` параметр — parser-level
// E_PARAM_MOD_CONFLICT (взаимоисключающие квалификаторы).

// EXPECT_COMPILE_ERROR E_PARAM_MOD_CONFLICT

module nova_tests.plan108_1.mut_readonly_conflict_neg

fn bad(mut readonly b []int) -> int => b.len()

test "mut + readonly → parser error" {
    let arr = [1]
    let _ = bad(arr)
}
