// Plan 108.1 (D176 amend): `readonly` параметр — явный synonym дефолта
// (без mut).  Только read-доступ — len, доступ к элементам без мутаций.

module plan108_1.readonly_param_explicit_ok

fn count_items(ro b []int) -> int => b.len()

fn sum(b []int) -> int {
    mut total = 0
    for x in b {
        total = total + x
    }
    total
}

test "ro param explicit + default param (read-only)" {
    mut arr = [10, 20, 30]
    assert(count_items(arr) == 3)
    assert(sum(arr) == 60)
}
