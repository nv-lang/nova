// Plan 108.1 (D176 amend) — Property test: param mutability invariant.
//
// Свойство: для любого N итераций, helper-функция с `mut`-параметром
// корректно мутирует переданный массив N раз; helper с readonly параметром
// видит accumulated state без мутации (read-only витрина).
//
// Это runtime-witness: если бы readonly-семантика была нарушена,
// suit бы failed at type-check.  Прохождение фикстуры = compile-time
// доказательство.

module nova_tests.plan108_1.param_mut_count_invariant_prop

fn append_n(mut buf []int, n int) -> int {
    let mut i = 0
    while i < n {
        buf.push(i)
        i = i + 1
    }
    buf.len()
}

fn observe_no_mut(readonly buf []int) -> int {
    let mut sum = 0
    for x in buf { sum = sum + x }
    sum
}

test "property: N=10 mutations + read-only observation" {
    let mut buf = []
    let len = append_n(buf, 10)
    assert(len == 10)
    let sum = observe_no_mut(buf)
    assert(sum == 45)             // 0+1+2+…+9 = 45
}

test "property: N=100 mutations + read-only observation" {
    let mut buf = []
    let len = append_n(buf, 100)
    assert(len == 100)
    let sum = observe_no_mut(buf)
    assert(sum == 4950)           // 0+1+…+99 = 4950
}

test "property: zero mutations preserves source" {
    let mut buf = [1, 2, 3]
    let len = append_n(buf, 0)
    assert(len == 3)
    let sum = observe_no_mut(buf)
    assert(sum == 6)
}
