// Plan 108.1 (D176 amend): `consume` параметр неявно подразумевает `mut`
// (ownership transfer → callee владеет → может мутировать).

module plan108_1.consume_implies_mut_ok

fn build_str(consume sb StringBuilder) -> str {
    sb.append("!")        // ✓ consume → mut неявный
    sb.as_str()
}

test "consume param can mutate" {
    consume sb = StringBuilder.from("hi")
    ro result = build_str(sb)
    assert(result == "hi!")
}
