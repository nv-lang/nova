// Plan 108.1 (D176 amend): default (без модификатора) и `readonly` —
// семантически идентичны (оба = read-only).  Доступны: read fields,
// non-mut методы, итерация.

module plan108_1.readonly_param_synonym_default_ok

fn count_default(b []int) -> int => b.len()
fn count_readonly(ro b []int) -> int => b.len()

fn iter_sum_default(b []int) -> int {
    mut s = 0
    for x in b { s = s + x }
    s
}

fn iter_sum_readonly(ro b []int) -> int {
    mut s = 0
    for x in b { s = s + x }
    s
}

test "default param ≡ ro param" {
    mut arr = [3, 4, 5]
    assert(count_default(arr) == count_readonly(arr))
    assert(iter_sum_default(arr) == iter_sum_readonly(arr))
    assert(iter_sum_default(arr) == 12)
}
