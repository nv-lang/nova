// Plan 108.1 (D176 amend): явный `readonly` параметр — вызов `.push`
// должен дать E_PARAM_NOT_MUT (default semantics same as missing modifier).

// EXPECT_COMPILE_ERROR E_PARAM_NOT_MUT

module nova_tests.plan108_1.readonly_explicit_push_neg

fn append_99(readonly b []int) -> int {
    b.push(99)             // ✗ E_PARAM_NOT_MUT — `readonly` строго запрещает
    b.len()
}

test "readonly + push → error" {
    let mut arr = [1, 2]
    let _ = append_99(arr)
}
