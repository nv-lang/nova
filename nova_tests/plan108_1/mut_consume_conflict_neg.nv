// Plan 108.1 (D176 amend): `mut consume` параметр — parser-level
// E_PARAM_MOD_CONFLICT (взаимоисключающие квалификаторы).

// EXPECT_COMPILE_ERROR E_PARAM_MOD_CONFLICT

module nova_tests.plan108_1.mut_consume_conflict_neg

fn bad(mut consume sb StringBuilder) -> str => sb.as_str()

test "mut + consume → parser error" {
    consume sb = StringBuilder.from("x")
    let _ = bad(sb)
}
