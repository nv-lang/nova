// Plan 108.1 (D176 amend): `mut` параметр для user-defined record-типа
// с `mut @method` методом.

module nova_tests.plan108_1.mut_param_user_record_ok

type Counter {
    mut value int
}

fn Counter.new() -> Counter => { value: 0 }

fn Counter mut @inc(n int) -> () {
    @value = @value + n
}

fn Counter @get() -> int => @value

fn bump_by_5(mut c Counter) -> int {
    c.inc(5)
    c.get()
}

test "mut param + user-defined mut @method" {
    let c = Counter.new()
    let v = bump_by_5(c)
    assert(v == 5)
    assert(c.get() == 5)
}
