// Plan 46 (D102) Ф.3 + Plan 50 (D102 ревизия): именованные аргументы +
// variadic. D102: named args только для параметров ДО variadic;
// variadic — последний, без дефолта.
//
// Plan 50 ревизия: параметр с дефолтом — keyword-only. Следствие для
// variadic: дефолтный regular-параметр НЕЛЬЗЯ передать позиционно, а
// named-параметр нельзя смешать с позиционным variadic-хвостом
// (named-before-positional). Поэтому:
//   - regular БЕЗ дефолта  → позиционно + variadic-хвост (валидно);
//   - regular С дефолтом   → по имени / опущен, variadic-хвост пуст.

module named_params.variadic

// --- regular-параметр БЕЗ дефолта: позиционный + variadic-хвост ---

fn sum_all(start int, ...nums []int) -> int {
    let mut total = start
    for n in nums {
        total = total + n
    }
    total
}

test "variadic: обязательный позиционный start + variadic-хвост" {
    // 1 -> start, [2,3] -> nums
    assert(sum_all(1, 2, 3) == 1 + 2 + 3)
}

test "variadic: обязательный start позиционно, пустой пакет" {
    assert(sum_all(7) == 7)
}

test "variadic: обязательный start именованный, пустой пакет" {
    // start именованный + пустой variadic — валидно.
    assert(sum_all(start: 100) == 100)
}

// --- regular-параметр С дефолтом: keyword-only, variadic-хвост пуст ---

fn sum_from(start int = 0, ...nums []int) -> int {
    let mut total = start
    for n in nums {
        total = total + n
    }
    total
}

test "variadic: дефолтный start опущен, пустой пакет" {
    assert(sum_from() == 0)
}

test "variadic: дефолтный start именованный, пустой пакет" {
    // start=100 named, nums=[] — regular named + пустой variadic.
    assert(sum_from(start: 100) == 100)
}

// --- то же для str-параметра ---

fn label_count(prefix str, ...items []int) -> int {
    let mut c = prefix.len()
    for it in items { c = c + it }
    c
}

test "variadic: обязательный prefix позиционно + variadic-хвост" {
    // "ab" -> prefix, [5,5] -> items
    assert(label_count("ab", 5, 5) == 2 + 5 + 5)
}
