// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 83.12: UDP datagram ping-pong.
//
// Two UDP sockets bound on OS-assigned ports.
// Sender sends a datagram; receiver receives it and checks last_sender.
//
// ENV NOVA_AUTOARM=0
// EXPECT_TIMEOUT_MS 30000

module plan83_12.udp_ping_pong_test

test "UDP: bind, send_to, recv_from — is_ok" {
    // Bind receiver on OS port.
    let rcv_r = UdpSocket.bind(SocketAddr.loopback(0))
    assert(rcv_r.is_ok())
    let rcv = rcv_r.unwrap()
    let rcv_port = rcv.local_port()
    assert(rcv_port > 0)

    // Bind sender on OS port.
    let snd_r = UdpSocket.bind(SocketAddr.loopback(0))
    assert(snd_r.is_ok())
    let snd = snd_r.unwrap()
    let snd_port = snd.local_port()
    assert(snd_port > 0)
    assert(snd_port != rcv_port)

    let mut recv_ok = false
    let mut sender_port_ok = false
    supervised {
        // Receiver fiber: recv_from, check last_sender port.
        spawn {
            let r = rcv.recv_from(512)
            recv_ok = r.is_ok()
            let sender = rcv.last_sender()
            sender_port_ok = (sender.port() == snd_port)
            rcv.close()
        }
        // Sender fiber: send a datagram to the receiver.
        spawn {
            let dest = SocketAddr.loopback(rcv_port)
            let s = snd.send_to("ping", dest)
            assert(s.is_ok())
            snd.close()
        }
    }
    assert(recv_ok)
    assert(sender_port_ok)
}

test "UDP: local_port and local_addr" {
    let sock_r = UdpSocket.bind(SocketAddr.loopback(0))
    assert(sock_r.is_ok())
    let sock = sock_r.unwrap()
    let port = sock.local_port()
    assert(port > 0)
    let addr = sock.local_addr()
    assert(addr.is_v4())
    assert(addr.port() == port)
    sock.close()
}
