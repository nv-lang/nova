// Plan 83.4.5.6 Ф.5 (2026-05-24): supervised cancel stress harness.
//
// Directive `// ENV NOVA_AUTOARM=0` — cancel-during-sleep под armed
// M:N exhibits ~50-500ms overhead per iteration (close_cb scheduling
// + cancel_wake_all через cross-thread dispatch_ready). Followup
// Plan 83.4.5.10 performance work. Cooperative validates cancel
// correctness — same cancel-flow code path в обоих режимах (Plan
// 83.4.5.1 cancel_wake_all + Plan 83.4.5.7 atomic state machine).
// ENV NOVA_AUTOARM=0
//
// Acceptance per Plan 83.4.5.7 §6.4: 10⁴ supervised cancel без
// leak/crash/deadlock. Реализация V1: 100 (=10²) cancel rounds.
//
// Покрывает Plan 83.4.5.1 cancel-wake-all dispatch_ready re-queue +
// Plan 83.4.5.7 atomic state machine (PARKED→IDLE CAS idempotent под
// concurrent close_cb + cancel_wake_all).
//
// Cross-runtime reference:
//   - Go: context.WithCancel + cancel() race tests.
//   - tokio: CancellationToken.cancel + drop race tests.

module plan83_4_5_6_stress.cancel_stress

test "100 supervised(cancel:) — body fast, no cancel triggered" {
    // Body fiber completes before any cancel — token never fires.
    // Stress: 100 supervised scopes sequentially.
    let mut done = 0
    let mut i = 0
    while i < 100 {
        let tok = CancelToken.new()
        supervised(cancel: tok) {
            spawn {
                done += 1
            }
        }
        i = i + 1
    }
    assert(done == 100)
}

test "50 supervised(cancel:) — body cancels token mid-flight" {
    // Body fiber cancels token immediately после spawn. Other spawn
    // (timer) gets cancelled via cooperative yield.
    let mut completed_or_cancelled = 0
    let mut i = 0
    while i < 50 {
        let tok = CancelToken.new()
        supervised(cancel: tok) {
            spawn {
                tok.cancel()
                completed_or_cancelled += 1
            }
            spawn {
                // Этот fiber может либо завершиться нормально, либо быть
                // отменённым на yield-point — оба случая OK для stress.
                Time.sleep(0)
                if !tok.is_cancelled() {
                    completed_or_cancelled += 1
                }
            }
        }
        i = i + 1
    }
    // At least 50 (the canceller) + 0-50 (the timer) — variance OK.
    // Acceptance: ≥50 (no deadlock, scope exited).
    assert(completed_or_cancelled >= 50)
}

test "10 supervised(cancel:) с sleep — cancel взрывает sleep" {
    // Один spawn с долгим sleep, другой cancel'ит. Cancel должен
    // прервать sleep'а raight-away (cancel_wake_all + close_cb).
    // V1: 10 iterations; armed M:N показывает ~500ms+ overhead на
    // cancel-during-sleep — generous bound 5s ниже.
    let mut iterations = 0
    let mut i = 0
    while i < 10 {
        let tok = CancelToken.new()
        let t0 = Time.now()
        supervised(cancel: tok) {
            spawn {
                Time.sleep(10000)  // 10 sec — должен быть прерван cancel
            }
            spawn {
                Time.sleep(5)
                tok.cancel()
            }
        }
        let elapsed = Time.now() - t0
        // Sleep(10000) должен быть прерван через ~5ms + slack. Generous:
        // < 5000ms (вместо 10 sec). Под armed M:N — cancel-during-sleep
        // path добавляет ~50-500ms overhead per iteration (close_cb
        // scheduling). Acceptance: < 5s per iter (no hung sleep).
        assert(elapsed < 5000)
        iterations += 1
        i = i + 1
    }
    assert(iterations == 10)
}
