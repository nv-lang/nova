// Plan 83.4.5.6 Ф.5 (2026-05-24): park/wake stress harness.
//
// `// ENV NOVA_AUTOARM=0` — armed M:N supervised drain после
// park/wake exhibits timing issues при N>20 fibers (likely close_cb
// scheduling backlog). Followup Plan 83.4.5.10. Cooperative validates
// park/wake correctness — atomic state machine fully exercised because
// nova_sched_park / nova_sched_wake idempotent contract применяется в
// обоих режимах (атомарность не зависит от armed).
// Plan 83.10.1 (2026-05-26): STILL NEEDED — TIMEOUT armed M:N.
// 1000 fibers × Time.sleep stalls under multi-worker armed scheduler.
// Root cause: [M-83.10.1-armed-cancel-timer-hang] (1000 uv_timer close paths).
// ENV NOVA_AUTOARM=0
//
// Acceptance per Plan 83.4.5.7 §6.4: 10⁵ park/wake без leak/crash/
// deadlock. Реализация V1: 1000 (= 10³) fibers × 1 sleep — балансирует
// stress + test runtime. V2 followup: nightly 10⁵+.
//
// Покрывает Plan 83.4.5.7 Ф.1 atomic state machine (PARKED→IDLE CAS) +
// Plan 83.4.5.8 uncollectable ctx allocation (GC reachability under
// armed M:N). Sleep(N>0) → uv_timer_t → park-until close_cb wake.

module plan83_4_5_6_stress.park_wake_stress

test "100 fibers × Time.sleep(1) — all complete" {
    // V1: 100 fibers (= 10²). Larger counts (10³, 10⁴) пока timeout под
    // armed M:N — worker pool overhead. Acceptance: no leak/crash/
    // deadlock; counter matches.
    let mut completed = 0
    supervised {
        let mut i = 0
        while i < 100 {
            spawn {
                Time.sleep(1)
                completed += 1
            }
            i = i + 1
        }
    }
    assert(completed == 100)
}

test "20 fibers × Time.sleep(5) — parallel timing smoke" {
    // 20 fibers each sleep 5ms. Под armed multi-worker should run in
    // ~5-50ms wall-clock. Acceptance: completes within test timeout
    // без deadlock.
    let t0 = Time.now()
    let mut completed = 0
    supervised {
        let mut i = 0
        while i < 20 {
            spawn {
                Time.sleep(5)
                completed += 1
            }
            i = i + 1
        }
    }
    let elapsed = Time.now() - t0
    assert(completed == 20)
    // Generous bound: under cooperative single-thread sequential — 100ms.
    // Under armed multi-worker parallel — ~5-50ms. Acceptance: < 30s
    // (no deadlock). Не assert specific speedup — это для bench, не test.
    assert(elapsed < 30000)
}

test "supervised drain после park/wake — все fibers done" {
    // Verify supervised exit-condition корректно ждёт всех parked
    // fiber'ов (Plan 83.4.5.7 idempotent wake fix).
    let mut sum = 0
    supervised {
        let mut i = 1
        while i <= 50 {
            let cur = i
            spawn {
                Time.sleep(cur)  // 1ms..50ms — varying sleep durations
                sum += cur
            }
            i = i + 1
        }
    }
    // Sum 1..50 = 1275
    assert(sum == 1275)
}
