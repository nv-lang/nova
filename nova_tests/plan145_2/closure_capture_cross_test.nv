// Plan 145.2 regression guard — closure mut-capture box across test functions.
//
// Два test-блока, каждый — отдельная C-функция, замыкание захватывает mut-локал
// с ОДНИМ именем `x`. До детерминизма эмиссии (Plan 145.2 BTreeMap) недетерминизм
// порядка эмиссии будил var_boxed cross-function leak: `_box_x` объявлялся в одной
// test-функции и использовался в другой -> CC-FAIL `use of undeclared identifier`.

module nova_tests.plan145_2

test "A: closure captures mut x" {
    mut x = 5
    ro f = fn() -> int => x
    assert(f() == 5)
}

test "B: closure captures mut x (same name)" {
    mut x = 7
    ro g = fn() -> int => x
    assert(g() == 7)
}

test "C: third closure, same name again" {
    mut x = 9
    ro h = fn() -> int => x
    assert(h() == 9)
}
