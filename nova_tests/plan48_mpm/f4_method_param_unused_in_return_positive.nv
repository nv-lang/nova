module nova_tests.plan48_mpm.f4_method_param_unused_in_return_positive

// Plan 48 Ф.9 / D119 positive: method-level U используется ТОЛЬКО в arg
// (не в return). Inference должен работать чисто через arg position,
// независимо от того что return type не содержит U.

export type Wrapper[T] { inner T }
export fn Wrapper[T].of(v T) -> Wrapper[T] => { inner: v }

// U inferred из closure return, но в return type не упоминается.
// Возвращаем нативный счётчик (T-dependent: nova_int).
export fn Wrapper[T] @discard_map[U](f fn(T) -> U) -> int {
    let _u = f(@inner)
    1
}

test "U inferred even if not in return" {
    let w = Wrapper[int].of(5)
    let n = w.discard_map(|x| str.from(x))  // U=str inferred from closure
    assert(n == 1, "U=str instance mono'd, return int correct")
}

test "different U yields different mono instance" {
    let w = Wrapper[int].of(7)
    let n1 = w.discard_map(|x| x * 2)         // U=int
    let n2 = w.discard_map(|x| str.from(x))   // U=str (different mono)
    assert(n1 == 1, "U=int instance")
    assert(n2 == 1, "U=str instance independently exists")
}

test "T=str path also works" {
    let w = Wrapper[str].of("hello")
    let n = w.discard_map(|s| s.len())  // T=str, U=int
    assert(n == 1, "(T=str, U=int) instance")
}
