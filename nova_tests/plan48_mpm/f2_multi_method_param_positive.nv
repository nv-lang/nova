module nova_tests.plan48_mpm.f2_multi_method_param_positive

// Plan 48 Ф.9 / D119 positive: метод с ДВУМЯ собственными type params.
// Exercises method-level multi-param mono: каждая (T, U, V) combination
// должна emit'ить отдельный mono-instance, и оба U, V корректно
// resolve'иться из call-site args (не Nova_U_p / Nova_V_p leak).

export type Box[T] { v T }
export fn Box[T].of(x T) -> Box[T] => { v: x }

// Оба U, V inferred из closure return types.
export fn Box[T] @combine[U, V](f fn(T) -> U, g fn(T) -> V) -> Box[U] {
    let _gv = g(@v)        // V binding — exercises V mono per call-site
    Box[U].of(f(@v))
}

test "combine: T=int, U=int, V=str" {
    let b = Box[int].of(5)
    let r = b.combine(|x| x + 1, |x| str.from(x))
    assert(r.v == 6, "U=int result")
}

test "combine: T=int, U=str, V=int (V differs from U)" {
    let b = Box[int].of(7)
    let r = b.combine(|x| str.from(x), |x| x * 10)
    assert(r.v == "7", "U=str result")
}

test "combine: T=str, U=int, V=str (T=str path)" {
    let b = Box[str].of("hi")
    let r = b.combine(|s| s.len(), |s| s + "!")
    assert(r.v == 2, "U=int from str len")
}
