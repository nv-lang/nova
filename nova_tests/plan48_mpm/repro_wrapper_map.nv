module nova_tests.plan48_mpm

// Plan 48 method-param mono: generic method с собственным type param.
// Currently codegen mono'ит только по receiver T, U остаётся Nova_U_p
// placeholder в return type → CC-FAIL.

export type Wrapper_reprowrappermap[T] { inner T }

export fn Wrapper_reprowrappermap[T].of(v T) -> Wrapper_reprowrappermap[T] => { inner: v }

export fn Wrapper_reprowrappermap[T] @map[U](f fn(T) -> U) -> Wrapper_reprowrappermap[U] {
    Wrapper_reprowrappermap[U].of(f(@inner))
}

test "Wrapper_reprowrappermap.map int → int" {
    ro w = Wrapper_reprowrappermap[int].of(10)
    ro m = w.map(|x| x * 2)
    assert(m.inner == 20, "int → int map")
}

test "Wrapper_reprowrappermap.map int → str" {
    ro w = Wrapper_reprowrappermap[int].of(5)
    ro s = w.map(|x| str.from(x))
    assert(s.inner == "5", "int → str map")
}
