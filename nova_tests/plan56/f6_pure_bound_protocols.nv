// Plan 56 Ф.2.7 — positive: pure bound protocols работают.

module nova_tests.plan56


type MyHashable protocol {
    @hash() -> u64
    @equal(other Self) -> bool
}


type MyDisplay protocol {
    @show() -> str
}


type Counter3 {
    n int
}


fn Counter3 @hash() -> u64 => @n as u64
fn Counter3 @equal(other Counter3) -> bool => @n == other.n


test "pure bound protocol declarations compile" {
    ro c = Counter3 { n: 42 }
    assert(c.hash() == 42 as u64)
    assert(c.equal(Counter3 { n: 42 }))
    assert(!c.equal(Counter3 { n: 99 }))
}
