// Plan 56 Ф.2 — @merge_from + @filter (stdlib unlock).
// Используют public keys()/get() API — обход cross-instance .buckets
// field access typing issue.

module plan56.f2_hashmap_merge_filter

import std.collections.hashmap.{HashMap}


test "@merge_from — пустой источник" {
    let mut m HashMap[str, int] = ["a": 1, "b": 2]
    let empty HashMap[str, int] = []
    m.merge_from(empty)
    assert(m.len() == 2)
    assert(m.get("a") == Some(1))
}


test "@merge_from — добавление новых ключей" {
    let mut m HashMap[str, int] = ["a": 1, "b": 2]
    let extra HashMap[str, int] = ["c": 3, "d": 4]
    m.merge_from(extra)
    assert(m.len() == 4)
    assert(m.get("c") == Some(3))
    assert(m.get("d") == Some(4))
}


test "@merge_from — override existing ключей" {
    let mut m HashMap[str, int] = ["a": 1, "b": 2]
    let other HashMap[str, int] = ["a": 100, "c": 3]
    m.merge_from(other)
    assert(m.len() == 3)
    assert(m.get("a") == Some(100))   // overridden
    assert(m.get("b") == Some(2))
    assert(m.get("c") == Some(3))
}


test "@filter — identity predicate (all)" {
    let m HashMap[str, int] = ["a": 1, "b": 2, "c": 3]
    let all = m.filter(|_k, _v| true)
    assert(all.len() == 3)
}


test "@filter — always-false (none)" {
    let m HashMap[str, int] = ["a": 1, "b": 2, "c": 3]
    let none = m.filter(|_k, _v| false)
    assert(none.len() == 0)
}


test "@filter — value-based predicate" {
    let m HashMap[str, int] = ["a": 1, "b": 2, "c": 3, "d": 4]
    let evens = m.filter(|_k, v| v % 2 == 0)
    assert(evens.len() == 2)
    assert(evens.get("b") == Some(2))
    assert(evens.get("d") == Some(4))
    assert(evens.get("a") == None)
}


test "@filter[int, str] — другие K, V types" {
    let m HashMap[int, str] = [1: "one", 2: "two", 3: "three", 4: "four"]
    let kept = m.filter(|k, _v| k > 2)
    assert(kept.len() == 2)
    assert(kept.get(3) == Some("three"))
    assert(kept.get(4) == Some("four"))
}
