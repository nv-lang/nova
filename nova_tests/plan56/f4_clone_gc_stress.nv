// Fast variant — reduced parameters. Full test: f4_clone_gc_stress_slow.nv
//
// Plan 56 Ф.3 — GC stress test для @clone().
// Fast: 10 clones × 100 entries (reduced from 100 clones).

module nova_tests.plan56

import std.collections.hashmap.{HashMap}


test "@clone × 10 итераций — heap bounded [fast]" {
    mut m HashMap[str, int] = []
    for i in 0..100 {
        m.insert(str.from(i), i)
    }
    ro baseline_pre = gc.heap_size()
    gc.collect()
    ro baseline_post = gc.heap_size()

    // 10 clones (fast: reduced from 100).
    for _ in 0..10 {
        ro _c = m.clone()
    }

    gc.collect()
    ro final_heap = gc.heap_size()

    // Heap bounded — clones собраны GC. Threshold: 4x baseline.
    ro upper = if baseline_post == 0 {
        16 * 1024 * 1024   // malloc backend: heap_size() == 0 always
    } else {
        baseline_post * 4
    }
    assert(final_heap <= upper)
}


test "@clone deep iterations — clone of clone of clone..." {
    mut m HashMap[str, int] = []
    for i in 0..50 {
        m.insert(str.from(i), i * 2)
    }
    // Chain clones — каждый clone независим.
    ro c1 = m.clone()
    ro c2 = c1.clone()
    ro c3 = c2.clone()
    ro c4 = c3.clone()
    assert(c1.len() == 50)
    assert(c2.len() == 50)
    assert(c3.len() == 50)
    assert(c4.len() == 50)
    // Все имеют те же values.
    assert(c1.get("25") == Some(50))
    assert(c4.get("25") == Some(50))
}
