// Plan 147 Ф.7 — positive: mut local binding allows index write.
//
// `mut v = Vec[int].of(...)` gives a mutable binding with mutable content-view
// (default). Index write `v[i] = val` is permitted (D246 P3 — opt-in with
// `mut`).
//
// EXPECT_OUTPUT: ok

module plan147.f7_pos2_mut_binding_write_ok

import std.collections.vec.{Vec}

fn main() -> () {
    mut v = Vec[int].of(1, 2, 3)
    v[0] = 10
    v[1] = 20
    v[2] = 30
    assert(v[0] == 10)
    assert(v[1] == 20)
    assert(v[2] == 30)
    println("ok")
}
