// Plan 147 Ф.2 — ORACLE row C NEG: prefix `ro *` is forbidden.
//
// `ro *T` puts a modifier before `*`. The ro/mut axis lives on the pointee
// (postfix) or the binding, never as a `*`-prefix.
//
// EXPECT_COMPILE_ERROR E_POINTER_PREFIX_MODIFIER

module plan147.c6_neg_prefix_ro_modifier

type Box { data ro *int }

test "rejects prefix ro *" { assert(1 == 1) }
