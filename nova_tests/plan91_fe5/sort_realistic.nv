// Plan 91 Ф.5 conformance: sort and binary_search realistic use-cases.
// sort + binary_search property: every element found at its sorted index.
module plan91_fe5.sort_realistic

import std.sort

test "sort and binary_search every element" {
    mut xs = [5, 3, 8, 1, 9, 2, 7, 4, 6]
    xs.sort()
    // verify sorted
    mut i = 0
    while i < xs.len() - 1 {
        assert(xs[i] <= xs[i + 1], "not sorted")
        i = i + 1
    }
    // binary_search each element (Plan 153.x: Vec canon -> Result[int,int])
    for x in xs {
        ro idx = xs.binary_search(x)
        match idx {
            Ok(pos) => assert(xs[pos] == x, "found wrong value")
            Err(_) => assert(false, "element not found after sort")
        }
    }
}

test "binary_search missing element returns Err(insertion_point)" {
    mut xs = [1, 3, 5, 7, 9]
    xs.sort()
    match xs.binary_search(4) {
        Ok(_) => assert(false, "4 not in array")
        Err(_) => assert(true)
    }
    match xs.binary_search(0) {
        Ok(_) => assert(false, "0 not in array")
        Err(_) => assert(true)
    }
    match xs.binary_search(10) {
        Ok(_) => assert(false, "10 not in array")
        Err(_) => assert(true)
    }
}

test "sort stability with duplicates" {
    mut xs = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]
    xs.sort()
    assert(xs[0] == 1)
    assert(xs[1] == 1)
    assert(xs[xs.len() - 1] == 9)
    // binary_search on duplicate returns Ok
    match xs.binary_search(5) {
        Ok(pos) => assert(xs[pos] == 5)
        Err(_) => assert(false, "5 should be found")
    }
}
