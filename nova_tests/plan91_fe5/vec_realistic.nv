// Plan 91 Ф.5 conformance: Vec realistic use-cases.
// build → filter → accumulate workflow.
module nova_tests.plan91_fe5

import std.runtime.string.{ParseIntError}

test "filter positives then sum" {
    ro raw = ["1", "-2", "3", "-4", "5"]
    mut nums = []int.new()
    for s in raw {
        match s.try_parse_int() {
            Ok(n) => if n > 0 { nums.push(n) }
            Err(_) => assert(false, "should parse")
        }
    }
    assert(nums.len() == 3, "expected 3 positives")
    mut sum = 0
    for x in nums { sum = sum + x }
    assert(sum == 9, "1+3+5 = 9")
}

test "map via loop — double each element" {
    mut xs = [1, 2, 3, 4, 5]
    mut result = []int.new()
    for x in xs {
        result.push(x * 2)
    }
    assert(result.len() == 5)
    assert(result[0] == 2)
    assert(result[4] == 10)
}

test "fold — manual sum and product" {
    ro nums = [1, 2, 3, 4, 5]
    mut sum = 0
    mut product = 1
    for n in nums {
        sum = sum + n
        product = product * n
    }
    assert(sum == 15)
    assert(product == 120)
}

test "push pop and len" {
    mut v = []int.new()
    v.push(10)
    v.push(20)
    v.push(30)
    assert(v.len() == 3)
    assert(v[0] == 10)
    assert(v[2] == 30)
}
