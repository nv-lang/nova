module nova_tests.plan60.f1_methods_zero_cost

// Plan 60 Ф.1: smoke test что новые size-accessor methods работают.
// После Ф.3 это будет единственный легальный путь; сейчас (Phase A)
// и field-path и method-path оба работают.

fn main() -> () {
    let a []int = [1, 2, 3]
    assert(a.len() == 3, "len method")
    assert(a.capacity() >= 3, "capacity method (Rust/C++/Swift naming; not Go cap)")
    assert(!a.is_empty(), "is_empty method false")

    let b []int = []
    assert(b.len() == 0, "empty len method")
    assert(b.is_empty(), "is_empty method true")

    let s str = "hello"
    assert(s.len() == 5, "str len method")
    assert(s.byte_len() == 5, "str byte_len method (ASCII)")
    assert(!s.is_empty(), "str is_empty method false")

    let e str = ""
    assert(e.is_empty(), "str is_empty method true")
    assert(e.len() == 0, "empty str len")

    // UTF-8: 1 codepoint, 3 bytes
    let u str = "ы"
    assert(u.len() == 1, "utf8 char_len")
    assert(u.byte_len() == 2, "utf8 byte_len")  // Cyrillic 'ы' = 2 bytes
    assert(!u.is_empty(), "utf8 is_empty false")

    println("plan60/f1 OK")
}
