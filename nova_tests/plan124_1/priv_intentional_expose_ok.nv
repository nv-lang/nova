// Plan 124.1 / D220 §5: прiv(type) = организационный инструмент, не security-барьер.
// Пользователь может намеренно добавить метод-акцессор — это его выбор.
module plan124_1.priv_intentional_expose_ok

type Counter value priv(type) {
    mut n int
}

fn Counter.new(start int) -> Counter => { n: start }
fn Counter @inc() { @n = @n + 1 }

// Намеренный акцессор: пользователь осознанно раскрывает priv(type) поле.
// D220 §5: это легально — priv(type) защищает от СЛУЧАЙНОГО доступа, не от намеренного.
fn Counter @value() -> int => @n

test "intentional accessor exposes priv(type) field" {
    mut c = Counter.new(10)
    c.inc()
    c.inc()
    c.inc()
    assert(c.value() == 13)
}

test "cross-instance via intentional accessor" {
    ro a = Counter.new(5)
    ro b = Counter.new(5)
    assert(a.value() == b.value())
}