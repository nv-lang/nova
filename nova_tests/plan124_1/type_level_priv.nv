// Plan 124.1 Ф.1 — positive: type-level `priv {}` default flip.
// `type X priv { ... }` — fields default = priv; `pub` overrides.
module nova_tests.plan124_1

// Все три поля default priv; tag — explicit pub override.
export type Secret_typelevelpriv priv {
    pub ro tag str
    mut salt u64
    key u64
}

export fn Secret_typelevelpriv.new(t str, s u64, k u64) -> Secret_typelevelpriv =>
    { tag: t, salt: s, key: k }

test "type-level priv flip parses + tag accessible (pub override)" {
    ro s = Secret_typelevelpriv.new("auth", 12345, 67890)
    assert(s.tag == "auth")
}
