// Plan 70.4 Ф.1 POSITIVE: Option[f32] distinct from Option[f64].
//
// Pre-fix: both would map to NovaOpt_nova_f64 via collapse.
// Post-fix: Option[f32] → NovaOpt_nova_f32, Option[f64] → NovaOpt_nova_f64.

module plan70_4.f2_option_f32_pos

test "Option[f64] Some/None" {
    ro a Option[f64] = Some(3.14)
    match a {
        Some(v) => assert(v == 3.14)
        None => assert(false)
    }

    ro b Option[f64] = None
    match b {
        None => {}
        Some(_) => assert(false)
    }
}

test "Option[f64] unwrap_or" {
    ro a Option[f64] = Some(1.5)
    assert(a.unwrap_or(0.0) == 1.5)

    ro b Option[f64] = None
    assert(b.unwrap_or(9.9) == 9.9)
}

test "Option[f32] Some/None" {
    ro a Option[f32] = Some(1.5 as f32)
    match a {
        Some(v) => assert(v == 1.5 as f32)
        None => assert(false)
    }

    ro b Option[f32] = None
    match b {
        None => {}
        Some(_) => assert(false)
    }
}

test "Option[f32] unwrap_or" {
    ro a Option[f32] = Some(2.5 as f32)
    assert(a.unwrap_or(0.0 as f32) == 2.5 as f32)

    ro b Option[f32] = None
    assert(b.unwrap_or(9.0 as f32) == 9.0 as f32)
}
