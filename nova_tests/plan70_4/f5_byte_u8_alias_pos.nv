module nova_tests.plan70_4.f5_byte_u8_alias_pos

// Plan 70.4 Ф.4: u8 and byte both map to nova_byte in C codegen.
// Option[u8] must produce NovaOpt_nova_byte, same as Option[byte].

test "u8 scalar arithmetic" {
    let a u8 = 10 as u8
    let b u8 = 20 as u8
    let c u8 = (a as int + b as int) as u8
    assert(c == 30 as u8)
}

test "u8 MAX constant" {
    let m u8 = u8.MAX
    assert(m == 255 as u8)
}

test "Option[u8] Some and unwrap_or" {
    let a Option[u8] = Some(42 as u8)
    let b Option[u8] = None
    assert(a.is_some())
    assert(b.is_none())
    assert(a.unwrap_or(0 as u8) == 42 as u8)
    assert(b.unwrap_or(99 as u8) == 99 as u8)
}

test "[]u8 push and access" {
    let arr []u8 = []u8.new()
    arr.push(1 as u8)
    arr.push(2 as u8)
    arr.push(3 as u8)
    assert(arr.len() == 3)
    assert(arr[0] == 1 as u8)
    assert(arr[2] == 3 as u8)
}
