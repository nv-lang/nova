// Plan 127 Ф.5 — POS: match arm escape — `&v` в match arm body.
module plan127.t11_match_arm_escape_ok

type Vec3 value {
    x f64
    y f64
    z f64
}

fn match_escape(tag int) -> *Vec3 {
    ro v = Vec3 { x: 1.0, y: 2.0, z: 3.0 }
    match tag {
        0 => unsafe { &v }
        _ => unsafe { &v }
    }
}

test "match-arm escape promotes" {
    ro p = match_escape(0)
    assert(unsafe { p.z } == 3.0)
}
