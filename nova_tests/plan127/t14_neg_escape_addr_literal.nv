// EXPECT_COMPILE_ERROR &
//
// Plan 127 Ф.5 — NEG: `&Vec3 { ... }` — temporary record literal address.
// Existing Plan 118 E_AMP_RVALUE / similar — `&` on rvalue (not Ident).
// Plan 127 doesn't change this — confirms baseline still rejects.
module plan127.t14_neg_escape_addr_literal

type Vec3 value {
    x f64
    y f64
    z f64
}

fn bad() -> *Vec3 {
    unsafe { &Vec3 { x: 1.0, y: 2.0, z: 3.0 } }
}
