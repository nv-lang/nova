// Plan 127 Ф.5 / A127.2 — POS: return `&v` → auto-promote to heap.
// Escape walker detects return-position `&v` → v gets ValueHeapPromoted,
// codegen heap-allocates and returns valid pointer.
module nova_tests.plan127

type Vec33 value {
    x f64
    y f64
    z f64
}

fn escape_ref() -> *Vec33 {
    ro v = Vec33 { x: 1.0, y: 2.0, z: 3.0 }
    unsafe { &v }
}

test "return `&v` escapes — auto-promote heap-allocates" {
    ro p = escape_ref()
    assert(unsafe { p.x } == 1.0)
    assert(unsafe { p.y } == 2.0)
    assert(unsafe { p.z } == 3.0)
}
