// Plan 127 Ф.5 / A127.11 — POS: priv-field access inside own-module method.
// After auto-promote, field reads work through instance method body (@field).
// Syntax: `fn Box2 @reveal() -> int` (space before @, no dot).
module nova_tests.plan127

type Box2 value {
    priv hidden int
}

fn Box2 @reveal() -> int =>
    @hidden

test "priv field accessible from own module" {
    ro b = Box2 { hidden: 99 }
    assert(b.reveal() == 99)
}
