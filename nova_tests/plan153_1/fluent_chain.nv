module nova_tests.plan153_1
test "reserve chains" {
    mut v = Vec[int].new()
    v.reserve(8).push(1).push(2).push(3)
    assert(v.len() == 3 && v.cap() >= 8)
}
test "retain chains" {
    mut v = Vec[int].of(1, 2, 3, 4, 5, 6)
    v.retain(|x| x % 2 == 0).push(8)
    assert(v.equal(Vec[int].of(2, 4, 6, 8)))
}
test "long fluent chain" {
    mut v = Vec[int].new()
    v.reserve(4).push(3).push(1).push(2).reverse().push(0)
    assert(v.equal(Vec[int].of(2, 1, 3, 0)))
}
