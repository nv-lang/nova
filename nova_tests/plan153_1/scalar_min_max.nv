// [M-153-scalar-min-max] — scalar @min / @max on numeric types (D239 §2).
// Verifies that (5).max(3) == 5, (5).min(3) == 3, etc.

module nova_tests.plan153_1

test "int min / max basic" {
    assert((5).max(3) == 5)
    assert((5).min(3) == 3)
    assert((3).max(5) == 5)
    assert((3).min(5) == 3)
    assert((7).max(7) == 7)
    assert((7).min(7) == 7)
}

test "int min / max negative values" {
    assert((-3).max(-5) == -3)
    assert((-3).min(-5) == -5)
    assert((-1).max(0) == 0)
    assert((-1).min(0) == -1)
}

test "int min / max chaining" {
    ro a = (10).min(20).min(5)
    assert(a == 5)
    ro b = (1).max(3).max(2)
    assert(b == 3)
}

test "f64 min / max" {
    assert((3.0 as f64).max(1.5 as f64) == (3.0 as f64))
    assert((3.0 as f64).min(1.5 as f64) == (1.5 as f64))
}
