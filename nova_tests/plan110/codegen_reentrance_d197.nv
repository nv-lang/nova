// SPDX-License-Identifier: MIT OR Apache-2.0
//
// Plan 110.1.8 (D197): `consume{}` inside another type's `on_exit`
// body — cleanup re-entrance. Outer cleanup acquires inner resource
// via inner consume scope; inner scope-exit fires inner on_exit;
// затем outer cleanup completes.
//
// Acceptance A110.1.8.a: nested consume{} inside on_exit works correctly.

module nova_tests.plan110

type Lock3 {
    ro id int
}

fn Lock3.new(id int) -> Lock3 => { id }
fn Lock3 consume @on_exit(_outcome ScopeOutcome) -> () => ()

type Connection3 {
    ro lock Lock3
    ro conn_id int
}

fn Connection3.new(conn_id int, lock_id int) -> Connection3 => {
    lock: Lock3.new(lock_id),
    conn_id,
}

// Connection3.on_exit acquires inner Lock3 через nested consume scope —
// D197 re-entrance.
fn Connection3 consume @on_exit(_outcome ScopeOutcome) -> () {
    consume _l = Lock3.new(@lock.id + 100) {
        // Inner cleanup work; _l fires on_exit at this scope end.
    }
}

fn use_with_reentrance() -> int {
    mut result = 0
    consume conn = Connection3.new(1, 7) {
        result = conn.conn_id
    }
    result
}

test "Plan 110.1.8 (D197): nested consume{} inside on_exit body" {
    assert(use_with_reentrance() == 1)
}
