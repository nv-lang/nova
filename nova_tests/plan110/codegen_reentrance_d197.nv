// SPDX-License-Identifier: MIT OR Apache-2.0
//
// Plan 110.1.8 (D197): `consume{}` inside another type's `on_exit`
// body — cleanup re-entrance. Outer cleanup acquires inner resource
// via inner consume scope; inner scope-exit fires inner on_exit;
// затем outer cleanup completes.
//
// Acceptance A110.1.8.a: nested consume{} inside on_exit works correctly.

module plan110.codegen_reentrance_d197

type Lock {
    ro id int
}

fn Lock.new(id int) -> Lock => { id }
fn Lock consume @on_exit(_outcome ScopeOutcome) -> () => ()

type Connection {
    ro lock Lock
    ro conn_id int
}

fn Connection.new(conn_id int, lock_id int) -> Connection => {
    lock: Lock.new(lock_id),
    conn_id,
}

// Connection.on_exit acquires inner Lock через nested consume scope —
// D197 re-entrance.
fn Connection consume @on_exit(_outcome ScopeOutcome) -> () {
    consume _l = Lock.new(@lock.id + 100) {
        // Inner cleanup work; _l fires on_exit at this scope end.
    }
}

fn use_with_reentrance() -> int {
    mut result = 0
    consume conn = Connection.new(1, 7) {
        result = conn.conn_id
    }
    result
}

test "Plan 110.1.8 (D197): nested consume{} inside on_exit body" {
    assert(use_with_reentrance() == 1)
}
