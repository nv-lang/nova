//
// Plan 110.1.1 (D188) + Plan 110.1.4.a: `consume X TYPE = init() { body }`
// scope-block с явной type annotation. Acceptance A110.1.1.a.

module nova_tests.plan110

type DummyRes3 {
    ro id int
}

fn DummyRes3.new(id int) -> DummyRes3 => { id }

fn DummyRes3 consume @on_exit(_outcome ScopeOutcome) -> () => ()

fn use_with_annot() -> int {
    mut result = 0
    consume r DummyRes3 = DummyRes3.new(7) {
        result = r.id
    }
    result
}

test "Plan 110.1.1: consume scope-block с type annotation" {
    assert(use_with_annot() == 7)
}
