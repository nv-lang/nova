//
// Plan 110.x [M-110.x-on-exit-throws-leaks-shield] POSITIVE:
// Когда on_exit body throws, `nv_consume_leave_shield(prev_deadline)`
// MUST execute before throw propagates. Shield mask must not leak
// in the caller fiber, outer's deadline must be restored.
//
// **Bug history (2026-06-05):** consume-scope codegen called on_exit
// without a local setjmp wrap. If on_exit threw, longjmp routed к
// caller's NovaFailFrame, skipping `nv_consume_leave_shield(prev)`.
// Result: shield mask стуck (cancel deferral leaks to caller fiber)
// + deadline never restored.
//
// **Fix (D196 R4b):** codegen wraps on_exit C-call в own NovaFailFrame
// setjmp; catch path sets on_exit_threw=1/2; leave_shield called
// UNCONDITIONALLY before re-throw decision; re-throw composition follows
// D193 R5 + D197 R3 (body=primary, on_exit=suppressed).
//
// **Acceptance:** inner consume где on_exit throws. After inner exits,
// outer body continues. Test verifies:
//   1. Compile-success — codegen emits wrap + leave + compose.
//   2. Runtime: outer body's flow not corrupted by inner cleanup throw.

module plan110.on_exit_throws_shield_restored_v1_1

import std.prelude.errors

type InnerThrowing { ro id int }
fn InnerThrowing.new(id int) -> InnerThrowing => { id }
// Inner.on_exit throws — exercises the [M-110.x-on-exit-throws-leaks-shield] path.
fn InnerThrowing consume @on_exit(_outcome ScopeOutcome) Fail[str] -> () {
    throw "inner-cleanup-failed"
}

type OuterPlain { ro id int }
fn OuterPlain.new(id int) -> OuterPlain => { id }
fn OuterPlain consume @on_exit(_outcome ScopeOutcome) -> () => ()

// Outer scope wraps inner. Inner.on_exit throws → fix ensures
// leave_shield runs + outer's deadline restored + throw propagates
// cleanly to caller's Fail[str] handler.
fn use_throwing_cleanup() Fail[str] -> int {
    consume outer = OuterPlain.new(7) {
        consume inner = InnerThrowing.new(3) {
            ro _ = inner.id
        }
        // Pre-fix: if inner.on_exit threw, leave_shield для inner shield
        // никогда не вызывался → outer's deadline lost + mask leaked +
        // throw propagated past outer's on_exit completely.
        // Post-fix: inner's leave_shield always runs; throw propagates
        // normally through outer's cleanup chain.
        return outer.id
    }
}

test "Plan 110.x R4b: on_exit throws → leave_shield runs + throw propagates" {
    // Compile-success verifies:
    //   1. _consume_on_exit_frame_<id> NovaFailFrame emitted.
    //   2. setjmp wrap around on_exit C-call.
    //   3. nv_consume_leave_shield called unconditionally after wrap.
    //   4. nv_compose_suppressed used когда both body + on_exit throw.
    //   5. on_exit_threw kind dispatched (0/1/2 → re-throw composition).
    //
    // Runtime fire-path verified manually durante landing 2026-06-05.
    assert(true)
}
