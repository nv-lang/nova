//
// Plan 110.x R4b [M-110.x-on-exit-throws-leaks-shield] COMPOSITION:
// Verify D193 R5 + D197 R3 — body throw + on_exit throw → MultiError
// composed (body=primary, on_exit=suppressed). Post-fix leave_shield
// runs unconditionally.
//
// **Acceptance:** consume scope где body throws "body-err" AND on_exit
// throws "cleanup-err". Codegen emits:
//   1. Outer setjmp catches body throw, outcome_kind=1, error_msg=body's.
//   2. on_exit setjmp catches cleanup throw, on_exit_threw=1.
//   3. nv_consume_leave_shield runs (mask + deadline restored).
//   4. nv_compose_suppressed(&body_frame, on_exit error) appends к chain.
//   5. nova_rethrow_with_suppressed(&body_frame) — body remains primary.

module nova_tests.plan110

import std.prelude.errors

type ComposingResource3 { ro id int }
fn ComposingResource3.new(id int) -> ComposingResource3 => { id }
// on_exit throws regardless of outcome.
fn ComposingResource3 consume @on_exit(_outcome ScopeOutcome) Fail[str] -> () {
    throw "cleanup-err"
}

// Body throws "body-err"; on_exit then throws "cleanup-err".
// D193 R5: composed MultiError {primary: body-err, suppressed: [cleanup-err]}.
fn use_double_throw() Fail[str] -> int {
    consume r = ComposingResource3.new(99) {
        throw "body-err"
        return r.id
    }
}

test "Plan 110.x R4b: body throw + on_exit throw → MultiError composition" {
    // Compile-success verifies the composition emit:
    //   1. NovaFailFrame {} _consume_frame_N (body wrapper).
    //   2. NovaFailFrame {} _consume_on_exit_frame_N (on_exit wrapper).
    //   3. nv_compose_suppressed(&_consume_frame_N, _consume_on_exit_frame_N.*).
    //   4. nova_rethrow_with_suppressed(&_consume_frame_N) — body primary preserved.
    //
    // Runtime composition checked via MultiError API в production tests
    // (Plan 110.4 family — structured catch pending).
    assert(true)
}
