// Минимальный Consumable[never] resource type для scope-block init.
type DummyResource {
    ro id int
}

fn DummyResource.new(id int) -> DummyResource => { id }

fn DummyResource consume @on_exit(_outcome ScopeOutcome) -> () => ()

// Basic scope-block — parser scaffold + AST variant existence.
fn use_resource() -> int {
