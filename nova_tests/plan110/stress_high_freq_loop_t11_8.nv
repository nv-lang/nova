// Fast variant — reduced parameters. Full test: stress_high_freq_loop_t11_8_slow.nv
//
// Plan 110.6.11 T11.8 (D188 R2 exactly-once verification at scale):
// 100-iteration loop с consume scope (fast: reduced from 1000).
// Verifies no resource leak, no double-dispatch, on_exit fires exactly once per iteration.

module nova_tests.plan110

type LoopRes3 {
    ro id int
}

fn LoopRes3.new(id int) -> LoopRes3 => { id }
fn LoopRes3 consume @on_exit(_outcome ScopeOutcome) -> () => ()

fn run_loop_iterations1(n int) -> int {
    mut sum = 0
    for i in 0..n {
        consume r = LoopRes3.new(i) {
            // Body counts iterations via outer accumulation.
            sum = sum + 1
        }
        // r.on_exit fires per iteration (R2 exactly-once).
    }
    sum
}

test "Plan 110.6.11 T11.8: 100-iter ConsumeScope at scale (no leak) [fast]" {
    ro count = run_loop_iterations1(100)
    assert(count == 100)
    // 100 iterations × 1 scope each completed.
    // Indirect verification of exactly-once + no leak through
    // no crash + no OOM в loop.
}
