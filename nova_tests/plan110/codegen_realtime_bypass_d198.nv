//
// Plan 110.2.4 (D198): #realtime fn bypasses 3-level timeout resolution.
// Codegen emits hardcoded 0 instead of nv_resolve_exit_timeout_ms()
// call. Verifies compile path для realtime cleanup contexts.

module nova_tests.plan110

type RtRes3 {
    ro id int
}

fn RtRes3.new(id int) -> RtRes3 => { id }
fn RtRes3 consume @on_exit(_outcome ScopeOutcome) -> () => ()

// #realtime fn — codegen emits Duration.zero timeout (no suspend).
#realtime
fn use_rt() -> int {
    mut result = 0
    consume r = RtRes3.new(7) {
        result = r.id
    }
    result
}

test "Plan 110.2.4 (D198): #realtime consume scope bypass" {
    assert(use_rt() == 7)
}
