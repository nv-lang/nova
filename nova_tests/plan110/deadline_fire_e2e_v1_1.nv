module plan110.deadline_fire_e2e_v1_1

import std.prelude.errors

type SlowCleanup { ro id int }

fn SlowCleanup.new(id int) -> SlowCleanup => { id }

// Plan 110.9.2 V1.1 Level 1: tiny budget — beats default 5000ms hard-fallback.
fn SlowCleanup @exit_timeout_ms() -> int => 1

// Plan 110.9.1 V1.1: on_exit с Fail[CleanupTimeoutError] effect-signature
// declares что throw path возможен. Time.sleep(50) reliably exceeds 1ms.
fn SlowCleanup consume @on_exit(_outcome ScopeOutcome) Fail[CleanupTimeoutError] -> () {
    Time.sleep(50)
    return ()
}

// Function-level Fail[CleanupTimeoutError] declaration propagates error up.
fn use_slow_cleanup() Fail[CleanupTimeoutError] -> int {
    consume r = SlowCleanup.new(42) {
        return r.id
    }
}

test "Plan 110.2.2.a + 110.9.1 + 110.9.2 V1.1: deadline fires typed CleanupTimeoutError E2E" {
    // Compile-success verifies full pipeline codegen:
