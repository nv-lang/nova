//
// Plan 110.4.7 (D195 R6): cross-fiber Application propagation.
// Spawn child fiber sees parent's Application handler via the D80
// effect-snapshot mechanism (TLS effect registry + per-fiber init
// snapshot — Plan 83.4.5.4 + Plan 83.10.4 Ф.3).
//
// Acceptance:
//   A110.4.7.a — child fiber's ConsumeScope inherits parent's
//                Application handler → exit_timeout resolves via
//                inherited handler, not Level 3 fallback.

module plan110.application_cross_fiber_t8_7

type Res {
    ro id int
}

fn Res.new(id int) -> Res => { id }
fn Res consume @on_exit(_outcome ScopeOutcome) -> () => ()

test "Plan 110.4.7 A110.4.7.a: child fiber inherits Application via D80 snapshot" {
    mut child_observed = -1
    with Application = effect Application {
        register_finalizer(_f) {
            return ()
        }
        default_exit_timeout_ms() {
            return 750
        }
    } {
        with Cleanup = effect Cleanup {
            on_scope_enter(_label, timeout_ms) {
                child_observed = timeout_ms
                return ()
            }
            on_scope_exit(_label, _outcome) {
                return ()
            }
        } {
            // Spawn a child fiber that opens a consume scope —
            // it must see Application 750ms через D80 snapshot.
            supervised {
                spawn {
                    consume r = Res.new(1) {
                        ro _ = r.id
                    }
                }
            }
        }
    }
    assert(child_observed == 750)
}
