module plan110.check_consume_unwrap_form

type FailableResource {
    ro id int
}

fn FailableResource.try_new(id int) -> Result[FailableResource, str] => Ok(FailableResource.new(id))

fn FailableResource.new(id int) -> FailableResource => { id }

fn FailableResource consume @on_exit(_outcome ScopeOutcome) -> () => ()

// `consume r = try_new()? { body }` — `?` unwrap inferred via recurse.
fn use_unwrap() Fail[str] -> int {
    consume r = FailableResource.try_new(7)? {
        r.id
    }
}
