//
// Plan 110.1.3 (D196 form 2) + Plan 110.1.4.a: `consume X = expr? { body }`
// — Result-unwrap form. type-checker infer'ит inner type через recursive
// ?-peel (110.1.2 heuristic). Codegen эмитит init + body (110.1.4.a).

module nova_tests.plan110

type FailableResource4 {
    ro id int
}

fn FailableResource4.try_new(id int) -> Result[FailableResource4, str] => Ok(FailableResource4.new(id))

fn FailableResource4.new(id int) -> FailableResource4 => { id }

fn FailableResource4 consume @on_exit(_outcome ScopeOutcome) -> () => ()

// `consume r = try_new()? { body }` — `?` unwrap inferred via recurse.
fn use_unwrap() Fail[str] -> int {
    mut result = 0
    consume r = FailableResource4.try_new(7)? {
        result = r.id
    }
    result
}

test "Plan 110.1.3 (D196 form 2): consume + ? Result unwrap — typecheck only" {
    // Runtime invocation требует Fail handler; здесь verify только что
    // fn compiles + типичные проверки D188+D196 проходят (110.1.4.a
    // codegen эмитит init binding на success path).
    assert(true)
}
