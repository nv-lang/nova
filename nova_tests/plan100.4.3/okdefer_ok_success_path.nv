// Plan 100.4.3 (D149): okdefer — выполняется только на success-path.

module nova_tests.plan100_4_3.okdefer_ok_success_path

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

// errdefer + okdefer = exhaustive cover для consume-tx.
fn process(should_succeed bool) Fail[str] -> () {
    consume tx = begin()
    errdefer { tx.rollback() }                  // error → rollback
    okdefer  { tx.commit()   }                  // success → commit
    if !should_succeed {
        throw "operation failed"
    }
    // normal exit → okdefer fires → tx.commit() ✅
}

test "okdefer на success-path, errdefer на error-path" {
    let r1 = process(true)                      // okdefer (commit)
    let r2 = process(false)                     // errdefer (rollback)
}
