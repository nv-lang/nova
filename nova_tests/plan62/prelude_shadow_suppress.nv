// Plan 62.F.bis Ф.2 positive test: `module X allow_prelude_shadow`
// suppresses W_PRELUDE_SHADOW warnings on user-declarations that shadow
// prelude names. User-declaration wins (как в _warning.nv), но warning
// silenced.
//
// Если бы suppress'а не было — test FAIL: пустой EXPECT_COMPILE_WARNING
// конфликтует с emitted warning. Отсутствие EXPECT_COMPILE_WARNING marker
// без suppress сейчас допустимо (test runner не fail'ит на unexpected
// warnings) — но регрессия suppress'а будет обнаружена ниже через assert
// что user-decl wins (через тип-checker accepts).

module plan62.prelude_shadow_suppress allow_prelude_shadow

// PRELUDE_VERSION shadow'ит prelude const. С `allow_prelude_shadow`
// clause — никакого warning'а; user-decl wins silently.
const PRELUDE_VERSION int = 99

test "suppress: user shadow PRELUDE_VERSION wins, no warning" {
    assert(PRELUDE_VERSION == 99)
}
