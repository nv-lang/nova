// protocols_bound_resolution.nv вЂ” Plan 62.E.
//
// Verifies С‡С‚Рѕ formal protocol declarations РІ std/prelude/protocols.nv
// (re-export'РЅСѓС‚С‹Рµ С‡РµСЂРµР· std/prelude.nv facade) auto-available РІРµР·РґРµ
// С‡РµСЂРµР· R27 auto-import, Рё С‡С‚Рѕ bound clauses `[T Hash]`/`[T Equal]`/
// `[T Compare]`/`[T From[X]]`/`[T Into[X]]`/`[T Display]` СЂРµР·РѕР»РІСЏС‚СЃСЏ
// С‡РµСЂРµР· cross-file resolve Р±РµР· explicit import.
//
// РџРѕРєСЂС‹С‚РёРµ (6 РёР· 8 protocols вЂ” TryFrom/TryInto deferred per Plan 56 Р¤.2.7
// effect-free enforcement):
//   1. `Hash` bound вЂ” generic fn РїСЂРёРЅРёРјР°РµС‚ T СѓРґРѕРІР»РµС‚РІРѕСЂСЏСЋС‰РёР№
//      `hash() -> u64`. User-defined type implementing СЃС‚СЂСѓРєС‚СѓСЂРЅРѕ.
//   2. `Equal` bound вЂ” generic fn РїСЂРёРЅРёРјР°РµС‚ T СѓРґРѕРІР»РµС‚РІРѕСЂСЏСЋС‰РёР№
//      `equals(other Self) -> bool`. User-defined type implementing.
//   3. `Compare` bound вЂ” generic fn РїСЂРёРЅРёРјР°РµС‚ T СѓРґРѕРІР»РµС‚РІРѕСЂСЏСЋС‰РёР№
//      `compare(other Self) -> int`. D183 (Plan 91.8a): int-based
//      memcmp convention; Ordering sum-type СѓРґР°Р»С‘РЅ.
//   4. `From[X]` bound вЂ” type-decl c bound РЅР° conversion.
//   5. `Into[X]` bound вЂ” bound РЅР° dual direction (D73 auto-derive).
//   6. `Display` bound вЂ” formatting protocol (StringBuilder dependency
//      СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· type-checker builtins HashSet).
//
// Acceptance: РІСЃРµ 6 tests РґРѕР»Р¶РЅС‹ pass вЂ” type-check РїСЂРѕС…РѕРґРёС‚ РїСЂРё
// satisfied bound'Р°С…, runtime behavior РєРѕСЂСЂРµРєС‚РЅС‹Р№.

module nova_tests.plan62


// User-defined С‚РёРї, СѓРґРѕРІР»РµС‚РІРѕСЂСЏСЋС‰РёР№ Hash + Equal + Compare
// СЃС‚СЂСѓРєС‚СѓСЂРЅРѕ. Р’СЃРµ С‚СЂРё РјРµС‚РѕРґР° СЂРµР°Р»РёР·РѕРІР°РЅС‹ РєР°Рє @hash/@equal/@compare instance fns.
// Plan 91.8a (D183): rename eqв†’equals, cmpв†’compare; Orderingв†’int.
type Item2 {
    id u64
}

fn Item2.new(id u64) -> Item2 => { id }

export fn Item2 @hash() -> u64 => @id

export fn Item2 @equal(other Item2) -> bool => @id == other.id

export fn Item2 @compare(other Item2) -> int =>
    if @id < other.id { -1 }
    else if @id > other.id { 1 }
    else { 0 }


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 1. Hash bound вЂ” СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude auto-import.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn hash_anything[T Hash](v T) -> u64 => v.hash()

test "Hash bound СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude вЂ” Item2.hash()" {
    ro it = Item2.new(42 as u64)
    ro h = hash_anything(it)
    assert(h == (42 as u64))
}


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 2. Equal bound вЂ” СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude auto-import.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn eq_via_bound[T Equal](a T, b T) -> bool => a.equal(b)

test "Equal bound вЂ” Item2.equals()" {
    ro a = Item2.new(7 as u64)
    ro b = Item2.new(7 as u64)
    ro c = Item2.new(8 as u64)
    assert(eq_via_bound(a, b) == true)
    assert(eq_via_bound(a, c) == false)
}


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 3. Compare bound вЂ” СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude auto-import.
//    Plan 91.8a (D183): compare РІРѕР·РІСЂР°С‰Р°РµС‚ int (memcmp-style).
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

fn min_of[T Compare](a T, b T) -> T =>
    if a.compare(b) <= 0 { a } else { b }

test "Compare bound вЂ” Item2.compare() СЃ int-based check" {
    ro a = Item2.new(3 as u64)
    ro b = Item2.new(7 as u64)
    ro m = min_of(a, b)
    assert(m.id == (3 as u64))
}


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 4. From[X] bound вЂ” type-decl СЃ bound РЅР° conversion.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

type Celsius { value f64 }
type Fahrenheit { value f64 }

// D73 `From[Fahrenheit]` impl: static factory, РЅРµ instance method.
// Syntax: `fn Type.from(...)` (Р±РµР· `@`) вЂ” see std/encoding/json.nv:627+.
export fn Celsius.from(f Fahrenheit) -> Celsius =>
    { value: (f.value - 32.0) * 5.0 / 9.0 }

// Generic fn СЃ bound `[T From[X]]` вЂ” bootstrap limitation: generic
// static method dispatch (`T.from(f)`) РЅРµ monomorphРёР·РёСЂСѓРµС‚СЃСЏ РІ
// bootstrap codegen (Plan 14 limitation, СЃРј. Q-result-monomorphization).
// РџРѕСЌС‚РѕРјСѓ Р·РґРµСЃСЊ С‚РµСЃС‚ РїСЂРѕРІРµСЂСЏРµС‚ direct call РЅР° concrete type вЂ” bound
// parsed and resolution С‡РµСЂРµР· prelude СЂР°Р±РѕС‚Р°РµС‚; full generic dispatch
// вЂ” Plan 62.E+.

test "From[X] bound вЂ” concrete Celsius.from(Fahrenheit) С‡РµСЂРµР· prelude resolution" {
    ro f = Fahrenheit { value: 212.0 }
    ro c = Celsius.from(f)
    // 212В°F == 100В°C
    assert(c.value > 99.9 && c.value < 100.1)
}

// Bound declaration parsed вЂ” type-checker eligibility check (Р±РµР· actual
// call) РїСЂРѕРІРµСЂСЏРµС‚ С‡С‚Рѕ bound СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude.
fn _accepts_from[T From[Fahrenheit]](_v T) -> () => ()


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 5. Into[X] bound вЂ” dual direction, D73 auto-derive (BOOTSTRAP NOTE).
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// D73 auto-derive `Into[U]` РѕС‚ `From[T]` РІ bootstrap'Рµ РќР• СЂРµР°Р»РёР·РѕРІР°РЅ:
// type-checker РЅРµ СЃРёРЅС‚РµР·РёСЂСѓРµС‚ `Fahrenheit.to_str()` body РёР· СЃСѓС‰РµСЃС‚РІСѓСЋС‰РµР№
// `Celsius.from(Fahrenheit)` РґРµРєР»Р°СЂР°С†РёРё (СЃРј. plan doc В§62.E + Plan 62.E+).
// РџРѕСЌС‚РѕРјСѓ Р·РґРµСЃСЊ С‚РµСЃС‚ РїСЂРѕРІРµСЂСЏРµС‚ explicit `@into` impl: РєР°РЅРѕРЅРёС‡РµСЃРєРёР№
// pattern РґР»СЏ Into-СѓРґРѕРІР»РµС‚РІРѕСЂРµРЅРёСЏ РґРѕ РїРѕР»РЅРѕР№ D73 СЂРµР°Р»РёР·Р°С†РёРё.

type FahrToC { value f64 }

export fn FahrToC @into() -> Celsius =>
    { value: (@value - 32.0) * 5.0 / 9.0 }

// Generic fn СЃ bound `[T Into[Celsius]]` вЂ” type-checker РІР°Р»РёРґРёСЂСѓРµС‚ С‡С‚Рѕ
// T РёРјРµРµС‚ `into() -> Celsius` РјРµС‚РѕРґ (СЃС‚СЂСѓРєС‚СѓСЂРЅРѕ С‡РµСЂРµР· prelude).
fn needs_into[T Into[Celsius]](v T) -> Celsius => v.into()

test "Into[X] bound вЂ” explicit @into impl СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· prelude" {
    ro f = FahrToC { value: 32.0 }
    ro c = needs_into(f)
    // 32В°F == 0В°C
    assert(c.value > -0.1 && c.value < 0.1)
}


// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// 6. Display bound вЂ” StringBuilder dependency СЂРµР·РѕР»РІРёС‚СЃСЏ С‡РµСЂРµР· builtins.
//    Plan 91.8a (D183): renamed Display в†’ Display.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// User-defined type СЃ Display impl. StringBuilder вЂ” opaque runtime type
// (builtin HashSet), API: `append(s str)`, `into() -> str` (СЃРј.
// std/runtime/string_builder.nv). `str.from(int)` РґР»СЏ int в†’ str.
type Pair { x int, y int }

export fn Pair @display(mut w Write) -> () {
    w.write("(")
    w.write(str.from(@x))
    w.write(", ")
    w.write(str.from(@y))
    w.write(")")
}

// Generic fn СЃ Display bound вЂ” caller-side РїСЂРѕРІРµСЂРєР° eligibility.
// Note: `mut sb` вЂ” StringBuilder mutation РІ protocol-method РІС‹Р·С‹РІР°РµС‚СЃСЏ
// РЅР°РїСЂСЏРјСѓСЋ (Р±РѕР№Р»РµСЂРїР»РµР№С‚ С‡РµСЂРµР· bound dispatch вЂ” Plan 56 effect-free
// СЂР°Р·СЂРµС€Р°РµС‚ mutating receiver С‡РµСЂРµР· `mut @method`).
fn fmt_to_string[T Display](v T) -> str {
    consume sb = StringBuilder.new()
    v.display(sb)
    sb.into_str()
}

test "Display bound вЂ” Pair.fmt() in StringBuilder" {
    ro p = Pair { x: 3, y: 7 }
    ro s = fmt_to_string(p)
    assert(s == "(3, 7)")
}
