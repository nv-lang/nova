// EXPECT_COMPILE_ERROR E_EXTERNAL_TYPE_RETRACTED
//
// D126 hard retract (Plan 91.12 V2, 2026-06-01) — negative test.
//
// **Updated history:**
// - Plan 62.D.bis Ф.1 (2026-05-18): `external type X` whitelisted к stdlib.
//   User-space declarations отвергались с whitelist diagnostic.
// - Plan 91.12 V1 (2026-06-01): WriteBuffer/ReadBuffer мигрированы на pure
//   Nova (паттерн StringBuilder/Plan 109).
// - Plan 91.12 V2 (2026-06-01): остающиеся OnceCell[T]/Lazy[T]/Condvar
//   мигрированы на `type X[T](ptr)` (Plan 115 D214 tuple-newtype). После
//   migration все 5 stdlib D126 типов retract'нуты. Plain `external type`
//   теперь — hard error [E_EXTERNAL_TYPE_RETRACTED] для ВСЕХ модулей
//   (включая stdlib).
//
// **D163 (FFI opaque consume-types) сохраняется:** `external type X consume`
// разрешено везде для FFI resource handles (File, Mutex и т.д.).
//
// Этот файл пытается declare `external type FooBar` (без consume) —
// ожидается hard error E_EXTERNAL_TYPE_RETRACTED с migration hint
// на `type FooBar(ptr)` (Plan 115 D214 tuple-newtype).
//
// Implementation: `compiler-codegen/src/types/mod.rs` — unconditional check
// `Opaque && !consume → error`.

module plan62.external_type_outside_whitelist

external type FooBar

// Plan 91.12 V2 followup [M-91.12-parser-body-detect-heuristic] (closed
// 2026-06-01): parser теперь корректно различает «next module decl» vs
// «newtype body» — добавлен trailing test block для проверки что
// type-checker reach'ает декларацию и emit'ит E_EXTERNAL_TYPE_RETRACTED
// (вместо ложного parser body error на следующий fn).
fn dummy() -> int => 1

test "should never reach this — type-check must fail with E_EXTERNAL_TYPE_RETRACTED" {
    ro _ = dummy()
}
