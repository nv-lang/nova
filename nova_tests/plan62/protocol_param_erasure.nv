// Plan 62 cleanup merge — protocol-type-as-function-parameter erasure
// (partial fix, declaration-only).
//
// Regression marker для codegen-фикса (commit 99a629634ab) после merge'а
// main → plan-62-main. До фикса: protocol-type в параметре функции
// эмитился как `Nova_Iter*` — undeclared C-type → CC-FAIL «unknown
// type name 'Nova_Iter'». Триггер: Plan 62.E ввёл formal `Iter[T]
// protocol { ... }` в std/prelude/collections.nv.
//
// Fix:
//   - new field `protocol_types: HashSet<String>` на CEmitter.
//   - emit_module скан skip'ает TypeDeclKind::Protocol(_) из
//     generic_type_templates, регистрирует в protocol_types.
//   - type_ref_to_c → `void*` для registered protocol-name.
//
// **Scope fix'а — partial:** declaration position (parameter type)
// теперь parses + codegens. Но method-dispatch / for-in на erased
// `void*` param **не работает** (это отдельный codegen blocker —
// см. std/collections/set.nv где from_iter tests были removed с
// note: «Iter[T] param in mono context emits for-in on unresolved
// 'Iter' type»).
//
// Этот тест exercise'ит ТОЛЬКО то что fix покрыл: declaration accepted,
// CC-FAIL «unknown type name 'Nova_Iter'» закрыт. Actual method-call
// usage на erased param — known limitation, не Plan 62 scope.

module plan62.protocol_param_erasure


type IntCounter {
    mut cur int
    end int
}


fn IntCounter.new(start int, end int) -> IntCounter => { cur: start, end }


fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        let v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}


// Function declares Iter[int] parameter type — закрытие CC-FAIL
// «unknown type name 'Nova_Iter'». Body не вызывает методы на `it`
// (это known-failing path вне 62 scope), просто демонстрирует что
// declaration accepts compile.
fn accepts_iter_param(it Iter[int], fallback int) -> int => fallback


test "Iter[int] as parameter type — declaration compiles (CC-FAIL fix)" {
    let c = IntCounter.new(1, 4)
    let r = accepts_iter_param(c, 42)
    assert(r == 42)
}


test "second call confirms repeated codegen path stable" {
    let c2 = IntCounter.new(0, 0)
    let r = accepts_iter_param(c2, 7)
    assert(r == 7)
}
