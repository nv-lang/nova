// option_or_from_prelude.nv — Plan 62.B, 2026-05-20.
//
// Tests для Option[T].or() — per-T trampoline Nova_Option_method_or_<T>.
// 5 позитивных тестов: 4 комбинации Some/None + chain + str payload.
// `None` всегда с явной аннотацией (`let b Option[int] = None`) — без
// неё bootstrap-inference дефолтит элемент к `int` (см. plan-doc 62).

module plan62.option_or_from_prelude

// ────────────────────────────────────────────────────────────────────
// Some.or(Some) — левый выигрывает
// ────────────────────────────────────────────────────────────────────

test "Option.or: Some.or(Some) returns left value" {
    ro a = Some(1)
    ro b = Some(2)
    ro r = a.or(b)
    assert(r.is_some())
    assert(r.unwrap() == 1)
}

// ────────────────────────────────────────────────────────────────────
// Some.or(None) — None как inline аргумент, тип из a
// ────────────────────────────────────────────────────────────────────

test "Option.or: Some.or(None) returns left value" {
    ro a = Some(42)
    ro b Option[int] = None
    ro r = a.or(b)
    assert(r.is_some())
    assert(r.unwrap() == 42)
}

// ────────────────────────────────────────────────────────────────────
// None.or(Some) — typed annotation, fallback к правому
// ────────────────────────────────────────────────────────────────────

test "Option.or: None.or(Some) returns right value" {
    ro a Option[int] = None
    ro b = Some(99)
    ro r = a.or(b)
    assert(r.is_some())
    assert(r.unwrap() == 99)
}

// ────────────────────────────────────────────────────────────────────
// Chain: typed None → None → Some
// ────────────────────────────────────────────────────────────────────

test "Option.or: chain finds first Some" {
    ro a Option[int] = None
    ro b Option[int] = None
    ro c = Some(7)
    ro r = a.or(b).or(c)
    assert(r.is_some())
    assert(r.unwrap() == 7)
}

// ────────────────────────────────────────────────────────────────────
// str payload — per-T специализация для nova_str
// ────────────────────────────────────────────────────────────────────

test "Option.or: works with str payload" {
    ro a = Some("hello")
    ro b = Some("world")
    ro r = a.or(b)
    assert(r.is_some())
    assert(r.unwrap() == "hello")
}
