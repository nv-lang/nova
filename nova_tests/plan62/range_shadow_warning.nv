// Plan 62.D non-opaque bis-1 Bug 4 closure — D29 user-shadow warning.
//
// До 62.D bis-1 + 62.A: re-export `Option` через prelude → `type Option`
// локально declared в test → hard CODEGEN-FAIL «duplicate top-level name
// Option» + redefinition C-struct'а NovaOpt_*. D29 spec явно требует
// warning, не error, для user-shadow prelude items.
//
// Plan 62.D bis-1 Bug 4 fix:
//   - types/mod.rs: `classify_dup` helper — prelude-visible → warning.
//   - emit_c.rs: should_skip_type / should_skip_fn — user wins,
//     merged duplicate skipped в codegen.
//
// Plan 91.8a (D183): Ordering удалён из prelude (Comparable.compare -> int).
// Раньше этот test использовал `Ordering` как shadow target; теперь shadow
// path для unit-variant sum-types покрыт через `nova_tests/plan62/d29_
// user_shadow_*.nv` (W_PRELUDE_SHADOW тестируется отдельно). Этот test
// сохранён как minimal local sum-type compile check после D183 cleanup.

module plan62.range_shadow_warning

// Local sum-type без collision с prelude — basic regression marker
// что local sum-type declarations всё ещё compile after D183 prelude
// cleanup (Ordering удалён, Comparable.compare -> int).
type Severity | Low | Medium | High

test "local sum-type compiles + match works (D183 cleanup verified)" {
    ro s = Medium
    match s {
        Low    => assert(false)
        Medium => assert(true)
        High   => assert(false)
    }
}
