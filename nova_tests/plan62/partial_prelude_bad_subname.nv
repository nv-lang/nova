// EXPECT_COMPILE_ERROR unknown prelude sub-module
//
// Plan 62.F Part 3 — `partial_prelude(...)` validation negative test.
//
// Verifies что resolver валидирует имена в `partial_prelude(...)` против
// реальных файлов `std/prelude/<name>.nv` и эмитит чёткую ошибку при
// опечатке. Bootstrap-stage: список valid имён hardcoded в diagnostic
// (core, runtime, errors, collections, protocols, effects).

module plan62.partial_prelude_bad_subname partial_prelude(c0re)

fn dummy() -> int => 1

test "should never reach this — bad partial_prelude name" {
    assert(dummy() == 1)
}
