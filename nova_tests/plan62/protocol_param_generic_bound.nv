// Probe: [U, T Iterable[U]] generic-bound pattern для protocol-as-parameter.
//
// Альтернатива erased `it Iterable[int]` (which только partial-works) —
// двойной generic: U свободный element-type, T concrete iterator
// bound by Iterable[U]. При monomorphization T заменяется на конкретный
// type, dispatch direct (Plan 56 D122 hybrid).
//
// Spec D72 example: `fn func[K, T From[K]](v K) -> T => T.from(v)`.

module nova_tests.plan62


type IntCounter9 {
    mut cur int
    end int
}


fn IntCounter9.new(start int, end int) -> IntCounter9 => { cur: start, end }


fn IntCounter9 mut @next() -> Option[int] => {
    if @cur < @end {
        ro v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}


// Generic-bound pattern: U свободный, T bound by Iterable[U].
fn sum_iter[U, T Iterable[U]](it_in T) -> int => {
    mut it = it_in
    mut total = 0
    while Some(_v) = it.next() {
        total += 1
    }
    total
}


test "[U, T Iterable[U]] generic bound — method dispatch через mono (turbofish)" {
    ro c = IntCounter9.new(1, 4)
    ro count = sum_iter[int, IntCounter9](c)
    assert(count == 3)
}
