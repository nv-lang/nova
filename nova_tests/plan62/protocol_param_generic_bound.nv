// Probe: [U, T Iter[U]] generic-bound pattern для protocol-as-parameter.
//
// Альтернатива erased `it Iter[int]` (which только partial-works) —
// двойной generic: U свободный element-type, T concrete iterator
// bound by Iter[U]. При monomorphization T заменяется на конкретный
// type, dispatch direct (Plan 56 D122 hybrid).
//
// Spec D72 example: `fn func[K, T From[K]](v K) -> T => T.from(v)`.

module plan62.protocol_param_generic_bound


type IntCounter {
    mut cur int
    end int
}


fn IntCounter.new(start int, end int) -> IntCounter => { cur: start, end }


fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        let v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}


// Generic-bound pattern: U свободный, T bound by Iter[U].
fn sum_iter[U, T Iter[U]](it_in T) -> int => {
    let mut it = it_in
    let mut total = 0
    while let Some(_v) = it.next() {
        total += 1
    }
    total
}


test "[U, T Iter[U]] generic bound — method dispatch через mono (turbofish)" {
    let c = IntCounter.new(1, 4)
    let count = sum_iter[int, IntCounter](c)
    assert(count == 3)
}
