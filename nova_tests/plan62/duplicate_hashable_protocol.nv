module nova_tests.plan62

// User shadows prelude Hash РЎРғ Р Т‘РЎРӮРЎС“Р С–Р С‘Р Сҳ required method (extra arg).
// W_PRELUDE_SHADOW warning, Р Р…Р Вө error. User-version wins Р Т‘Р В»РЎРҸ structural
// matching Р РҶР Р…РЎС“РЎвҖҡРЎРӮР С‘ РЎРҢРЎвҖҡР С•Р С–Р С• module'РЎРҸ.
type Hash protocol {
    @hash_with_seed(seed u64) -> u64
}

type Bucket2 {
    value int
}

fn Bucket2 @hash_with_seed(seed u64) -> u64 => (@value as u64) ^ seed

test "user-defined Hash shadow РІРӮвҖқ runs OK РЎвҖЎР ВөРЎРӮР ВөР В· user-version" {
    ro b = Bucket2 { value: 42 }
    ro h = b.hash_with_seed(7 as u64)
    assert(h != (0 as u64))
}
