module plan62.protocol_as_value_probe


type IntCounter {
    mut cur int
    end int
}


fn IntCounter.new(start int, end int) -> IntCounter => { cur: start, end }


fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        ro v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}


// Positive: protocol-as-value coercion РІ let-annotation вЂ” compile OK.
// Р­С‚Рѕ existential binding вЂ” concrete С‚РёРї converts Рє protocol-type
// reference С‡РµСЂРµР· void* erasure (Plan 56 D122 binding-level).
test "let x: Iterable[int] = concrete вЂ” existential binding (coercion compiles)" {
    ro c = IntCounter.new(1, 4)
    ro _x Iterable[int] = c
    assert(true)  // binding compiles + concrete value lives РІ x
}
