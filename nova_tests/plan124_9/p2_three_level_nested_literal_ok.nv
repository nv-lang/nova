// Plan 124.9 Р¤.2 вЂ” positive: 3-level nested record literal.
// Each level allocates its own declared field type (Bv2, Cv1).
module nova_tests.plan124_9

type Cv1 {
    mut x int
}

type Bv2 {
    mut Cv1 Cv1
}

type Av2 {
    mut Bv2 Bv2
}

test "3-level nested record literal" {
    mut Av2 = Av2 { Bv2: Bv2 { Cv1: Cv1 { x: 1 } } }
    assert(Av2.Bv2.Cv1.x == 1)
    Av2.Bv2.Cv1.x = 99
    assert(Av2.Bv2.Cv1.x == 99)
}
