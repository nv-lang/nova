// Plan 124.9 Р¤.2 вЂ” positive: 3-level nested record literal.
// Each level allocates its own declared field type (Bv, Cv).
module plan124_9.p2_three_level_nested_literal_ok

type Cv {
    mut x int
}

type Bv {
    mut Cv Cv
}

type Av {
    mut Bv Bv
}

test "3-level nested record literal" {
    mut Av = Av { Bv: Bv { Cv: Cv { x: 1 } } }
    assert(Av.Bv.Cv.x == 1)
    Av.Bv.Cv.x = 99
    assert(Av.Bv.Cv.x == 99)
}
