// Plan 124.9 Р¤.2 вЂ” positive: nested literals where each level has
// multiple fields. Verifies field-type allocation is per-field, not
// inherited from the outermost type.
module plan124_9.p6_nested_literal_with_multiple_fields_ok

type Cv {
    mut p int
    mut q int
}

type Bv {
    mut Cv Cv
    mut tag int
}

type Av {
    mut Bv Bv
    mut name int
}

test "nested literal with multiple fields per level" {
    mut Av = Av { Bv: Bv { Cv: Cv { p: 1, q: 2 }, tag: 3 }, name: 4 }
    assert(Av.Bv.Cv.p == 1)
    assert(Av.Bv.Cv.q == 2)
    assert(Av.Bv.tag == 3)
    assert(Av.name == 4)
    Av.Bv.Cv.q = 20
    Av.Bv.tag = 30
    assert(Av.Bv.Cv.q == 20)
    assert(Av.Bv.tag == 30)
}
