// Plan 124.9 Ф.2 — positive: nested literals where each level has
// multiple fields. Verifies field-type allocation is per-field, not
// inherited from the outermost type.
module plan124_9.p6_nested_literal_with_multiple_fields_ok

type C {
    mut p int
    mut q int
}

type B {
    mut c C
    mut tag int
}

type A {
    mut b B
    mut name int
}

test "nested literal with multiple fields per level" {
    mut a = A { b: B { c: C { p: 1, q: 2 }, tag: 3 }, name: 4 }
    assert(a.b.c.p == 1)
    assert(a.b.c.q == 2)
    assert(a.b.tag == 3)
    assert(a.name == 4)
    a.b.c.q = 20
    a.b.tag = 30
    assert(a.b.c.q == 20)
    assert(a.b.tag == 30)
}
