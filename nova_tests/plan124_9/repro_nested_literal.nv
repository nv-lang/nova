// Plan 124.9 Р¤.0 вЂ” bug repro: 4-level nested record literal.
// Expected: each level allocates its own declared field type (Bv, Cv, Dv),
// not the outermost type Av four times.
module plan124_9.repro_nested_literal

type Dv {
    mut value int
}

type Cv {
    mut Dv Dv
}

type Bv {
    mut Cv Cv
}

type Av {
    mut Bv Bv
}

test "4-level nested record literal allocates correct types" {
    mut Av = Av { Bv: Bv { Cv: Cv { Dv: Dv { value: 0 } } } }
    assert(Av.Bv.Cv.Dv.value == 0)
    Av.Bv.Cv.Dv.value = 42
    assert(Av.Bv.Cv.Dv.value == 42)
}
