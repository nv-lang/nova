// Plan 124.9 Р¤.2 вЂ” positive: 2-level nested record literal.
// Each level allocates its own declared field type (Bv), not Av twice.
module plan124_9.p1_two_level_nested_literal_ok

type Bv {
    mut x int
}

type Av {
    mut Bv Bv
}

test "2-level nested record literal" {
    mut Av = Av { Bv: Bv { x: 1 } }
    assert(Av.Bv.x == 1)
    Av.Bv.x = 7
    assert(Av.Bv.x == 7)
}
