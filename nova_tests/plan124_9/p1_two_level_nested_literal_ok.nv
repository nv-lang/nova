// Plan 124.9 Р¤.2 вЂ” positive: 2-level nested record literal.
// Each level allocates its own declared field type (Bv1), not av1 twice.
module nova_tests.plan124_9

type Bv1 {
    mut x int
}

type Av1 {
    mut Bv1 Bv1
}

test "2-level nested record literal" {
    mut av1 = Av1 { Bv1: Bv1 { x: 1 } }
    assert(av1.Bv1.x == 1)
    av1.Bv1.x = 7
    assert(av1.Bv1.x == 7)
}
