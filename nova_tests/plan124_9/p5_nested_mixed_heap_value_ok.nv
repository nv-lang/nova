// Plan 124.9 Ф.2 — positive: mix of heap + value records nested.
// A heap record containing a value record containing a heap record;
// each level must allocate its own declared field type.
module plan124_9.p5_nested_mixed_heap_value_ok

type Leaf {
    mut value int
}

type Mid value {
    leaf Leaf
}

type Top {
    mut mid Mid
}

test "nested mixed heap + value records" {
    mut t = Top { mid: Mid { leaf: Leaf { value: 3 } } }
    assert(t.mid.leaf.value == 3)
    t.mid.leaf.value = 11
    assert(t.mid.leaf.value == 11)
}
