// Plan 124.9 Р¤.2 вЂ” positive: 4-level nested record literal.
// The original failing pattern Av3{Bv3:Bv3{Cv2:Cv2{Dv1:Dv1{value:0}}}}.
// Before the fix this CC-FAILed because nested literals allocated the
// outermost type Av3 repeatedly instead of each declared field type.
module nova_tests.plan124_9

type Dv1 {
    mut value int
}

type Cv2 {
    mut Dv1 Dv1
}

type Bv3 {
    mut Cv2 Cv2
}

type Av3 {
    mut Bv3 Bv3
}

test "4-level nested record literal allocates correct types" {
    mut Av3 = Av3 { Bv3: Bv3 { Cv2: Cv2 { Dv1: Dv1 { value: 0 } } } }
    assert(Av3.Bv3.Cv2.Dv1.value == 0)
    Av3.Bv3.Cv2.Dv1.value = 42
    assert(Av3.Bv3.Cv2.Dv1.value == 42)
}
