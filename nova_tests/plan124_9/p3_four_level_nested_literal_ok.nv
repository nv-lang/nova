// Plan 124.9 Р¤.2 вЂ” positive: 4-level nested record literal.
// The original failing pattern Av{Bv:Bv{Cv:Cv{Dv:Dv{value:0}}}}.
// Before the fix this CC-FAILed because nested literals allocated the
// outermost type Av repeatedly instead of each declared field type.
module plan124_9.p3_four_level_nested_literal_ok

type Dv {
    mut value int
}

type Cv {
    mut Dv Dv
}

type Bv {
    mut Cv Cv
}

type Av {
    mut Bv Bv
}

test "4-level nested record literal allocates correct types" {
    mut Av = Av { Bv: Bv { Cv: Cv { Dv: Dv { value: 0 } } } }
    assert(Av.Bv.Cv.Dv.value == 0)
    Av.Bv.Cv.Dv.value = 42
    assert(Av.Bv.Cv.Dv.value == 42)
}
