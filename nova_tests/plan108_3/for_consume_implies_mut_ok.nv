// Plan 108.3 (D36 amend): `for consume x in iter` — consume implies mut.

module nova_tests.plan108_3.for_consume_implies_mut_ok

type Token consume { val int }
fn Token.new(v int) -> Token => { val: v }
fn Token consume @release() -> int => @val

test "for consume x — implicit mut" {
    ro toks = [Token.new(1), Token.new(2)]
    mut total = 0
    for consume t in toks {
        total = total + t.release()
    }
    assert(total == 3)
}
