// Plan 100.3 (D146): view-closure (FnMut/Fn analog) — multiple invokes OK.

module nova_tests.plan100_3.closure_view_ok_multi_invoke

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }

test "view-closure — multiple invokes" {
    consume tx = Transaction { id: 10 }
    let logger = || println(tx.id)              // view-capture (no consume в body)
    logger()                                     // ✅ OK
    logger()                                     // ✅ OK, multi-invoke
    logger()                                     // ✅ OK
    tx.commit()                                  // tx Live после view-closure scope
}
