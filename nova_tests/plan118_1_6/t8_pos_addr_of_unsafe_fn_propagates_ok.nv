// Plan 118.1.6 Ф.4 T8 POS — unsafe fn → *unsafe fn type propagation.
//
// Verifies that bare unsafe fn name carries safety bit through coercion
// к *unsafe fn(...) — type matches binding annotation exactly (no widening,
// no narrowing). Direct evidence: assignment к annotated *unsafe binding
// type-checks без ошибок, plus call site requires unsafe wrap.
//
// (Acceptance criterion A-118.1.6.f — propagation correctness.)

module nova_tests.plan118_1_6

unsafe fn unsafe_triple(x i64) -> i64 {
    x * 3
}

test "bare unsafe fn → *unsafe fn type propagation" {
    // Exact-match annotation. Coercion path lifts FnDecl.unsafe_attr=true
    // into Pointer(Func{unsafe_attr=true}). If propagation dropped safety
    // bit, RHS would be *fn(...) — but then T4-NEG E_UNSAFE_FN_PTR_COERCION
    // would NOT fire (it does). Verified through paired NEG fixture.
    ro p *unsafe fn(i64) -> i64 = unsafe_triple
    ro v = unsafe { p(14) }
    assert(v == 42)
}
