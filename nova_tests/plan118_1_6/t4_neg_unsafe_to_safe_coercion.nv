// Plan 118.1.6 Ф.4 T4 NEG — #unsafe fn → *fn pointer (silent safety drop).
//
// Per Plan 118.1.6 covariance rule «unsafe → safe drops safety bit» —
// REJECTED. Bare #unsafe fn name lifted к *fn (safe) binding would silently
// strip safety annotation. Compiler must flag.
//
// EXPECT_COMPILE_ERROR E_UNSAFE_FN_PTR_COERCION

module plan118_1_6.t4_neg_unsafe_to_safe_coercion

#unsafe
fn risky_id(x i64) -> i64 {
    x
}

test "rejects coercing #unsafe fn → *fn (safe) pointer binding" {
    // addr_of(#unsafe fn) yields *unsafe fn(...). LHS *fn(i64) -> i64
    // (safe) — silent safety-bit drop. Must error.
    ro p *fn(i64) -> i64 = unsafe { addr_of(risky_id) }
    assert(true)
}
