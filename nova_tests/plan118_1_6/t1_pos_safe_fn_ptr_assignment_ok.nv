// Plan 118.1.6 Ф.4 T1 POS — safe fn → *fn pointer assignment + indirect call.
//
// Per design §«Получение pointer»: bare fn name implicitly coerces к
// `*fn(...) -> Ret` at let-binding. Indirect call позволен в safe context
// (safe ptr → safe call-site).

module nova_tests.plan118_1_6

fn safe_get() -> i64 {
    42
}

test "safe fn → *fn pointer + indirect call" {
    ro p *fn() -> i64 = safe_get
    ro v = p()
    assert(v == 42)
}
