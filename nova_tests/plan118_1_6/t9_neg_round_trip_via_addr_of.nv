// Plan 118.1.6 Ф.4 T9 NEG — bare unsafe fn → *fn coercion round-trip rejected.
//
// Verifies нельзя «launder» unsafe-ness через bare fn-name coercion в safe
// pointer binding. Covariance permits ONLY safe → unsafe widening. Reverse
// direction (unsafe → safe) — error. Same enforcement как T4, focus на
// implicit coercion path (no explicit addr_of indirection).
//
// EXPECT_COMPILE_ERROR E_UNSAFE_FN_PTR_COERCION

module plan118_1_6.t9_neg_round_trip_via_addr_of

unsafe fn risky_neg(x i64) -> i64 {
    -x
}

test "rejects round-trip &(unsafe fn) → *fn binding" {
    // & yields *unsafe fn(i64) -> i64.
    // LHS *fn(i64) -> i64 strips safety — must error.
    ro p *fn(i64) -> i64 = unsafe { &risky_neg }
    assert(true)
}
