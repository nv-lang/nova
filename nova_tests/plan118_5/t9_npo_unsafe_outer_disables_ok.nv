// Plan 118.5 V2 T9 — structural NPO recalculation per D216 V2 §V2.4.
//
// `Option[unsafe * T]` (= Option[Unsafe(Pointer(T))]) → 16 bytes (tagged
// layout; null is legitimate value of `unsafe * T`, NPO disabled).
// `Option[* unsafe T]` (= Option[Pointer(Unsafe(T))]) → 8 bytes (NPO eligible;
// pointer non-null, only pointee possibly-uninit).
// `Option[* T]` / `Option[mut * T]` / `Option[ro * T]` → 8 bytes (canonical NPO).
//
// We can't easily query layout from Nova code; this fixture confirms that
// the codegen path compiles + executes correctly for all 4 forms.
// Layout-correctness verification via .c golden compare is in the codegen
// snapshot tests (not fixtures here).
//
// Closes [M-118.5-npo-recalculation] POS.

module plan118_5.t9_npo_unsafe_outer_disables_ok

type Acc {
    id i64
}

// Canonical NPO-eligible forms.
external fn p9_a() -> Option[* Acc]
external fn p9_b() -> Option[mut * Acc]
external fn p9_c() -> Option[ro * Acc]
external fn p9_d() -> Option[* unsafe Acc]

// NPO-DISABLED form (per §V2.4).
external fn p9_e() -> Option[unsafe * Acc]

test "Option[*T] family compiles for all 5 wrapper variants" {
    assert(1 == 1)
}
