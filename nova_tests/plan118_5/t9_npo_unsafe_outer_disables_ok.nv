// Plan 118.5 V2 T9 → MIGRATED by Plan 138.5 (2026-06-11).
//
// The retired §V2.4 NPO-DISABLE rule (for the prefix `unsafe * T` /
// Option[unsafe * T] form) is gone — that prefix form no longer exists. All
// pointers are non-null, so Option[*…] is ALWAYS NPO-eligible (8 bytes, None
// = null). This fixture now confirms all canonical POSTFIX pointer forms
// compile under Option:
//   Option[*T] / Option[*mut T] / Option[*ro T] / Option[*unsafe T]
// (the last is the FFI nullable-uninit form: None = null, Some = non-null
// ptr to a possibly-uninit pointee).

module plan118_5.t9_npo_unsafe_outer_disables_ok

type Acc {
    id i64
}

external fn p9_a() -> Option[* Acc]
external fn p9_b() -> Option[*mut Acc]
external fn p9_c() -> Option[*ro Acc]
external fn p9_d() -> Option[*unsafe Acc]

test "Option[*T] family compiles for all canonical postfix variants" {
    assert(1 == 1)
}
