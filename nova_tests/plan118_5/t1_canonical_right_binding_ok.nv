// Plan 118.5 / 138.5 T1 — canonical postfix pointer syntax parses + typechecks.
//
// Tests final pointer grammar: *T, *ro T, *mut T, *unsafe T forms in
// external fn signatures (parser + typecheck only — no runtime ops).
//
// Per D216 final model, pointee-mut is POSTFIX (after `*`); reassignability
// of the pointer is binding, not type.

module plan118_5.t1_canonical_right_binding_ok

type Acc {
    id i64
}

external fn p118_5_t1_a(p * Acc) -> ()
external fn p118_5_t1_b(p *ro Acc) -> ()
external fn p118_5_t1_c(p *mut Acc) -> ()
external fn p118_5_t1_d(p *unsafe Acc) -> ()

test "parses canonical right-binding forms" {
    assert(1 == 1)
}
