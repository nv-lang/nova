// Plan 118.5 V2 T7 — passing unsafe-T arg к unsafe-T param is OK.
//
// Matched contract: callee param is also `unsafe T`, no narrow happens,
// no error. Demonstrates the [M-118.5-arg-coerce-unsafe] precise check:
// only fires when arg is unsafe-T but param is NOT.
//
// Closes [M-118.5-arg-coerce-unsafe] POS half.

module nova_tests.plan118_5

fn accepts_unsafe(x unsafe int) -> () {
    // Body would need unsafe { } to read x (Ф.4 enforcement);
    // here we just demonstrate the contract — caller side.
    assert(1 == 1)
}

fn driver() -> () {
    mut x unsafe int = 0
    x = 42                       // safe write
    accepts_unsafe(x)            // ✅ unsafe T → unsafe T param — matched
}

test "unsafe T arg к unsafe T param accepted" {
    driver()
}
