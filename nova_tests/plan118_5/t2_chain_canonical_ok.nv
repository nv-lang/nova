// Plan 118.5 / 138.5 T2 — multi-level chain in postfix form.
//
// Tests AST shape for chained pointee-mut modifiers: `*mut *T` builds as
// Pointer(Mut(Pointer(T))). All wrappers transparent at C codegen level
// (Mut inner-wrap к Pointer gives T*; the ro pointee is the bare canon `*T`,
// `*T ≡ *ro T` per Plan 147 / D246 — explicit `*ro` migrated here).

module nova_tests.plan118_5

type Node {
    val i64
}

extern "nova" fn p118_5_t2_a(p *mut *Node) -> ()
extern "nova" fn p118_5_t2_b(p **mut Node) -> ()
extern "nova" fn p118_5_t2_c(p *unsafe *Node) -> ()

test "parses multi-level canonical chains" {
    assert(1 == 1)
}
