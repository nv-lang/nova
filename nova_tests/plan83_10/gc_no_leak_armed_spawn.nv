// Plan 83.10 (2026-05-25): race detection — N spawn workload под
// armed M:N + gc.collect; verify heap bounded (no SpawnCtx leak;
// pool retention bounded by Plan 83.6 cap).
//
// ALLOC_REQUIRES boehm
// EXPECT_TIMEOUT_MS 180000
//
// Plan 83.10: standalone PASS. Под jobs=16 [M-83.9-arena-pressure-1M]
// applies — relaxed budget.

module plan83_10.gc_no_leak_armed_spawn

test "spawn workload → collect → heap bounded" {
    gc.collect()
    ro baseline = gc.heap_size()

    // Single parallel-for (codegen restriction — multiple parallel-for
    // в одной test fn создаёт name collision).
    ro xs = parallel for i in 0..1000 { i }
    assert(xs[999] == 999)
    assert(xs[0] == 0)

    gc.collect()
    ro h = gc.heap_size()

    ro growth = if h > baseline { h - baseline } else { 0 }
    println("baseline=${baseline} after=${h} growth=${growth}")

    // Generous bound: 16MB (covers pool retention + Boehm overhead +
    // result array 1K ints = ~8KB).
    assert(growth < 16 * 1024 * 1024)
}
