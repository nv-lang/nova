// Plan 83.10 (2026-05-25): race detection — Plan 83.4.5.4 spawn-time
// handler-snapshot capture. Each fiber видит свои `with Time = h`
// bindings, не peer's handlers.
//
// Plan 83.10.1 (2026-05-26): directive OBSOLETE — 3/3 runs PASS under
// armed M:N. Plan 83.10 fix [M-83.10-armed-user-throw-routing] + TLS
// snapshot isolation via spawn-time capture work correctly under M:N.
// Note: concurrency/per_fiber_handlers.nv still needs directive (more complex
// handler interaction scenarios).
// (test runs under armed M:N default — Plan 83.10 fix)

module plan83_10.handler_isolation_per_fiber

fn helper_h_100() Time -> int {
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 100 }
    } {
        Time.now()
    }
}

fn helper_h_999() Time -> int {
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 999 }
    } {
        Time.now()
    }
}

test "per-fiber handler isolation — different values seen" {
    let mut a = 0
    let mut b = 0
    supervised {
        spawn { a = helper_h_100() }
        spawn { b = helper_h_999() }
    }
    assert(a == 100)
    assert(b == 999)
}
