// Plan 83.10 (2026-05-25): race detection — cancel mid-spawn N циклов;
// verify scope properly cleaned (no orphan parked state, no leaked
// sched_state). Plan 83.4.5.1 cancel wake-all infrastructure.
//
// Plan 83.10.1 (2026-05-26): directive OBSOLETE — 3/3 runs PASS under
// armed M:N after Plan 83.10 fix [M-83.10-armed-user-throw-routing].
// Simple cancel without Time.sleep works — no timer handle cleanup needed.
// (test runs under armed M:N default — Plan 83.10 fix)

module plan83_10.cancel_race_no_orphan_state

test "1K cancel cycles — no orphan state, no hang" {
    let mut i = 0
    while i < 1000 {
        let tok = CancelToken.new()
        let cur = i
        supervised(cancel: tok) {
            spawn {
                if cur % 3 == 0 {
                    tok.cancel()
                }
            }
        }
        i = i + 1
    }
    // 1000 cancel scopes without hang либо leak. Implicit: assertion
    // by reaching here без timeout.
    assert(i == 1000)
}
