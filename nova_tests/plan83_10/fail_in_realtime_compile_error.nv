// EXPECT_COMPILE_ERROR realtime
//
// Plan 83.10 (2026-05-25): D64 — realtime banned suspend-effect call
// chain. Function calling Time.now() inside realtime — compile error
// because Time effect propagates.

module plan83_10.fail_in_realtime_compile_error

fn time_now_in_realtime() Time -> int {
    let _ = realtime {
        let _t = Time.now()
        0
    }
    0
}
