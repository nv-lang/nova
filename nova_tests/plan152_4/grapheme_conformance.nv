test "UAX#29 GraphemeBreakTest (chunk 4, 93 cases)" {
    {
        mut g = "\u{200d}\u{231a}".as_graphemes()
        match g.next() { Some(s) => assert(s == "\u{200d}"), None => assert(false) }
        match g.next() { Some(s) => assert(s == "\u{231a}"), None => assert(false) }
        assert(g.next() == None)
    }
    {
        mut g = "\u{200d}\u{308}\u{231a}".as_graphemes()
        match g.next() { Some(s) => assert(s == "\u{200d}\u{308}"), None => assert(false) }
        match g.next() { Some(s) => assert(s == "\u{231a}"), None => assert(false) }
        assert(g.next() == None)
