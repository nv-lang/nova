// Plan 48: generic-методы (instance + static) с собственными type params.
//
// Покрывает sentinel MethodSig + register_mono_method_instance +
// emit_monomorphized_method для обоих kinds. Метод НЕ изменяет
// receiver, чтобы избежать mono generic records (это Ф.3, V2).
//
// После Ф.7.1: `let r = c.method(...)` инфер'ит правильный mono'д
// return type — workaround `let r int = ...` больше не нужен.
// После Ф.7.2: static `Type.method[T]()` работает через sentinel
// routing с правильной C signature (без nova_self).

module nova_tests.generics.p48_mono_method


type Counter {
    ro base int
}


// Generic method — T параметр метода, не Counter.
export fn Counter @apply[T](f fn(int) -> T) -> T => f(@base)


// Static generic method — без instance receiver.
export fn Counter.combine[T](x T, y T, merge fn(T, T) -> T) -> T => merge(x, y)


test "mono method: int return (Ф.7.1 — без annotation)" {
    ro c = Counter { base: 10 }
    ro r = c.apply(fn(n int) -> int { n * 2 })
    assert(r == 20)
}

test "mono method: bool return (Ф.7.1)" {
    ro c = Counter { base: 3 }
    ro r = c.apply(fn(n int) -> bool { n > 0 })
    assert(r == true)
}

test "mono method: closure с block body" {
    ro c = Counter { base: 5 }
    ro r = c.apply(fn(n int) -> int {
        ro doubled = n * 2
        doubled + 1
    })
    assert(r == 11)
}

test "static mono method: int merge (Ф.7.2)" {
    ro r = Counter.combine(2, 3, fn(a int, b int) -> int { a + b })
    assert(r == 5)
}
