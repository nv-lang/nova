// Plan 48: instance generic-метод с собственными type params (не type
// params receiver-а).
//
// Покрывает sentinel MethodSig + register_mono_method_instance +
// emit_monomorphized_method для **instance** методов. Метод НЕ изменяет
// receiver, чтобы избежать mono generic records (это Ф.3, V2).
//
// FIXME / followups:
//  - call-site `let r = c.method(...)` тип `r` инфер'ится как `void*`
//    (infer_expr_c_type method-call branch не делает Plan 48 mono
//    inference). Workaround: явная type annotation. Followup в Plan 48.
//  - Static generic methods (`Type.method[T]()` без receiver) — sentinel
//    `__mono_method__T__m` попадает в C-output как c_name линковщику,
//    не resolved через mono routing. Followup в Plan 48.

module nova_tests.generics.p48_mono_method


type Counter {
    readonly base int
}


// Generic method — T параметр метода, не Counter.
export fn Counter @apply[T](f fn(int) -> T) -> T => f(@base)


// Static generic method — без instance receiver.
export fn Counter.combine[T](x T, y T, merge fn(T, T) -> T) -> T => merge(x, y)


test "mono method: int return" {
    let c = Counter { base: 10 }
    let r int = c.apply(fn(n int) -> int { n * 2 })
    assert(r == 20)
}

test "mono method: bool return" {
    let c = Counter { base: 3 }
    let r bool = c.apply(fn(n int) -> bool { n > 0 })
    assert(r == true)
}

test "mono method: closure with block body" {
    let c = Counter { base: 5 }
    let r int = c.apply(fn(n int) -> int {
        let doubled = n * 2
        doubled + 1
    })
    assert(r == 11)
}

test "static mono method: int merge" {
    let r int = Counter.combine(2, 3, fn(a int, b int) -> int { a + b })
    assert(r == 5)
}
