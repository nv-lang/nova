// Plan 97.1 final hardening — protocol-литерал с большим protocol'ом
// (5 методов + overloaded). Проверяет: vtable struct корректно
// генерируется, overload-mangling работает, dispatch всех методов
// через box правильный.

module nova_tests.plan97.pos_protocol_lit_multi_method


export type Storage protocol {
    get(key str) -> int
    put(key str, value int) -> ()
    has(key str) -> bool
    size() -> int
    clear() -> ()
}


test "protocol-литерал с 5 разными методами" {
    mut total = 0
    mut last_get = -1
    mut s = protocol Storage {
        get(key) {
            last_get = total + 1
            42
        }
        put(key, value) {
            total = total + value
        }
        has(key) => true
        size() => total
        clear() {
            total = 0
        }
    }
    // put(3) → total=3
    s.put("a", 3)
    assert(s.size() == 3)
    // put(7) → total=10
    s.put("b", 7)
    assert(s.size() == 10)
    // get(a) → 42, last_get=11
    ro v = s.get("a")
    assert(v == 42)
    assert(s.has("zzz"))
    // clear → total=0
    s.clear()
    assert(s.size() == 0)
}
