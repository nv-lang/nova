// Plan 97 Ф.4 — user-defined protocol с .method (static) синтаксисом.
//
// Проверяет: парсер принимает leading-точку в protocol-теле; реализация
// через D35 static-метод (`fn Type.name(...)`); прямой вызов работает.

module nova_tests.plan97


export type MyBuilder[T] protocol {
    .make(x T) -> Self
}


type Box4 {
    value int
}

fn Box4.make(x int) -> Box4 => { value: x }


test "static-protocol метод объявлен через .make, вызов через Type.method" {
    ro b = Box4.make(42)
    assert(b.value == 42)
}

test "несколько вызовов" {
    ro a = Box4.make(1)
    ro b = Box4.make(99)
    assert(a.value + b.value == 100)
}
