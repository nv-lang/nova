// Plan 97 Ф.2 (D142) — анонимный protocol-тип в позиции параметра.
//
// Проверяет: парсер принимает `protocol { method-sig* }` в типе параметра;
// type-checker (compute_protocol_satisfaction inline) не требует named-
// типа в registry; вызов метода через структурную совместимость работает.

module plan97.pos_anon_protocol_param


type Doc {
    title str
}

fn Doc @close() -> () => ()


// Анонимный protocol-тип `protocol { close() -> () }` — параметр должен
// иметь метод `close`. `Doc` структурно совместим.
fn use_closer(c protocol { close() -> () }) -> () => c.close()


test "анонимный protocol-тип в параметре, structural match" {
    ro d = Doc { title: "x" }
    use_closer(d)
    assert(d.title == "x")
}
