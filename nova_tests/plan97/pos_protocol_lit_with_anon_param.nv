// Plan 97.1 Ф.4.4 (D142) — cross-test Ф.2 (anon-protocol type)
// + Ф.4 (protocol-literal value).
//
// fn принимает анонимный protocol-type `c protocol { close() -> () }`
// (Plan 97 Ф.2). Caller передаёт protocol-литерал значение.

module nova_tests.plan97.pos_protocol_lit_with_anon_param


export type Resource protocol {
    close() -> ()
}


// Helper принимает named protocol-typed value.
fn use_closer(c Resource) -> () => c.close()


test "protocol-литерал передан в fn ожидающую named protocol" {
    mut closed = 0
    ro r = protocol Resource {
        close() {
            closed = closed + 1
        }
    }
    use_closer(r)
    use_closer(r)
    assert(closed == 2)
}
