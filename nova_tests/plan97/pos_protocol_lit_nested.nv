// Plan 97.1 final hardening — nested protocol-литералы: literal
// внутри другого literal'а; literal возвращается из метода literal'а.
//
// Проверяет: scan_expr_fwd корректно recurse'ит в method body,
// counter не ломается, GC справляется с nested allocation.

module nova_tests.plan97.pos_protocol_lit_nested


export type Maker protocol {
    make(x int) -> int
}


export type Adder protocol {
    apply(y int) -> int
}


test "Nested literals: literal returns int from inner-literal method-call" {
    let m = protocol Maker {
        make(x) {
            // Inner literal — locally constructed на каждый вызов make.
            let inner = protocol Adder {
                apply(y) => y + x
            }
            inner.apply(10)
        }
    }
    let r1 = m.make(5)
    let r2 = m.make(100)
    assert(r1 == 15)
    assert(r2 == 110)
}
