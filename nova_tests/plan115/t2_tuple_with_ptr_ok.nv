// Plan 115 Ф.2 T2.1-T2.4 — tuple with *() destructure (regular Nova fn,
// without extern "nova" fn boundary). Verifies tuple-by-value layout +
// destructuring + *()-in-tuple semantics works end-to-end через codegen.
//
// extern "nova" fn variant (T2 actual FFI) — см. t2_external_fn_tuple_ok.nv
// (если присутствует) или extracted в Plan 115.1.

module plan115.t2_tuple_with_ptr_ok

fn make_handle_pair(seed int) -> (*(), int) {
    ro h = seed as *()
    (h, seed * 2)
}

fn make_three_ptrs() -> (*(), *(), *()) {
    (1 as *(), 2 as *(), 3 as *())
}

test "tuple with *() — destructure" {
    ro (h, code) = make_handle_pair(42)
    assert(h as int == 42)
    assert(code == 84)
}

test "tuple with three ptrs — all fields preserved" {
    ro (a, b, c) = make_three_ptrs()
    assert(a as int == 1)
    assert(b as int == 2)
    assert(c as int == 3)
}

test "(0 as *()) inside tuple" {
    ro (p, n) = ((0 as *()), 99)
    assert(p == (0 as *()))
    assert(n == 99)
}
