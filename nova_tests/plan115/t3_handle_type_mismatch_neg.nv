// Plan 115 Ф.3 T3.3 — type safety: distinct handle types prevent
// accidental cross-mixing. Compile error at type-check stage.

// EXPECT_COMPILE_ERROR E7301

module plan115.t3_handle_type_mismatch_neg

type SqHandle(ptr)
type PngHandle(ptr)

fn close_sqlite(h SqHandle) -> int => 0

test "passing PngHandle to fn expecting SqHandle is a type error" {
    ro png = PngHandle((0 as ptr))
    ro result = close_sqlite(png)
    assert(result == 0)
}
