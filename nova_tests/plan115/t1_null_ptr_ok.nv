// Plan 115 Ф.1 T1.1-T1.2 — `(0 as ptr)` literal + equality + default value.

module plan115.t1_null_ptr_ok

test "(0 as ptr) literal parses and assigns" {
    ro p ptr = (0 as ptr)
    assert(p == (0 as ptr))
}

test "(0 as ptr) inequality with itself is false" {
    ro p ptr = (0 as ptr)
    ro q ptr = (0 as ptr)
    assert(p == q)
    assert(!(p != q))
}
