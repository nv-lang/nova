// Plan 99.2 Ф.4: contextual `Some(v)`/`None` (bare ident form)
// в expr-position эмитят typed compound literal `(NovaOpt_<X>){...}`
// для return-type `-> Option[X]`, вместо legacy
// `nova_make_Option_Some` (которая всегда returns `NovaOpt_nova_int`).

module plan99_2_ctor.option_ctor_in_body

type User { id int, name str }

fn make_some_int() -> Option[int] => Some(42)
fn make_some_str() -> Option[str] => Some("hello")
fn make_some_char() -> Option[char] => Some('A')
fn make_none_str() -> Option[str] => None
fn make_none_user() -> Option[User] => None

test "Some(int) bare → contextual NovaOpt_nova_int" {
    ro o = make_some_int()
    assert(o.is_some())
    assert(o.unwrap_or(0) == 42)
}

test "Some(str) bare → contextual NovaOpt_nova_str" {
    ro o = make_some_str()
    assert(o.is_some())
    assert(o.unwrap_or("") == "hello")
}

test "Some(char) bare → contextual NovaOpt_nova_char" {
    ro o = make_some_char()
    assert(o.is_some())
    assert(o.unwrap_or('?') == 'A')
}

test "None bare с Option[str] context" {
    ro o = make_none_str()
    assert(o.is_none())
}

test "None bare с Option[User] context (non-primitive)" {
    ro o = make_none_user()
    assert(o.is_none())
}
