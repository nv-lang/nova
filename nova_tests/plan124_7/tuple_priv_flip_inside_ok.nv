// Plan 124.7 — positive: `type X priv (...)` тип-level flip для named
// tuple. Все fields default = priv. Inside method scope access OK.
module plan124_7.tuple_priv_flip_inside_ok

type Secret priv (key str, salt str)

fn Secret.new(k str, s str) -> Secret =>
    Secret(key: k, salt: s)

fn Secret @check(other_key str) -> bool =>
    @key == other_key

test "Plan 124.7: type-level priv flip — inside method OK" {
    ro s = Secret.new("alpha", "beta")
    assert(s.check("alpha"))
}
