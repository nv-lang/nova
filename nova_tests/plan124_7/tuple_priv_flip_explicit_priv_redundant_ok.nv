// Plan 124.7 — positive: explicit `priv` per-field на типе с type-level
// flip — redundant но valid (idempotent). Same priv_field = true result.
module plan124_7.tuple_priv_flip_explicit_priv_redundant_ok

type Secret priv (priv key str, salt str)

fn Secret.new(k str, s str) -> Secret =>
    Secret(key: k, salt: s)

fn Secret @get_key() -> str =>
    @key

test "Plan 124.7: explicit priv on type-flip — idempotent" {
    ro s = Secret.new("a", "b")
    assert(s.get_key() == "a")
}
