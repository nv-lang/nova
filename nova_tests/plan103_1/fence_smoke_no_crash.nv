// Plan 103.1 Ф.6 smoke — 1000 fence calls, no crash, no panic.
//
// Нет runtime.random() → детерминированный цикл: 200 итераций × 5 вариантов
// = 1000 вызовов fence. Проверяет что runtime (nova_fn_fence/atomic_thread_fence)
// не падает при многократном вызове с разными orderings.

module plan103_1.fence_smoke_no_crash

/// 5 fence-вызовов — один полный цикл по всем вариантам ordering.
fn fence_cycle() {
    fence(Relaxed)
    fence(Acquire)
    fence(Release)
    fence(AcqRel)
    fence(SeqCst)
}

test "1000 fence calls — no crash" {
    ro i = 0
    while i < 200 {
        fence_cycle()
        i = i + 1
    }
    assert(true)
}

test "повторные fence(SeqCst) — 200 раз, no crash" {
    ro i = 0
    while i < 200 {
        fence(SeqCst)
        i = i + 1
    }
    assert(true)
}

test "чередование Acquire/Release — 500 пар" {
    ro i = 0
    while i < 500 {
        fence(Acquire)
        fence(Release)
        i = i + 1
    }
    assert(true)
}
