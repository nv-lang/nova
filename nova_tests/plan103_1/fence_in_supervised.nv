// Plan 103.1 Ф.6 positive — fence внутри supervised/spawn блоков.
//
// Проверяет интеграцию fence() со structured concurrency:
// - fence в spawn body (fiber context)
// - fence до и после spawn (coordinator context)
// - fence внутри parallel for
//
// Important для downstream Plan 103.2: atomic store/load с fence
// используются в fiber-coordination patterns.

module nova_tests.plan103_1.fence_in_supervised

test "fence(SeqCst) внутри spawn body" {
    let mut counter = AtomicInt.new(0)
    supervised {
        spawn {
            fence(SeqCst)
            counter.fetch_add(1)
        }
    }
    assert(counter.load() == 1)
}

test "fence в координаторе до и после supervised" {
    let mut counter = AtomicInt.new(0)
    fence(Release)
    supervised {
        spawn { counter.fetch_add(1) }
        spawn { counter.fetch_add(1) }
    }
    fence(Acquire)
    assert(counter.load() == 2)
}

test "fence внутри parallel for — каждая итерация" {
    let mut counter = AtomicInt.new(0)
    parallel for i in 0..3 {
        fence(AcqRel)
        counter.fetch_add(1)
    }
    assert(counter.load() == 3)
}

test "fence(Relaxed) — no-op, не нарушает fiber scheduling" {
    let mut flag = AtomicBool.new(false)
    supervised {
        spawn {
            fence(Relaxed)
            flag.store(true)
        }
    }
    assert(flag.load() == true)
}

test "разные orderings в разных spawn'ах" {
    let mut counter = AtomicInt.new(0)
    supervised {
        spawn {
            fence(Acquire)
            counter.fetch_add(1)
        }
        spawn {
            fence(Release)
            counter.fetch_add(1)
        }
        spawn {
            fence(SeqCst)
            counter.fetch_add(1)
        }
    }
    assert(counter.load() == 3)
}
