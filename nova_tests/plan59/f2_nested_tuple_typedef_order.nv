// Positive: nested tuple `((int, int), (int, int))` требует topo-sort
// mono'd typedef'ов — outer struct ссылается на inner mangled type.

module plan59.f2_nested_tuple_typedef_order


test "tuple of tuples — nested mono'd typedef order" {
    let pair_of_pairs = ((1, 2), (3, 4))
    let (left, right) = pair_of_pairs
    assert(left.0 == 1)
    assert(left.1 == 2)
    assert(right.0 == 3)
    assert(right.1 == 4)
}


test "triple-nested tuple — recursive topo-sort" {
    let deep = (((1, 2), 3), ((4, 5), 6))
    assert(deep.0.0.0 == 1)
    assert(deep.0.0.1 == 2)
    assert(deep.0.1 == 3)
    assert(deep.1.0.0 == 4)
    assert(deep.1.1 == 6)
}
