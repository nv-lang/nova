// EXPECT_COMPILE_ERROR arity mismatch
//
// Negative (Ф.7.1): arity mismatch в **for-loop** tuple pattern —
// `for (a, b, c) in iter_of_2_tuple`. Покрывает третий site
// pattern_destructure_tuple (после emit_tuple_destructure для let
// и pattern_bind_typed для match — f24/f23).

module plan59.f26_arity_mismatch_in_for_loop_rejected


type PairCounter {
    end       int
    mut idx   int
}


export fn PairCounter mut @next() -> Option[(int, int)] {
    if @idx >= @end {
        None
    } else {
        let pair = (@idx, @idx * 10)
        @idx = @idx + 1
        Some(pair)
    }
}


export fn PairCounter.new(end int) -> PairCounter =>
    { end, idx: 0 }


test "for (a, b, c) in iter-of-2-tuple — should reject" {
    let mut total = 0
    for (i, v, w) in PairCounter.new(3) {
        total = total + i + v + w
    }
    assert(total == 0)
}
