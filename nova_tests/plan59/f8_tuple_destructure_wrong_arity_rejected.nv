// EXPECT_COMPILE_ERROR arity mismatch
//
// Negative: tuple-pattern arity не совпадает с RHS tuple arity.
// Plan 59 Ф.7.1 — Nova-level clear diagnostic до C-emit. Раньше
// EXPECT_CC_ERROR через C compiler error "no member 'fN'", теперь
// production-grade UX: codegen error message с file:line + hint.

module plan59.f8_tuple_destructure_wrong_arity_rejected


fn make_triple() -> (int, int, int) {
    (1, 2, 3)
}


test "destructure 3-tuple as 2-tuple — should reject" {
    ro (a, b) = make_triple()
    assert(a == 1)
    assert(b == 2)
}
