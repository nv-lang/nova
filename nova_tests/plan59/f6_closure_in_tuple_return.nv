// Positive: fn returning tuple of closures. Closures хранятся как
// `nova_int` slot, но return type — `_NovaTuple____void_p__void_p`.
// Без field-wise copy struct assignment fails C type-check.

module nova_tests.plan59


fn make_pair2() -> (fn() -> int, fn() -> int) {
    mut n = 0
    ro inc = || { n += 1; n }
    ro get = || n
    (inc, get)
}


test "pair of closures — shared mut box via tuple return" {
    ro pair = make_pair2()
    ro inc = pair.0
    ro get = pair.1
    assert(get() == 0)
    inc()
    assert(get() == 1)
    inc()
    inc()
    assert(get() == 3)
}
