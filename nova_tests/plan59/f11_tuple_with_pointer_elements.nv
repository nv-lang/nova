// Positive (Phase 5): tuple с pointer-element types — exercises `_p`
// суффикс sanitize_c_for_ident + length-prefixed encoding.
// User record как pointer-stored → `Nova_Foo_p` в mangled name.
// Тест гарантирует что parser handle'ит `_p` corectly: `Nova_Foo_p`
// (length=10) → desanitize → `Nova_Foo*` round-trip.

module plan59.f11_tuple_with_pointer_elements


type Foo {
    val int
}


type Bar {
    label str
}


test "tuple of two pointer-typed records — _p suffix in mangle" {
    ro f = Foo { val: 100 }
    ro b = Bar { label: "hello" }
    ro pair = (f, b)
    assert(pair.0.val == 100)
    assert(pair.1.label == "hello")
}


test "triple pointer mix: (Foo, Bar, int)" {
    ro f = Foo { val: 7 }
    ro b = Bar { label: "x" }
    ro triple = (f, b, 42)
    assert(triple.0.val == 7)
    assert(triple.1.label == "x")
    assert(triple.2 == 42)
}


test "tuple of pointer with destructure — round-trip parse" {
    ro f = Foo { val: 99 }
    ro b = Bar { label: "world" }
    ro pair = (f, b)
    ro (fp, bp) = pair
    assert(fp.val == 99)
    assert(bp.label == "world")
}
