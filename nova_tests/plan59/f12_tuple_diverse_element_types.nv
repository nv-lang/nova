// Positive (Phase 5): tuple с **разными** sanitized element types
// варьирующейся длины — exercises length-prefix encoding для каждого
// element'а. Mangle: `_NovaTuple_<arity>_<L1>_<T1>_<L2>_<T2>...` где
// `<Ln>` ≠ для каждого element'а. Parser должен брать exactly Ln chars.

module plan59.f12_tuple_diverse_element_types


test "5-element tuple: (int, str, bool, byte, f64)" {
    let mix = (42, "label", true, 255 as byte, 3.14)
    assert(mix.0 == 42)
    assert(mix.1 == "label")
    assert(mix.2)
    assert(mix.3 == (255 as byte))
    assert(mix.4 == 3.14)
}


test "destructure 5-element tuple — каждый field точно typed" {
    let pair = (100, "answer", false, 0 as byte, 2.71)
    let (i, s, b, by, f) = pair
    assert(i == 100)
    assert(s == "answer")
    assert(!b)
    assert(by == (0 as byte))
    assert(f == 2.71)
}


// Varying lengths: `nova_int` (8) ≠ `nova_str` (8) = `nova_f64` (8) ≠
// `nova_bool` (9) ≠ `nova_byte` (9). Length prefix должен точно
// разделять — split-by-`__` старого парсера бы спутал bool/byte.
test "tuple где element name lengths varying — length-prefix critical" {
    let combo = (true, 1 as byte, 2.0, "z", 7)
    assert(combo.0)
    assert(combo.1 == (1 as byte))
    assert(combo.2 == 2.0)
    assert(combo.3 == "z")
    assert(combo.4 == 7)
}
