// Plan 137 (D237) — POS P12:
// `#impl(Compare)` на record → auto-derive @compare; ordering operators.
module nova_tests.strings

#impl(Compare)
type Score3 {
    val int
}

fn Score3 @compare(other Score3) -> int => @val - other.val

test "Compare auto-derive works" {
    ro a = Score3 { val: 10 }
    ro b = Score3 { val: 20 }
    assert(a < b)
    assert(b > a)
}
