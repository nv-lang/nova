// concat_ok.nv — Plan 139.2 Ф.3
// str @concat(other) -> str — Nova-body. Allocates a fresh []u8 of size
// @len() + other.byte_len(), copies both operands' bytes (via @as_bytes()), then
// str.from_bytes_unchecked (owned + NUL-term). Byte-exact with the retired C
// nova_str_concat. Direct method-form call (`s.concat(t)`) routes here; the
// `+` operator lowers separately to C nova_str_concat (option (b)) — both
// must agree on result content.

module nova_tests.strings

test "concat: basic ASCII" {
    ro a = "foo"
    ro b = "bar"
    ro r = a.concat(b)
    assert(r == "foobar")
    assert(r.byte_len() == 6)
}

test "concat: empty left operand" {
    ro r = "".concat("tail")
    assert(r == "tail")
    assert(r.byte_len() == 4)
}

test "concat: empty right operand" {
    ro r = "head".concat("")
    assert(r == "head")
    assert(r.byte_len() == 4)
}

test "concat: both empty" {
    ro r = "".concat("")
    assert(r == "")
    assert(r.byte_len() == 0)
}

test "concat: multi-byte UTF-8 preserved byte-exact" {
    // "café" (é = 0xC3 0xA9) + " ★" (★ = 0xE2 0x98 0x85).
    ro a = "café"
    ro b = " ★"
    ro r = a.concat(b)
    assert(r == "café ★")
    assert(r.byte_len() == a.byte_len() + b.byte_len())
    // NUL-term invariant + byte boundary: last byte of é region intact.
    assert(r.as_bytes()[0] == 0x63 as u8)   // 'c'
    assert(r.as_bytes()[3] == 0xC3 as u8)   // é lead byte
    assert(r.as_bytes()[4] == 0xA9 as u8)   // é continuation
}

test "concat: method result equals `+` operator result" {
    // The migrated Nova-body method and the still-C `+` operator must produce
    // identical content (option (b): two code paths, one semantics).
    ro a = "Nova"
    ro b = "Lang"
    ro via_method = a.concat(b)
    ro via_operator = a + b
    assert(via_method == via_operator)
    assert(via_operator == "NovaLang")
}

test "concat: chained concat (used by @replace internally)" {
    ro r = "a".concat("b").concat("c").concat("d")
    assert(r == "abcd")
    assert(r.byte_len() == 4)
}

test "concat: result is independently owned (source unchanged)" {
    ro a = "src"
    ro r = a.concat("X")
    assert(a == "src")       // source intact
    assert(r == "srcX")
}
