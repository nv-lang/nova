module nova_tests.strings
import std.unicode

test "to_nfc composes combining accent" {
    ro s = "cafe\u{0301}"
    ro nfc = s.to_nfc()
    assert(nfc.byte_len() < s.byte_len())
}

test "to_nfd decomposes precomposed char" {
    ro s = "caf\u{00E9}"
    ro nfd = s.to_nfd()
    assert(nfd.byte_len() > s.byte_len())
}

test "round-trip nfc -> nfd -> nfc" {
    ro s = "Stra\u{00DF}e"
    ro nfc = s.to_nfc()
    ro nfd_of_nfc = nfc.to_nfd()
    ro back = nfd_of_nfc.to_nfc()
    assert(back == nfc)
}

test "to_nfkc decomposes compatibility" {
    ro s = "\u{FB01}"
    ro nfkc = s.to_nfkc()
    assert(nfkc == "fi")
}
