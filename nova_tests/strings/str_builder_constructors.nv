// Plan 85.1 Ф.1 — StringBuilder constructors.
//
// Покрывает: new(), with_capacity(0/1/100), from(str), from(char).

module nova_tests.strings


// ── new() ──────────────────────────────────────────────────────────

test "new() — пустой, capacity >= 16" {
    consume sb = StringBuilder.new()
    assert(sb.len() == 0)
    assert(sb.capacity() >= 16)
    assert(sb.is_empty())
    ro _ = sb.into_str()
}


// ── with_capacity(n) ───────────────────────────────────────────────

test "with_capacity(0) — пустой, валидный" {
    consume sb = StringBuilder.with_capacity(0)
    assert(sb.len() == 0)
    assert(sb.capacity() >= 0)
    assert(sb.is_empty())
    ro _ = sb.into_str()
}

test "with_capacity(1) — capacity >= 1" {
    consume sb = StringBuilder.with_capacity(1)
    assert(sb.len() == 0)
    assert(sb.capacity() >= 1)
    ro _ = sb.into_str()
}

test "with_capacity(100) — capacity >= 100" {
    consume sb = StringBuilder.with_capacity(100)
    assert(sb.len() == 0)
    assert(sb.capacity() >= 100)
    ro _ = sb.into_str()
}

test "with_capacity(0) — append после ноль-капасити растёт" {
    consume sb = StringBuilder.with_capacity(0)
    sb.append("data")
    assert(sb.len() == 4)
    assert(sb.capacity() >= 4)
    ro _ = sb.into_str()
}


// ── from(str) ──────────────────────────────────────────────────────

test "from(str) — ASCII" {
    consume sb = StringBuilder.from("hello")
    assert(sb.len() == 5)
    ro _ = sb.into_str()
}

test "from(str) — пустая строка" {
    consume sb = StringBuilder.from("")
    assert(sb.len() == 0)
    assert(sb.is_empty())
    ro _ = sb.into_str()
}

test "from(str) — Cyrillic codepoints vs bytes" {
    consume sb = StringBuilder.from("Привет")
    assert(sb.char_len() == 6)  // 6 codepoints
    assert(sb.len() == 12)      // 2 байта на codepoint
    ro _ = sb.into_str()
}

test "from(str) — append продолжает с готового контента" {
    consume sb = StringBuilder.from("abc")
    sb.append("def")
    assert(sb.len() == 6)
    assert(sb.into_str() == "abcdef")
}


// ── from(char) ─────────────────────────────────────────────────────

test "from(char) — ASCII single codepoint" {
    consume sb = StringBuilder.from('A')
    assert(sb.len() == 1)
    ro _ = sb.into_str()
}

test "from(char) — Cyrillic codepoint = 2 байта" {
    consume sb = StringBuilder.from('Я')
    assert(sb.char_len() == 1)
    assert(sb.len() == 2)
    ro _ = sb.into_str()
}

test "from(char) — CJK codepoint = 3 байта" {
    consume sb = StringBuilder.from('中')
    assert(sb.char_len() == 1)
    assert(sb.len() == 3)
    ro _ = sb.into_str()
}

test "from(char) — emoji codepoint = 4 байта" {
    consume sb = StringBuilder.from('😀')
    assert(sb.char_len() == 1)
    assert(sb.len() == 4)
    ro _ = sb.into_str()
}

test "from(char) — content проверяется через as_str" {
    consume sb = StringBuilder.from('Z')
    assert(sb.into_str() == "Z")
}
