// Plan 139 Ф.1 — find/rfind migrated to Nova-body.
// Plan 152.1 Ф.2 (D249): find/rfind теперь возвращают BYTE offsets (композируются
// с s[k..]); для ASCII byte-offset == прежний cp-offset (тесты ниже не меняются),
// для не-ASCII — byte-offset (UTF-8 тест мигрирован).
module nova_tests.strings

test "find basic" {
    assert("hello".find("l") == Some(2))
    assert("hello".find("he") == Some(0))
    assert("hello".find("lo") == Some(3))
    assert("hello".find("z") == None)
    assert("hello".find("") == Some(0))   // empty → 0
    assert("he".find("hello") == None)    // needle longer than s
}

test "rfind basic" {
    assert("hello".rfind("l") == Some(3))
    assert("hello".rfind("he") == Some(0))
    assert("hello".rfind("o") == Some(4))
    assert("hello".rfind("z") == None)
    assert("hello".rfind("") == Some(5))  // empty → total codepoint count
}

test "find byte offset (utf8)" {
    ro s = "héllo"            // bytes: h=0 é=1,2 l=3 l=4 o=5 (byte_len 6)
    assert(s.find("l") == Some(3))   // byte offset (was cp offset 2)
    assert(s.find("o") == Some(5))   // byte offset (was 4)
    assert(s.rfind("l") == Some(4))  // last 'l' byte offset (was 3)
}
