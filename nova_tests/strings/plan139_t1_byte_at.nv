// Plan 139 Ф.1 — byte_at REMAINS the irreducible C byte-access primitive (#1).
// Regression guard: O(1) byte read, the foundation other Nova-body str methods
// read through (@as_bytes is the view sibling). Must stay green.
module nova_tests.strings

test "byte_at ascii" {
    ro s = "abc"
    assert(s.as_bytes()[0] == 97)
    assert(s.as_bytes()[1] == 98)
    assert(s.as_bytes()[2] == 99)
}

test "byte_at multibyte raw bytes" {
    ro s = "é"                // 0xC3 0xA9
    assert(s.as_bytes()[0] == 0xC3)
    assert(s.as_bytes()[1] == 0xA9)
    assert(s.byte_len() == 2)
}

test "as_bytes view matches byte_at" {
    ro s = "hello"
    ro bs = s.as_bytes()
    assert(bs.len() == 5)
    mut i = 0
    while i < s.byte_len() {
        assert(bs[i] == s.as_bytes()[i])
        i = i + 1
    }
}
