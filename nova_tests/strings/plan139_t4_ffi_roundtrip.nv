// Plan 139 Ф.4 / A4.1 — full str ↔ C round-trip on the value-record ABI.
//   C → str  : p139_make_str() builds a nova_str via nova_str_from_cstr.
//   str → C  : p139_str_byte_sum reads .ptr/.len of the str passed by value.
//   str → CStr → C : as_cstr() + p139_cstr_strlen (NUL-terminated, D26 §3).
// Closes the loop: a C-origin str behaves identically to a literal through
// every conversion direction.
module nova_tests.strings

import std.ffi.cstr.{CStr}

extern "nova" fn p139_make_str() -> str
extern "nova" fn p139_str_byte_sum(s str) -> int
extern "nova" fn p139_cstr_strlen(c CStr) -> int

test "C->str->C byte-sum round-trip" {
    ro s = p139_make_str()                 // "hello world" from C rodata
    // byte sum of "hello world" = 104+101+108+108+111+32+119+111+114+108+100
    assert(p139_str_byte_sum(s) == 1116)
    assert(s == "hello world")
}

test "C-origin str -> CStr -> C strlen" {
    ro s = p139_make_str()
    ro c = s.as_cstr()
    assert(p139_cstr_strlen(c) == 11)
    assert(p139_cstr_strlen(c) == s.len())
}

test "literal and C-origin str are byte-equal and interchangeable" {
    ro from_c = p139_make_str()
    ro literal = "hello world"
    assert(from_c == literal)
    assert(p139_str_byte_sum(from_c) == p139_str_byte_sum(literal))
    assert(p139_cstr_strlen(from_c.as_cstr()) == p139_cstr_strlen(literal.as_cstr()))
}
