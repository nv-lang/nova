// Plan 139 Ф.2 NEG — as_bytes() returns a readonly view (ro []u8); mutating it
// must be a compile error. Proves the str buffer immutability contract (R8):
// to_bytes (Nova-body) reads through this ro view but never mutates it.
module nova_tests.strings

test "as_bytes view is readonly — push forbidden" {
    ro s = "abc"
    mut v = s.as_bytes()   // ro []u8 — binding cannot grant mutation
    v.push(100)            // E_*: cannot mutate readonly view
}
