// Plan 139 Ф.1 — char_len migrated to Nova-body (count non-continuation bytes
// via @as_bytes). len() = bytes (D26), char_len() = codepoints.
module nova_tests.strings

test "ascii char_len == byte len" {
    assert("abc".as_chars().count() == 3)
    assert("abc".byte_len() == 3)
    assert("".as_chars().count() == 0)
}

test "multibyte char_len < byte len" {
    ro s = "héllo"            // h é l l o : 5 codepoints, 6 bytes
    assert(s.as_chars().count() == 5)
    assert(s.byte_len() == 6)
}

test "mixed multibyte widths" {
    // é = 2 bytes, € = 3 bytes, 😀 = 4 bytes
    ro s = "é€😀"
    assert(s.as_chars().count() == 3)
    assert(s.byte_len() == 2 + 3 + 4)
}
