// Plan 85.1 Ф.2 — StringBuilder @clone() — изоляция копии.
//
// @clone() создаёт независимую копию (deep copy buffer). Мутация
// клона не влияет на оригинал и наоборот.

module nova_tests.strings


test "clone — мутация клона не влияет на оригинал" {
    consume a = StringBuilder.new()
    a.append("hello")
    consume b = a.clone()
    b.append(" world")
    assert(a.len() == 5)         // оригинал не изменён (bytes)
    assert(b.len() == 11)
    ro _ = a.into_str()
    ro _ = b.into_str()
}

test "clone — мутация оригинала не влияет на клон" {
    consume a = StringBuilder.new()
    a.append("base")
    consume b = a.clone()
    a.append("-extra")
    assert(a.len() == 10)
    assert(b.len() == 4)         // клон не изменён
    ro _ = a.into_str()
    ro _ = b.into_str()
}

test "clone — содержимое идентично на момент копирования" {
    consume a = StringBuilder.from("snapshot")
    consume b = a.clone()
    assert(a.into_str() == "snapshot")
    assert(b.into_str() == "snapshot")
}

test "clone пустого — пустой клон" {
    consume a = StringBuilder.new()
    consume b = a.clone()
    assert(b.is_empty())
    assert(b.len() == 0)
    ro _ = a.into_str()
    ro _ = b.into_str()
}

test "clone с Unicode — bytes сохранены" {
    consume a = StringBuilder.new()
    a.append("Привет 😀")
    consume b = a.clone()
    assert(b.len() == a.len())
    assert(b.char_len() == a.char_len())
    b.append("!")
    assert(b.len() == a.len() + 1)
    ro _ = a.into_str()
    ro _ = b.into_str()
}

test "clone клона — двойная копия независима" {
    consume a = StringBuilder.from("a")
    consume b = a.clone()
    b.append("b")
    consume c = b.clone()
    c.append("c")
    assert(a.into_str() == "a")
    assert(b.into_str() == "ab")
    assert(c.into_str() == "abc")
}

test "clone — оба независимо до consume" {
    consume a = StringBuilder.from("x")
    consume b = a.clone()
    a.append("1")
    b.append("2")
    assert(a.into_str() == "x1")
    assert(b.into_str() == "x2")
}
