// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 91.13 — positive: str @as_ptr() -> *u8 bytes-FFI bridge.
//
// Acceptance A13-ptr:
//   (1) as_ptr() returns a non-null pointer for non-empty strings.
//   (2) as_ptr() on empty string returns some pointer (may point to a sentinel byte).
//   (3) byte_len() + as_ptr() pair can be passed to extern "C" fn expecting
//       (const uint8_t*, int64_t) — confirmed via round-trip: build a str from
//       the same bytes and check equality.
//   (4) as_ptr() is *u8 (coerces to int via cast); no UB pointer arithmetic in Nova.
//
// D294: str @as_ptr() specification.

module plan91_12.net_v2_str_as_ptr_ok

test "as_ptr: non-empty string returns non-null (int cast > 0)" {
    ro s = "hello"
    ro p = s.as_ptr()
    // Cast *u8 → int to test non-null without dereferencing in Nova.
    ro p_int = p as int
    assert(p_int != 0)
}

test "as_ptr: empty string has pointer (may be sentinel, not null)" {
    ro s = ""
    ro p = s.as_ptr()
    // Empty str may have a valid pointer (e.g. to a static empty buffer).
    // We only verify the call compiles and returns *u8; value is implementation-defined.
    ro _ = p
}

test "as_ptr: byte_len and as_ptr are consistent (round-trip via from_bytes_unchecked)" {
    ro s = "nova"
    ro bytes = s.as_bytes()   // []u8 copy
    ro s2 = str.from_bytes_unchecked(bytes)
    // Round-trip: from_bytes_unchecked preserves content.
    assert(s == s2)
    // as_ptr on both points into their respective buffers; byte_len is the same.
    assert(s.byte_len() == s2.byte_len())
}

test "as_ptr: works on string with multi-byte UTF-8 codepoints" {
    ro s = "ёж"  // 2 Cyrillic chars = 4 bytes (2 bytes each in UTF-8)
    assert(s.byte_len() == 4)
    ro p_int = s.as_ptr() as int
    assert(p_int != 0)
}

test "as_ptr: single ASCII char" {
    ro s = "X"
    assert(s.byte_len() == 1)
    ro p_int = s.as_ptr() as int
    assert(p_int != 0)
}
