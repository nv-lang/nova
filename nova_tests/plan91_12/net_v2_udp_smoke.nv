// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 91.12 Ф.7: std/net V2 UDP bind smoke.
//
// V2 bind() returns Result[UdpSocket, NetError].
// Use `match r { Ok(v) => v, Err(_) => panic(...) }` to extract values.

module plan91_12.net_v2_udp_smoke

import std.net.{SocketAddr, UdpSocket, real_udp_net}

test "V2 UdpSocket bind returns ok" {
    supervised {
        with UdpNet = real_udp_net() {
            ro r = UdpSocket.bind(SocketAddr.loopback(0))
            assert(r.is_ok())
            mut sock = match r { Ok(s) => s, Err(_) => panic("bind failed") }
            assert(sock.local_port() > 0)
            sock.close()
        }
    }
}

test "V2 UdpSocket local_addr is_v4" {
    supervised {
        with UdpNet = real_udp_net() {
            ro r = UdpSocket.bind(SocketAddr.loopback(0))
            mut sock = match r { Ok(s) => s, Err(_) => panic("bind failed") }
            ro addr = sock.local_addr()
            assert(addr.is_v4())
            sock.close()
        }
    }
}

test "V2 UdpSocket send_to and recv_from loopback" {
    // with UdpNet outside supervised so the handler is live when fibers run.
    // spawn required: send_to/recv_from park the fiber; inline body
    // (main thread, slot=-1) cannot call nova_sched_park.
    with UdpNet = real_udp_net() {
        supervised {
            spawn {
                // Bind two sockets; send from a to b; recv on b.
                mut a = match UdpSocket.bind(SocketAddr.loopback(0)) { Ok(s) => s, Err(_) => panic("bind a") }
                mut b = match UdpSocket.bind(SocketAddr.loopback(0)) { Ok(s) => s, Err(_) => panic("bind b") }
                ro b_port = b.local_port()
                ro sent_r = a.send_to("hello", SocketAddr.loopback(b_port))
                assert(sent_r.is_ok())
                ro recv_r = b.recv_from(512)
                assert(recv_r.is_ok())
                ro (data, _sender) = match recv_r { Ok(t) => t, Err(_) => panic("recv_from failed") }
                assert(data.len() == 5)
                a.close()
                b.close()
            }
        }
    }
}
