// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 91.12 Ф.7: std/net V2 smoke -- SocketAddr construction (no I/O).
//
// Tests pure SocketAddr methods via AddrNet effect.
// Validates that the V2 module compiles and the Ф.0 C entry-points work.

module plan91_12.net_v2_addr_smoke

import std.net.{SocketAddr, real_addr_net}

test "V2 SocketAddr.loopback preserves port" {
    with AddrNet = real_addr_net() {
        ro addr = SocketAddr.loopback(9090)
        assert(addr.port() == 9090)
    }
}

test "V2 SocketAddr.loopback is_v4" {
    with AddrNet = real_addr_net() {
        ro addr = SocketAddr.loopback(0)
        assert(addr.is_v4())
        assert(!addr.is_v6())
    }
}

test "V2 SocketAddr.loopback_v6 is_v6" {
    with AddrNet = real_addr_net() {
        ro addr = SocketAddr.loopback_v6(8888)
        assert(addr.is_v6())
        assert(addr.port() == 8888)
    }
}

test "V2 SocketAddr.v4 all fields preserved" {
    with AddrNet = real_addr_net() {
        ro addr = SocketAddr.v4(127, 0, 0, 1, 4321)
        assert(addr.is_v4())
        assert(addr.port() == 4321)
    }
}

test "V2 SocketAddr.to_str non-empty" {
    with AddrNet = real_addr_net() {
        ro addr = SocketAddr.loopback(1234)
        ro s = addr.to_str()
        assert(s.len() > 0)
    }
}
