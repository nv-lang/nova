// EXPECT_COMPILE_ERROR E_PRIV_FIELD_INIT
//
// Plan 91.12 Ф.7 — negative: direct struct-literal init of priv field → E_PRIV_FIELD_INIT.
//
// Full path: D:\Sources\nv-lang\nova-p91-12\nova_tests\plan91_12\net_v2_double_close_neg.nv
//
// Acceptance A-priv: SocketAddr { priv handle CSocketAddr } — the handle
// field is type-private (Plan 124 / D220). Initialising it from outside
// the type's methods (i.e. a different module) → E_PRIV_FIELD_INIT.

module plan91_12.net_v2_double_close_neg

import std.net.{SocketAddr, CSocketAddr}

test "SocketAddr struct-literal init of priv handle → E_PRIV_FIELD_INIT" {
    ro addr = SocketAddr { handle: CSocketAddr(0 as *()) }  // E_PRIV_FIELD_INIT
}
