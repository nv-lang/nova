// Plan 128 Ф.4 T15 — composition of D228 value-record and D215
// named-tuple: a regular heap record containing both kinds of
// fields exercises mut-method ABI on each independently.
//
// Coverage point: ensures that no ABI conflict exists between the
// `NovaValue_X*` (D226) and `NovaTuple_X*` (Ф.2 mirror) paths when
// both kinds of receiver types live in the same module и share
// codegen helpers (receiver_c_type / prepare_method_recv).

module plan128.t15_value_record_in_named_tuple_ok

// Value-record (D228) — gets NovaValue_VVec* receiver on mut method.
type VVec value {
    x f64
    y f64
}

fn VVec.new(a f64, b f64) -> VVec => { x: a, y: b }

fn VVec mut @set_x(v f64) -> () {
    @x = v
}

fn VVec @sum() -> f64 => @x + @y

// Named tuple (D215) — gets NovaTuple_NTPair* receiver on mut method.
type NTPair(a f64, b f64)

fn NTPair mut @set_a(v f64) -> () {
    @a = v
}

fn NTPair @prod() -> f64 => @a * @b

// Heap record containing one of each + a primitive.
type Holder {
    mut name str
    mut nt NTPair
    mut vv VVec
}

fn Holder.new() -> Self => {
    name: "init",
    nt: NTPair(a: 2.0, b: 3.0),
    vv: VVec.new(4.0, 5.0),
}

test "holder reads both kinds of field via ro method" {
    ro h = Holder.new()
    assert(h.name == "init")
    assert(h.nt.prod() == 6.0)
    assert(h.vv.sum() == 9.0)
}

test "value-record mut binding mut method works standalone" {
    mut v = VVec.new(1.0, 2.0)
    v.set_x(10.0)
    assert(v.x == 10.0)
    assert(v.y == 2.0)
}

test "named tuple mut binding mut method works standalone" {
    mut t = NTPair(a: 1.0, b: 2.0)
    t.set_a(99.0)
    assert(t.a == 99.0)
    assert(t.b == 2.0)
}

test "extract-mutate-writeback пакеты для обоих типов из holder" {
    mut h = Holder.new()
    h.name = "updated"

    mut t = h.nt
    t.set_a(7.0)
    h.nt = t

    mut v = h.vv
    v.set_x(8.0)
    h.vv = v

    assert(h.name == "updated")
    assert(h.nt.a == 7.0)
    assert(h.nt.b == 3.0)
    assert(h.vv.x == 8.0)
    assert(h.vv.y == 5.0)
}
