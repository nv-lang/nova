// Plan 128 Ф.4 T12 — named tuple direct field-write + mut-method
// composition through local rebind.
//
// Coverage: interleaved direct-field writes and mut-method calls on
// the same named-tuple binding all land in the original slot.
// The chained `obj.field.mut_method()` form lifted in Plan 128.1 Ф.1
// is covered separately by T12b (this fixture keeps the local-binding
// pattern as regression guard for the simple case).

module plan128.t12_named_tuple_field_mut_ok

type Vec3(x f64, y f64, z f64)

fn Vec3 mut @set_x(v f64) -> () {
    @x = v
}

fn Vec3 mut @scale_inplace(k f64) -> () {
    @x = @x * k
    @y = @y * k
    @z = @z * k
}

test "direct field write + subsequent mut method on binding" {
    mut v = Vec3(x: 1.0, y: 2.0, z: 3.0)
    v.x = 10.0
    v.scale_inplace(2.0)
    assert(v.x == 20.0)
    assert(v.y == 4.0)
    assert(v.z == 6.0)
}

test "mut method + subsequent direct field write" {
    mut v = Vec3(x: 1.0, y: 2.0, z: 3.0)
    v.set_x(100.0)
    v.y = 200.0
    assert(v.x == 100.0)
    assert(v.y == 200.0)
    assert(v.z == 3.0)
}

test "interleaved direct + method writes" {
    mut v = Vec3(x: 1.0, y: 1.0, z: 1.0)
    v.x = 2.0
    v.set_x(3.0)
    v.x = 4.0
    v.set_x(5.0)
    assert(v.x == 5.0)
    assert(v.y == 1.0)
    assert(v.z == 1.0)
}
