// Plan 128 Ф.4 T9 — primitive `f64` cannot have mut-methods.
//
// EXPECT_COMPILE_ERROR E_PRIMITIVE_MUT_METHOD

module plan128.t9_primitive_f64_mut_method_neg

fn f64 mut @scale(k f64) -> () {
    @ = @ * k
}

test "should not compile: fn f64 mut @scale" {
    mut x = 2.0
    x.scale(3.0)
    assert(x == 6.0)
}
