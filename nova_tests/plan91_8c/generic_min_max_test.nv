module plan91_8c.generic_min_max_test

import std.sort

// Plan 91.8c (D185): generic min_of/max_of для [T Comparable].

test "min_of/max_of для []int" {
    ro xs []int = [3, 1, 4, 1, 5, 9, 2, 6]
    match xs.min_of() {
        Some(m) => assert(m == 1)
        None    => assert(false)
    }
    match xs.max_of() {
        Some(m) => assert(m == 9)
        None    => assert(false)
    }
}

test "min_of/max_of для []str" {
    ro xs []str = ["zebra", "apple", "mango"]
    match xs.min_of() {
        Some(m) => assert(m == "apple")
        None    => assert(false)
    }
    match xs.max_of() {
        Some(m) => assert(m == "zebra")
        None    => assert(false)
    }
}

test "min_of/max_of empty array → None" {
    ro empty []int = []
    match empty.min_of() {
        Some(_) => assert(false)
        None    => assert(true)
    }
}
