module nova_tests.plan91_8c.generic_sort_test

import std.sort

// Plan 91.8c (D185): generic sort_of/binary_search_of для [T Comparable].

test "sort_of []int" {
    mut xs []int = [3, 1, 4, 1, 5, 9, 2, 6]
    xs.sort_of()
    assert(xs == [1, 1, 2, 3, 4, 5, 6, 9])
}

test "sort_of []str" {
    mut xs []str = ["zebra", "apple", "mango"]
    xs.sort_of()
    assert(xs[0] == "apple")
    assert(xs[1] == "mango")
    assert(xs[2] == "zebra")
}

test "sort_of empty array — no-op" {
    mut xs []int = []
    xs.sort_of()
    assert(xs.len() == 0)
}

test "sort_of single element" {
    mut xs []int = [42]
    xs.sort_of()
    assert(xs[0] == 42)
}

test "binary_search_of []int found / not found" {
    mut xs []int = [1, 3, 5, 7, 9]
    match xs.binary_search_of(5) {
        Some(idx) => assert(idx == 2)
        None      => assert(false)
    }
    match xs.binary_search_of(4) {
        Some(_) => assert(false)
        None    => assert(true)
    }
}

test "binary_search_of []str" {
    mut xs []str = ["apple", "mango", "zebra"]
    match xs.binary_search_of("mango") {
        Some(idx) => assert(idx == 1)
        None      => assert(false)
    }
}

test "sort_of + binary_search_of pipeline" {
    mut xs []int = [5, 2, 8, 1, 9, 3]
    xs.sort_of()
    // after sort: [1, 2, 3, 5, 8, 9]
    match xs.binary_search_of(8) {
        Some(idx) => assert(idx == 4)
        None      => assert(false)
    }
}
