// Plan 114.4.4 Ф.2 NEG: const fn passed as arg to runtime fn → friendly
// E_CONST_FN_FIRST_CLASS_RUNTIME_HOF error.

// EXPECT_COMPILE_ERROR E_CONST_FN_FIRST_CLASS_RUNTIME_HOF

module plan114_4_4.runtime_hof_const_fn_neg

fn double(const x int) -> const int => x * 2

fn apply(f fn(int) -> int, x int) -> int => f(x)

test "const fn passed to runtime HOF" {
    ro r = apply(double, 5)
    assert(r == 10)
}
