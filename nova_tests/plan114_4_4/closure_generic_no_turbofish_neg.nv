// Plan 114.4.4 V4.5 Ф.4 NEGATIVE: generic closure-returning const fn
// без explicit TurboFish → cannot infer T → friendly error.

// EXPECT_COMPILE_ERROR E_CONST_FN_CLOSURE_GENERIC_NO_TURBOFISH

module plan114_4_4.closure_generic_no_turbofish_neg

fn make_id[T]() -> const fn(T) -> T => fn(x T) -> T => x

test "generic closure-returning без TurboFish rejected" {
    // No [T] — compiler не может infer.
    ro id_x = make_id()
    assert(id_x(42) == 42)
}
