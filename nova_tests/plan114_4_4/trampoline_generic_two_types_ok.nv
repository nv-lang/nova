// Plan 114.4.4 V4.5 Ф.3 POSITIVE: generic const fn instantiated с разными
// concrete types — две distinct trampoline specializations.

module nova_tests.plan114_4_4

fn id3[T](const x T) -> const T => x

fn apply_i3(f fn(int) -> int, x int) -> int => f(x)
fn apply_b2(f fn(bool) -> bool, x bool) -> bool => f(x)

test "generic const fn — multiple instantiations" {
    ro r1 = apply_i3(id3, 99)       // id__trampoline_int
    assert(r1 == 99)

    ro r2 = apply_b2(id3, true)     // id__trampoline_bool — distinct spec
    assert(r2 == true)
}
