// Plan 114.4.4 Ф.5 positive: sizeof[T]() intrinsic для primitive types.

module plan114_4_4.sizeof_primitives_ok

const SIZE_INT = sizeof[int]()
const SIZE_BOOL = sizeof[bool]()
const SIZE_CHAR = sizeof[char]()
const SIZE_F64 = sizeof[f64]()
const ALIGN_INT = align_of[int]()

test "sizeof primitives" {
    assert(SIZE_INT == 8)
    assert(SIZE_BOOL == 1)
    assert(SIZE_CHAR == 4)
    assert(SIZE_F64 == 8)
    assert(ALIGN_INT == 8)
}
