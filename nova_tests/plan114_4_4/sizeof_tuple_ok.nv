// Plan 114.4.4 Ф.5 V4.4 Ф.1 POSITIVE: sizeof для tuple types.
// Closes part of [M-114.4.4-trampoline-record-reflection].

module plan114_4_4.sizeof_tuple_ok

// (int, int) — 2 × 8 = 16, align 8
const SIZE_2INT = sizeof[(int, int)]()
const ALIGN_2INT = align_of[(int, int)]()

// (i8, i32) — pad i8 to align 4, then i32 → 8 bytes (4+4), align 4
const SIZE_MIXED = sizeof[(i8, i32)]()
const ALIGN_MIXED = align_of[(i8, i32)]()

// (bool, int) — pad bool to align 8, then int → 16 bytes, align 8
const SIZE_BI = sizeof[(bool, int)]()
const ALIGN_BI = align_of[(bool, int)]()

// (i8, i8, i8) — 3 bytes, align 1
const SIZE_3I8 = sizeof[(i8, i8, i8)]()
const ALIGN_3I8 = align_of[(i8, i8, i8)]()

test "sizeof for tuple types" {
    assert(SIZE_2INT == 16)
    assert(ALIGN_2INT == 8)

    assert(SIZE_MIXED == 8)
    assert(ALIGN_MIXED == 4)

    assert(SIZE_BI == 16)
    assert(ALIGN_BI == 8)

    assert(SIZE_3I8 == 3)
    assert(ALIGN_3I8 == 1)
}
