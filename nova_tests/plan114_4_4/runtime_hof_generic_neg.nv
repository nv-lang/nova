// Plan 114.4.4.3 V4.2 NEGATIVE: generic const fn cannot be used as
// first-class value в V1 — trampoline gen requires concrete types
// (transitive sizeof[T]/align_of[T] dispatch from generic body).

// EXPECT_COMPILE_ERROR E_CONST_FN_TRAMPOLINE_GENERIC

module plan114_4_4.runtime_hof_generic_neg

fn id[T](const x T) -> const T => x

fn apply_i(f fn(int) -> int, x int) -> int => f(x)

test "generic const fn as HOF arg rejected" {
    ro r = apply_i(id, 7)
    assert(r == 7)
}
