// Plan 114.4.4.3 V4.2 POSITIVE: transitive trampoline — const fn body
// calls другой const fn; обе fn становятся trampoline targets.
//
// `compose` (HOF used) calls `inner` (nested), оба → trampoline.
// Trampoline `compose__trampoline` body внутри переписан на
// `inner__trampoline(x)`.

module nova_tests.plan114_4_4

fn inner(const x int) -> const int => x + 1

fn compose(const x int) -> const int => inner(x) * 2

fn apply5(f fn(int) -> int, x int) -> int => f(x)

test "transitive trampoline" {
    ro r = apply5(compose, 3)
    // inner(3) = 4, compose(3) = 4 * 2 = 8
    assert(r == 8)
}
