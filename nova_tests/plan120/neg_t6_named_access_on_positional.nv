// Plan 120 Ф.2 negative — named `.x` access on positional tuple type.
//
// EXPECT_COMPILE_ERROR E_TUPLE_NAMED_ACCESS_ON_POSITIONAL

module plan120.neg_t6_named_access_on_positional

type Pos2(f64, f64)

test "should not compile: .x on positional tuple" {
    ro p Pos2 = Pos2(3.0, 4.0)
    assert(p.x == 3.0)
}
