// Plan 70.5 Ф.4 — negative: uint value assigned to str variable.
//
// uint (uint64_t) несовместим со str (nova_str struct).
// Clang обязан отвергнуть инициализацию без явного привода типов.
//
// Параллель Rust: `let x: &str = u64::MAX` — compile error.

module neg.plan70_5_f6_uint_str_assign_neg

// EXPECT_CC_ERROR incompatible type
fn bad1() -> str {
    ro x str = uint.MAX
    x
}
