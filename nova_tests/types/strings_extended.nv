// 34_strings_extended.nv — расширенные тесты строковых операций.
// 11_strings.nv покрыл базовые. Здесь — escape sequences, Unicode,
// case-sensitivity.

module types.strings_extended

fn classify(cmd str) -> int => match cmd {
    "start"  => 1
    "stop"   => 2
    "pause"  => 3
    _        => 0
}

test "escape \\n newline" {
    let nl = "line1\nline2"
    assert(nl.contains("\n"))
    assert(nl.len > 10)
}

test "escape \\t tab" {
    let tab = "col1\tcol2"
    assert(tab.contains("\t"))
}

test "escape quote" {
    let q = "he said \"hi\""
    assert(q.contains("\""))
}

test "escape backslash" {
    let bsl = "path\\to\\file"
    assert(bsl.contains("\\"))
}

test "пустая строка" {
    let s = ""
    assert(s.len == 0)
    assert(s == "")
    assert(s + "x" == "x")
}

test "Unicode chars (Cyrillic)" {
    let cyr = "привет"
    // bootstrap: len = chars().count() — число code points, не байтов
    assert(cyr.len == 6)
}

test "Unicode mixed ASCII + Cyrillic" {
    let mixed = "hello мир"
    assert(mixed.contains("мир"))
    assert(mixed.contains("hello"))
    assert(mixed.starts_with("hello"))
}

test "case-sensitivity" {
    assert("abc" == "abc")
    assert("abc" != "ABC")
    assert("abc".to_upper() == "ABC")
    assert("ABC".to_lower() == "abc")
}

test "trim only edges" {
    assert("   hello   ".trim() == "hello")
    assert("hello".trim() == "hello")
    assert("  ".trim() == "")
}

test "concat последовательно" {
    let a = "1"
    let b = a + "2" + "3" + "4" + "5"
    assert(b == "12345")
    assert(b.len == 5)
}

test "длинная строка" {
    let big = "the quick brown fox jumps over the lazy dog"
    assert(big.len > 30)
    assert(big.starts_with("the"))
    assert(big.ends_with("dog"))
    assert(big.contains("brown"))
}

test "строка-литерал в match" {
    assert(classify("start") == 1)
    assert(classify("stop") == 2)
    assert(classify("pause") == 3)
    assert(classify("unknown") == 0)
}
