// generic_record_mono.nv — Plan 48 Ф.3: мономорфизация generic record/sum-type.
//
// Ф.3: для каждого `GenericType[Concrete1, Concrete2]` в коде
// codegen эмитит отдельный C-struct `Nova_GenericType____Nova_Concrete1__Nova_Concrete2`.
// Поля получают конкретные типы (не void*).

module types.generic_record_mono

// === 1. Wrapper[T] — одно поле ===

type Wrapper[T] {
    value T
}

fn Wrapper[T].of(v T) -> Wrapper[T] =>
    { value: v }

fn Wrapper[T] @get() -> T => @value

fn Wrapper[T] @map_int() -> int => 0    // smoke: компилируется для любого T

test "Wrapper[int] конструктор и get" {
    let w = Wrapper[int].of(42)
    assert(w.get() == 42)
}

test "Wrapper[str] конструктор и get" {
    let w = Wrapper[str].of("hello")
    assert(w.get() == "hello")
}

test "Wrapper[bool] конструктор и get" {
    let w = Wrapper[bool].of(true)
    assert(w.get() == true)
}

test "два Wrapper разных типов независимы" {
    let a = Wrapper[int].of(1)
    let b = Wrapper[str].of("x")
    assert(a.get() == 1)
    assert(b.get() == "x")
}


// === 2. Pair[A, B] — два разных поля ===

type Pair[A, B] {
    fst A
    snd B
}

fn Pair[A, B].make(a A, b B) -> Pair[A, B] =>
    { fst: a, snd: b }

test "Pair[int, str] — fst и snd независимы" {
    let p = Pair[int, str].make(7, "hi")
    assert(p.fst == 7)
    assert(p.snd == "hi")
}

test "Pair[str, bool].make" {
    let p = Pair[str, bool].make("ok", true)
    assert(p.fst == "ok")
    assert(p.snd == true)
}


// === 3. Generic sum type Result2[T] ===

type Result2[T]
    | Ok2(T)
    | Err2

fn Result2[T] @is_ok() -> bool => match @ {
    Ok2(_) => true
    Err2   => false
}

fn Result2[T] @unwrap_or(fallback T) -> T => match @ {
    Ok2(v) => v
    Err2   => fallback
}

test "Result2[int] Ok2 — is_ok и unwrap_or" {
    let r = Ok2(42)
    assert(r.is_ok())
    assert(r.unwrap_or(0) == 42)
}

test "Result2[int] Err2 — is_ok false" {
    let r = Err2
    assert(!r.is_ok())
    assert(r.unwrap_or(99) == 99)
}

test "Result2[str] Ok2" {
    let r = Ok2("value")
    assert(r.is_ok())
    assert(r.unwrap_or("") == "value")
}
