// generic_record_mono.nv — Plan 48 Ф.3: мономорфизация generic record/sum-type.
//
// Ф.3: для каждого `GenericType[Concrete1, Concrete2]` в коде
// codegen эмитит отдельный C-struct `Nova_GenericType____Nova_Concrete1__Nova_Concrete2`.
// Поля получают конкретные типы (не void*).

module nova_tests.types

// === 1. Wrapper4[T] — одно поле ===

type Wrapper4[T] {
    value T
}

fn Wrapper4[T].of(v T) -> Wrapper4[T] =>
    { value: v }

fn Wrapper4[T] @get() -> T => @value

fn Wrapper4[T] @map_int() -> int => 0    // smoke: компилируется для любого T

test "Wrapper4[int] конструктор и get" {
    ro w = Wrapper4[int].of(42)
    assert(w.get() == 42)
}

test "Wrapper4[str] конструктор и get" {
    ro w = Wrapper4[str].of("hello")
    assert(w.get() == "hello")
}

test "Wrapper4[bool] конструктор и get" {
    ro w = Wrapper4[bool].of(true)
    assert(w.get() == true)
}

test "два Wrapper4 разных типов независимы" {
    ro a = Wrapper4[int].of(1)
    ro b = Wrapper4[str].of("x")
    assert(a.get() == 1)
    assert(b.get() == "x")
}


// === 2. Pair3[A, B] — два разных поля ===

type Pair3[A, B] {
    fst A
    snd B
}

fn Pair3[A, B].make(a A, b B) -> Pair3[A, B] =>
    { fst: a, snd: b }

test "Pair3[int, str] — fst и snd независимы" {
    ro p = Pair3[int, str].make(7, "hi")
    assert(p.fst == 7)
    assert(p.snd == "hi")
}

test "Pair3[str, bool].make" {
    ro p = Pair3[str, bool].make("ok", true)
    assert(p.fst == "ok")
    assert(p.snd == true)
}


// === 3. Generic sum type Result23[T] ===

type Result23[T]
    | Ok2(T)
    | Err2

fn Result23[T] @is_ok() -> bool => match @ {
    Ok2(_) => true
    Err2   => false
}

fn Result23[T] @unwrap_or(fallback T) -> T => match @ {
    Ok2(v) => v
    Err2   => fallback
}

test "Result23[int] Ok2 — is_ok и unwrap_or" {
    ro r = Ok2(42)
    assert(r.is_ok())
    assert(r.unwrap_or(0) == 42)
}

test "Result23[int] Err2 — is_ok false" {
    ro r = Err2
    assert(!r.is_ok())
    assert(r.unwrap_or(99) == 99)
}

test "Result23[str] Ok2" {
    ro r = Ok2("value")
    assert(r.is_ok())
    assert(r.unwrap_or("") == "value")
}


// === 4. Protocol-bounded dispatch в generic body ===
// Plan 48 Ф.7.7: когда `k: K` и K имеет bound, method call k.method(...)
// в мономорфном теле должен диспетчиться на конкретный тип.

type GrmEq protocol {
    @equal(other Self) -> bool
}

type GrmPoint {
    x int
    y int
}

export fn GrmPoint @equal(other GrmPoint) -> bool => @x == other.x && @y == other.y

fn contains_point[K GrmEq](items []K, target K) -> bool {
    for it in items {
        if it.equal(target) { return true }
    }
    false
}

test "protocol-bounded dispatch: GrmPoint.eq через generic fn" {
    ro pts = [GrmPoint { x: 1, y: 2 }, GrmPoint { x: 3, y: 4 }]
    assert(contains_point(pts, GrmPoint { x: 1, y: 2 }) == true)
    assert(contains_point(pts, GrmPoint { x: 5, y: 6 }) == false)
}
