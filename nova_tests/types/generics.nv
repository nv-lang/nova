// 19_generics.nv — generic-параметры функций и типов.
//
// Bootstrap'е generics — runtime erasure: тип-параметр игнорируется
// в проверке, значение проходит как есть. Этого достаточно чтобы
// убедиться что синтаксис парсится и интерпретатор не путает контексты.

module types.generics

fn identity[T](x T) -> T {
    x
}

fn pair[A, B](a A, b B) -> (A, B) {
    (a, b)
}

fn first_of_three[T](a T, b T, c T) -> T {
    a
}

type Box[T] {
    value T
}

fn box_get[T](b Box[T]) -> T {
    b.value
}

type Pair[A, B] {
    fst A
    snd B
}

test "generic identity на int" {
    assert(identity(42) == 42)
}

test "generic identity на str" {
    assert(identity("hi") == "hi")
}

test "generic identity на bool" {
    assert(identity(true) == true)
}

test "generic с двумя параметрами" {
    ro p = pair(1, "x")
    assert(p.0 == 1)
    assert(p.1 == "x")
}

test "generic с одинаковыми T для всех аргументов" {
    assert(first_of_three(10, 20, 30) == 10)
    assert(first_of_three("a", "b", "c") == "a")
}

test "generic record type" {
    ro b = Box { value: 42 }
    assert(box_get(b) == 42)
}

test "generic record на разных типах" {
    ro b1 = Box { value: 100 }
    ro b2 = Box { value: "world" }
    assert(b1.value == 100)
    assert(b2.value == "world")
}

test "generic record с двумя параметрами" {
    ro p = Pair { fst: 1, snd: "k" }
    assert(p.fst == 1)
    assert(p.snd == "k")
}

test "generic функция возвращает generic record" {
    ro b = Box { value: identity(7) }
    assert(b.value == 7)
}

// ─── D72 generic-bounds: парсятся и игнорируются (smoke) ───
// Spec D72 разрешает `type X[T Bound, U Other]` — bound это identifier
// (имя protocol'а) после имени параметра. Bootstrap парсит и игнорирует
// (нет typecheck'а на satisfaction). Production type-checker (D72)
// проверит что T реально удовлетворяет Bound.

type WithBound[T Hashable] {
    value T
}

type TwoBounds[K Hashable, V Eq] {
    key   K
    value V
}

test "D72 bound: type-decl с одним bound parsed" {
    ro w = WithBound { value: 42 }
    assert(w.value == 42)
}

test "D72 bound: type-decl с двумя bound'ами parsed" {
    ro t = TwoBounds { key: "k", value: 7 }
    assert(t.key == "k")
    assert(t.value == 7)
}

// ─── D38 turbofish: `func[T](args)`, `Type[T].method(...)` ───
// Bootstrap monomorphization идёт по call-site/receiver, поэтому type-args
// в turbofish — explicit hint, который codegen прозрачно делегирует в base.
// Грамматика: `Имя[T1, T2, ...]` активируется как turbofish только когда
// за `]` идёт `(` (call), `.IDENT(` (method-call) или `?` (Try).
//
// Static-method-call с turbofish (`Type[T].method(...)`) проверяется в
// std/* через HashMap[K, V].new() — там же где этот синтаксис реально
// используется.

fn parse_one[T](x T) -> T {
    x
}

test "D38 turbofish: function call with one type-arg" {
    ro n = parse_one[int](42)
    assert(n == 42)
}

test "D38 turbofish: function call with two type-args" {
    ro p = pair[int, str](7, "hi")
    assert(p.0 == 7)
    assert(p.1 == "hi")
}

test "D38 turbofish не ломает обычный Index" {
    // arr[i] остаётся Index'ом — за `]` идёт `;` / EOL / op, не `(`/`.IDENT(`/`?`.
    ro xs = [10, 20, 30]
    assert(xs[0] == 10)
    assert(xs[1] == 20)
    ro mid = xs[1] + xs[2]
    assert(mid == 50)
}

test "D38 turbofish: arr[i].field остаётся Index→Member (не turbofish)" {
    // post-`]` token — `.field` без `(` после; это НЕ turbofish.
    ro bs = [Box { value: 1 }, Box { value: 2 }]
    assert(bs[0].value == 1)
    assert(bs[1].value == 2)
}
