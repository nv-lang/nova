// 30_alias_tagged.nv — type aliases (`type X alias T`) и
// tagged template literals.

module types.alias_tagged

// --- Alias types ---

type Name alias str
type UserId alias int
type Score alias int

fn greet(n Name) -> str {
    "hello, " + n
}

fn double_score(s Score) -> Score {
    s * 2
}

test "alias на str — функция-парам" {
    ro n Name = "alice"
    assert(greet(n) == "hello, alice")
}

test "alias на int — арифметика" {
    ro id UserId = 42
    assert(id + 8 == 50)
}

test "alias возвращается из функции" {
    ro s Score = 50
    ro doubled = double_score(s)
    assert(doubled == 100)
}

test "alias использует методы базового типа" {
    ro n Name = "world"
    assert(n.len() == 5)
    assert(n.starts_with("wor"))
}

// --- Tagged template ---
//
// В bootstrap'е tag-функция игнорируется, parts конкатенируются.
// Это достаточно для написания компилятора.

test "tagged template простая строка" {
    ro q = sql`SELECT * FROM users`
    assert(q.contains("SELECT"))
}

test "tagged template с json" {
    ro payload = json`{"id": 1, "name": "alice"}`
    assert(payload.contains("alice"))
}

test "tagged template multiline" {
    ro big = html`
        <html>
            <body>hello</body>
        </html>
    `
    assert(big.contains("hello"))
}
