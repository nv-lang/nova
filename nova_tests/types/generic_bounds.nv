// generic_bounds.nv вЂ” Plan 15 (D72): generic bounds enforcement.
//
// `[T Hash]` вЂ” bound РЅР° generic-РїР°СЂР°РјРµС‚СЂРµ. Type-checker РІР°Р»РёРґРёСЂСѓРµС‚
// С‡С‚Рѕ concrete-T СѓРґРѕРІР»РµС‚РІРѕСЂСЏРµС‚ protocol-bound'Сѓ РЅР° use-site.
//
// РўРµСЃС‚С‹ РІ СЌС‚РѕРј С„Р°Р№Р»Рµ РїСЂРѕРІРµСЂСЏСЋС‚ С‡С‚Рѕ **type-check РїСЂРѕС…РѕРґРёС‚** РїСЂРё satisfied
// bound'Р°С… вЂ” runtime-СЂРѕР»СЊ generic-erased С„СѓРЅРєС†РёР№ Р·РґРµСЃСЊ РІС‚РѕСЂРѕСЃС‚РµРїРµРЅРЅР°.
// (Codegen monomorphization РґР»СЏ generic-fn СЃ body вЂ” РѕС‚РґРµР»СЊРЅР°СЏ Р·Р°РґР°С‡Р°;
// РІСЃРµ С‚РµСЃС‚С‹ Р·РґРµСЃСЊ РєРѕРЅСЃС‚СЂСѓРёСЂСѓСЋС‚ value Рё РїРµСЂРµРґР°СЋС‚ РІ generic fn, РЅРѕ
// СЂРµР·СѓР»СЊС‚Р°С‚ ignore'РёС‚СЃСЏ.)
//
// Negative tests (compile-error РїСЂРё non-satisfied bound) вЂ” РѕС‚РґРµР»СЊРЅС‹Р№
// С„Р°Р№Р» `tmp_*.nv`, РїСЂРѕРІРµСЂСЏРµС‚СЃСЏ РІСЂСѓС‡РЅСѓСЋ С‡РµСЂРµР· `nova-codegen check`.

module types.generic_bounds


// Plan 15 D53 strict: protocol/effect СЂР°Р·РґРµР»РµРЅС‹ РІ AST. Codegen СЌРјРёС‚РёС‚
// vtable С‚РѕР»СЊРєРѕ РґР»СЏ effect-kind; protocol вЂ” compile-time-only. Р­С‚Рѕ
// РїРѕРїСѓС‚РЅРѕ С„РёРєСЃРёС‚ pre-existing Self-bug вЂ” `Self` РІ protocol-РјРµС‚РѕРґРµ
// Р±РѕР»СЊС€Рµ РЅРµ Р»РѕРјР°РµС‚ codegen РїРѕС‚РѕРјСѓ С‡С‚Рѕ type_ref_to_c РґР»СЏ protocol-
// РјРµС‚РѕРґРѕРІ РІРѕРѕР±С‰Рµ РЅРµ РІС‹Р·С‹РІР°РµС‚СЃСЏ.

type GbHashable protocol {
    @hash() -> u64
    @equal(other Self) -> bool
}


// Р’С‚РѕСЂРѕР№ protocol вЂ” РјРµС‚РѕРґС‹ СЃ primitives.
type GbCountable protocol {
    @count() -> int
}


// Concrete С‚РёРї СЃ СЂРµР°Р»РёР·Р°С†РёРµР№ РѕР±РѕРёС… required methods.
type GbUser {
    id   u64
    name str
}


export fn GbUser @hash() -> u64 => @id


export fn GbUser @equal(other GbUser) -> bool => @id == other.id


export fn GbUser @count() -> int => @id as int


// Generic fn СЃ bound. Bound-РїСЂРѕРІРµСЂРєР° РІ type-checker'Рµ (Plan 15).
fn require_hashable[T GbHashable](x T) -> T => x


test "bound satisfied вЂ” GbUser РёРјРµРµС‚ hash() в†’ type-check OK" {
    ro user = GbUser { id: 42 as u64, name: "alice" }
    ro _ = require_hashable(user)   // type-checker РІР°Р»РёРґРёСЂСѓРµС‚ bound
    assert(true)
}


// Multi-bound: РґРІР° generic'Р° СЃ РѕРґРЅРёРј Рё С‚РµРј Р¶Рµ bound.
fn require_two_hashable[A GbHashable, B GbHashable](a A, _b B) -> A => a


test "multi-bound вЂ” РѕР±Р° satisfied" {
    ro u = GbUser { id: 7 as u64, name: "x" }
    ro v = GbUser { id: 8 as u64, name: "y" }
    ro _ = require_two_hashable(u, v)
    assert(true)
}


// No-bound generic вЂ” РѕР±С‹С‡РЅС‹Р№ generic, Р±РµР· D72-РїСЂРѕРІРµСЂРѕРє.
fn identity_no_bound[T](x T) -> T => x


test "no-bound generic вЂ” РєРѕРјРїРёР»РёСЂСѓРµС‚СЃСЏ РєР°Рє СЂР°РЅСЊС€Рµ" {
    ro u = GbUser { id: 1 as u64, name: "n" }
    ro _ = identity_no_bound(u)
    assert(true)
}


// Mixed: РѕРґРёРЅ СЃ bound (GbHashable), РІС‚РѕСЂРѕР№ Р±РµР·.
fn lookup_or_bound[K GbHashable, V](_key K, fallback V) -> V => fallback


test "mixed bound вЂ” РѕРґРёРЅ СЃ bound, РґСЂСѓРіРѕР№ Р±РµР·" {
    ro key = GbUser { id: 1 as u64, name: "k" }
    ro r = lookup_or_bound(key, 99)
    // r вЂ” int (primitive), roundtrip С‡РµСЂРµР· void* СЂР°Р±РѕС‚Р°РµС‚ (intptr_t).
    assert(r == 99)
}


// Multiple distinct protocols.
fn require_countable[T GbCountable](x T) -> T => x


test "different bound вЂ” GbCountable vs GbHashable" {
    ro u = GbUser { id: 5 as u64, name: "o" }
    ro _ = require_countable(u)   // GbUser РёРјРµРµС‚ @count в†’ OK
    ro _ = require_hashable(u)    // GbUser РёРјРµРµС‚ @hash в†’ OK
    assert(true)
}


// Plan 15 Р¤.4: forward-dependency bound вЂ” bound РЅР° V СЃСЃС‹Р»Р°РµС‚СЃСЏ РЅР°
// РїСЂРµРґС‹РґСѓС‰РёР№ generic-РїР°СЂР°РјРµС‚СЂ K. РџР°СЂСЃРµСЂ РїСЂРёРЅРёРјР°РµС‚ `[K Bound1, V
// Bound2[K]]` (bound вЂ” РѕР±С‹С‡РЅС‹Р№ TypeRef С‡РµСЂРµР· parse_type, РєРѕС‚РѕСЂС‹Р№
// РґРѕРїСѓСЃРєР°РµС‚ type-args). BoundCtx::check_satisfaction РґР»СЏ
// РїР°СЂР°РјРµС‚СЂРёР·РѕРІР°РЅРЅС‹С… bound'РѕРІ СЃРµР№С‡Р°СЃ permissive (early-return РґР»СЏ
// non-single-name path) вЂ” СЌС‚Рѕ Р·Р°РєСЂС‹РІР°РµС‚СЃСЏ РѕС‚РґРµР»СЊРЅРѕР№ Р·Р°РґР°С‡РµР№. РўРµСЃС‚
// С„РёРєСЃРёСЂСѓРµС‚ С‡С‚Рѕ РїР°СЂСЃРµСЂ + С‚РµРєСѓС‰РёР№ С‡РµРєРµСЂ РїСЂРѕРїСѓСЃРєР°СЋС‚ РІР°Р»РёРґРЅС‹Р№ РєРѕРґ.
type GbFromKey[T] protocol {
    @from_key(t T) -> Self
}


type GbKey {
    raw u64
}


type GbValue {
    derived u64
}


export fn GbKey @hash() -> u64 => @raw


export fn GbKey @equal(other GbKey) -> bool => @raw == other.raw


export fn GbValue @from_key(k GbKey) -> GbValue => { derived: k.raw }


fn pair_forward[K GbHashable, V GbFromKey[K]](k K, v V) -> V => v


test "forward-dependency вЂ” bound[V] СЃСЃС‹Р»Р°РµС‚СЃСЏ РЅР° K" {
    ro k = GbKey { raw: 100 as u64 }
    ro v = GbValue { derived: 0 as u64 }
    ro _ = pair_forward(k, v)
    assert(true)
}
