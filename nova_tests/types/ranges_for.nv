// 12_ranges_for.nv — range-литералы (D58), for-in

module types.ranges_for

test "range exclusive 0..n" {
    let mut sum = 0
    for i in 0..5 {
        sum += i
    }
    assert(sum == 0 + 1 + 2 + 3 + 4)
}

test "range from positive lower" {
    let mut sum = 0
    for i in 3..6 {
        sum += i
    }
    assert(sum == 3 + 4 + 5)
}

test "empty range" {
    let mut count = 0
    for _ in 5..5 {
        count += 1
    }
    assert(count == 0)
}

test "range over single value" {
    let mut count = 0
    for _ in 0..1 {
        count += 1
    }
    assert(count == 1)
}

test "for over array" {
    let xs = [10, 20, 30]
    let mut sum = 0
    for x in xs {
        sum += x
    }
    assert(sum == 60)
}

test "nested for" {
    let mut total = 0
    for i in 0..3 {
        for j in 0..3 {
            total += i * 3 + j
        }
    }
    assert(total == 0 + 1 + 2 + 3 + 4 + 5 + 6 + 7 + 8)
}

test "for collects via array.push" {
    let squares = []
    for i in 1..6 {
        squares.push(i * i)
    }
    assert(squares.len() == 5)
    assert(squares[0] == 1)
    assert(squares[4] == 25)
}

test "break inside for" {
    let mut found = -1
    for x in [10, 20, 30, 40] {
        if x == 30 {
            found = x
            break
        }
    }
    assert(found == 30)
}

test "continue inside for" {
    let mut sum = 0
    for x in [1, 2, 3, 4, 5] {
        if x % 2 == 0 { continue }
        sum += x
    }
    assert(sum == 1 + 3 + 5)
}

test "inclusive range 1..=n" {
    let mut sum = 0
    for i in 1..=5 {
        sum += i
    }
    assert(sum == 1 + 2 + 3 + 4 + 5)
}

test "inclusive range single value 7..=7" {
    let mut count = 0
    for _ in 7..=7 {
        count += 1
    }
    assert(count == 1)
}

test "exclusive vs inclusive size" {
    let mut a = 0
    for _ in 0..5 { a += 1 }
    let mut b = 0
    for _ in 0..=5 { b += 1 }
    assert(a == 5)
    assert(b == 6)
}
