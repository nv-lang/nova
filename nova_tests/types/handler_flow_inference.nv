// Plan 39 Issue A: handler-flow inference в `with`-блоке.
//
// Codegen теперь категоризует тип `with`-блока:
//   - int/bool — nova_interrupt(int)
//   - pointer (Nova_X*) — nova_interrupt_ptr(p)
//   - value struct (NovaOpt_X, ...) — heap-allocate + nova_interrupt_ptr
//
// NovaInterruptFrame получил `value_ptr` slot. emit_with declare'ит
// result_tmp с правильным C-типом, не nova_int.

module nova_tests.types.handler_flow_inference

type WrapperError { msg str }

type Box {
    readonly value int
}

// ──────────────────────────────────────────────────────────────────────────
// Case 1 — IntLike: body даёт int, handler interrupt'ит int.
// Раньше работало (legacy nova_int slot).
// ──────────────────────────────────────────────────────────────────────────

test "int body, int interrupt — basic happy-path" {
    let r = with Fail[WrapperError] = |e| interrupt -1 {
        42
    }
    assert(r == 42)
}

test "int body, int interrupt — fail-path" {
    let r = with Fail[WrapperError] = |e| interrupt -1 {
        throw WrapperError { msg: "fail" }
    }
    assert(r == -1)
}

// ──────────────────────────────────────────────────────────────────────────
// Case 2 — Pointer: body даёт Box* (record pointer), handler interrupt'ит ptr.
// Раньше падало: result_tmp как nova_int, value дискардился.
// ──────────────────────────────────────────────────────────────────────────

test "pointer body, pointer interrupt — happy-path" {
    let fallback = Box { value: -999 }
    let r = with Fail[WrapperError] = |e| interrupt fallback {
        Box { value: 100 }
    }
    assert(r.value == 100)
}

test "pointer body, pointer interrupt — fail-path uses fallback" {
    let fallback = Box { value: -999 }
    let r = with Fail[WrapperError] = |e| interrupt fallback {
        throw WrapperError { msg: "boom" }
    }
    assert(r.value == -999)
}

// ──────────────────────────────────────────────────────────────────────────
// Case 3 — ValueStruct (Option): body даёт Option[Box*], handler interrupt None.
// Это сценарий из range.nv "inclusive overflow throws".
// ──────────────────────────────────────────────────────────────────────────

test "option-of-pointer body, None interrupt — happy-path" {
    let r = with Fail[WrapperError] = |e| interrupt None {
        Some(Box { value: 7 })
    }
    // r == Some(Box{value:7})
    assert(r.is_some())
}

test "option-of-pointer body, None interrupt — fail-path" {
    let r = with Fail[WrapperError] = |e| interrupt None {
        if false { Some(Box { value: 1 }) } else { throw WrapperError { msg: "x" } }
    }
    // r == None
    assert(r.is_none())
}
