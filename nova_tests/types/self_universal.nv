// 36_self_universal.nv — D66: `Self` universal в любом type-контексте.
//
// До D66: `Self` валиден только внутри `protocol { ... }` блока (D42).
// После D66: `Self` валиден в любом type-контексте — static-методах,
// instance-методах, sum-вариантах, effect-объявлениях.

module nova_tests.types

// === 1. Self в static-методе record'а ===

type Box8 {
    mut value int
}

fn Box8.new(v int) -> Self {
    Box8 { value: v }
}

fn Box8.zero() -> Self {
    Box8 { value: 0 }
}

test "Self в static-методе" {
    ro b = Box8.new(42)
    assert(b.value == 42)
    ro z = Box8.zero()
    assert(z.value == 0)
}

// === 2. Self в instance-методе record'а — для clone/builder ===

fn Box8 @clone() -> Self {
    Box8 { @value }
}

fn Box8 @doubled() -> Self {
    Box8 { value: @value * 2 }
}

test "Self в @clone" {
    ro b = Box8 { value: 7 }
    ro c = b.clone()
    assert(c.value == 7)
}

test "Self в return type instance-метода (builder)" {
    ro b = Box8 { value: 5 }
    ro d = b.doubled()
    assert(d.value == 10)
}

// === 3. Self в generic record'е ===

type Pair6[A, B] {
    fst A
    snd B
}

fn Pair6[A, B] @swap() -> Pair6[B, A] {
    Pair6 { fst: @snd, snd: @fst }
}

test "Self не нужен — но альтернатива через Pair6[B, A] явная" {
    mut p = Pair6 { fst: 1, snd: "x" }
    ro s = p.swap()
    assert(s.fst == "x")
    assert(s.snd == 1)
}

// === 4. Self в sum-варианте ===

type Tree2
    | Leaf
    | Node(int, Tree2, Tree2)

fn Tree2 @count() -> int => match @ {
    Leaf          => 0
    Node(_, l, r) => 1 + l.count() + r.count()
}

test "Self в sum-варианте через @count" {
    ro t = Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Node(4, Leaf, Leaf)))
    assert(t.count() == 4)
}

// === 5. Self в effect-методах ===
// Bootstrap может ограничивать; используем простую форму.

type Counter effect {
    next() -> int
}

test "effect методы используют обычные типы (не Self) для return" {
    mut s = 0
    with Counter = effect Counter {
        next() {
            s += 1
            return s
        }
    } {
        ro v = Counter.next()
        assert(v == 1)
    }
}

// === 6. Self в protocol — исходный D42 use-case ===
//
// String conversion in Nova: `Into[str]` via `@into() -> str` (D73,
// replaces old D70 `ToStr` / `@to_str`). Built-in `str.from(int)`
// turns an int into its decimal string.

type UserId3 { id u64 }

fn UserId3 @into() -> str => "user#" + str.from(@id)

test "Into[str] for UserId3 — string conversion via D73" {
    ro u = UserId3 { id: 42 }
    ro s str = u.into()
    assert(s == "user#42")
}

// === 7. Self vs обычное имя типа — DRY ===

type Account3 { balance int }

// Без Self — повтор имени
fn Account3.with_balance(b int) -> Account3 {
    Account3 { balance: b }
}

// С Self — DRY (рекомендуется)
fn Account3.zero_balance() -> Self {
    Self { balance: 0 }
}

test "Self literal — Self { ... } работает в bootstrap" {
    ro a = Account3.zero_balance()
    assert(a.balance == 0)
}

test "обе формы возвращают тот же тип" {
    ro a1 = Account3.with_balance(100)
    ro a2 = Account3.zero_balance()
    assert(a1.balance == 100)
    assert(a2.balance == 0)
}
