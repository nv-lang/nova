// 36_self_universal.nv — D66: `Self` universal в любом type-контексте.
//
// До D66: `Self` валиден только внутри `protocol { ... }` блока (D42).
// После D66: `Self` валиден в любом type-контексте — static-методах,
// instance-методах, sum-вариантах, effect-объявлениях.

module nova_tests.types.self_universal

// === 1. Self в static-методе record'а ===

type Box {
    mut value int
}

fn Box.new(v int) -> Self {
    Box { value: v }
}

fn Box.zero() -> Self {
    Box { value: 0 }
}

test "Self в static-методе" {
    let b = Box.new(42)
    assert(b.value == 42)
    let z = Box.zero()
    assert(z.value == 0)
}

// === 2. Self в instance-методе record'а — для clone/builder ===

fn Box @clone() -> Self {
    Box { value: @value }
}

fn Box @doubled() -> Self {
    Box { value: @value * 2 }
}

test "Self в @clone" {
    let b = Box { value: 7 }
    let c = b.clone()
    assert(c.value == 7)
}

test "Self в return type instance-метода (builder)" {
    let b = Box { value: 5 }
    let d = b.doubled()
    assert(d.value == 10)
}

// === 3. Self в generic record'е ===

type Pair[A, B] {
    fst A
    snd B
}

fn Pair[A, B] @swap() -> Pair[B, A] {
    Pair { fst: @snd, snd: @fst }
}

test "Self не нужен — но альтернатива через Pair[B, A] явная" {
    let p = Pair { fst: 1, snd: "x" }
    let s = p.swap()
    assert(s.fst == "x")
    assert(s.snd == 1)
}

// === 4. Self в sum-варианте ===

type Tree
    | Leaf
    | Node(int, Tree, Tree)

fn Tree @count() -> int => match @ {
    Leaf          => 0
    Node(_, l, r) => 1 + l.count() + r.count()
}

test "Self в sum-варианте через @count" {
    let t = Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Node(4, Leaf, Leaf)))
    assert(t.count() == 4)
}

// === 5. Self в effect-методах ===
// Bootstrap может ограничивать; используем простую форму.

type Counter effect {
    next() -> int
}

test "effect методы используют обычные типы (не Self) для return" {
    let mut s = 0
    with Counter = handler Counter {
        next() {
            s += 1
            return s
        }
    } {
        let v = Counter.next()
        assert(v == 1)
    }
}

// === 6. Self в protocol — исходный D42 use-case ===
//
// String conversion in Nova: `Into[str]` via `@into() -> str` (D73,
// replaces old D70 `ToStr` / `@to_str`). Built-in `str.from(int)`
// turns an int into its decimal string.

type UserId { id u64 }

fn UserId @into() -> str => "user#" + str.from(@id)

test "Into[str] for UserId — string conversion via D73" {
    let u = UserId { id: 42 }
    let s str = u.into()
    assert(s == "user#42")
}

// === 7. Self vs обычное имя типа — DRY ===

type Account { balance int }

// Без Self — повтор имени
fn Account.with_balance(b int) -> Account {
    Account { balance: b }
}

// С Self — DRY (рекомендуется)
fn Account.zero_balance() -> Self {
    Self { balance: 0 }
}

test "Self literal — Self { ... } работает в bootstrap" {
    let a = Account.zero_balance()
    assert(a.balance == 0)
}

test "обе формы возвращают тот же тип" {
    let a1 = Account.with_balance(100)
    let a2 = Account.zero_balance()
    assert(a1.balance == 100)
    assert(a2.balance == 0)
}
