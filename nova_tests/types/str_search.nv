// str_search.nv — D26 string search/slice API: find / rfind / slice
// edge cases (byte-offsets).
//
// Spec D26: все индексы — byte-offset (consistent с Rust/Go),
// возвращаемое значение — Option[int] для find/rfind.

module types.str_search

// ================================================================
// SECTION 1: find — первое вхождение
// ================================================================

test "find: ASCII presence returns Some(byte_offset)" {
    ro s = "hello world"
    ro r = s.find("world")
    assert(r.unwrap_or(-1) == 6)
}

test "find: at the start" {
    ro r = "hello".find("hel")
    assert(r.unwrap_or(-1) == 0)
}

test "find: at the end" {
    ro r = "hello".find("llo")
    assert(r.unwrap_or(-1) == 2)
}

test "find: needle not present" {
    ro r = "hello".find("world")
    assert(r.is_none())
}

test "find: empty needle returns Some(0)" {
    // Rust convention: пустой needle всегда matches at offset 0.
    ro r = "hello".find("")
    assert(r.unwrap_or(-1) == 0)
}

test "find: needle longer than haystack" {
    ro r = "abc".find("abcdef")
    assert(r.is_none())
}

test "find: empty haystack with non-empty needle" {
    ro r = "".find("x")
    assert(r.is_none())
}

test "find: empty haystack with empty needle" {
    ro r = "".find("")
    assert(r.unwrap_or(-1) == 0)
}

test "find: returns first match (not later)" {
    ro r = "abc-abc-abc".find("abc")
    assert(r.unwrap_or(-1) == 0)
}

test "find: single character search" {
    ro r = "hello".find("e")
    assert(r.unwrap_or(-1) == 1)
}

// ================================================================
// SECTION 2: rfind — последнее вхождение
// ================================================================

test "rfind: returns last match offset" {
    ro r = "abc-abc-abc".rfind("abc")
    assert(r.unwrap_or(-1) == 8)
}

test "rfind: when only one match" {
    ro r = "hello".rfind("ll")
    assert(r.unwrap_or(-1) == 2)
}

test "rfind: not present returns None" {
    ro r = "hello".rfind("xyz")
    assert(r.is_none())
}

test "rfind: empty needle returns Some(s.len)" {
    // Rust convention: пустой needle для rfind = position past last char.
    ro r = "abc".rfind("")
    assert(r.unwrap_or(-1) == 3)
}

// ================================================================
// SECTION 3: find vs rfind для unique/multi-occurrence
// ================================================================

test "find != rfind для multi-occurrence" {
    ro s = "ab-cd-ef"
    ro f = s.find("-").unwrap_or(-1)
    ro r = s.rfind("-").unwrap_or(-1)
    assert(f == 2)
    assert(r == 5)
    assert(f != r)
}

test "find == rfind для unique match" {
    ro s = "abc-def"
    ro f = s.find("-").unwrap_or(-1)
    ro r = s.rfind("-").unwrap_or(-1)
    assert(f == r)
    assert(f == 3)
}

// ================================================================
// SECTION 4: find + slice — типичный split-by-delimiter pattern
// ================================================================

test "split-by-find: parse 'key:value'" {
    ro s = "user:42"
    ro i = s.find(":").unwrap_or(-1)
    assert(i == 4)
    ro key = s[0..i]
    ro val = s[i + 1..s.len()]
    assert(key == "user")
    assert(val == "42")
}

test "split-by-rfind: get last segment of path" {
    ro path = "/usr/local/bin/nova"
    ro i = path.rfind("/").unwrap_or(-1)
    assert(i == 14)
    ro dir = path[0..i]
    ro name = path[i + 1..path.len()]
    assert(dir == "/usr/local/bin")
    assert(name == "nova")
}

// ================================================================
// SECTION 5: slice edge cases
// ================================================================

test "slice: full range == original" {
    ro s = "hello"
    ro r = s[0..s.len()]
    assert(r == "hello")
}

test "slice: empty slice (a == b)" {
    ro s = "hello"
    ro r = s[2..2]
    assert(r == "")
    assert(r.len() == 0)
}

test "slice: middle" {
    ro r = "hello world"[6..11]
    assert(r == "world")
}

test "slice: from start" {
    ro r = "hello"[0..3]
    assert(r == "hel")
}

test "slice: to end" {
    ro s = "hello"
    ro r = s[2..s.len()]
    assert(r == "llo")
}

// ================================================================
// SECTION 6: case-sensitivity для всех методов
// ================================================================

test "find is case-sensitive" {
    ro s = "Hello World"
    assert(s.find("hello").is_none())          // нижний регистр не найдём
    assert(s.find("Hello").unwrap_or(-1) == 0)
}

test "rfind is case-sensitive" {
    ro s = "Hello hello"
    assert(s.rfind("Hello").unwrap_or(-1) == 0) // только заглавный
    ro r = s.rfind("hello")
    assert(r.unwrap_or(-1) == 6)
}

// ================================================================
// SECTION 7: len/char_len — Plan 108 D26 rev
// ================================================================
// Plan 108 D26 rev: s.len() — длина в байтах O(1) (как Rust/Go).
//                  s.char_len() — длина в codepoints O(n).

test "len: ASCII — bytes == codepoints" {
    ro s = "hello"
    assert(s.len() == 5)          // 5 bytes (ASCII; D26 rev: len = bytes O(1))
    assert(s.char_len() == 5)     // 5 codepoints
}

test "len: Cyrillic — bytes != codepoints" {
    ro s = "Привет"               // 6 codepoints, 12 bytes (2 byte/char UTF-8)
    assert(s.len() == 12)          // D26 rev: len = bytes
    assert(s.char_len() == 6)      // codepoints
}

test "len: emoji — 4 байта на codepoint" {
    ro s = "ab😀cd"                // 5 codepoints, 4 ASCII + 4 emoji = 8 bytes
    assert(s.len() == 8)            // D26 rev: len = bytes
    assert(s.char_len() == 5)       // codepoints
}

test "len: empty string" {
    assert("".len() == 0)
    assert("".char_len() == 0)
}

test "len for mixed content" {
    ro s = "a Привет b"           // a + space + 6 cyrillic + space + b = 10 codepoints
                                   // ASCII: a, space, space, b = 4 bytes
                                   // Cyrillic: 6*2 = 12 bytes; total bytes = 16
    assert(s.len() == 16)           // D26 rev: bytes
    assert(s.char_len() == 10)      // codepoints
}

// ================================================================
// SECTION 8: find/rfind/slice с Unicode (codepoint offsets)
// ================================================================

test "find: Cyrillic returns codepoint offset, not u8 offset" {
    ro s = "Привет мир"           // 'мир' starts at codepoint 7 (u8 13)
    ro r = s.find("мир")
    assert(r.unwrap_or(-1) == 7)   // codepoint, не 13
}

test "rfind: Cyrillic returns codepoint offset" {
    ro s = "ааа-ааа"              // последний 'ааа' начинается с codepoint 4
    ro r = s.rfind("ааа")
    assert(r.unwrap_or(-1) == 4)
}

test "slice: Cyrillic codepoint indices" {
    ro s = "Привет мир"
    // codepoints: П(0) р(1) и(2) в(3) е(4) т(5) ' '(6) м(7) и(8) р(9)
    ro hello = s[0..6]      // "Привет"
    assert(hello == "Привет")
    ro world = s[7..10]     // "мир"
    assert(world == "мир")
}

test "split-by-find with Cyrillic" {
    ro s = "ключ:значение"        // 'ключ'(0..4) + ':'(4) + 'значение'(5..13)
    ro i = s.find(":").unwrap_or(-1)
    assert(i == 4)                 // codepoint offset
    ro key = s[0..i]
    // Plan 108 D26 rev: slice uses codepoint indices; use char_len() not len().
    ro val = s[i + 1..s.char_len()]
    assert(key == "ключ")
    assert(val == "значение")
}

test "slice across emoji boundary" {
    ro s = "ab😀cd"                // codepoints: a(0) b(1) 😀(2) c(3) d(4)
    ro r = s[2..3]
    assert(r == "😀")
    assert(r.len() == 4)           // emoji = 4 bytes (D26 rev: len = bytes)
    assert(r.char_len() == 1)      // 1 codepoint
}

// ================================================================
// SECTION 9: to_bytes() и to_chars() — итерация по строке (D178 rename)
// ================================================================
// D178: s.to_bytes() → []u8 (UTF-8 байты, allocating copy),
//       s.to_chars() → []char (codepoints, allocating).
// for-in по результату должен работать.

test "bytes: ASCII — каждый символ = 1 байт" {
    ro s = "abc"
    ro bs = s.to_bytes()
    assert(bs.len() == 3)
}

test "bytes: Cyrillic — UTF-8 многобайтовое представление" {
    ro s = "Привет"               // 6 codepoints, 12 bytes
    ro bs = s.to_bytes()
    assert(bs.len() == 12)
}

test "bytes: for-in over s.to_bytes()" {
    ro s = "abc"
    mut sum int = 0
    for b in s.to_bytes() {
        sum = sum + (b as int)
    }
    // 'a'(97) + 'b'(98) + 'c'(99) = 294
    assert(sum == 294)
}

test "bytes: ro-binding then for-in" {
    ro s = "ABC"
    ro bs = s.to_bytes()
    mut count = 0
    for b in bs {
        if b == 'A' as u8 { count = count + 1 }
        if b == 'B' as u8 { count = count + 1 }
        if b == 'C' as u8 { count = count + 1 }
    }
    assert(count == 3)
}

test "chars: count codepoints через for-in" {
    ro s = "Привет"
    mut n = 0
    for c in s.to_chars() {
        ro _ = c
        n = n + 1
    }
    assert(n == 6)                 // 6 codepoints
}

test "chars: emoji decode" {
    ro s = "ab😀"                  // 3 codepoints
    mut count = 0
    for c in s.to_chars() {
        ro _ = c
        count = count + 1
    }
    assert(count == 3)
}

// ================================================================
// SECTION 10: split — D26 (eager bootstrap)
// ================================================================

test "split: basic" {
    ro parts = "a,b,c".split(",")
    assert(parts.len() == 3)
}

test "split: no separator → один элемент" {
    ro parts = "abc".split(",")
    assert(parts.len() == 1)
}

test "split: для for-in" {
    mut count = 0
    for p in "x,y,z,w".split(",") {
        ro _ = p
        count = count + 1
    }
    assert(count == 4)
}

test "split: trailing separator" {
    ro parts = "a,b,".split(",")
    // ["a", "b", ""] — empty tail
    assert(parts.len() == 3)
}

// ================================================================
// SECTION 11: []u8 — packed storage (real uint8_t[], не int64-erasure)
// ================================================================
// Codegen-маппинг `[]u8` → `NovaArray_nova_byte*` с реальным uint8_t[]
// (не nova_int слотами). Тест проверяет что round-trip через
// bytes() / for-in / WriteBuffer + str.try_from работает.
//
// Plan 04 Этап 6: Buffer удалён. Replaces:
//   - Buffer.from(bs).into_str_unchecked() → str.try_from(bs)? (D77)
//   - Buffer.with_capacity + add_byte       → WriteBuffer + write_byte

test "bytes: round-trip через str.try_from" {
    ro original = "Hello, мир!"
    ro bs = original.to_bytes()
    // Восстановим строку: bs → str.try_from(bs) → str. UTF-8 валидный
    // (исходник был str), поэтому Ok.
    ro recon = match str.try_from(bs) {
        Ok(s)  => s
        Err(_) => ""    // unreachable — original was valid UTF-8
    }
    assert(recon == original)
}

test "bytes: extreme values 0..255 через WriteBuffer" {
    // Если []u8 был int64-erasure, 0xFF мог бы потеряться при
    // приведении (signed sign-extend). С packed uint8_t[] сохраняется
    // битово-точно.
    mut wb = WriteBuffer.with_capacity(3)
    wb.write_byte(0xFF)
    wb.write_byte(0x00)
    wb.write_byte(0x7F)
    ro bs = wb.into()
    assert(bs.len() == 3)
}

test "bytes: for-in over packed []u8" {
    // For-in: каждый элемент — реально u8 (uint8_t), не int64.
    ro s = "ABC"
    ro bs = s.to_bytes()
    mut sum = 0
    for b in bs {
        // b — это u8 (nova_byte = uint8_t), но cast to int для арифметики
        sum = sum + (b as int)
    }
    // 'A'(65) + 'B'(66) + 'C'(67) = 198
    assert(sum == 198)
}
