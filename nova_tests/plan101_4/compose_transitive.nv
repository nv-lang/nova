// Plan 101.4 вАФ positive: transitive embed.
// `Closeable use Reader` + `Reader` has @read. Flatten –і–Њ–ї–ґ–µ–љ –њ–Њ–і–љ—П—В—М
// `read` —З–µ—А–µ–Ј —Ж–µ–њ–Њ—З–Ї—Г Closeable вЖТ Reader.

module nova_tests.plan101_4.compose_transitive


type Reader protocol {
    read() -> str
}

type Closeable protocol {
    use Reader
    close() -> bool
}

// CloseableReader –Ї–Њ–Љ–њ–Њ–Ј–Є—А—Г–µ—В Closeable (–Ї–Њ—В–Њ—А—Л–є —Г–ґ–µ –≤–Ї–ї—О—З–∞–µ—В Reader).
type CloseableReader protocol {
    use Closeable
}


type Handle {
    id int
}

fn Handle @read() -> str => "h${@id}"
fn Handle @close() -> bool => true


// T –і–Њ–ї–ґ–µ–љ —Г–і–Њ–≤–ї–µ—В–≤–Њ—А–Є—В—М CloseableReader вЖТ flatten { read, close }.
fn finish[T CloseableReader](x T) -> str {
    ro s = x.read()
    ro _ = x.close()
    s
}


test "transitive embed: Handle satisfies through chain" {
    ro h = Handle { id: 42 }
    ro s = finish(h)
    assert(s == "h42")
}
