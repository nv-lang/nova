// Plan 101.4 — positive: один composed protocol используется для
// двух независимых concrete-типов (sanity check, что flatten не
// прибит к одному вызову).

module plan101_4.compose_independent_concretes


type Hashable_ protocol {
    hash() -> int
}

type Sized_ protocol {
    size() -> int
}

// HashSize = Hashable_ + Sized_.
type HashSize protocol {
    use Hashable_
    use Sized_
}


type IntBox {
    v int
}

fn IntBox @hash() -> int => @v
fn IntBox @size() -> int => 4


type Tag {
    name str
}

fn Tag @hash() -> int => @name.len()
fn Tag @size() -> int => @name.len() + 1


// Generic — оба concrete-типа должны проходить bound.
fn sum_hs[T HashSize](x T) -> int => x.hash() + x.size()


test "IntBox satisfies HashSize" {
    ro b = IntBox { v: 7 }
    assert(sum_hs(b) == 11)
}

test "Tag satisfies HashSize" {
    ro t = Tag { name: "abc" }
    assert(sum_hs(t) == 7)
}
