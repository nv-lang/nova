// Plan 52 Ф.7 positive: [k: v] map-литерал — HashMap[int, str].
module map_literals.positive_int_str

import std.collections.hashmap.{HashMap}

test "int→str basic" {
    ro m HashMap[int, str] = [1: "a", 2: "b", 3: "c"]
    assert(m.len() == 3)
    assert(m.get(2) == Some("b"))
    assert(m.contains(3))
    assert(!m.contains(99))
}

test "expressions as keys/values" {
    ro base = 100
    ro m HashMap[int, str] = [base: "first", base + 1: "second", base * 2: "third"]
    assert(m.len() == 3)
    assert(m.get(100) == Some("first"))
    assert(m.get(101) == Some("second"))
    assert(m.get(200) == Some("third"))
}
