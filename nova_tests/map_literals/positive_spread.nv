// Plan 52.x закрытие: map-spread `[...m, k: v]`.
//
// Реализовано Plan 55 (spread-инфраструктура: parser/desugar/annotator,
// `6c1fe6465f8`) + Plan 56 (codegen). Раньше — [M-52-spread-not-supported].
// Этот файл фиксирует рабочее поведение регрессионно.
module map_literals.positive_spread

import std.collections.hashmap.{HashMap}

test "spread + extra pair" {
    ro base HashMap[str, int] = ["a": 1, "b": 2]
    mut m = [...base, "c": 3]
    assert(m.len() == 3)
    assert(m.get("a") == Some(1))
    assert(m.get("b") == Some(2))
    assert(m.get("c") == Some(3))
}

test "two spreads — union (без аннотации, тип из источников)" {
    ro a HashMap[str, int] = ["a": 1]
    ro b HashMap[str, int] = ["b": 2, "c": 3]
    mut m = [...a, ...b]
    assert(m.len() == 3)
    assert(m.get("a") == Some(1))
    assert(m.get("c") == Some(3))
}

test "spread then overriding pair" {
    ro base HashMap[str, int] = ["a": 1, "b": 2]
    mut m = [...base, "a": 99]
    assert(m.len() == 2)
    assert(m.get("a") == Some(99))
    assert(m.get("b") == Some(2))
}

test "leading pair then spread" {
    ro base HashMap[str, int] = ["b": 2]
    mut m = ["a": 1, ...base]
    assert(m.len() == 2)
    assert(m.get("a") == Some(1))
    assert(m.get("b") == Some(2))
}

test "spread does not mutate source" {
    ro base HashMap[str, int] = ["a": 1]
    mut m = [...base, "b": 2]
    assert(base.len() == 1)
    assert(m.len() == 2)
}
