// Plan 52 Ф.7 positive: [k: v] map-литерал — HashMap[int, int].
module map_literals.positive_int_int

import std.collections.hashmap.{HashMap}

test "int→int basic" {
    let m HashMap[int, int] = [1: 100, 2: 200, 3: 300]
    assert(m.len() == 3)
    assert(m.get(1) == Some(100))
    assert(m.get(2) == Some(200))
    assert(m.get(3) == Some(300))
}

test "int→int large literal — no rehash (with_capacity contract)" {
    // [k:v] десугарится в with_capacity(8)+8 insert — n=8 был баг
    // в pre-fix with_capacity (bucket-count → 4 → threshold=3 → rehash на 4-м).
    // После Plan 52 Ф.6 fix: with_capacity(8) → ceil(32/3)=11 → next_pow2=16 →
    // threshold=12 ≥ 8 → no rehash.
    let m HashMap[int, int] = [
        1: 1, 2: 4, 3: 9, 4: 16,
        5: 25, 6: 36, 7: 49, 8: 64,
    ]
    assert(m.len() == 8)
    assert(m.get(5) == Some(25))
    assert(m.get(8) == Some(64))
}
