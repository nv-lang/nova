// Plan 52 Ф.10: D55 map-coercion mixed punning + explicit, str values.
// Отдельный файл от positive_record_punning из-за pre-existing
// multi-instance HashMap mono-collision (Plan 48 baseline).
module map_literals.positive_record_punning_str

import std.collections.hashmap.{HashMap}

test "mixed punning + explicit values" {
    ro host = "localhost"
    ro cfg HashMap[str, str] = { host, port: "8080" }
    assert(cfg.len() == 2)
    assert(cfg.get("host") == Some("localhost"))
    assert(cfg.get("port") == Some("8080"))
}
