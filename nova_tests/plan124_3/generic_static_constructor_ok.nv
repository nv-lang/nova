// Plan 124.3 — positive: generic type's static method (constructor)
// — recv = "Stack_genericstaticconstructorok", priv field init via anonymous record literal
// allowed внутри статического метода (inferred from return type).
//
// Note: explicit-type generic record literal `Stack_genericstaticconstructorok[T] { ... }`
// has parser limit; anonymous `{ ... }` form (inferred from
// `-> Stack_genericstaticconstructorok[T]` return) — supported и canonical.
module nova_tests.plan124_3

export type Stack_genericstaticconstructorok[T] {
    priv mut len int
    ro capacity int
}

export fn Stack_genericstaticconstructorok[T].empty(cap int) -> Stack_genericstaticconstructorok[T] =>
    { len: 0, capacity: cap }

// Static method = type scope; record literal с priv field OK
// (anonymous form, return type inference).
export fn Stack_genericstaticconstructorok[T].with_len(initial int, cap int) -> Stack_genericstaticconstructorok[T] =>
    { len: initial, capacity: cap }

test "Plan 124.3: static constructor with priv field init (anonymous)" {
    ro s = Stack_genericstaticconstructorok[int].with_len(0, 10)
    assert(s.capacity == 10)
}
