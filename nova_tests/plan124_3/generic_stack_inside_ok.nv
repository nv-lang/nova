// Plan 124.3 — positive: generic Stack[T] с priv mut len + items array.
// Methods access priv через @len — recv tracking name-based, generic
// param ignored.
module plan124_3.generic_stack_inside_ok

export type Stack[T] {
    priv mut len int
    ro capacity int
}

export fn Stack[T].new(cap int) -> Stack[T] =>
    { len: 0, capacity: cap }

export fn Stack[T] @push(item T) {
    @len = @len + 1
}

export fn Stack[T] @count() -> int =>
    @len

test "Plan 124.3: generic Stack[int] метод access OK" {
    mut s = Stack[int].new(10)
    s.push(1)
    s.push(2)
    s.push(3)
    assert(s.count() == 3)
}

test "Plan 124.3: generic Stack[str] метод access OK" {
    mut s = Stack[str].new(5)
    s.push("a")
    s.push("b")
    assert(s.count() == 2)
}
