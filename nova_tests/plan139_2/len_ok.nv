// len_ok.nv — Plan 139.2 Ф.1
// @len() — Nova-body, reads priv `@len` field directly (str lang-item,
// type-method privacy). Returns byte length O(1) (D26: str.len = bytes).
// Identical semantics to the retired C nova_str_byte_len.

module nova_tests.plan139_2

test "len: empty string is 0" {
    assert("".byte_len() == 0)
}

test "len: ASCII length equals byte count" {
    assert("hello".byte_len() == 5)
    assert("a".byte_len() == 1)
}

test "len: multi-byte UTF-8 counts BYTES not codepoints" {
    // "Привет" = 6 Cyrillic codepoints × 2 bytes = 12 bytes.
    assert("Привет".byte_len() == 12)
    // "😀" = 1 codepoint × 4 bytes.
    assert("😀".byte_len() == 4)
}

test "len: byte_len alias agrees with len" {
    ro s = "café"            // 'é' is 2 bytes → 5 bytes total
    assert(s.byte_len() == s.byte_len())
    assert(s.byte_len() == 5)
}

test "len: is_empty consistent with len" {
    assert("".is_empty())
    assert(!"x".is_empty())
}
