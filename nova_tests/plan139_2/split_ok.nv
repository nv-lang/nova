// split_ok.nv — Plan 139.2 Ф.2
// @split(sep) — Nova-body: byte-scan over @as_bytes(); each segment is a
// zero-copy sub-view `str{ptr: @ptr+off, len}` pushed into a Vec[str], returned
// as `ro []str`. Semantics identical to the retired C nova_str_split:
//   - empty sep → single-element array holding the whole string,
//   - N non-overlapping matches → N+1 segments (trailing tail always emitted).

module plan139_2.split_ok

test "split: basic ASCII, 3 parts" {
    ro parts = "a,b,c".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "b")
    assert(parts[2] == "c")
}

test "split: leading + trailing empty segments" {
    // ",x," → ["", "x", ""]  (tail always emitted; empty leading from match at 0).
    ro parts = ",x,".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "")
    assert(parts[1] == "x")
    assert(parts[2] == "")
}

test "split: no match → single segment (whole string)" {
    ro parts = "hello".split(",")
    assert(parts.len() == 1)
    assert(parts[0] == "hello")
}

test "split: multi-byte separator" {
    ro parts = "a::b::c".split("::")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "b")
    assert(parts[2] == "c")
}

test "split: empty separator → whole string as single view" {
    // Mirrors C nova_str_split: sep.len == 0 ⇒ push the whole string, no scan.
    ro parts = "abc".split("")
    assert(parts.len() == 1)
    assert(parts[0] == "abc")
}

test "split: separator over UTF-8 boundary preserves multi-byte segments" {
    // "héllo" split on "l" — "é" = 0xC3 0xA9 stays intact in the first segment.
    // bytes: h(1) é(2) l l o  → split on "l" yields ["hé", "", "o"].
    ro s = "héllo"
    ro parts = s.split("l")
    assert(parts.len() == 3)
    assert(parts[0] == "hé")
    assert(parts[1] == "")
    assert(parts[2] == "o")
    // Verify the multi-byte segment is byte-exact (zero-copy view, no corruption).
    assert(parts[0].len() == 3)            // 'h' + 2-byte 'é'
    assert(parts[0].byte_at(0) == 0x68 as u8)   // 'h'
    assert(parts[0].byte_at(1) == 0xC3 as u8)   // 'é' lead
    assert(parts[0].byte_at(2) == 0xA9 as u8)   // 'é' cont
}

test "split: empty string, non-empty sep → single empty segment" {
    ro parts = "".split(",")
    assert(parts.len() == 1)
    assert(parts[0] == "")
}

test "split: adjacent separators yield empty middle segments" {
    ro parts = "a,,b".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "")
    assert(parts[2] == "b")
}
