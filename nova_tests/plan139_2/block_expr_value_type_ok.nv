// Plan 139.2 regression guard — block-expression-as-value type inference.
//
// A block-expr `{ stmts; tail }` must infer its VALUE type from its OWN
// trailing expr resolved in the block's local scope — NOT from a stale
// same-named `var_types` entry leaked from a prior function (var_types is not
// per-fn scoped). Plan 139.2 made str methods (@as_bytes/@split/...) Nova-body
// with `Vec[u8]` locals named `a`/`b`/etc.; those leaked, so `{ ro a=10;
// ro b=20; a+b }` inferred `a+b` against a stale `a: Vec____nova_byte*` →
// `lt_is_cptr` → pointer-arith → the whole block typed as a Vec view → `v == 30`
// dispatched to `Vec____nova_byte_method_equal` → SEGV.
// Fix: emit_c `emit_block_expr` + `infer_expr_c_type` Block arm pre-register the
// block's own let-bindings before inferring the trailing type.
// EXPECT: all PASS (pre-fix: SEGV / RUN-FAIL).

module plan139_2.block_expr_value_type_ok

test "block-expr int value + ==" {
    ro v = { ro a = 10
        ro b = 20
        a + b }
    assert(v == 30)
}

test "nested block-expr" {
    ro w = { ro x = { ro p = 1
            ro q = 2
            p + q }
        x * 10 }
    assert(w == 30)
}

test "block-expr with str local, int trailing" {
    // str prelude present + a str local `s` inside the block; trailing is int.
    // Stresses the var_types interaction that caused the original mis-typing.
    ro r = { ro s = "hello"
        ro n = s.byte_len()
        n + 1 }
    assert(r == 6)
}

test "block-expr bool value" {
    ro ok = { ro a = 5
        a > 3 }
    assert(ok)
}
