// from_bytes_ok.nv — Plan 139.2 Ф.2
// str.from_bytes_unchecked / from_bytes_lossy / from_bytes_unchecked_steal —
// Nova-body. Reads the source (ptr,len[,cap]) via the public Vec getters
// (@as_ptr/@len/@cap) and builds an owned, NUL-terminated str (or zero-copy
// reuse for steal). Round-trip with @to_bytes / @as_bytes must be byte-exact.

module plan139_2.from_bytes_ok

test "from_bytes_unchecked: round-trip ASCII" {
    ro bytes = "hello".to_bytes()
    ro s = str.from_bytes_unchecked(bytes)
    assert(s == "hello")
    assert(s.byte_len() == 5)
}

test "from_bytes_unchecked: round-trip multi-byte UTF-8" {
    // "héllo wörld" — multi-byte é (0xC3 0xA9) and ö (0xC3 0xB6).
    ro original = "héllo wörld"
    ro bytes = original.to_bytes()
    ro s = str.from_bytes_unchecked(bytes)
    assert(s == original)
    assert(s.byte_len() == original.byte_len())
}

test "from_bytes_unchecked: empty array → empty string" {
    mut empty = []u8.new()
    ro s = str.from_bytes_unchecked(empty)
    assert(s == "")
    assert(s.byte_len() == 0)
}

test "from_bytes_unchecked: explicit byte build" {
    // Build "ABC" from raw bytes.
    mut b = []u8.new()
    b.push(65 as u8)   // 'A'
    b.push(66 as u8)   // 'B'
    b.push(67 as u8)   // 'C'
    ro s = str.from_bytes_unchecked(b)
    assert(s == "ABC")
    assert(s.as_bytes()[0] == 65 as u8)
}

test "from_bytes_lossy: valid UTF-8 fast path (copy)" {
    ro original = "valid café"
    ro bytes = original.to_bytes()
    ro s = str.from_bytes_lossy(bytes)
    assert(s == original)
}

test "from_bytes_lossy: invalid byte replaced with U+FFFD" {
    // 0xFF is never a valid UTF-8 lead byte → one U+FFFD (0xEF 0xBF 0xBD).
    mut b = []u8.new()
    b.push(65 as u8)   // 'A'
    b.push(0xFF as u8) // invalid lead
    b.push(66 as u8)   // 'B'
    ro s = str.from_bytes_lossy(b)
    // "A" + U+FFFD (3 bytes) + "B" = 5 bytes.
    assert(s.byte_len() == 5)
    assert(s.as_bytes()[0] == 0x41 as u8)   // 'A'
    assert(s.as_bytes()[1] == 0xEF as u8)   // FFFD byte 1
    assert(s.as_bytes()[2] == 0xBF as u8)   // FFFD byte 2
    assert(s.as_bytes()[3] == 0xBD as u8)   // FFFD byte 3
    assert(s.as_bytes()[4] == 0x42 as u8)   // 'B'
}

test "from_bytes_lossy: truncated multi-byte sequence replaced" {
    // 0xC3 with no continuation byte → invalid; replaced with U+FFFD.
    mut b = []u8.new()
    b.push(0xC3 as u8) // lead of 2-byte seq, but no continuation follows
    ro s = str.from_bytes_lossy(b)
    assert(s.byte_len() == 3)                 // single U+FFFD
    assert(s.as_bytes()[0] == 0xEF as u8)
    assert(s.as_bytes()[1] == 0xBF as u8)
    assert(s.as_bytes()[2] == 0xBD as u8)
}

test "from_bytes_unchecked_steal: zero-copy reuse when cap > len" {
    // with_capacity(16) then push 3 → cap (16) > len (3): in-place NUL-term reuse.
    mut b = []u8.with_capacity(16)
    b.push(120 as u8)  // 'x'
    b.push(121 as u8)  // 'y'
    b.push(122 as u8)  // 'z'
    ro s = str.from_bytes_unchecked_steal(b)
    assert(s == "xyz")
    assert(s.byte_len() == 3)
}

test "from_bytes_unchecked_steal: alloc+copy fallback when cap == len" {
    // with_capacity(2) + 2 pushes → cap (2) == len (2): no room for the NUL
    // terminator → alloc+copy fallback path (not the in-place reuse path).
    mut b = []u8.with_capacity(2)
    b.push(113 as u8)  // 'q'
    b.push(119 as u8)  // 'w'
    ro s = str.from_bytes_unchecked_steal(b)
    assert(s == "qw")
    assert(s.byte_len() == 2)
}

test "from_bytes_unchecked_steal: empty buffer" {
    mut b = []u8.new()
    ro s = str.from_bytes_unchecked_steal(b)
    assert(s == "")
    assert(s.byte_len() == 0)
}
