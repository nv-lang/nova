// EXPECT_COMPILE_ERROR E_PRIV_FIELD_INIT
//
// Plan 139.2 Ф.2 — negative: the str sub-view producer pattern is module-private.
//
// @split builds each segment as a zero-copy sub-view `str { ptr: @ptr+off, len }`.
// This construction is sound ONLY inside a str type-method (receiver `str` ⇒
// `current_recv_type == "str"` ⇒ type-based priv access, Plan 139.1/D220). From
// OUTSIDE the str module, forging a str view via the same record literal fires
// E_PRIV_FIELD_INIT — `str.ptr` / `str.len` are `priv`. This is what keeps the
// producer surface (split, from_bytes_*) the ONLY sanctioned way to build a str
// from raw (ptr, len): user code cannot alias an arbitrary buffer as a str and
// break the D26 §3 NUL / content-eq / hash invariants.
module neg.neg_split_view_construct_outside

fn forge_view(p *u8, n int) -> str {
    // priv-field init via record literal outside str-module → E_PRIV_FIELD_INIT.
    str { ptr: p, len: n }
}
