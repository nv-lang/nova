// Plan 55 Ф.2 — negative: match arms возвращают несовместимые типы.
// `Some(v) => v` (int) и `None => "str"` — type-check error.

module nova_tests.plan55


// EXPECT_CC_ERROR initializing
fn bad(opt Option[int]) -> int {
    match opt {
        Some(v) => v
        None    => "not an int"     // type mismatch
    }
}
