// Plan 55 Ф.2 — match-arm pattern_inner_type из scrutinee.
//
// `match opt { Some(v) => v; None => fallback }` — `v` имеет тип
// `inner T` от scrutinee (`Option[T]`). До fix'а: infer не учитывал
// pattern bindings из scrutinee → result типизировался случайно
// (стрэйл `var_types[v]` или fallback default).
//
// Параллель Rust/Swift: exhaustive type inference, `v` всегда T.

module plan55.f2_match_some_v_inference


fn unwrap_or_int(opt Option[int], fallback int) -> int {
    match opt {
        Some(v) => v
        None    => fallback
    }
}


fn unwrap_or_str(opt Option[str], fallback str) -> str {
    match opt {
        Some(v) => v
        None    => fallback
    }
}


fn unwrap_or_bool(opt Option[bool], fallback bool) -> bool {
    match opt {
        Some(v) => v
        None    => fallback
    }
}


test "match Some(v) — int inner" {
    assert(unwrap_or_int(Some(42), 0) == 42)
    ro none_int Option[int] = None
    assert(unwrap_or_int(none_int, -1) == -1)
}


test "match Some(v) — str inner" {
    assert(unwrap_or_str(Some("hello"), "fb") == "hello")
    ro none_str Option[str] = None
    assert(unwrap_or_str(none_str, "fb") == "fb")
}


test "match Some(v) — bool inner" {
    assert(unwrap_or_bool(Some(true), false) == true)
    ro none_bool Option[bool] = None
    assert(unwrap_or_bool(none_bool, false) == false)
}
