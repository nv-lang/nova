// Fast variant — reduced parameters. Full test: f1_closure_array_gc_stress_slow.nv
//
// Plan 55 Ф.1 — GC stress test для `[]fn` closure storage.
// Fast: 1000 closures × 5 циклов (reduced from 50 cycles).

module plan55.f1_closure_array_gc_stress


fn run_one() -> int {
    mut arr []fn() -> int = []
    for i in 0..1000 {
        arr.push(|| i + 1)
    }
    mut sum = 0
    for f in arr {
        sum = sum + f()
    }
    sum
}


test "1000 closures × 5 циклов — heap bounded [fast]" {
    // Fast variant: 5 cycles instead of 50 (1/10th).
    // Warm-up + reset
    ro _ = run_one()
    gc.collect()
    gc.reset_stats()
    ro baseline = gc.heap_size()

    for _ in 0..5 {
        ro _ = run_one()
    }
    gc.collect()
    ro after = gc.heap_size()

    // Bounded growth: malloc-backend (baseline=0) → after=0 (always trivial).
    // Boehm — позволяем рост × 4.
    ro upper = if baseline == 0 { 8 * 1024 * 1024 } else { baseline * 4 }
    assert(after <= upper)
}
