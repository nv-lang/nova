// Plan 55 Ф.4 — repro mono-pass type-context corruption.
//
// Добавление @clone() в HashMap триггерит mono-pass для @maybe_grow(),
// @find_slot() chain, и type-context corrupts. Без fix'а — массивная
// регрессия (-21 PASS).
//
// Этот тест — просто использование HashMap (без @clone). После того
// как @clone() будет добавлен в stdlib (после fix mono-pass), этот
// тест должен продолжать работать без регрессий.

module plan55.f4_hashmap_clone_method

import std.collections.hashmap.{HashMap}


test "HashMap base operations работают" {
    let m HashMap[str, int] = ["a": 1, "b": 2, "c": 3]
    assert(m.len() == 3)
    assert(m.get("a") == Some(1))
}


test "HashMap insert после литерала работает" {
    let mut m HashMap[str, int] = ["a": 1, "b": 2]
    m.insert("c", 3)
    m.insert("d", 4)
    assert(m.len() == 4)
}


test "HashMap rehash (триггер @maybe_grow через много insert'ов)" {
    let mut m HashMap[int, int] = [0: 0]
    for i in 1..50 {
        m.insert(i, i * 2)
    }
    assert(m.len() == 50)
    assert(m.get(25) == Some(50))
}
