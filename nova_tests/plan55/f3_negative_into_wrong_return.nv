// Plan 55 Ф.3 — negative: inferred return type — type mismatch на caller.
// `@into() => 42` inferred как i64, но caller использует как str → CC type error.

module nova_tests.plan55


type Thing { x i64 }


// `=> 42` инфирится как i64.
export fn Thing @into() => 42


// EXPECT_CC_ERROR incompatible
fn use_as_str() {
    ro t = Thing { x: 1 }
    ro s str = t.into()    // expected str, returns i64 → CC type mismatch
}
