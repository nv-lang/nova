// Plan 55 Ф.5 — nested map literals inferring type chain.

module plan55.f5_nested_map_infer

import std.collections.hashmap.{HashMap}


test "let m = [str: int] множественное использование" {
    let m1 = ["x": 10, "y": 20]
    let m2 = ["a": 1, "b": 2, "c": 3]
    assert(m1.len() == 2)
    assert(m2.len() == 3)
    assert(m1.get("x") == Some(10))
    assert(m2.get("c") == Some(3))
}


test "[k:v] в выражении для conditional" {
    let m = if true { ["a": 1] } else { ["a": 2] }
    assert(m.get("a") == Some(1))
}
