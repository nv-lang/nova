// Plan 55 Ф.6 — 3 instances одного generic type в одной fn.

module plan55.f6_triple_generic_instance


fn id[T](x T) -> T => x


test "id[int], id[str], id[bool] в одной fn без instance leak" {
    let a = id[int](42)
    let b = id[str]("hello")
    let c = id[bool](true)
    assert(a == 42)
    assert(b == "hello")
    assert(c == true)
}


fn pair_first[A, B](a A, b B) -> A => a
fn pair_second[A, B](a A, b B) -> B => b


test "pair_first/pair_second различные A/B" {
    let x = pair_first[int, str](1, "x")
    let y = pair_second[str, int]("y", 2)
    assert(x == 1)
    assert(y == 2)
}
