// Plan 55 Ф.3 — call-chain через method'ы с inferred return type.
// Тестирует что caller правильно типизирует chain'd calls когда
// inner methods НЕ имеют explicit `-> T`.

module plan55.f3_inferred_return_type_chain


type Box {
    n i64
}


// Без annotations — infered all из body.
export fn Box @value() => @n
export fn Box @doubled() => @n * 2
export fn Box @label() => "Box(" + str.from(@n) + ")"


// Chain: caller использует .doubled() + .value() + .label().
fn describe(b Box) -> str => b.label() + " value=" + str.from(b.value()) + " doubled=" + str.from(b.doubled())


test "inferred i64 from `=> @n`" {
    let b = Box { n: 21 }
    assert(b.value() == 21)
}


test "inferred i64 from `=> @n * 2`" {
    let b = Box { n: 21 }
    assert(b.doubled() == 42)
}


test "inferred str from `=> @n + ...`" {
    let b = Box { n: 7 }
    let s = b.label()
    assert(s == "Box(7)")
}


test "chained inferred-types в одном expression" {
    let b = Box { n: 10 }
    let s = describe(b)
    assert(s == "Box(10) value=10 doubled=20")
}
