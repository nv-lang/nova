// Plan 104.9 neg: str.len is not a method (replaced by byte_len() in Plan 152.x).
// nova-lsp completion now surfaces byte_len(), not len.
// EXPECT_COMPILE_ERROR [E_STR_NO_LEN]
module plan104_9.neg_str_len_removed

test "str does not have .len field" {
    ro s = "hello"
    ro n = s.len
    assert(n == 5)
}
