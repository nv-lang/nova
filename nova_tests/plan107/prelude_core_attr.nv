// Plan 107 Ф.7 — `#prelude(core, runtime)` makes Option/Result/panic visible.

#prelude(core, runtime)
module plan107.prelude_core_attr

test "prelude(core, runtime) — Option visible" {
    let x Option[int] = Some(42)
    assert(x == Some(42))
}

test "prelude(core, runtime) — Result visible" {
    let r Result[int, str] = Ok(1)
    assert(r == Ok(1))
}

test "prelude(core, runtime) — assert visible (runtime)" {
    assert(true)
}
