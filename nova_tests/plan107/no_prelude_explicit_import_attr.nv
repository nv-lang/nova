// Plan 107 –§.7 ‚Äî `#no_prelude` + manual import of Option/assert.
// Positive: module compiles, Option/assert explicitly imported.

#no_prelude
module plan107.no_prelude_explicit_import_attr

import std.prelude.core.{Option, Some, None}
import std.prelude.runtime.{assert}

fn make_opt(x int) -> Option[int] {
    Some(x)
}

test "no_prelude + explicit import ‚Äî Option visible" {
    let o = make_opt(7)
    assert(o.is_some())
}
