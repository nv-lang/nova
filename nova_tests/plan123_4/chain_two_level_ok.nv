// Plan 123.4 T1.1: @parent.inner accessed 2+ times → chain cached.

module nova_tests.plan123_4

type Inner2 {
    ro value int
}

type Outer3 {
    ro inner Inner2
    ro mark int
}

fn Outer3 @sum_with_chain() -> int {
    // 3 reads of @inner.value (= chain length 2 = "inner.value").
    @inner.value + @inner.value + @inner.value + @mark
}

fn Outer3.new(v int, m int) -> Outer3 {
    Outer3 { inner: Inner2 { value: v }, mark: m }
}

test "chain @inner.value cached" {
    ro o = Outer3.new(7, 5)
    ro r = o.sum_with_chain()
    // 3*7 + 5 = 26.
    assert(r == 26)
}
