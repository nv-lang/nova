// Plan 123.4 T-NEG.2: chain accessed only once → not cached
// (threshold not met). Multi single-occurrence chains coexist.

module nova_tests.plan123_4

type Pair_C3 {
    ro a Pair_C_Sub
    ro b Pair_C_Sub
}

type Pair_C_Sub {
    ro v int
}

fn Pair_C3 @first_each() -> int {
    @a.v + @b.v
}

fn Pair_C3.new(av int, bv int) -> Pair_C3 {
    Pair_C3 { a: Pair_C_Sub { v: av }, b: Pair_C_Sub { v: bv } }
}

test "single-access chains skipped" {
    ro p = Pair_C3.new(3, 7)
    assert(p.first_each() == 10)
}
