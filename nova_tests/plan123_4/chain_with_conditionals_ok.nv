// Plan 123.4 T1.6: chain reads spanning if-else branches.

module plan123_4.chain_with_conditionals_ok

type Wrap {
    ro inner Wrap_Inner
}

type Wrap_Inner {
    ro flag int
    ro data int
}

fn Wrap @select_value() -> int {
    if @inner.flag > 0 {
        @inner.data + @inner.data
    } else {
        @inner.flag * 0 + 100
    }
}

fn Wrap.new(f int, d int) -> Wrap {
    Wrap { inner: Wrap_Inner { flag: f, data: d } }
}

test "chain caching across branches" {
    assert(Wrap.new(1, 5).select_value() == 10)
    assert(Wrap.new(0, 99).select_value() == 100)
}
