// Plan 169.1.1 Ф.1: positive category — basic compute test (no EXPECT_* marker).
// Validates that default `nova test` picks up tests without any EXPECT_* marker.
module nova_tests.plan169

test "pos: sum 1..10" {
    mut sum = 0
    for i in 1..=10 {
        sum = sum + i
    }
    assert(sum == 55)
}

test "pos: string length" {
    ro s = "hello"
    assert(s.byte_len() == 5)
}

test "pos: boolean logic" {
    assert(true && !false)
    assert(!(false || false))
}
