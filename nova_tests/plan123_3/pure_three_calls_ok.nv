// Plan 123.3 T1.6: three calls of pure method → single cached.

module plan123_3.pure_three_calls_ok

type Sum {
    ro a int
    ro b int
    ro c int
}

#pure
fn Sum @total() -> int => @a + @b + @c

fn Sum @triple() -> int {
    @total() + @total() + @total()
}

fn Sum.new(a int, b int, c int) -> Sum {
    Sum { a, b, c }
}

test "three calls — cached once" {
    ro s = Sum.new(1, 2, 3)
    ro r = s.triple()
    assert(r == 18)  // 6 * 3
}
