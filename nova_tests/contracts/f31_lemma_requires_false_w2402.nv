// Ф.31.3 (Plan 33.6): lemma c `requires false` → W2402 (vacuous precondition).
// EXPECT_COMPILE_WARNING W2402

module nova_tests.contracts

lemma vacuous_lemma(x int)
    requires false
    ensures result == x
=> x

#verify
fn caller1(x int) -> int
    requires x >= 0
    ensures result >= 0
{
    apply vacuous_lemma(x)
    x
}
