// EXPECT_COMPILE_ERROR нарушает контракт эффекта
// Plan 33.5 Ф.5.2: Liskov-верификация — отрицательный тест.
// Handler возвращает константу 5, но ensures требует result == 10.
// Trivial backend: 5 == 10 → false → Liskov-нарушение.

module nova_tests.contracts.liskov_handler_fail

type ConstEffect effect {
    get_ten() -> int
        ensures result == 10
}

test "liskov handler fail" {
    with #verify ConstEffect = effect ConstEffect {
        get_ten() => 5
    } {
        ro r = ConstEffect.get_ten()
        assert(r == 5)
    }
}
