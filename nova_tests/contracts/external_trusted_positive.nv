// Ф.4.2 (Plan 33.6): #trusted external fn — ensures становятся axioms.
// Z3 доказывает контракт caller через UF + forall axiom.
// REQUIRES_SMT_BACKEND z3

module contracts.external_trusted_positive

#trusted
external fn libc_abs(x int) -> int
    ensures result >= 0

#verify
fn use_abs(x int) -> int
    ensures result >= 0
{
    libc_abs(x)
}

test "trusted external fn acceptance" {
    assert(libc_abs(5) >= 0)
    assert(libc_abs(-3) >= 0)
}
