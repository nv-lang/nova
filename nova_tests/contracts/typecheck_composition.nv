// EXPECT_COMPILE_ERROR calling user function `helper` in contracts requires `#pure` attribute
//
// Plan 33.2 Ф.7 (D24): composition разрешён только для #pure функций.
// Без #pure атрибута — compile error.

module nova_tests.contracts.typecheck_composition

// БЕЗ #pure — нельзя использовать в контракте.
fn helper(x int) -> int => x + 1

fn caller(x int) -> int
    requires helper(x) > 0
=> x
