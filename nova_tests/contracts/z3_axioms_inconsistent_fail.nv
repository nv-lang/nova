// EXPECT_COMPILE_ERROR axioms of effect `Db` are inconsistent
// REQUIRES_SMT_BACKEND z3
//
// Plan 33.3 Ф.9.5: pre-flight check on module load. Если conjunction
// axioms эффекта unsatisfiable, любая verify-formula под этими
// axioms становится trivially proven (vacuously, под `false`).
// Compiler ловит этот «cheat» до per-fn verify.

module contracts.z3_axioms_inconsistent_fail

type Db effect {
    #pure balance(id int) -> int
    axiom non_negative(id) => balance(id) >= 0
    axiom always_negative(id) => balance(id) < 0
}
