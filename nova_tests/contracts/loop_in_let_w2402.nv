// SOUNDNESS_REGRESSION — Plan 33.8 Ф.7: стережёт закрытую soundness-дыру.
//
// Plan 33.8 Ф.6.4: цикл внутри значения `let` (block-выражение). До Ф.6.4
// `collect_loop_preservation/decreases_in_block` спускались только в
// `Stmt::Expr` — такой цикл молча пропускался, preservation НЕ проверялась.
// Теперь спуск в `Stmt::Let` → цикл найден; тело model-incomplete
// (условное присваивание) → fail-safe W2402 (Ф.2.1).
// EXPECT_COMPILE_WARNING W2402

module contracts.loop_in_let_w2402

fn sum_in_let(n int) -> int
    requires n >= 0
{
    ro total = {
        mut i = 0
        mut s = 0
        while i < n
            invariant s >= 0
        {
            if i > 0 { s = s + 1 }
            i = i + 1
        }
        s
    }
    total
}
