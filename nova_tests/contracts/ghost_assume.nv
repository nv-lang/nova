// Plan 33.3 + Ф.9.1: ghost let + assume.
//
// Ghost erasure: `ghost let x = ...` не emit'ится в codegen (Verus/Dafny
// semantics). Non-ghost код не может читать ghost-vars (TODO: enforce
// в type-check полностью; пока только naturally через codegen-erasure).

module contracts.ghost_assume

fn use_ghost(x int) -> int {
    // ghost let — spec-only, не emit'ится в codegen.
    // В runtime значение не существует; читать его из non-ghost кода
    // нельзя (codegen эрейзит).
    ghost ro initial_snapshot = x
    // initial_snapshot можно использовать в спеке (requires/ensures),
    // но не в обычном коде.
    x
}

fn use_assume(x int) -> int {
    assume x >= 0      // программист утверждает x >= 0
    x + 1
}

test "ghost + assume" {
    assert(use_ghost(5) == 5)
    assert(use_assume(3) == 4)
}
