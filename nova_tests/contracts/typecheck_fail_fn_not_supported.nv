// EXPECT_COMPILE_ERROR contracts on `Fail`-returning functions not yet supported in Plan 33.1
//
// Plan 33.1 Ф.4 (D24): контракты на Fail-функциях требуют ContractResult +
// flow-аналитики для result.is_ok / result.value / result.error. Полная
// реализация — Ф.3 SMT integration. В 33.1 — explicit compile error.

module nova_tests.contracts.typecheck_fail_fn_not_supported

type Overdraft | Overdraft

fn withdraw_with_fail(amount int) Fail[Overdraft] -> int
    requires amount > 0
    ensures result == amount
=> amount
