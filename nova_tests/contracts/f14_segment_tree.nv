// Plan 33.3 Ф.14: Dafny-parity test 18 — Segment tree properties.
// Range query / update arithmetic invariants.

module contracts.f14_segment_tree

// Node count for n leaves: 2*n - 1.
#verify
fn seg_tree_size(n int) -> int
    requires n >= 1
    ensures result == 2 * n - 1
    ensures result >= n
{
    2 * n - 1
}

// Leaf index (1-based): n + i - 1 (0-based i).
#verify
fn leaf_index(n int, i int) -> int
    requires n >= 1 && i >= 0 && i < n
    ensures result >= n - 1
{
    n + i - 1
}

// Parent of node i: (i - 1) / 2.
#verify
fn parent_index(i int) -> int
    requires i > 0
    ensures result >= 0 && result < i
{
    (i - 1) / 2
}

// Left child of i: 2*i + 1.
#verify
fn left_child(i int) -> int
    requires i >= 0
    ensures result > i
{
    2 * i + 1
}

// Right child of i: 2*i + 2.
#verify
fn right_child(i int) -> int
    requires i >= 0
    ensures result > i
{
    2 * i + 2
}

// Range [lo, hi] split at mid: both halves valid.
#verify
fn range_split(lo int, hi int) -> bool
    requires lo < hi
    ensures result == true
{
    lo <= lo + (hi - lo) / 2 && lo + (hi - lo) / 2 < hi
}

test "f14 segment tree" {
    assert(seg_tree_size(8) == 15)
    assert(leaf_index(8, 0) == 7)
    assert(parent_index(3) == 1)
    assert(left_child(2) == 5)
    assert(right_child(2) == 6)
    assert(range_split(0, 8) == true)
}
