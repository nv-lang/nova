// Ф.1.3 (Plan 33.6): handler с branching под #trusted → OK, не проверяется.

module nova_tests.contracts

type Db9 effect {
    SetBalance(id int, amount int)
    #pure balance(id int) -> int
    axiom after_set(id, x) => post(SetBalance(id, x))(balance(id)) == x
}

test "handler с branching под #trusted компилируется" {
    mut store = 0
    with #trusted Db9 = effect Db9 {
        SetBalance(id, amount) {
            if amount >= 0 {
                store = amount  // branching — trusted, не проверяется
            }
        }
        balance(id) => store
    } {
        Db9.SetBalance(1, 42)
        assert(Db9.balance(1) == 42)
    }
}
