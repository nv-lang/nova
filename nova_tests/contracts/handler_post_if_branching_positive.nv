// Ф.11.5 (Plan 33.6): handler с if-branching в action body —
// extract_block_assignments извлекает оба branches как ite.
// REQUIRES_SMT_BACKEND z3v2
// (Под TrivialBackend post-axiom вернёт Unknown — нужен Z3 для решения ite.
//  Под Z3 V1 symbolic-exec тоже даёт Disproved на branching action — требует
//  Plan 33.5 Ф.6 V2 handler-exec extension. Gated на фиктивный backend
//  `z3v2` чтобы skip до реализации V2 — fixture сохранён для будущей сессии.)

module nova_tests.contracts

type Flag3 effect {
    SetFlag(v bool)
    #pure get_flag() -> bool
    axiom after_set(v) => post(SetFlag(v))(get_flag()) == v
}

test "handler if-branching post-axiom" {
    mut store = false
    with #verify Flag3 = effect Flag3 {
        SetFlag(v) {
            if v {
                store = true
            } else {
                store = false
            }
        }
        get_flag() => store
    } {
        Flag3.SetFlag(true)
        assert(Flag3.get_flag() == true)
    }
}
