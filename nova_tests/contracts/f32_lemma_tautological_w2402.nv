// Ф.32.1 (Plan 33.6): lemma c ensures идентичными requires → W2402 (tautological).
// EXPECT_COMPILE_WARNING W2402

module nova_tests.contracts

// requires x >= 0; ensures x >= 0 — лемма не добавляет ничего нового.
lemma identity_lemma(x int)
    requires x >= 0
    ensures x >= 0
=> x

#verify
fn caller2(x int) -> int
    requires x >= 0
    ensures result >= 0
{
    apply identity_lemma(x)
    x
}
