// REQUIRES_SMT_BACKEND z3
// Plan 33.5 Ф.6: post(Action)(view) symbolic exec V2.
// Верификация аксиомы post(SetBalance(id, x))(balance(id)) == x.
// Handler: SetBalance assigns store = amount; balance reads store.
// TrivialBackend не может доказать x==x после symbolic rewrite — нужен Z3.

module contracts.post_action_view_positive

type Db effect {
    SetBalance(id int, amount int)
    #pure balance(id int) -> int
    axiom after_set(id, x) => post(SetBalance(id, x))(balance(id)) == x
}

test "post action view symbolic exec" {
    mut store = 0
    with #verify Db = effect Db {
        SetBalance(id, amount) { store = amount }
        balance(id) => store
    } {
        Db.SetBalance(1, 42)
        assert(Db.balance(1) == 42)
    }
}
