// EXPECT_COMPILE_ERROR external function `bad` cannot have contracts
//
// Plan 33.1 Ф.1 (D24): extern "nova" fn не может иметь requires/ensures
// в 33.1 (полная поддержка с `@trusted` атрибутом — в Plan 33.3).

module contracts.parse_external_with_contract

extern "nova" fn bad(x int) -> int
    requires x > 0
