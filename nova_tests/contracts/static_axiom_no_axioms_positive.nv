// Ф.7.5 positive (Plan 33.6): handler без axiom — W2402 не эмитится.
// verify_handlers пропускает effects без axioms.

module nova_tests.contracts

type Greeter effect {
    greet() -> str
}

fn use_greeter() -> str
{
    "hello"
}

test "handler без axioms → no W2402" {
    with #verify Greeter = effect Greeter {
        greet() => "hi"
    } {
        assert(use_greeter() == "hello")
    }
}
