// Plan 33.3 Ф.9.4: fn с `decreases` и правильной recursion → проходит
// без panic (depth не превышает limit).

module nova_tests.contracts

fn factorial1(n int) -> int
    requires n >= 0
    decreases n
=> if n == 0 { 1 } else { n * factorial1(n - 1) }

fn fib(n int) -> int
    requires n >= 0
    decreases n
=> if n < 2 { n } else { fib(n - 1) + fib(n - 2) }

test "decreases correct recursion" {
    assert(factorial1(5) == 120)
    assert(factorial1(0) == 1)
    assert(fib(10) == 55)
}
