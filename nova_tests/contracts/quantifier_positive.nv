module contracts.quantifier_positive

// D.1.3: forall/exists quantifier expressions in contracts.
// TrivialBackend не reasoning'ует над forall'ами (возвращает Unknown),
// поэтому тест проверяет parse + codegen + runtime correctness.

fn sum_nonneg(n int) -> int
    requires n >= 0
    requires forall i in 0..n : i >= 0
{
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    s
}

test "sum_nonneg computes correctly" {
    assert(sum_nonneg(5) == 10)
    assert(sum_nonneg(0) == 0)
    assert(sum_nonneg(1) == 0)
}
