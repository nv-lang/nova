// Ф.13.2 (Plan 33.6): handler с match-branching по constant patterns.
// extract_match_assignments конвертирует в nested ite.
// REQUIRES_SMT_BACKEND z3v2
// (V2 handler-exec: parser сейчас не принимает `pat => stmt` с assignment
//  внутри `match`-arm для action body, и нет extract_match_assignments
//  логики. Gated на `z3v2` — fixture для Plan 33.5 Ф.6 V2 session.)

module contracts.handler_post_match_const_positive

type Setter effect {
    SetByCode(c int)
    #pure get_value() -> int
    axiom after_code_0(c) => post(SetByCode(c))(get_value()) == c
}

test "handler match-branching const patterns" {
    mut store = 0
    with #verify Setter = effect Setter {
        SetByCode(c) {
            match c {
                0 => store = 0,
                1 => store = 1,
                _ => store = c,
            }
        }
        get_value() => store
    } {
        Setter.SetByCode(5)
        assert(Setter.get_value() == 5)
    }
}
