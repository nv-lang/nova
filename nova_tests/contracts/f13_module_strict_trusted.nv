// Plan 33.3 Ф.13 acceptance test: #must_verify_module.
//
// Проверяет: #must_verify_module — все функции модуля MustVerify без явного #verify.
// Любой unproven контракт → compile error.
// #trusted extern "nova" fn тестируется в parse-only тесте (extern "nova" fn ограничен std.runtime.*).

#must_verify_module
module nova_tests.contracts

// Без #verify, но #must_verify_module → MustVerify автоматически.
fn double1(x int) -> int
    ensures result == x * 2
{
    x * 2
}

// Тоже без #verify — MustVerify через модуль.
fn add_one(x int) -> int
    ensures result == x + 1
{
    x + 1
}

// Функция без контрактов — MustVerify не применяется (нет контрактов).
fn identity2(x int) -> int {
    x
}

test "f13 module strict mode" {
    assert(double1(5) == 10)
    assert(double1(0) == 0)
    assert(add_one(3) == 4)
    assert(identity2(7) == 7)
}
