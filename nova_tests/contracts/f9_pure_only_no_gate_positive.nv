// Plan 33.3 Ф.9 (refactor): effect с #pure но БЕЗ axiom — gate НЕ
// срабатывает. Handler без атрибута допустим (нечего верифицировать).

module nova_tests.contracts

type Db6 effect {
    SetBalance(id int, amount int)
    #pure balance(id int) -> int
    // axiom отсутствует → gate не активируется
}

test "no gate without axiom" {
    mut store = 0
    with Db6 = effect Db6 {
        SetBalance(id, amount) { store = amount }
        balance(id) => store
    } {
        Db6.SetBalance(1, 42)
        assert(Db6.balance(1) == 42)
    }
}
