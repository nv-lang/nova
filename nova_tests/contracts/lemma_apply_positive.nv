// Plan 33.5 Ф.4.1: apply lemma в теле функции — активирует ensures леммы как SMT-аксиому.
// Рефлексивные леммы (trivial backend provable) + apply в caller fn.

module nova_tests.contracts

lemma double_lemma(x int)
    ensures result == x * 2
=> x * 2

#verify
fn use_lemma3(n int) -> int
    ensures result == n * 2
{
    apply double_lemma(n)
    n * 2
}

test "lemma apply positive" {
    assert(use_lemma3(3) == 6)
    assert(use_lemma3(0) == 0)
}
