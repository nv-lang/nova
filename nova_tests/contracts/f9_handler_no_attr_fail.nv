// EXPECT_COMPILE_ERROR handler for effect `Db` must be marked
//
// Plan 33.3 Ф.9.6: handler-gate. Эффект `Db` имеет pure_view → любой
// `with Db = handler` обязан быть `#verify_handler` или
// `#trusted_handler`. Без атрибута — compile error.

module contracts.f9_handler_no_attr_fail

type Db effect {
    SetBalance(id int, amount int)
    pure_view balance(id int) -> int
}

test "handler без attribute → error" {
    let mut store = 0
    with Db = handler Db {
        SetBalance(id, amount) { store = amount }
        balance(id) => store
    } {
        Db.SetBalance(1, 100)
    }
}
