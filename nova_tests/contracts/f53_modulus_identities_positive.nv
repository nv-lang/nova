// Ф.53 (Plan 33.6): TrivialBackend modulus identities.
// Ф.53.1: a % 1 → 0  (любое число mod 1 = 0)
// Ф.53.2: a % a → 0  (non-zero — spec assumption)

module contracts.f53_modulus_identities_positive

#verify
fn mod_by_one(x int) -> int
    ensures result == 0
{
    x % 1
}

#verify
fn mod_by_self(x int) -> int
    requires x >= 1
    ensures result == 0
{
    x % x
}

test "modulus identities" {
    assert(mod_by_one(7) == 0)
    assert(mod_by_self(5) == 0)
}
