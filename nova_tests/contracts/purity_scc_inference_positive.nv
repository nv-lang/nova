// Ф.3 (Plan 33.5): Purity SCC inference.
// fn is_positive3 без @pure авто-определяется как pure через SCC,
// можно использовать в requires другой функции.

module nova_tests.contracts

// Нет @pure — должно быть авто-выведено через SCC.
fn is_positive3(x int) -> bool => x > 0

fn safe_div(a int, b int) -> int
    requires is_positive3(b)
{
    a / b
}

test "purity_scc_inferred" {
    assert(is_positive3(5) == true)
    assert(is_positive3(-1) == false)
    assert(safe_div(10, 2) == 5)
}
