// Ф.34.1 (Plan 33.6): ensures_fail на fn без Fail effect → W2402.
// EXPECT_COMPILE_WARNING W2402

module contracts.f34_ensures_fail_no_fail_w2402

// Нет Fail в effects, но есть ensures_fail — unreachable warning.
#verify
fn safe_compute(x int) -> int
    requires x >= 0
    ensures result >= 0
    ensures_fail false
{
    x
}
