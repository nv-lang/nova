// Plan 33.3 Ф.9 (refactor): protocol разрешает #pure + axiom.
// В V1 axioms в protocol trusted-by-default (impl не верифицируется).
//
// Тест: парсинг + type-check проходят без ошибок.

module nova_tests.contracts

type Storage2 protocol {
    #pure @size() -> int
    axiom non_negative() => size() >= 0
}

test "protocol with #pure and axiom parses and type-checks" {
    assert(1 + 1 == 2)
}
