// Plan 33.3 Ф.9 (refactor): #verify и #trusted на with-binding.
// Effect имеет axiom → gate требует атрибут → #trusted пропускает.

module nova_tests.contracts

type Counter4 effect {
    Increment()
    #pure value() -> int
    axiom non_negative() => value() >= 0
}

test "#trusted handler passes gate" {
    mut n = 0
    with #trusted Counter4 = effect Counter4 {
        Increment() { n = n + 1 }
        value() => n
    } {
        Counter4.Increment()
        Counter4.Increment()
        assert(Counter4.value() == 2)
    }
}
