// Plan 33.3 (refactor): axiom с тремя типизированными биндерами.
// Проверяет, что парсер и type-check принимают аксиомы с 3 параметрами.

module nova_tests.contracts

type Ledger effect {
    #pure balance(from int, to int) -> int
    axiom non_negative(from int, to int) => balance(from, to) >= 0
    axiom symmetric(from int, to int, limit int) => balance(from, to) >= limit
}

test "multi-param typed binders" {
    assert(1 + 1 == 2)
}
