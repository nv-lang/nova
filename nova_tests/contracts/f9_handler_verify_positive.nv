// Plan 33.3 Ф.9.6: positive — handler для эффекта с axiom помечен
// `#trusted`, gate пропускает.

module nova_tests.contracts

type Db5 effect {
    SetBalance(id int, amount int)
    #pure balance(id int) -> int
    axiom non_negative(id) => balance(id) >= 0
}

test "trusted handler for axiom-bearing effect type-checks" {
    mut store = 0
    with #trusted Db5 = effect Db5 {
        SetBalance(id, amount) { store = amount }
        balance(id) => store
    } {
        Db5.SetBalance(1, 100)
        assert(Db5.balance(1) == 100)
    }
}
