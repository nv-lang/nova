// Plan 33.3 Ф.9.6: positive — handler с pure_view-эффектом помечен
// `#trusted_handler`, gate пропускает.

module contracts.f9_handler_verify_positive

type Db effect {
    SetBalance(id int, amount int)
    pure_view balance(id int) -> int
}

test "trusted handler for pure_view effect type-checks" {
    let mut store = 0
    with #trusted_handler Db = handler Db {
        SetBalance(id, amount) { store = amount }
        balance(id) => store
    } {
        Db.SetBalance(1, 100)
        assert(Db.balance(1) == 100)
    }
}
