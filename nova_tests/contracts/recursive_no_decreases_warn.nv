// SOUNDNESS_REGRESSION — Plan 33.8 Ф.7: стережёт закрытую soundness-дыру.
module nova_tests.contracts

fn count_down5(n int) -> int
    requires n >= 0
    ensures result == 0
{
    if n == 0 { 0 } else { count_down5(n - 1) }
}
