// REQUIRES_SMT_BACKEND trivial
// EXPECT_COMPILE_WARNING opaque fn `double2` called without `reveal double2`
// EXPECT_COMPILE_WARNING opaque fn `double2` was revealed but TrivialBackend
//
// Plan 33.9 Ф.4 (positive): opaque fn call under TrivialBackend → W2402 with
// an opaque-aware message. TrivialBackend cannot discharge opaque-fn contracts;
// the message names the fn and points at `reveal` / Z3.
// Trivial-specific: under Z3 the contract is proven, so the opaque-aware
// W2402 wording does not appear — REQUIRES_SMT_BACKEND trivial pins the test.
//
// Two cases, both asserted by distinct message substrings:
//   1. No reveal   → "called without `reveal double2`"
//   2. With reveal → "was revealed but TrivialBackend"
// Default verify mode → Unknown becomes W2402 (warning, not error).

module nova_tests.contracts

#opaque #pure
fn double2(x int) -> int
    requires x >= 0
    ensures result >= 0
=> x + x

// Case 1: no reveal → message tells user to add `reveal double2`.
fn caller_no_reveal(n int) -> int
    requires n >= 0
    ensures result >= 0
{
    double2(n)
}

// Case 2: with reveal → message tells user TrivialBackend cannot discharge
// the reveal-injected quantified axiom; use Z3.
fn caller_with_reveal1(n int) -> int
    requires n >= 0
    ensures result >= 0
{
    reveal double2
    double2(n)
}
