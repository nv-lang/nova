// Plan 33.2 Ф.8: `assert_static <bool>` — intermediate proof obligation.

module nova_tests.contracts.assert_static

fn use_assert_static(x int) -> int {
    assert_static x == x
    assert_static 1 + 1 == 2
    assert_static (true && true)
    x
}

test "assert_static tautologies" {
    assert(use_assert_static(5) == 5)
}
