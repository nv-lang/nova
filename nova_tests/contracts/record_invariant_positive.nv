// Plan 33.3 Ф.9.2: record invariant auto-enforce — positive.
//
// `Account2 { balance: 100 }` где invariant `balance >= 0` проходит check.

module nova_tests.contracts

type Account2 {
    balance int
}
    invariant balance >= 0

test "record invariant positive" {
    ro a = Account2 { balance: 100 }
    ro b = Account2 { balance: 0 }
    assert(a.balance == 100)
    assert(b.balance == 0)
}
