// EXPECT_COMPILE_ERROR ghost variable `spec_only` cannot be read in non-ghost code
//
// Plan 33.3 Ф.9.1 + Ф.9.7: ghost var не доступен в non-ghost коде.
// Теперь catch'ится на type-check этапе (proper compile-error),
// не на C-level (где была undeclared identifier как honest fallback).

module nova_tests.contracts.ghost_read_from_nonghost_fail

fn bad_ghost(x int) -> int {
    ghost let spec_only = x * 2
    spec_only + 1
}
