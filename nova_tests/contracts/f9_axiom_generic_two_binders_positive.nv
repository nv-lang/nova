module contracts.f9_axiom_generic_two_binders_positive

type Store effect {
    #pure get(key int) -> int
    axiom bounded[T, U](k T, limit U) => get(0) >= 0
}

test "two generic params in axiom" {
    assert(1 + 1 == 2)
}
