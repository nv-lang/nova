// Ф.16.3 (Plan 33.6): TrivialBackend strict-monotone const multiply.
// `requires x >= 0; ensures 2 * x >= 0` доказывается через const-mul check.

module contracts.trivial_const_mul_positive

#verify
fn double_non_neg(x int) -> int
    requires x >= 0
    ensures 2 * x >= 0
{
    2 * x
}

test "const mul trivial positive" {
    assert(double_non_neg(0) == 0)
    assert(double_non_neg(7) == 14)
}
