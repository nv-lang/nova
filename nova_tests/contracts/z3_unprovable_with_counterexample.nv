// EXPECT_COMPILE_ERROR contract violation in `bad_double`
// REQUIRES_SMT_BACKEND z3
//
// Plan 33 Z3 milestone: counterexample test. Trivial backend ловит
// только `result == const` mismatches; Z3 находит symbolic
// counterexample для linear-arith.
//
// `bad_double` обещает `result == x * 2` но возвращает `x + x + 1`.
// При x=0: result=1, должно быть 0 → counterexample x=0.
//
// Запуск с NOVA_SMT_BACKEND=z3.

module contracts.z3_unprovable_with_counterexample

#verify
fn bad_double(x int) -> int
    ensures result == x * 2
=> x + x + 1
