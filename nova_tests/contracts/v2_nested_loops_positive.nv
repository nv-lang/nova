// Ф.9.9 (Plan 33.6): V2 coverage — nested loops с invariants.
// Outer loop sum, inner loop count — both have invariants.

module contracts.v2_nested_loops_positive

fn nested_sum(n int) -> int
    requires n >= 0
    ensures result >= 0
{
    let mut total = 0
    let mut i = 0
    while i < n
        invariant i >= 0
        invariant total >= 0
        decreases n - i
    {
        let mut j = 0
        while j < i
            invariant j >= 0
            invariant total >= 0
            decreases i - j
        {
            total = total + 1
            j = j + 1
        }
        i = i + 1
    }
    total
}

test "nested loops positive" {
    assert(nested_sum(0) == 0)
    assert(nested_sum(3) == 3)
}
