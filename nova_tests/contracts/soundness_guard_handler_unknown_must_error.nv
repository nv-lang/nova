// EXPECT_COMPILE_ERROR E2402
// REQUIRES_SMT_BACKEND trivial
//
// Ф.1.4 soundness regression guard (Plan 33.6):
// Handler с branching под #verify → E2402.
// Если silent-skip вернётся — этот тест упадёт.
// Z3-вариант: handler-exec V1 успешно Disproves (другой error path) —
// gated на trivial; V2 даст positive coverage в отдельном тесте.

module contracts.soundness_guard_handler_unknown_must_error

type Store effect {
    Set(v int)
    #pure get() -> int
    axiom after_set(v) => post(Set(v))(get()) == v
}

test "handler branching под #verify должен давать E2402" {
    let mut s = 0
    with #verify Store = handler Store {
        Set(v) {
            if v > 0 { s = v }  // branching — V1 не поддерживает
        }
        get() => s
    } {
        Store.Set(5)
    }
}
