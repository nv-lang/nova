// REQUIRES_SMT_BACKEND z3
//
// Plan 33.9 Ф.5 (upgraded from V1 parse smoke): opaque + reveal + fuel verified by Z3.
// Previously (V1) this was a parse-only smoke test; now that Z3 axiomatic encoding is
// implemented, verification works and proves ensures under reveal.

module contracts.f58_opaque_parse_smoke

// #opaque + #pure + #fuel(2) — все три attribute composable.
#opaque #pure #fuel(2)
fn opaque_helper(x int) -> int
    requires x >= 0
    ensures result >= 0
=> x + x

// Caller uses reveal — parser принимает statement.
#verify
fn use_opaque(n int) -> int
    requires n >= 0
    ensures result >= 0
{
    reveal opaque_helper
    opaque_helper(n)
}

test "opaque + reveal + fuel parse smoke" {
    assert(opaque_helper(5) == 10)
    assert(use_opaque(7) == 14)
}
