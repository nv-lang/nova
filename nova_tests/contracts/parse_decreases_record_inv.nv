// Plan 33.2 Ф.7: parse decreases для fn + record invariants.

module nova_tests.contracts

// Record invariant.
type Account1 {
    balance int
}
    invariant balance >= 0

// Recursive function с decreases (parser принимает, SMT-verify в 33.3).
#unverified
fn factorial2(n int) -> int
    requires n >= 0
    decreases n
=> if n == 0 { 1 } else { n * factorial2(n - 1) }

// Decreases на не-recursive fn — тоже валидно (assertion).
#unverified
fn add1(a int, b int) -> int
    requires a >= 0
    requires b >= 0
    decreases 0
=> a + b

test "decreases + record invariant parse" {
    ro acc = Account1 { balance: 100 }
    assert(acc.balance == 100)
    assert(factorial2(5) == 120)
    assert(add1(3, 4) == 7)
}
