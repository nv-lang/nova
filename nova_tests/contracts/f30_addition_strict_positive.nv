// Ф.30.2 (Plan 33.6): TrivialBackend addition `>` strict.
// `requires x >= 5; requires y >= 5; ensures result > 0 { x + y }` —
// lower(x)+lower(y) = 10 >= effective_goal(1) → true.

module contracts.f30_addition_strict_positive

#verify
fn sum_strict_positive(x int, y int) -> int
    requires x >= 5
    requires y >= 5
    ensures result > 0
{
    x + y
}

// requires x >= 10; ensures result > 5 { x + 0 }
#verify
fn shifted_strict(x int) -> int
    requires x >= 10
    ensures result > 5
{
    x + 0
}

test "addition strict positive" {
    assert(sum_strict_positive(5, 5) == 10)
    assert(shifted_strict(11) == 11)
}
