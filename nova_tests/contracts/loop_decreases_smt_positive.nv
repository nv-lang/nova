// Ф.1.3 (Plan 33.5): Loop decreases SMT verify.
// while i > 0 decreases i { i -= 1 } — Z3 verifies termination.

module nova_tests.contracts

fn count_down2(n int) -> int
    requires n >= 0
{
    mut i = n
    while i > 0 decreases i {
        i -= 1
    }
    i
}

test "count_down2 terminates" {
    assert(count_down2(5) == 0)
    assert(count_down2(0) == 0)
}
