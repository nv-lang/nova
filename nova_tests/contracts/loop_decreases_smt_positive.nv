// Ф.1.3 (Plan 33.5): Loop decreases SMT verify.
// while i > 0 decreases i { i -= 1 } — Z3 verifies termination.

module nova_tests.contracts.loop_decreases_smt_positive

fn count_down(n int) -> int
    requires n >= 0
{
    let mut i = n
    while i > 0 decreases i {
        i -= 1
    }
    i
}

test "count_down terminates" {
    assert(count_down(5) == 0)
    assert(count_down(0) == 0)
}
