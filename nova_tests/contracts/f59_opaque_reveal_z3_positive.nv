// REQUIRES_SMT_BACKEND z3
//
// Plan 33.9 Ф.5: opaque fn + reveal — Z3 verifies caller contract.
// Without reveal, Z3 sees _pure_fn_double(x) as uninterpreted function and
// cannot prove result == x * 2. With reveal, the body axiom is injected and
// Z3 can prove the ensures.

module nova_tests.contracts

#opaque #pure
fn double3(x int) -> int
    requires x >= 0
    ensures result >= 0
=> x * 2

#verify
fn caller_with_reveal2(n int) -> int
    requires n >= 0
    ensures result == n * 2
{
    reveal double3
    double3(n)
}

test "opaque reveal z3 positive" {
    assert(double3(5) == 10)
    assert(caller_with_reveal2(7) == 14)
}
