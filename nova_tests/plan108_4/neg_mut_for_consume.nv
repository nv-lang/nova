// EXPECT_COMPILE_ERROR E_PROTO_IMPL_MUT_FOR_CONSUME
// Plan 108.4 Ф.2: protocol declares `consume @close()`, impl uses mut receiver.

#no_prelude
module plan108_4.neg_mut_for_consume

type Closeable protocol {
    consume @close()
}

#impl(Closeable)
type Handle { fd int }

// mut receiver — mismatch: protocol requires consume
fn Handle mut @close() { @fd = -1 }
