// Plan 123.2 T1.9: semantic equivalence — runtime result identical
// regardless of LICM ON/OFF. Verified by test runner under env vars.

module plan123_2.licm_escape_hatch_ok

type Inv {
    ro x int
    ro y int
}

fn Inv @combo(n int) -> int {
    mut total = 0
    mut i = 0
    while i < n {
        total = total + @x + @y + @x * @y
        i = i + 1
    }
    total
}

fn Inv.new(x int, y int) -> Inv {
    Inv { x, y }
}

test "escape hatch — runtime semantic preserved" {
    ro v = Inv.new(2, 3)
    ro r = v.combo(4)
    // 4 × (2+3+6) = 4 × 11 = 44.
    assert(r == 44)
}
