// Plan 123.2 T1.9: semantic equivalence — runtime result identical
// regardless of LICM ON/OFF. Verified by test runner under env vars.

module nova_tests.plan123_2

type Inv3 {
    ro x int
    ro y int
}

fn Inv3 @combo(n int) -> int {
    mut total = 0
    mut i = 0
    while i < n {
        total = total + @x + @y + @x * @y
        i = i + 1
    }
    total
}

fn Inv3.new(x int, y int) -> Inv3 {
    Inv3 { x, y }
}

test "escape hatch — runtime semantic preserved" {
    ro v = Inv3.new(2, 3)
    ro r = v.combo(4)
    // 4 × (2+3+6) = 4 × 11 = 44.
    assert(r == 44)
}
