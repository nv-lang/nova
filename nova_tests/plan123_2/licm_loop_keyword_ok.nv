// Plan 123.2 T1.4: `loop { ... break ... }` form.

module nova_tests.plan123_2

type Wrap3 {
    ro limit int
}

fn Wrap3 @find_first() -> int {
    mut x = 0
    loop {
        if x >= @limit + @limit { break }
        x = x + 1
    }
    x
}

fn Wrap3.new(l int) -> Wrap3 {
    Wrap3 { limit: l }
}

test "loop keyword form — @limit hoisted" {
    ro w = Wrap3.new(5)
    ro r = w.find_first()
    // limit*2 = 10, x increments from 0 to 10.
    assert(r == 10)
}
