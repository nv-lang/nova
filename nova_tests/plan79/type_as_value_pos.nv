// Plan 79 Ф.4: positive — proper value construction compiles. A record
// literal and a constructor call ARE values; only the bare type name is
// the misuse Ф.4 rejects. Guards against false positives.

module nova_tests.plan79

type Widget2 { w int }

fn Widget2.new(w int) -> Widget2 => { w }
fn use_widget(x Widget2) -> int => x.w

test "Ф.4 — record literal and constructor are values" {
    ro a Widget2 = { w: 1 }       // record literal — a value
    ro b = Widget2.new(2)         // constructor call — a value
    assert(use_widget(a) == 1)
    assert(use_widget(b) == 2)
}
