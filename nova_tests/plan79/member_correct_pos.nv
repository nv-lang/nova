// Plan 79 Ф.3: positive — valid field and method access compiles and
// runs. Guards against false positives.

module plan79.member_correct_pos

type Account { owner str, balance int }

fn Account @summary() -> str => @owner
fn Account mut @deposit(amount int) { @balance += amount }

test "Ф.3 — valid field/method access compiles" {
    mut a Account = { owner: "alice", balance: 100 }
    assert(a.balance == 100)        // field access
    assert(a.owner == "alice")      // field access
    a.deposit(50)                   // method call
    assert(a.balance == 150)
    assert(a.summary() == "alice")  // method call
}
