// EXPECT_COMPILE_ERROR E_PROTOCOL_RENAMED
//
// Plan 137 (D237) — NEG P05:
// `#impl(Printable)` → E_PROTOCOL_RENAMED: use `#impl(Display)`.
module plan137.p05_neg_protocol_renamed_printable

#impl(Printable)
type Greeting {
    msg str
}

test "Printable is renamed to Display" {
    ro g = Greeting { msg: "hi" }
    assert(g.msg == "hi")
}
