// Plan 137 (D237) — POS P15:
// `@debug` method works in `${expr:?}` interpolation.
module plan137.p15_debug_protocol

type Pair {
    a int
    b int
}

fn Pair @debug(mut w Write) -> () {
    w.write("Pair { a: ")
    w.write(str.from(@a))
    w.write(", b: ")
    w.write(str.from(@b))
    w.write(" }")
}

test "Debug @debug works in :? interpolation" {
    ro p = Pair { a: 1, b: 2 }
    ro s = "${p:?}"
    assert(s == "Pair { a: 1, b: 2 }")
}
