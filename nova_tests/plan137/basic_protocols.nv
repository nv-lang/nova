// Plan 137 (D237) — basic protocol rename smoke test.
// Verifies: Hash, Equal, Compare, Clone, Display, Debug all work.

module nova_tests.plan137


// ── Hash ──────────────────────────────────────────────────────────

type Color2 { r u8, g u8, b u8 }

fn Color2 @hash() -> u64 =>
    (@r as u64) * 65536 + (@g as u64) * 256 + (@b as u64)

test "Hash — determinism" {
    ro c = Color2 { r: 255, g: 0, b: 128 }
    assert(c.hash() == c.hash())
}

test "Hash — different values differ" {
    ro red = Color2 { r: 255, g: 0, b: 0 }
    ro blue = Color2 { r: 0, g: 0, b: 255 }
    assert(red.hash() != blue.hash())
}


// ── Equal ─────────────────────────────────────────────────────────

type Point2 { x int, y int }

fn Point2 @equal(other Point2) -> bool => @x == other.x && @y == other.y

test "Equal — basic equality" {
    ro a = Point2 { x: 1, y: 2 }
    ro b = Point2 { x: 1, y: 2 }
    assert(a.equal(b))
}

test "Equal — inequality" {
    ro a = Point2 { x: 1, y: 2 }
    ro b = Point2 { x: 9, y: 2 }
    assert(!a.equal(b))
}

test "Equal — operator == uses @equal" {
    ro a = Point2 { x: 10, y: 20 }
    ro b = Point2 { x: 10, y: 20 }
    assert(a == b)
}

test "Equal — operator != uses @equal" {
    ro a = Point2 { x: 1, y: 1 }
    ro b = Point2 { x: 2, y: 2 }
    assert(a != b)
}


// ── Compare ───────────────────────────────────────────────────────

type Money2 { cents int }

fn Money2 @compare(other Money2) -> int => @cents - other.cents

test "Compare — less returns negative" {
    ro a = Money2 { cents: 10 }
    ro b = Money2 { cents: 20 }
    assert(a.compare(b) < 0)
}

test "Compare — equal returns zero" {
    ro a = Money2 { cents: 50 }
    ro b = Money2 { cents: 50 }
    assert(a.compare(b) == 0)
}

test "Compare — greater returns positive" {
    ro a = Money2 { cents: 100 }
    ro b = Money2 { cents: 50 }
    assert(a.compare(b) > 0)
}

test "Compare — operators < / > / <= / >=" {
    ro a = Money2 { cents: 10 }
    ro b = Money2 { cents: 20 }
    assert(a < b)
    assert(b > a)
    assert(a <= a)
    assert(b >= b)
}


// ── Display ───────────────────────────────────────────────────────

type Pair2 { x int, y int }

fn Pair2 @display(mut w Write) -> () {
    w.write("(")
    w.write(str.from(@x))
    w.write(", ")
    w.write(str.from(@y))
    w.write(")")
}

test "Display — @display method works" {
    ro p = Pair2 { x: 3, y: 4 }
    consume sb = StringBuilder.new()
    p.display(sb)
    assert(sb.as_str() == "(3, 4)")
}

test "Display — interp-string uses @display" {
    ro p = Pair2 { x: 7, y: 8 }
    ro s = "${p}"
    assert(s == "(7, 8)")
}
