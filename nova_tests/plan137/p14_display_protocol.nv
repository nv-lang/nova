// Plan 137 (D237) — POS P14:
// `@display` method works in string interpolation.
module plan137.p14_display_protocol

type Point {
    x int
    y int
}

fn Point @display(mut w Write) -> () {
    w.write_str("Point(")
    w.write_str(str.from(@x))
    w.write_str(", ")
    w.write_str(str.from(@y))
    w.write_str(")")
}

test "Display @display works in interpolation" {
    ro p = Point { x: 3, y: 4 }
    ro s = "${p}"
    assert(s == "Point(3, 4)")
}
