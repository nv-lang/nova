// Plan 137 (D237) — POS P14:
// `@display` method works in string interpolation.
module nova_tests.plan137

type Point4 {
    x int
    y int
}

fn Point4 @display(mut w Write) -> () {
    w.write("Point4(")
    w.write(str.from(@x))
    w.write(", ")
    w.write(str.from(@y))
    w.write(")")
}

test "Display @display works in interpolation" {
    ro p = Point4 { x: 3, y: 4 }
    ro s = "${p}"
    assert(s == "Point4(3, 4)")
}
