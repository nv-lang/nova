// Plan 137 (D237) — POS P11:
// `#impl(Equal)` на record → auto-derive @equal; == / != operators.
module nova_tests.plan137

#impl(Equal)
type Money4 {
    cents int
}

fn Money4 @compare(other Money4) -> int => @cents - other.cents

test "Equal auto-derive works via compare" {
    ro a = Money4 { cents: 100 }
    ro b = Money4 { cents: 100 }
    ro c = Money4 { cents: 200 }
    assert(a == b)
    assert(a != c)
}
