// [M-125-method-call-never-detection] positive — static method `Type.method()`
// с `-> never` тоже детектится.

module nova_tests.plan125_followups

type Errors2 {}

fn Errors2.boom(reason str) -> never => panic("Errors2.boom: ${reason}")

fn pick(c bool) -> int {
    if c {
        42
    } else {
        Errors2.boom("got false")
    }
}

test "static-method-never in else picks int from then" {
    assert(pick(true) == 42)
}
