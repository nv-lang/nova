// [M-125-unreachable-builtin] positive — unreachable() в expression-position.
// Проверяет что unreachable интегрирован с divergence-aware inference Plan 125:
// тип if-expr = тип не-unreachable ветки.

module nova_tests.plan125_followups

fn classify2(n int) -> str {
    if n == 0 {
        "zero"
    } else if n > 0 {
        "pos"
    } else if n < 0 {
        "neg"
    } else {
        unreachable("int trichotomy violated")
    }
}

test "unreachable in else picks str from other branches" {
    assert(classify2(0) == "zero")
    assert(classify2(5) == "pos")
    assert(classify2(-3) == "neg")
}
