// [M-125-method-call-never-detection] positive — user-type instance
// method с `-> never` детектится как divergent в if-expr inference.

module nova_tests.plan125_followups

type Logger2 { tag str }

fn Logger2 @fail(msg str) -> never => panic("[${@tag}] FATAL: ${msg}")

fn classify1(log Logger2, c bool) -> str {
    if c {
        "ok"
    } else {
        log.fail("invariant violated")
    }
}

test "method-never in else picks str from then" {
    ro logger = Logger2 { tag: "test" }
    assert(classify1(logger, true) == "ok")
}
