// [M-125-codegen-never-cast] positive — f64 target type.
// (different scalar — exercises typed_zero_value_125 float branch)

module plan125_followups.never_cast_f64_target

fn ratio(num f64, denom f64) -> f64 {
    if denom == 0.0 {
        panic("zero denominator")
    } else {
        num / denom
    }
}

test "f64 if-expr with panic in then" {
    ro r = ratio(10.0, 4.0)
    assert(r == 2.5)
}
