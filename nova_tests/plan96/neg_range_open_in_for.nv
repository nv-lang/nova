// EXPECT_COMPILE_ERROR open-ended Range
//
// Plan 96 Ф.2 — негатив: open-ended Range в for-loop → compile error.
// `for x in 3..` не имеет смысла (нет верхней границы для остановки).
// Open-ended Range допустим **только** в slice-context (arr[3..]).

module nova_tests.plan96.neg_range_open_in_for

fn main() -> () {
    let mut sum = 0
    for x in 3.. {
        sum = sum + x
    }
}
