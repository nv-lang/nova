// EXPECT_RUNTIME_PANIC array: index -1 out of bounds for length 3
//
// Plan 96 Ф.1 — негатив: arr[-1] → panic, НЕ wrap-around.
// Nova не следует Python-семантике negative-index wrap.

module nova_tests.plan96.neg_index_negative

fn main() -> () {
    let mut arr = [10, 20, 30]
    let _ = arr[-1]
}
