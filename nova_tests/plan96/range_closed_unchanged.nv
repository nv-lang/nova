// Plan 96 Ф.2 — regression: closed-form Range (a..b, a..=b) работает
// без изменений после AST-миграции Option<Box<Expr>>.

module plan96.range_closed_unchanged

test "exclusive range in for-loop" {
    mut sum = 0
    for i in 0..5 {
        sum = sum + i
    }
    assert(sum == 10)
}

test "inclusive range in for-loop" {
    mut sum = 0
    for i in 1..=5 {
        sum = sum + i
    }
    assert(sum == 15)
}
