// Plan 96 Ф.4 — позитив: slice работает для []byte (mono check).
// Net-byte-friendly: copy_from срезов = быстрые network/crypto-ops.

module plan96.slice_byte_array

test "byte slice" {
    ro buf []u8 = [0x48, 0x65, 0x6c, 0x6c, 0x6f, 0x21]
    ro header = buf[0..2]
    ro payload = buf[2..]
    assert(header.len() == 2)
    assert(header[0] == 0x48)
    assert(payload.len() == 4)
    assert(payload[0] == 0x6c)
}

test "byte slice copy_from" {
    ro src []u8 = [0xAA, 0xBB, 0xCC, 0xDD]
    mut dst []u8 = [0, 0]
    dst.copy_from(src[1..3])
    assert(dst[0] == 0xBB)
    assert(dst[1] == 0xCC)
}
