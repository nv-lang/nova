// Plan 96 Ф.4 D-str-slice — позитив: s[a..b] для строк (codepoint-indexed,
// panic при OOB). Унифицирует idiom: arr[a..b] ≡ str[a..b].

module nova_tests.plan96.str_slice_basic

test "basic str slice" {
    let s = "hello"
    let part = s[1..4]
    assert(part == "ell")
}

test "str slice from start" {
    let s = "hello world"
    let part = s[0..5]
    assert(part == "hello")
}

test "empty str slice" {
    let s = "hello"
    let part = s[2..2]
    assert(part == "")
}

test "str slice inclusive" {
    let s = "abcde"
    let part = s[1..=3]
    assert(part == "bcd")
}
