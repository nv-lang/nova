// Plan 96 Ф.1 — позитив: индексация в границах не падает.
// arr[0] и arr[len-1] — крайние валидные позиции.

module nova_tests.plan96.boundary_ok

test "arr[0] and arr[len-1] don't panic" {
    let arr = [10, 20, 30, 40, 50]
    assert(arr[0] == 10)
    assert(arr[4] == 50)
}

test "single-element array boundary" {
    let arr = [42]
    assert(arr[0] == 42)
}
