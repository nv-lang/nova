// EXPECT_RUNTIME_PANIC str: slice
//
// Plan 96 Ф.4 D-str-slice — негатив: s[a..b] с OOB → panic
// (НЕ clamp, в отличие от старого s.slice(a, b) метода).
// Plan 152.1 (D249): str получил собственный byte-range slice-путь →
// паника `str: slice [a..b] out of bounds for byte-length N` (была общая
// `array: slice ... length` от Vec-пути). Директива обновлена под новый текст.

module plan96.neg_str_slice_oob

fn main() -> () {
    ro s = "abc"
    ro _ = s[0..100]
}
