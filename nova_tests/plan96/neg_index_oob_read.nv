// EXPECT_RUNTIME_PANIC array: index 100 out of bounds for length 3
//
// Plan 96 Ф.1 — негатив: чтение arr[i] при i >= len → panic.
// До Plan 96 codegen эмитил raw `arr->data[100]` (UB read).
//
// `fn main` (не `test`-блок): panic должен дойти до runtime-frame
// (внутри test-блока он перехватывается harness'ом).

module plan96.neg_index_oob_read

fn main() -> () {
    mut arr = [1, 2, 3]
    ro _ = arr[100]
}
