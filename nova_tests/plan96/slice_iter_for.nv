// Plan 96 Ф.5 D-iter-snap — позитив: for x in arr[a..b] работает.
// View это []T → for-in использует view->len как snapshot (Go-style).

module nova_tests.plan96.slice_iter_for

test "for-in over slice view" {
    let mut arr = [10, 20, 30, 40, 50]
    let view = arr[1..4]
    let mut sum = 0
    for x in view {
        sum = sum + x
    }
    assert(sum == 90)
}

test "for-in over open-ended slice" {
    let mut arr = [1, 2, 3, 4, 5]
    let view = arr[2..]
    let mut count = 0
    for _ in view {
        count = count + 1
    }
    assert(count == 3)
}
