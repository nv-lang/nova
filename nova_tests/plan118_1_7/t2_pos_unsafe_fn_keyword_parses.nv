// Plan 118.1.7 Ф.4 T2 POS — `unsafe fn` and `external unsafe fn` keyword syntax parses.
// D2 amend / D216 §9: `unsafe fn` is the canonical keyword form (not `#unsafe fn`).
//
// A-118.1.7.a: `unsafe fn foo()` parses, unsafe_attr=true.
// A-118.1.7.b: `external unsafe fn foo()` parses, unsafe_attr=true.
// A-118.1.7.c: call inside `unsafe {}` — accepted.

module plan118_1_7.t2_pos_unsafe_fn_keyword_parses

// Nova unsafe fn — keyword syntax (Plan 118.1.7).
unsafe fn add_unsafe(a i64, b i64) -> i64 {
    a + b
}

// External unsafe fn — keyword syntax (D2 amend). Declaration only; no call (no C shim).
export external unsafe fn p118_1_7_extern_placeholder(x int) -> ()

test "unsafe fn keyword — parses and callable from unsafe block" {
    ro result = unsafe { add_unsafe(7, 8) }
    assert(result == 15)
}

test "external unsafe fn keyword — declaration parses without error" {
    // Declaration-only smoke: verifies parser accepts `external unsafe fn`.
    // No call (linker symbol not provided). Checker must not reject the declaration.
    assert(1 == 1)
}
