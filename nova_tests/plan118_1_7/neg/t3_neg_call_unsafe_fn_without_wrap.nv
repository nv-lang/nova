// Plan 118.1.7 Ф.4 T3 NEG — calling `unsafe fn` outside `unsafe {}` → error.
// D216 §9 enforcement: call-site must wrap in unsafe block.
//
// A-118.1.7.c: E_UNSAFE_CALL_REQUIRES_WRAP.
//
// EXPECT_COMPILE_ERROR E_UNSAFE_CALL_REQUIRES_WRAP

module neg.t3_neg_call_unsafe_fn_without_wrap

unsafe fn risky(x i64) -> i64 {
    x + 1
}

test "calling unsafe fn without unsafe wrap — rejected" {
    // Direct call to unsafe fn outside unsafe {} block — must be rejected.
    ro v = risky(5)
    assert(v == 6)
}
