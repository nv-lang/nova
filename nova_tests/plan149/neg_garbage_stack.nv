// neg_garbage_stack.nv — Plan 149 D233 AC5: garbage NOVA_FIBER_STACK → warn +
// default, NEVER crash.
//
// NOVA_FIBER_STACK="banana" is unparseable (no leading digits). The arena
// prints ONE stderr diagnostic ("invalid NOVA_FIBER_STACK ... using default
// 4MB") and falls back to the builtin 4MB default — the program runs to
// completion normally and exits 0. EXPECT_STDERR asserts the warning is
// emitted; the test passing asserts no crash.
//
// NOVA_MAXPROCS=1 keeps it to one worker arena (one warning).
//
// ENV NOVA_FIBER_STACK=banana
// ENV NOVA_MAXPROCS=1
// EXPECT_STDERR invalid NOVA_FIBER_STACK

module nova_tests.plan149

test "garbage NOVA_FIBER_STACK: warn + default, program still runs" {
    mut total = 0
    supervised {
        mut i = 1
        while i <= 10 {
            ro cur = i
            spawn { total += cur }
            i += 1
        }
    }
    assert(total == 55)
}
