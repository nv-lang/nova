// neg_max_clamp.nv — Plan 149 D233 AC5: NOVA_MAX_FIBERS above SLOT_COUNT_MAX →
// clamp + warn, NEVER crash.
//
// NOVA_MAX_FIBERS=999999999 far exceeds the compile-time SLOT_COUNT_MAX
// (262144 on 64-bit / Windows). The arena rounds up to a multiple of 64 then
// CLAMPS to MAX, printing ONE stderr warning ("exceeds max ... clamped"). The
// program runs normally on the clamped slot count and exits 0. EXPECT_STDERR
// asserts the clamp warning; the test passing asserts no crash.
//
// NOVA_MAXPROCS=1 keeps it to one worker arena.
//
// ENV NOVA_MAX_FIBERS=999999999
// ENV NOVA_MAXPROCS=1
// EXPECT_STDERR exceeds max

module plan149.neg_max_clamp

test "huge NOVA_MAX_FIBERS: clamped to MAX, fibers still spawn" {
    mut total = 0
    supervised {
        mut i = 1
        while i <= 25 {
            ro cur = i
            spawn { total += cur }
            i += 1
        }
    }
    // 1 + 2 + ... + 25 = 325
    assert(total == 325)
}
