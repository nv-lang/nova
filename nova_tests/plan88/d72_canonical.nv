// Plan 88 Ф.3.2 — D72-канонический пример из spec/decisions/02-types.md
// §D72 «Порядок объявления параметров»:
//
//   fn func[K, T From[K]](v K) -> T => T.from(v)
//
// Двойной type-параметр; bound `From[K]` ссылается на ранее объявленный
// `K`. Static-вызов `T.from(v)` на typevar `T` + `K` в параметре —
// end-to-end через мономорфизацию (Rust-паритет).

module nova_tests.plan88.d72_canonical


type Label { s str }
fn Label.from(v str) -> Label => { s: v }

type Code { n int }
fn Code.from(v int) -> Code => { n: v }


fn func[K, T From[K]](v K) -> T => T.from(v)


test "D72 func[str, Label] — K=str, T=Label" {
    ro l = func[str, Label]("hello")
    assert(l.s == "hello")
}

test "D72 func[int, Code] — K=int, T=Code" {
    ro c = func[int, Code](42)
    assert(c.n == 42)
}
