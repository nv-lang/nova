// Test: blanket @bany, @ball (return bool, T appears in callback only)
module nova_tests.plan161

import std.collections.vec.{Vec}
import std.prelude.collections.{Next}
import std.collections.vec_iter.{FilterIter}

fn[I Next[T]] I mut @bany(pred fn(T) -> bool) -> bool {
    while true {
        match @next() {
            Some(x) => { if pred(x) { return true } },
            None => return false,
        }
    }
    false
}

fn[I Next[T]] I mut @ball(pred fn(T) -> bool) -> bool {
    while true {
        match @next() {
            Some(x) => { if !pred(x) { return false } },
            None => return true,
        }
    }
    true
}

test "blanket bany on FilterIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    assert(v.iter().filter(|x| x > 2).bany(|x| x == 4))
    assert(!v.iter().filter(|x| x > 2).bany(|x| x == 1))
}

test "blanket ball on FilterIter" {
    ro v = Vec[int].of(2, 4, 6, 8)
    assert(v.iter().filter(|x| x > 0).ball(|x| x % 2 == 0))
    assert(!v.iter().filter(|x| x > 0).ball(|x| x > 5))
}
