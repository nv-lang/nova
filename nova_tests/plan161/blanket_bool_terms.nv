// Test: blanket @bany, @ball (return bool, T appears in callback only)
module plan161.blanket_bool_terms

import std.collections.vec.{Vec}
import std.prelude.collections.{Next}
import std.collections.vec_iter_zc.{FilterIter}

fn[I Next[T]] I mut @bany(pred fn(T) -> bool) -> bool {
    while true {
        match @next() {
            Some(x) => { if pred(x) { return true } },
            None => return false,
        }
    }
    false
}

fn[I Next[T]] I mut @ball(pred fn(T) -> bool) -> bool {
    while true {
        match @next() {
            Some(x) => { if !pred(x) { return false } },
            None => return true,
        }
    }
    true
}

test "blanket bany on FilterIter" {
    ro v = Vec[int].from([1, 2, 3, 4, 5])
    assert(v.ziter().zfilter(|x| x > 2).bany(|x| x == 4))
    assert(!v.ziter().zfilter(|x| x > 2).bany(|x| x == 1))
}

test "blanket ball on FilterIter" {
    ro v = Vec[int].from([2, 4, 6, 8])
    assert(v.ziter().zfilter(|x| x > 0).ball(|x| x % 2 == 0))
    assert(!v.ziter().zfilter(|x| x > 0).ball(|x| x > 5))
}
