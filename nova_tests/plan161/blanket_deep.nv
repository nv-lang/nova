module plan161.blanket_deep

import std.collections.vec.{Vec}
import std.collections.vec_iter_zc

test "blanket chain depth 3" {
    ro v = Vec[int].of(1, 2, 3, 4, 5, 6)
    ro r = v.ziter()
        .zmap(|x| x * 2)
        .zfilter(|x| x > 4)
        .zcollect()
    assert(r == Vec[int].of(6, 8, 10, 12))
}
