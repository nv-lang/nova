// Test: blanket @bcount terminator — return type is just `int` (no T/U)
module nova_tests.plan161

import std.collections.vec.{Vec, VecIter}
import std.prelude.collections.{Next}
import std.collections.vec_iter.{MapIter, FilterIter}

// Blanket count — just counts elements, return type `int` has no type vars
fn[I Next[T]] I mut @bcount() -> int {
    mut n = 0
    while true {
        match @next() {
            Some(_) => { n = n + 1 },
            None => return n,
        }
    }
    n
}

test "blanket bcount on VecIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    mut it = v.iter()
    ro c = it.bcount()
    assert(c == 5)
}

test "blanket bcount on FilterIter (via existing filter)" {
    ro v = Vec[int].of(1, 2, 3, 4, 5, 6)
    ro c = v.iter().filter(|x| x % 2 == 0).bcount()
    assert(c == 3)
}

test "blanket bcount on MapIter (via existing map)" {
    ro v = Vec[int].of(1, 2, 3)
    ro c = v.iter().map(|x| x * 2).bcount()
    assert(c == 3)
}
