// Probe fixture for [M-161-parametric-return]: blanket methods with parametric
// return types: Vec[T], Option[T], and identity T return.
module plan161.blanket_param_return

import std.collections.vec.{Vec, VecIter}
import std.prelude.collections.{Next}
import std.collections.vec_iter_zc.{FilterIter}

// ── Vec[T] return ──────────────────────────────────────────────────────────

fn[I Next[T]] I mut @bcollect2() -> Vec[T] {
    mut out = Vec[T].new()
    while true {
        match @next() {
            Some(x) => out.push(x),
            None => return out,
        }
    }
    out
}

test "blanket collect Vec[T] on VecIter" {
    ro v = Vec[int].of(1, 2, 3)
    mut it = v.iter()
    ro r = it.bcollect2()
    assert(r == Vec[int].of(1, 2, 3))
}

test "blanket collect Vec[T] on FilterIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro r = v.ziter().zfilter(|x| x % 2 == 1).bcollect2()
    assert(r == Vec[int].of(1, 3, 5))
}

// ── Option[T] return (existing — verify still works) ──────────────────────

fn[I Next[T]] I mut @bfind2(pred fn(T) -> bool) -> Option[T] {
    while true {
        match @next() {
            Some(x) => { if pred(x) { return Some(x) } },
            None => return None,
        }
    }
    None
}

test "blanket find Option[T] on VecIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    mut it = v.iter()
    ro r = it.bfind2(|x| x > 3)
    assert(r.unwrap_or(0) == 4)
}
