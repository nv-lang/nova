// Test: blanket @bfold — Acc is separate generic, init/return is Acc
module plan161.blanket_fold

import std.collections.vec.{Vec}
import std.prelude.collections.{Next}
import std.collections.vec_iter_zc.{FilterIter}

fn[I Next[T]] I mut @bfold[Acc](init Acc, f fn(Acc, T) -> Acc) -> Acc {
    mut acc = init
    while true {
        match @next() {
            Some(x) => { acc = f(acc, x) },
            None => return acc,
        }
    }
    acc
}

test "blanket bfold on FilterIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro s = v.ziter().zfilter(|x| x % 2 == 1).bfold(0, |acc, x| acc + x)
    assert(s == 9) // 1+3+5
}
