// Plan 139 Ф.1 — concat/+ REMAIN C (nova_str_concat): the `+` operator lowers
// DIRECTLY to nova_str_concat in BinOp codegen, so the method alone cannot
// retire it. Regression guard: concat + `+` operator stay correct.
module nova_tests.plan139

test "concat method" {
    assert("ab".concat("cd") == "abcd")
    assert("".concat("x") == "x")
    assert("x".concat("") == "x")
    assert("".concat("") == "")
}

test "plus operator" {
    ro a = "foo"
    ro b = "bar"
    assert(a + b == "foobar")
    assert("a" + "b" + "c" == "abc")
}

test "concat with migrated methods composes" {
    ro s = "  Hi  "
    assert(s.trim_ascii().to_ascii_lower().concat("!") == "hi!")
}
