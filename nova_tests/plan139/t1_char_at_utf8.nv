// Plan 139 Ф.1 — char_at migrated to Nova-body (UTF-8 decode cursor, codepoint
// indexed; cp_to_char helper). None on OOB. Semantics identical to nova_str_char_at.
module plan139.t1_char_at_utf8

test "char_at ascii" {
    assert("abc".char_at(0) == Some('a'))
    assert("abc".char_at(1) == Some('b'))
    assert("abc".char_at(2) == Some('c'))
    assert("abc".char_at(3) == None)
    assert("abc".char_at(-1) == None)
}

test "char_at multibyte (codepoint indexed)" {
    ro s = "héllo"
    assert(s.char_at(0) == Some('h'))
    assert(s.char_at(1) == Some('é'))   // codepoint index 1, byte offset 1
    assert(s.char_at(2) == Some('l'))
    assert(s.char_at(4) == Some('o'))
    assert(s.char_at(5) == None)
}

test "char_at 3- and 4-byte codepoints" {
    ro s = "é€😀"
    assert(s.char_at(0) == Some('é'))
    assert(s.char_at(1) == Some('€'))
    assert(s.char_at(2) == Some('😀'))
    assert(s.char_at(3) == None)
}
