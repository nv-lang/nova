// Plan 139 Ф.1 — to_lower/to_upper migrated to Nova-body (ASCII case, alloc
// via []u8 + str.from_bytes_unchecked). Non-ASCII bytes pass through unchanged.
module plan139.t1_case

test "to_lower ascii" {
    assert("AbC".to_lower() == "abc")
    assert("HELLO".to_lower() == "hello")
    assert("already".to_lower() == "already")
    assert("".to_lower() == "")
    assert("123!@#".to_lower() == "123!@#")
}

test "to_upper ascii" {
    assert("AbC".to_upper() == "ABC")
    assert("hello".to_upper() == "HELLO")
    assert("ALREADY".to_upper() == "ALREADY")
    assert("".to_upper() == "")
    assert("123!@#".to_upper() == "123!@#")
}

test "case preserves non-ascii bytes" {
    // é is multibyte; ASCII case-fold must leave its bytes untouched.
    assert("héLLo".to_lower() == "héllo")
    assert("héllo".to_upper() == "HéLLO")
}

test "len preserved after case" {
    ro s = "MixedCase"
    assert(s.to_lower().byte_len() == s.byte_len())
    assert(s.to_upper().byte_len() == s.byte_len())
}
