// Plan 139 Ф.3 — hash/eq consistency: equal strings (by content) hash equal.
// str.@hash is FNV/SipHash over the bytes (nova_str_hash), so two byte-equal
// strings from distinct buffers must produce the same hash.
module plan139.t3_hash_eq_consistency

test "equal strings have equal hash (distinct buffers)" {
    ro a = "hello"
    ro b = "hel" + "lo"
    assert(a == b, "content equal")
    assert(a.hash() == b.hash(), "hash equal for equal strings")
}

test "empty string hash is stable and equal" {
    ro a = ""
    ro b = "x"[0..0]
    assert(a == b, "both empty")
    assert(a.hash() == b.hash(), "empty hashes equal")
}

test "self hash deterministic within run" {
    ro s = "deterministic"
    assert(s.hash() == s.hash(), "same value same hash")
}
