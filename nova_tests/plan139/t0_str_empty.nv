// Plan 139 Ф.0 — A0.1: empty literal `""` lowers to a valid value-record
// with len 0; len()/is_empty() behave.
module plan139.t0_str_empty

test "empty str has len 0 and is_empty" {
    ro e = ""
    assert(e.byte_len() == 0)
    assert(e.is_empty())
}

test "empty + concat yields the other operand" {
    ro e = ""
    ro s = e + "abc"
    assert(s == "abc")
    assert(s.byte_len() == 3)
}
