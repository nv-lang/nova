// Plan 139 Ф.3 (neg) — different-byte keys do NOT collide-match in a str-keyed
// HashMap. Behavioral negative: lookup with a key whose bytes differ from any
// inserted key must MISS (None), proving content-eq gates membership.
module nova_tests.plan139
import std.collections.hashmap.{HashMap}

test "lookup absent content key misses" {
    mut m = HashMap[str, int].new()
    m.insert("alpha", 1)
    m.insert("beta", 2)
    match m.get("gamma") {
        Some(_) => assert(false, "gamma must not be present")
        None => assert(true, "miss as expected")
    }
    assert(!m.contains("alph"), "prefix is not a key")
    assert(!m.contains("alphaa"), "suffix-extended is not a key")
}

test "case-different key misses" {
    mut m = HashMap[str, int].new()
    m.insert("Key", 5)
    assert(!m.contains("key"), "case differs -> miss")
    match m.get("KEY") {
        Some(_) => assert(false, "uppercase must miss")
        None => assert(true, "miss")
    }
}

test "removed key no longer matches" {
    mut m = HashMap[str, int].new()
    m.insert("x" + "y", 9)
    m.remove("xy")               // content-keyed removal
    assert(!m.contains("xy"), "removed by content")
}
