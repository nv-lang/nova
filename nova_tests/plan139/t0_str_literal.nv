// Plan 139 Ф.0 — A0.1/A0.4: str literal lowers to the value-record
// `{ ptr *u8, len int }` (C ABI image `nova_str`, sizeof 16, .len = bytes).
module nova_tests.plan139

test "str literal len is byte count (D26)" {
    ro s = "abc"
    assert(s.byte_len() == 3)
}

test "ascii literal byte-length" {
    ro s = "hello world"
    assert(s.byte_len() == 11)
}

test "multibyte literal counts BYTES not codepoints (D26 str.len = bytes)" {
    // "é" is 2 UTF-8 bytes; .byte_len() reports bytes.
    ro s = "é"
    assert(s.byte_len() == 2)
}
