// Plan 139 Ф.3 — str-keyed HashMap uses byte-content hash + eq (R11).
// Insert with a BUILT key (concat -> fresh buffer), look up with a LITERAL key
// (rodata buffer). Distinct pointers; must hit because the HashMap key path
// uses nova_str_hash + nova_str_eq (content), not pointer identity.
module plan139.t3_hashmap_str_key
import std.collections.hashmap.{HashMap}

test "insert built key, lookup literal key -> hit" {
    mut m = HashMap[str, int].new()
    m.insert("ab" + "c", 42)
    match m.get("abc") {
        Some(v) => assert(v == 42, "built-key lookup-via-literal hits")
        None => assert(false, "must hit")
    }
}

test "insert literal, lookup built key -> hit" {
    mut m = HashMap[str, int].new()
    m.insert("key", 7)
    ro built = "ke" + "y"
    match m.get(built) {
        Some(v) => assert(v == 7, "literal-key lookup-via-built hits")
        None => assert(false, "must hit")
    }
}

test "duplicate content key overwrites (content identity)" {
    mut m = HashMap[str, int].new()
    m.insert("dup", 1)
    m.insert("d" + "up", 2)        // same content, different buffer
    assert(m.len() == 1, "one entry, content-keyed")
    match m.get("dup") {
        Some(v) => assert(v == 2, "overwritten to 2")
        None => assert(false, "must hit")
    }
}

test "contains by content" {
    mut m = HashMap[str, int].new()
    m.insert("present", 99)
    assert(m.contains("pre" + "sent"), "contains by content")
    assert(!m.contains("absent"), "absent miss")
}
