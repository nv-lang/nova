// Plan 139 Ф.4 / A4.2 — sliced (mid-buffer) str → as_cstr allocates + NUL-
// terminates per D26 §3. A mid-buffer slice's backing buffer is NOT terminated
// at the slice's len (the next byte belongs to the parent), so a naive zero-copy
// CStr would make C strlen over-read into the parent. as_cstr() detects this
// (`ptr[len] != 0`) and falls back to a fresh len+1 NUL-terminated copy, so
// strlen sees exactly the slice length.
module nova_tests.plan139

import std.ffi.cstr.{CStr}

extern "nova" fn p139_cstr_strlen(c CStr) -> int

test "mid-buffer slice as_cstr terminates at slice len (no over-read)" {
    ro s = "hello world"
    ro sub = s[0..5]            // "hello" — parent byte at idx 5 is ' ', not NUL
    assert(sub.len() == 5)
    ro c = sub.as_cstr()
    assert(p139_cstr_strlen(c) == 5)   // 5, NOT 11 (parent length)
}

test "slice ending at parent len stays zero-copy-correct" {
    ro s = "hello world"
    ro tail = s[6..11]          // "world" — ends at parent.len → already terminated
    assert(tail.len() == 5)
    ro c = tail.as_cstr()
    assert(p139_cstr_strlen(c) == 5)
}

test "full literal str as_cstr is correct (already terminated)" {
    ro c = "abcdef".as_cstr()
    assert(p139_cstr_strlen(c) == 6)
}
