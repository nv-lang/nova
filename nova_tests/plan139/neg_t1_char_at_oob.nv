// Plan 139 Ф.1 — char_at OOB contract: out-of-range codepoint index returns
// None (SAFE, no panic), unlike byte_at which panics. This is the negative
// boundary fixture for the Nova-body char_at migration.
module nova_tests.plan139

test "char_at past end is None" {
    assert("abc".as_chars().nth(3) == None)
    assert("abc".as_chars().nth(100) == None)
}

test "char_at negative index is None" {
    assert("abc".as_chars().nth(-1) == None)
    assert("abc".as_chars().nth(-100) == None)
}

test "char_at on empty string is None" {
    assert("".as_chars().nth(0) == None)
    assert("".as_chars().nth(-1) == None)
}

test "char_at multibyte OOB by codepoint not byte" {
    ro s = "é"               // 1 codepoint, 2 bytes
    assert(s.as_chars().nth(0) == Some('é'))
    assert(s.as_chars().nth(1) == None)   // codepoint index 1 OOB even though byte 1 exists
}
