// Plan 139 Ф.0 — A0.1: str is a `value` type → copy semantics. Passing a
// str to a fn and rebinding the local does NOT affect the caller's binding.
module plan139.t0_str_pass_byvalue

fn rebind_local(s str) -> int {
    // local rebinding (copy of the 16-byte value-record handle)
    mut local = s
    local = local + "X"
    return local.len()
}

test "str passed by value; caller binding unchanged (copy semantics)" {
    ro original = "abc"
    ro inner_len = rebind_local(original)
    assert(inner_len == 4)        // local saw "abcX"
    assert(original.len() == 3)   // caller's str unchanged
    assert(original == "abc")
}
