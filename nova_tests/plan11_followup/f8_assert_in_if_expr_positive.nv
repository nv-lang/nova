module plan11_followup.f8_assert_in_if_expr_positive

// Plan 11 Follow-up: `assert(cond)` в expression position if-expression
// branch — same fix через comma-operator NOVA_UNIT cast.

test "assert в if-expression branch — compiles + runs" {
    ro n = 7
    if n > 0 {
        assert(n == 7)
    } else {
        assert(false)
    }
}

test "assert как last expression в block" {
    ro m = 10
    ro _ = {
        ro doubled = m * 2
        assert(doubled == 20)
    }
}
