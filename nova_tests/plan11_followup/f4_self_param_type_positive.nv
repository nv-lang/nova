module plan11_followup.f4_self_param_type_positive

// Plan 11 Follow-up: Self в **param type** (`other Self`) должен резолвиться
// в Nova_<Recv>* — pre-fix эмитил Nova_Self* (unknown type).

export type Pair[T] {
    a T
    b T
}

export fn Pair[T].new(a T, b T) -> Self =>
    { a, b }

export fn Pair[T] @swap_with(other Self) -> Self =>
    { a: other.a, b: other.b }

test "Self в param type generic instance method работает" {
    let p1 = Pair[int].new(1, 2)
    let p2 = Pair[int].new(10, 20)
    let p3 = p1.swap_with(p2)
    assert(p3.a == 10)
    assert(p3.b == 20)
}
