module plan11_followup.f15_stringbuilder_consumed_negative

// EXPECT_RUNTIME_PANIC string builder consumed
//
// Sprint F.36: StringBuilder.@into() ставит consumed flag. Subsequent
// mutating ops (append) триггерят runtime panic. Verify это поведение
// сохранено после добавления non-consuming методов.

test "append после @into() — runtime panic" {
    let mut sb = StringBuilder.new()
    sb.append("hello")
    let _ = sb.into()                     // consume
    sb.append(" world")                   // ← должен panic
}
