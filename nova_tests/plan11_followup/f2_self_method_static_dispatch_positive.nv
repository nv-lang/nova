module plan11_followup.f2_self_method_static_dispatch_positive

// Plan 11 Follow-up: Self.method() в static fn'е generic типа должен
// dispatch'иться в правильный mono'd Nova_<Recv>_static_<method>, не
// в free-fn nova_fn_<...>.

export type Holder[T] {
    v T
}

export fn Holder[T].new(v T) -> Self =>
    { v }

export fn Holder[T].dup(v T) -> Self =>
    Self.new(v)

test "Self.method() в static method generic типа работает" {
    ro c = Holder[int].dup(99)
    assert(c.v == 99)
}

test "Self.method() с разными generic instances" {
    ro ci = Holder[int].dup(7)
    ro cs = Holder[str].dup("hi")
    assert(ci.v == 7)
    assert(cs.v == "hi")
}
