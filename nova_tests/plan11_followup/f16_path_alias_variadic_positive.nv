module plan11_followup.f16_path_alias_variadic_positive

// Plan 63 Bug B / Fix B regression test:
// при `import X as p`, variadic flag должен пройти через alias.
// Раньше `p.Path.join(...)` падал в codegen как «assert не variadic».

import std.path.path as p

test "alias import: variadic Path.join via p.Path.join" {
    let r = p.Path.join("a", "b", "c")
    assert(r == "a/b/c")
}

test "alias import: spread через alias" {
    let parts []str = ["x", "y", "z"]
    let r = p.Path.join(...parts)
    assert(r == "x/y/z")
}

test "alias import: non-variadic Path.normalize через alias" {
    let r = p.Path.normalize("/a/b/../c")
    assert(r == "/a/c")
}
