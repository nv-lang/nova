module plan11_followup.f13_path_join_normalize_positive

// Sprint F.36: Path.join fixed (removed dead branch с consume-after-use)
// + Path.normalize workaround (let _ = stack.pop()).
//
// NB: variadic calls inside assert(...) parsed как spread-в-assert (compiler
// limitation). Используем helper vars везде.

import std._experimental.path.path.{Path}

test "Path.join: basic concatenation" {
    ro r = Path.join("a", "b", "c")
    assert(r == "a/b/c")
}

test "Path.join: absolute prefix" {
    ro r = Path.join("/usr", "bin")
    assert(r == "/usr/bin")
}

test "Path.join: strip leading slash на не-первой части" {
    ro r = Path.join("a", "/b")
    assert(r == "a/b")
}

test "Path.join: пропуск пустых частей" {
    ro r = Path.join("", "b")
    assert(r == "b")
}

test "Path.join: spread" {
    ro parts []str = ["x", "y", "z"]
    ro result = Path.join(...parts)
    assert(result == "x/y/z")
}

test "Path.normalize: basic collapse .." {
    ro r = Path.normalize("/a/b/../c")
    assert(r == "/a/c")
}

test "Path.normalize: collapse ." {
    ro r = Path.normalize("/a/./b")
    assert(r == "/a/b")
}

test "Path.normalize: relative .. вверх" {
    ro r = Path.normalize("a/b/..")
    assert(r == "a")
}

test "Path.normalize: collapse double slashes" {
    ro r = Path.normalize("//a//b//")
    assert(r == "/a/b")
}

test "Path.normalize: dot alone" {
    ro r = Path.normalize(".")
    assert(r == ".")
}

test "Path.normalize: double-dot alone (relative)" {
    ro r = Path.normalize("..")
    assert(r == "..")
}

test "Path.parent + basename" {
    ro par = Path.parent("/usr/bin/ls")
    ro base = Path.basename("/usr/bin/ls")
    assert(par == Some("/usr/bin"))
    assert(base == "ls")
}

test "Path.extension с dotfile" {
    ro e1 = Path.extension("file.txt")
    ro e2 = Path.extension("README")
    ro e3 = Path.extension(".bashrc")
    assert(e1 == Some("txt"))
    assert(e2 == None)
    assert(e3 == None)
}

test "Path.is_absolute" {
    ro abs1 = Path.is_absolute("/usr/bin")
    ro abs2 = Path.is_absolute("relative/path")
    ro abs3 = Path.is_absolute("")
    assert(abs1)
    assert(!abs2)
    assert(!abs3)
}
