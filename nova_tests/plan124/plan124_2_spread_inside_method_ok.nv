// Plan 124.2 — positive: record literal spread `...other` ВНУТРИ
// type-method scope разрешён (recv = Account_spreadinsidemethodok, has_priv allowed).
module nova_tests.plan124

export type Account_spreadinsidemethodok {
    priv mut money f64
    ro name str
}

export fn Account_spreadinsidemethodok.new(n str) -> Account_spreadinsidemethodok =>
    { money: 0.0, name: n }

// Static method scope — spread allowed (recv = Account_spreadinsidemethodok).
export fn Account_spreadinsidemethodok.rename(orig Account_spreadinsidemethodok, new_name str) -> Account_spreadinsidemethodok {
    Account_spreadinsidemethodok { ...orig, name: new_name }
}

test "Plan 124.2: spread allowed внутри static метода" {
    ro a = Account_spreadinsidemethodok.new("eve")
    ro b = Account_spreadinsidemethodok.rename(a, "eve2")
    assert(b.name == "eve2")
}
