// Plan 124.2 — positive: record spread на type WITHOUT priv fields,
// outside any type scope — OK (no priv concern).
module nova_tests.plan124

// Все public — нет priv → spread allowed везде.
export type Point_spreadnoprivoutsideok {
    ro x f64
    ro y f64
}

export fn Point_spreadnoprivoutsideok.origin() -> Point_spreadnoprivoutsideok => { x: 0.0, y: 0.0 }

fn shift(p Point_spreadnoprivoutsideok, dx f64) -> Point_spreadnoprivoutsideok {
    Point_spreadnoprivoutsideok { ...p, x: p.x + dx }
}

test "Plan 124.2: spread на public-only type — OK везде" {
    ro p = Point_spreadnoprivoutsideok.origin()
    ro q = shift(p, 5.0)
    assert(q.x == 5.0)
    assert(q.y == 0.0)
}
