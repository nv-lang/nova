// Plan 124.9 Р¤.2 вЂ” positive: nested literals where each level has
// multiple fields. Verifies field-type allocation is per-field, not
// inherited from the outermost type.
module nova_tests.plan124

type Cv3 {
    mut p int
    mut q int
}

type Bv4 {
    mut Cv3 Cv3
    mut tag int
}

type Av4 {
    mut Bv4 Bv4
    mut name int
}

test "nested literal with multiple fields per level" {
    mut av4 = Av4 { Bv4: Bv4 { Cv3: Cv3 { p: 1, q: 2 }, tag: 3 }, name: 4 }
    assert(av4.Bv4.Cv3.p == 1)
    assert(av4.Bv4.Cv3.q == 2)
    assert(av4.Bv4.tag == 3)
    assert(av4.name == 4)
    av4.Bv4.Cv3.q = 20
    av4.Bv4.tag = 30
    assert(av4.Bv4.Cv3.q == 20)
    assert(av4.Bv4.tag == 30)
}
