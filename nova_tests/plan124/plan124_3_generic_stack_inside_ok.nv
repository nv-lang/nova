// Plan 124.3 — positive: generic Stack_genericstackinsideok[T] с priv mut len + items array.
// Methods access priv через @len — recv tracking name-based, generic
// param ignored.
module nova_tests.plan124

export type Stack_genericstackinsideok[T] {
    priv mut len int
    ro capacity int
}

export fn Stack_genericstackinsideok[T].new(cap int) -> Stack_genericstackinsideok[T] =>
    { len: 0, capacity: cap }

export fn Stack_genericstackinsideok[T] @push(item T) {
    @len = @len + 1
}

export fn Stack_genericstackinsideok[T] @count() -> int =>
    @len

test "Plan 124.3: generic Stack_genericstackinsideok[int] метод access OK" {
    mut s = Stack_genericstackinsideok[int].new(10)
    s.push(1)
    s.push(2)
    s.push(3)
    assert(s.count() == 3)
}

test "Plan 124.3: generic Stack_genericstackinsideok[str] метод access OK" {
    mut s = Stack_genericstackinsideok[str].new(5)
    s.push("a")
    s.push("b")
    assert(s.count() == 2)
}
