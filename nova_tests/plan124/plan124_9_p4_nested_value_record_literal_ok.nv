// Plan 124.9 Ф.2 — positive: nested value-records (D228).
// Nested value-record literals must allocate each declared field type.
// V1 codegen treats value records as heap-backed transparent fallback.
module nova_tests.plan124

type Inner value {
    x int
}

type Outer value {
    inner Inner
}

test "nested value-record literal" {
    ro o = Outer { inner: Inner { x: 5 } }
    assert(o.inner.x == 5)
}
