// Plan 124.5 — doc fixture: type without any priv fields — all
// fields shown by default (backward compat sanity).
module nova_tests.plan124

/// Simple Point_plan1245docnoprivfixture type, all fields public.
export type Point_plan1245docnoprivfixture {
    ro x f64
    ro y f64
}

export fn Point_plan1245docnoprivfixture.new(a f64, b f64) -> Point_plan1245docnoprivfixture =>
    { x: a, y: b }

test "Plan 124.5: no-priv type works backward compat" {
    ro p = Point_plan1245docnoprivfixture.new(1.0, 2.0)
    assert(p.x == 1.0)
    assert(p.y == 2.0)
}
