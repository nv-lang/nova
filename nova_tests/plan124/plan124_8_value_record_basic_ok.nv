// Plan 124.8 — positive: value-record (D228 NEW).
// V1 codegen treats as heap-backed (transparent fallback) — see
// [M-124.8-value-codegen-stack] для V2 proper stack allocation.
module nova_tests.plan124

type Vec38 value {
    x f64
    y f64
    z f64
}

fn Vec38.new(a f64, b f64, c f64) -> Vec38 =>
    { x: a, y: b, z: c }

test "value-record construct + field access" {
    ro v = Vec38.new(1.0, 2.0, 3.0)
    assert(v.x == 1.0)
    assert(v.y == 2.0)
    assert(v.z == 3.0)
}
