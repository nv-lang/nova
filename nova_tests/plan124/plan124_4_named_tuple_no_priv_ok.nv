// Plan 124.4 — positive: named tuple без priv-fields — обычное поведение
// (Plan 120 D215 backward compat). No false-positive from Plan 124.4
// changes.
module nova_tests.plan124

type Point_plan1244namedtuplenoprivok(x f64, y f64)

fn make_point(a f64, b f64) -> Point_plan1244namedtuplenoprivok =>
    Point_plan1244namedtuplenoprivok(x: a, y: b)

test "Plan 124.4: named tuple без priv — access OK extern" {
    ro p = make_point(3.0, 4.0)
    assert(p.x == 3.0)
    assert(p.y == 4.0)
}
