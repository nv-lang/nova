// Plan 124.1 — positive: priv field read внутри instance method body — OK.
module nova_tests.plan124

export type Account_privreadinsidemethodok {
    priv mut money f64
    ro name str
}

export fn Account_privreadinsidemethodok.new(n str) -> Account_privreadinsidemethodok =>
    { money: 0.0, name: n }

// Instance method: priv access PASS.
export fn Account_privreadinsidemethodok @balance() -> f64 => @money

// Static method: priv access PASS.
export fn Account_privreadinsidemethodok.zero_balance() -> f64 =>
    Account_privreadinsidemethodok { money: 0.0, name: "" }.money    // Inside static method scope

test "priv field читается изнутри instance method" {
    ro acc = Account_privreadinsidemethodok.new("alice")
    ro b = acc.balance()
    assert(b == 0.0)
}
