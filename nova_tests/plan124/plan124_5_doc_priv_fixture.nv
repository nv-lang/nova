// Plan 124.5 — doc fixture: priv field hidden by default, shown with
// --include-private. Verified through `nova doc` invocations (manual
// e2e check during Plan 124.5 closure).
module nova_tests.plan124

/// Account_plan1245docprivfixture holds user balance.
export type Account_plan1245docprivfixture {
    ro name str
    priv mut balance f64
}

export fn Account_plan1245docprivfixture.new(n str) -> Account_plan1245docprivfixture =>
    { name: n, balance: 0.0 }

export fn Account_plan1245docprivfixture @get_name() -> str =>
    @name

test "Plan 124.5: fixture parses + balance accessible from method" {
    ro acc = Account_plan1245docprivfixture.new("alice")
    assert(acc.get_name() == "alice")
}
