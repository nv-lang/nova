// Plan 124.8 V2 — verifies multiple value-record instances live independently
// на stack (no aliasing). Critical для proving real stack semantic vs
// V1 heap-fallback (where pointers would alias через shared GC handle).
module nova_tests.plan124

type Pair3 value {
    first int
    second int
}

fn Pair3.new(a int, b int) -> Pair3 => { first: a, second: b }

fn Pair3 @sum() -> int => @first + @second

test "V2 multiple independent value-records на stack" {
    ro p1 = Pair3.new(1, 2)
    ro p2 = Pair3.new(10, 20)
    ro p3 = Pair3.new(100, 200)
    assert(p1.sum() == 3)
    assert(p2.sum() == 30)
    assert(p3.sum() == 300)
    // Independence check: p1 unchanged after p2/p3 constructed.
    assert(p1.first == 1 && p1.second == 2)
}
