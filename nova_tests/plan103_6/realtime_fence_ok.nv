// Plan 103.6 — fence() is #realtime; allowed in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_TIMEOUT_MS 60000

module plan103_6.realtime_fence_ok

#realtime fn _rt_fence_seqcst(a mut AtomicI64) {
    fence(SeqCst)
    ro _ = a.load()
}

#realtime fn _rt_fence_acq_rel(a mut AtomicI64) {
    fence(Acquire)
    fence(Release)
    ro _ = a.load()
}

test "fence(SeqCst) allowed in #realtime fn" {
    mut a = AtomicI64.new(0)
    a.store(1)
    _rt_fence_seqcst(a)
    assert(a.load() == 1)
}

test "fence(Acquire) and fence(Release) allowed in #realtime fn" {
    mut a = AtomicI64.new(0)
    _rt_fence_acq_rel(a)
    assert(true)
}
