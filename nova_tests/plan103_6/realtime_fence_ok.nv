// Plan 103.6 — fence() is #realtime; allowed in realtime{}.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.plan103_6.realtime_fence_ok

test "fence(SeqCst) allowed in realtime block" {
    let a = AtomicI64.new(0)
    a.store(1)
    // fence() is a statement, not a trailing expression (avoids void-cast issue)
    realtime {
        fence(SeqCst)
        let _ = a.load()
    }
    assert(a.load() == 1)
}

test "fence(Acquire) and fence(Release) allowed in realtime block" {
    let a = AtomicI64.new(0)
    realtime {
        fence(Acquire)
        fence(Release)
        let _ = a.load()
    }
    assert(true)
}
