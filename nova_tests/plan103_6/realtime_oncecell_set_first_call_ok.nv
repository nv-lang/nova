// Plan 103.6 — OnceCell.set and OnceCell.take are #realtime; allowed in realtime{}.
// set() is a leaf CAS operation; take() is atomic reset.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.plan103_6.realtime_oncecell_set_first_call_ok

test "OnceCell.set allowed in realtime block" {
    let c = OnceCell[int].new()
    let mut ok = false
    realtime {
        ok = c.set(77)
    }
    assert(ok == true)
    let v = c.get()
    assert(match v { Some(x) => x == 77, None => false })
}

test "OnceCell.take allowed in realtime block" {
    let c = OnceCell[str].new()
    let _ = c.set("hi")
    let mut taken_ok = false
    realtime {
        let taken = c.take()
        taken_ok = match taken { Some(s) => s == "hi", None => false }
    }
    assert(taken_ok)
    assert(c.is_initialized() == false)
}
