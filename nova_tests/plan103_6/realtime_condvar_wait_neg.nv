// Plan 103.6 — Condvar.wait is #parks; forbidden in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module plan103_6.realtime_condvar_wait_neg

#realtime fn _rt_check_condvar_wait(cv mut Condvar, m mut Mutex) {
    cv.wait(m)
}

test "Condvar.wait banned in #realtime fn" {
    mut m = Mutex.new()
    mut cv = Condvar.new()
    m.lock()
    _rt_check_condvar_wait(cv, m)
    m.unlock()
}
