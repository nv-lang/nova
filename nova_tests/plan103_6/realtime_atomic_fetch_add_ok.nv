// Plan 103.6 — AtomicI64.fetch_add is #realtime_safe; allowed in realtime{}.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.plan103_6.realtime_atomic_fetch_add_ok

test "AtomicI64.fetch_add allowed in realtime block" {
    let a = AtomicI64.new(10)
    let prev = realtime {
        a.fetch_add(5)
    }
    assert(prev == 10)
    assert(a.load() == 15)
}

test "AtomicI32.fetch_add allowed in realtime block" {
    let a = AtomicI32.new(0)
    let _ = realtime {
        a.fetch_add(1)
    }
    assert(a.load() == 1)
}
