// Plan 103.6 — OnceCell.get_or_init is #parks; forbidden in realtime{}.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_oncecell_get_or_init_neg

test "OnceCell.get_or_init banned in realtime block" {
    let c = OnceCell[int].new()
    realtime {
        let _ = c.get_or_init() { 42 }
    }
}
