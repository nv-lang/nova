// Plan 103.6 — OnceCell.get_or_init is #parks; forbidden in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_oncecell_get_or_init_neg

#realtime fn _rt_check_oncecell_get_or_init(c mut OnceCell[int]) -> int {
    c.get_or_init() { 42 }
}

test "OnceCell.get_or_init banned in #realtime fn" {
    mut c = OnceCell[int].new()
    ro _ = _rt_check_oncecell_get_or_init(c)
}
