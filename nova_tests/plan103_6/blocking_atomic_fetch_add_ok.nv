// Plan 103.6 — AtomicI64.fetch_add is #realtime; allowed in #blocking fn.
// Plan 113 migration: blocking { } → #blocking fn.
//
// EXPECT_TIMEOUT_MS 60000
// ENV NOVA_AUTOARM=0

module plan103_6.blocking_atomic_fetch_add_ok

#blocking fn _blk_fetch_add(a mut AtomicI64, delta int) -> int {
    a.fetch_add(delta)
}

test "AtomicI64.fetch_add allowed in #blocking fn" {
    mut a = AtomicI64.new(100)
    ro prev = _blk_fetch_add(a, 50)
    assert(prev == 100)
    assert(a.load() == 150)
}
