// Plan 103.6 — CountDownLatch.await is #parks; forbidden in realtime{}.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_countdown_await_neg

test "CountDownLatch.await banned in realtime block" {
    let latch = CountDownLatch.new(1)
    realtime {
        latch.await()
    }
}
