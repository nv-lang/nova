// Plan 103.6 — Mutex.try_lock is #realtime; allowed in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_TIMEOUT_MS 60000

module plan103_6.realtime_mutex_try_lock_ok

#realtime fn _rt_try_lock(m mut Mutex) -> bool {
    m.try_lock()
}

test "Mutex.try_lock allowed in #realtime fn (unlocked)" {
    mut m = Mutex.new()
    ro acquired = _rt_try_lock(m)
    assert(acquired == true)
    m.unlock()
}

test "Mutex.try_lock returns false when locked" {
    mut m = Mutex.new()
    m.lock()
    ro acquired = _rt_try_lock(m)
    assert(acquired == false)
    m.unlock()
}
