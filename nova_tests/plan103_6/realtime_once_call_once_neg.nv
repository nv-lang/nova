// Plan 103.6 — Once.call_once is #parks; forbidden in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_once_call_once_neg

#realtime fn _rt_check_once_call_once(o mut Once) {
    o.call_once() { () }
}

test "Once.call_once banned in #realtime fn" {
    ro o = Once.new()
    _rt_check_once_call_once(o)
}
