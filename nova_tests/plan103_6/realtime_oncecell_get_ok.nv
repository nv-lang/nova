// Plan 103.6 — OnceCell.get and OnceCell.is_initialized are #realtime.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_TIMEOUT_MS 60000

module plan103_6.realtime_oncecell_get_ok

#realtime fn _rt_oncecell_get_check(c mut OnceCell[int]) -> bool {
    ro v = c.get()
    match v { Some(x) => x == 99, None => false }
}

#realtime fn _rt_oncecell_is_initialized(c mut OnceCell[int]) -> bool {
    c.is_initialized()
}

test "OnceCell.get allowed in #realtime fn" {
    mut c = OnceCell[int].new()
    ro _ = c.set(99)
    ro got = _rt_oncecell_get_check(c)
    assert(got)
}

test "OnceCell.is_initialized allowed in #realtime fn" {
    mut c = OnceCell[int].new()
    ro before = _rt_oncecell_is_initialized(c)
    ro _ = c.set(1)
    ro after = _rt_oncecell_is_initialized(c)
    assert(before == false)
    assert(after == true)
}
