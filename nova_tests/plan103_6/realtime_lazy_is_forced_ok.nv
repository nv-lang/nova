// Plan 103.6 — Lazy.is_forced is #realtime; allowed in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.plan103_6.realtime_lazy_is_forced_ok

#realtime fn _rt_lazy_is_forced(lz mut Lazy[int]) -> bool {
    lz.is_forced()
}

test "Lazy.is_forced allowed in #realtime fn" {
    ro lz = Lazy[int].new() { 42 }
    ro before = _rt_lazy_is_forced(lz)
    assert(before == false)
    ro _ = lz.force()
    ro after = _rt_lazy_is_forced(lz)
    assert(after == true)
}
