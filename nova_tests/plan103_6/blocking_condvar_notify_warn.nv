// Plan 103.6 — Condvar.notify_one inside #blocking fn triggers W_BLOCKING_NOTIFY_RISK.
// Plan 113 migration: blocking { } → #blocking fn.
//
// EXPECT_COMPILE_WARNING W_BLOCKING_NOTIFY_RISK
// ENV NOVA_AUTOARM=0

module nova_tests.plan103_6.blocking_condvar_notify_warn

#blocking fn _blk_notify(mut cv Condvar) {
    cv.notify_one()
}

test "Condvar.notify_one warns in #blocking fn" {
    let cv = Condvar.new()
    _blk_notify(cv)
}
