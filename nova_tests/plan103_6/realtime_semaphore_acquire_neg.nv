// Plan 103.6 — Semaphore.acquire is #parks; forbidden in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_semaphore_acquire_neg

#realtime fn _rt_check_semaphore_acquire(s mut Semaphore) {
    s.acquire()
}

test "Semaphore.acquire banned in #realtime fn" {
    let s = Semaphore.new(1)
    _rt_check_semaphore_acquire(s)
    s.release()
}
