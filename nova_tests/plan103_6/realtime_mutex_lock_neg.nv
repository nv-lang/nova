// Plan 103.6 — Mutex.lock is #parks; forbidden in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_6.realtime_mutex_lock_neg

#realtime fn _rt_check_mutex_lock(m mut Mutex) {
    m.lock()
}

test "Mutex.lock banned in #realtime fn" {
    let m = Mutex.new()
    _rt_check_mutex_lock(m)
}
