// Plan 103.6 — user-fn annotated #parks called from #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_NESTED_SYNC_VIA_FN

module plan103_6.realtime_via_user_fn_neg

#parks
fn parks_fn() {
    mut m = Mutex.new()
    m.lock()
    m.unlock()
}

#realtime fn _rt_call_parks_fn() {
    parks_fn()
}

test "user fn with #parks banned in #realtime fn" {
    _rt_call_parks_fn()
}
