// Plan 103.6 — Mutex.try_lock_for inside realtime{} triggers W_REALTIME_TRY_LOCK_FOR_TIMER.
// try_lock_for uses a libuv timer; annotated #realtime_safe but emits a warning.
//
// EXPECT_COMPILE_WARNING W_REALTIME_TRY_LOCK_FOR_TIMER

module nova_tests.plan103_6.realtime_mutex_try_lock_for_neg

import std.time.duration

test "Mutex.try_lock_for warns in realtime block" {
    let m = Mutex.new()
    let mut got = false
    realtime {
        got = m.try_lock_for(Duration.from_millis(50))
    }
    if got {
        m.unlock()
    }
}
