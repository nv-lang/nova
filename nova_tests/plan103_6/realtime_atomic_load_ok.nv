// Plan 103.6 — AtomicI64.load is #realtime; allowed in #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.plan103_6.realtime_atomic_load_ok

#realtime fn _rt_load_i64(a mut AtomicI64) -> int {
    a.load()
}

#realtime fn _rt_load_bool(b mut AtomicBool) -> bool {
    b.load()
}

test "AtomicI64.load allowed in #realtime fn" {
    let mut a = AtomicI64.new(42)
    let v = _rt_load_i64(a)
    assert(v == 42)
}

test "AtomicBool.load allowed in #realtime fn" {
    let mut b = AtomicBool.new(true)
    let v = _rt_load_bool(b)
    assert(v == true)
}
