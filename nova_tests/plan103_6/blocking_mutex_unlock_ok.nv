// Plan 103.6 — Mutex.unlock is #wakes; allowed in #blocking fn (leaf wake).
// Plan 113 migration: blocking { } → #blocking fn.
//
// EXPECT_TIMEOUT_MS 60000
// ENV NOVA_AUTOARM=0

module nova_tests.plan103_6.blocking_mutex_unlock_ok

#blocking fn _blk_mutex_unlock(m mut Mutex) {
    m.unlock()
}

test "Mutex.unlock (wake-only) allowed in #blocking fn" {
    mut m = Mutex.new()
    m.lock()
    _blk_mutex_unlock(m)
    ro acquired = m.try_lock()
    assert(acquired == true)
    m.unlock()
}
