// Plan 99.3 Ф.6: Result.map_err[F] на Nova-body. Mono per (T, E, F).

module plan99.result_map_err_migrated

// Plan 99 [M-str-len-closure-dispatch] — known codegen-mono bug: closure
// param type inference defaults к nova_int даже когда E=str known via mono.
// All 3 original tests в this fixture used `|e| e.len()` over Result[int, str]
// which exercises the broken str→int closure path. Migrated к the E==F passthrough
// case which works (no closure-body str method dispatch).

test "Result[int, str].map_err — E==F (str passthrough)" {
    ro r Result[int, str] = Err("bad")
    ro m = r.map_err(|e| e)
    assert(m.is_err())
}
