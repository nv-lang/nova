// Plan 99.3 Ф.6: Result.map_err[F] на Nova-body. Mono per (T, E, F).

module plan99.result_map_err_migrated

test "Result[int, str].map_err — Err str→int (len)" {
    ro r Result[int, str] = Err("boom")
    ro m = r.map_err(|e| e.len())
    assert(m.is_err())
}

test "Result[int, str].map_err — Ok passes through" {
    ro r Result[int, str] = Ok(42)
    ro m = r.map_err(|e| e.len())
    assert(m.is_ok())
    assert(m.unwrap_or(0) == 42)
}

test "Result[int, str].map_err — E==F (str passthrough)" {
    ro r Result[int, str] = Err("bad")
    ro m = r.map_err(|e| e)
    assert(m.is_err())
}
