// Plan 99.3 Ф.4: Result.unwrap_or_else lazy recovery.

module plan99.result_unwrap_or_else_migrated

test "Result[int,str].unwrap_or_else — Ok skip closure" {
    ro r Result[int, str] = Ok(42)
    ro v = r.unwrap_or_else(|e| 0)
    assert(v == 42)
}

test "Result[int,str].unwrap_or_else — Err invokes f(e)" {
    ro r Result[int, str] = Err("boom")
    // Plan 99 [M-str-len-closure-dispatch] fix (2026-06-06): closure body
    // emit подставляет E=str для closure param.
    ro v = r.unwrap_or_else(|e| e.byte_len())
    assert(v == 4)
}

test "Result[str,int].unwrap_or_else — reversed E type" {
    ro r Result[str, int] = Err(99)
    ro s = r.unwrap_or_else(|n| str.from(n))
    assert(s == "99")
}
