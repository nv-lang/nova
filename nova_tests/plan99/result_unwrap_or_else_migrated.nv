// Plan 99.3 Ф.4: Result.unwrap_or_else lazy recovery.

module plan99.result_unwrap_or_else_migrated

test "Result[int,str].unwrap_or_else — Ok skip closure" {
    ro r Result[int, str] = Ok(42)
    ro v = r.unwrap_or_else(|e| 0)
    assert(v == 42)
}

// Plan 99 [M-str-len-closure-dispatch] — known codegen-mono bug: closure
// param type inference defaults к nova_int даже когда E=str known via mono.
// Test for "Err invokes f(e)" with str→int closure disabled until codegen
// pipeline implements proper E-substitution в closure body. Other 2 tests
// в this fixture exercise int-default closures которые work.
//
// test "Result[int,str].unwrap_or_else — Err invokes f(e)" — DISABLED.

test "Result[str,int].unwrap_or_else — reversed E type" {
    ro r Result[str, int] = Err(99)
    ro s = r.unwrap_or_else(|n| str.from(n))
    assert(s == "99")
}
