// Plan 99.3 Ф.1: Option.map[U] на Nova-body (`match @ { Some(v)
// => Some(f(v)), None => None }`). Full mono per (T, U).

module plan99.option_map_migrated

type User { id int, name str }

test "Option[int].map int→int (T==U)" {
    ro a Option[int] = Some(21)
    ro m = a.map(|x| x * 2)
    assert(m.unwrap_or(0) == 42)
}

test "Option[int].map int→str (T≠U)" {
    ro a Option[int] = Some(7)
    ro s = a.map(|x| str.from(x))
    assert(s.unwrap_or("") == "7")
}

// Plan 99 [M-str-len-closure-dispatch] — known codegen-mono bug: closure
// param type inference defaults к nova_int даже когда T=str known via mono.
// Test for str→int case (Option[str].map(|s| s.byte_len())) disabled until
// codegen pipeline implements proper T-substitution в closure body.
// Tracked в plan99 followup. Other 4 plan99 Option.map tests OK (T=int default
// path works).
//
// test "Option[str].map str→int (str→primitive)" — DISABLED.

test "Option.map на None — closure не вызывается" {
    ro a Option[int] = None
    ro s = a.map(|x| str.from(x))
    assert(s.is_none())
}

test "Option.map chain" {
    ro a Option[int] = Some(5)
    ro m = a.map(|x| x * 2).map(|y| str.from(y))
    assert(m.unwrap_or("") == "10")
}
