// SPDX-License-Identifier: MIT OR Apache-2.0
// Plan 152.7-B (D258) POS T3 — radix types: x / X (hex), b (binary), o (octal),
// with `#` alternate prefix (0x / 0b / 0o) and width/zero-pad interaction.
module nova_tests.plan152_7

test "lower hex" {
    assert("${255:x}" == "ff")
}

test "upper hex" {
    assert("${255:X}" == "FF")
}

test "hex alternate prefix" {
    assert("${255:#x}" == "0xff")
}

test "upper hex alternate prefix" {
    assert("${255:#X}" == "0xFF")
}

test "binary" {
    assert("${255:b}" == "11111111")
}

test "binary alternate prefix" {
    assert("${5:#b}" == "0b101")
}

test "octal" {
    assert("${8:o}" == "10")
}

test "octal alternate prefix" {
    assert("${64:#o}" == "0o100")
}

test "hex zero pad" {
    assert("${255:08x}" == "000000ff")
}

test "hex alternate zero pad (prefix then zeros)" {
    assert("${255:#08x}" == "0x0000ff")
}

test "hex width right-align" {
    assert("${255:>6x}" == "    ff")
}

test "negative hex (unsigned two's-complement, Rust semantics)" {
    // nova_int is 64-bit (intptr_t on x64): -1 → all-ones bit pattern.
    assert("${-1:x}" == "ffffffffffffffff")
}

test "hex zero" {
    assert("${0:x}" == "0")
}

test "hex of large value" {
    assert("${4096:x}" == "1000")
}
