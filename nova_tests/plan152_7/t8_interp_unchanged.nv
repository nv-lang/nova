// Plan 152.7.1 (D258 AMEND) POS T8 — interpolation unchanged after Write-sink migration.
//
// Verifies that "${expr}" interpolation still works correctly for all primitive
// types after the Display/Debug protocol migrated from StringBuilder to Write.
module nova_tests.plan152_7

test "int interpolation" {
    assert("${42}" == "42")
}

test "negative int interpolation" {
    assert("${-7}" == "-7")
}

test "f64 interpolation" {
    assert("${3.14}" == "3.14")
}

test "bool interpolation true" {
    assert("${true}" == "true")
}

test "bool interpolation false" {
    assert("${false}" == "false")
}

test "str interpolation" {
    ro s = "world"
    assert("hello ${s}" == "hello world")
}

test "multiple interpolations in one string" {
    assert("${42} ${3.14} ${true}" == "42 3.14 true")
}

test "interpolation with surrounding text" {
    ro x = 10
    ro y = 20
    assert("x=${x}, y=${y}" == "x=10, y=20")
}
