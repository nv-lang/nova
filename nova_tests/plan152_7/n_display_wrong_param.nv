// Plan 152.7.1 (D258 AMEND) NEG — Write-sink: Display param must be `Write`, not `StringBuilder`.
//
// After D258 AMEND the canonical Display signature is:
//   fn T @display(mut w Write) -> ()
//
// The pre-D258 form using the concrete `StringBuilder` type is now a
// type-mismatch against the protocol — even though StringBuilder *satisfies*
// Write, `#impl(Display)` checks the declared param type, not structural
// conformance.  Pinning this boundary guards against accidental regression to
// the old API.
//
// EXPECT_COMPILE_ERROR E_IMPL_SIGNATURE_MISMATCH
module plan152_7.n_display_wrong_param

type Point { x int, y int }

// Wrong: param type is `StringBuilder` (concrete), not `Write` (protocol).
// D258 AMEND changed Display to accept `Write` — this must be rejected.
#impl(Display)
fn Point @display(mut sb StringBuilder) -> () {
    sb.append(@x)
}

fn main() -> () {}
