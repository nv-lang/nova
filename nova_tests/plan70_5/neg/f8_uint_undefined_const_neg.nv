// Plan 70.5 Ф.4 — negative: несуществующая константа uint.NONEXISTENT.
//
// После Ф.4 `uint.X` парсится как Path(["uint", "X"]).
// Если X не в numeric_type_constant_mapping, кодоген эмитит
// идентификатор `uint_X` в C, который не объявлен → CC-FAIL.
//
// Документирует поведение codegen для неизвестных type-path констант.

module neg.f8_uint_undefined_const_neg

// EXPECT_CC_ERROR undeclared identifier
fn bad3() -> uint {
    uint.NONEXISTENT
}
