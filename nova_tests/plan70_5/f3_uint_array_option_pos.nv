module plan70_5.f3_uint_array_option_pos

// Plan 70.5: []uint and Option[uint] use NovaArray_uint64_t / NovaOpt_uint64_t.

test "[]uint push and access" {
    mut arr []uint = []uint.new()
    arr.push(1 as uint)
    arr.push(2 as uint)
    arr.push(3 as uint)
    assert(arr.len() == 3)
    assert(arr[0] == 1 as uint)
    assert(arr[2] == 3 as uint)
}

test "Option[uint] Some and unwrap_or" {
    ro a Option[uint] = Some(99 as uint)
    ro b Option[uint] = None
    assert(a.is_some())
    assert(b.is_none())
    assert(a.unwrap_or(0 as uint) == 99 as uint)
    assert(b.unwrap_or(7 as uint) == 7 as uint)
}
