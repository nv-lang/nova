// Plan 100.2 (D156): collection-aware iteration `for tx in []Transaction`.
//
// Каждый element в arm-теле — Live linear, обязан consumed в arm'е.
// После for — vec considered Consumed (pragmatic loop-handling).

module nova_tests.plan100_2.for_consume_iter_ok

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

test "for consume tx in vec — каждый element consume'ится в arm'е" {
    consume tx1 = Transaction { id: 1 }
    consume tx2 = Transaction { id: 2 }
    consume tx3 = Transaction { id: 3 }
    let txs = [tx1, tx2, tx3]                  // []Transaction — generic-заразность (D133 D6)
    for consume tx in txs {
        tx.commit()                             // каждый element consume'ится ✅
    }
    // txs Consumed после for ✅
}
