// Plan 100.2 (D156): passing T inside generic body to consume-param fn.

module nova_tests.plan100_2.generic_bound_ok_pass_consume

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }

// Внешняя consume-функция.
fn finish(consume t Transaction) -> () {
    t.commit()
}

// Generic c [T consume] передаёт x в consume-param finish (только если
// T = Transaction). На других T — тип incompatible.
fn delegate[T consume](consume x T) -> () {
    // В strict mode требует, чтобы x был consumed.
    // Pass-through в external consume-fn для Transaction-specific code:
    finish(x)                                    // x consumed через consume-param
}

test "generic body передаёт T в consume-fn" {
    consume tx = Transaction { id: 7 }
    delegate(tx)
}
