// Plan 100.2 (D156): HashMap[K, V consume] propagation — V consume,
// HashMap сам становится consume через generic-заразность.

module nova_tests.plan100_2.hashmap_consume_value_ok

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn begin(n int) -> Transaction => Transaction { id: n }

test "HashMap[str, Transaction] — V consume, HashMap consume" {
    consume tx1 = begin(1)
    consume tx2 = begin(2)
    let mut tx_map HashMap[str, Transaction] = HashMap.new()
    tx_map.insert("first", tx1)                 // consume value
    tx_map.insert("second", tx2)
    // tx_map — consume-HashMap; обязан consumed на scope-exit
    // (через consume-метод HashMap, который consume'ит каждое value).
    for (_, tx) in tx_map.drain() {             // consume-iteration
        tx.commit()
    }
}
