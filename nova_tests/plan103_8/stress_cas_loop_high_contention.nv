// Plan 103.8 — Stress: high-contention CAS loop.
//
// 16 fibers each increment AtomicI64 via CAS-loop × 20 times.
// Final value must be exactly 320 (16 × 20).
// Tests both compare_exchange (strong) and compare_exchange_weak variants.
// No "lost update" — every CAS loop eventually succeeds.
//
// EXPECT_TIMEOUT_MS 300000

module plan103_8.stress_cas_loop_high_contention

test "CAS loop high contention: 16 fibers × 20 compare_exchange — final = 320" {
    mut counter = AtomicI64.new(0)
    mut wg = WaitGroup.new()
    wg.add(16)

    supervised {
        for _i in 0..16 {
            spawn {
                for _j in 0..20 {
                    // CAS-loop: retry until strong CAS succeeds
                    ro done = false
                    while !done {
                        ro cur = counter.load(Acquire)
                        done = counter.compare_exchange(cur, cur + 1, AcqRel, Acquire)
                    }
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(counter.load(SeqCst) == 320,
        "16 fibers x 20 increments via strong CAS must yield 320")
}

test "CAS loop high contention: 16 fibers × 20 compare_exchange_weak — final = 320" {
    mut counter = AtomicI64.new(0)
    mut wg = WaitGroup.new()
    wg.add(16)

    supervised {
        for _i in 0..16 {
            spawn {
                for _j in 0..20 {
                    // CAS weak loop: tolerates spurious failures
                    ro done = false
                    while !done {
                        ro cur = counter.load(Acquire)
                        done = counter.compare_exchange_weak(cur, cur + 1, AcqRel, Acquire)
                    }
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(counter.load(SeqCst) == 320,
        "16 fibers x 20 increments via weak CAS must yield 320")
}

test "CAS mixed: 8 strong + 8 weak fibers x 20 each — final = 320" {
    mut counter = AtomicI64.new(0)
    mut wg = WaitGroup.new()
    wg.add(16)

    supervised {
        // 8 using strong CAS
        for _i in 0..8 {
            spawn {
                for _j in 0..20 {
                    ro done = false
                    while !done {
                        ro cur = counter.load(Acquire)
                        done = counter.compare_exchange(cur, cur + 1, AcqRel, Acquire)
                    }
                }
                wg.done()
            }
        }
        // 8 using weak CAS
        for _i in 0..8 {
            spawn {
                for _j in 0..20 {
                    ro done = false
                    while !done {
                        ro cur = counter.load(Relaxed)
                        done = counter.compare_exchange_weak(cur, cur + 1, Release, Relaxed)
                    }
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(counter.load() == 320,
        "mixed CAS: 8*20 + 8*20 = 320 total increments")
}
