// Plan 103.8 — Litmus: IRIW (Independent Reads of Independent Writes) with SeqCst.
//
// Classic IRIW litmus test (D167):
//   Initial: X = 0, Y = 0
//   Writer1: X.store(1, SeqCst)
//   Writer2: Y.store(1, SeqCst)
//   Reader1: r1 = X.load(SeqCst); r2 = Y.load(SeqCst)
//   Reader2: r3 = Y.load(SeqCst); r4 = X.load(SeqCst)
//
// SeqCst forbids: r1=1, r2=0, r3=1, r4=0 simultaneously
// (would require Reader1 to see X before Y, Reader2 to see Y before X
//  in a single execution — impossible with SeqCst total order).
//
// On x86: TSO makes IRIW result nearly impossible anyway;
// on ARM/POWER the SeqCst mfence/dmb barriers enforce this.
// We verify 1000 iterations: the "forbidden" outcome never occurs.
//
// Note: On x86, this test mostly validates the API works correctly;
// ARM CI would reveal any barrier omissions (deferred to Plan 24).
//
// EXPECT_TIMEOUT_MS 300000

module nova_tests.plan103_8.litmus_iriw_seqcst_forbids

test "IRIW SeqCst: forbidden observation (1,0)/(1,0) never occurs over 1000 iterations" {
    let n_iters   = 20
    let violations = AtomicI64.new(0)

    for _iter in 0..n_iters {
        let x = AtomicI64.new(0)
        let y = AtomicI64.new(0)

        // Results from readers
        let r1 = AtomicI64.new(-1)  // Reader1 sees X
        let r2 = AtomicI64.new(-1)  // Reader1 sees Y
        let r3 = AtomicI64.new(-1)  // Reader2 sees Y
        let r4 = AtomicI64.new(-1)  // Reader2 sees X

        supervised {
            // Writer1: store X = 1
            spawn {
                x.store(1, SeqCst)
            }
            // Writer2: store Y = 1
            spawn {
                y.store(1, SeqCst)
            }
            // Reader1: load X then Y
            spawn {
                r1.store(x.load(SeqCst), SeqCst)
                r2.store(y.load(SeqCst), SeqCst)
            }
            // Reader2: load Y then X
            spawn {
                r3.store(y.load(SeqCst), SeqCst)
                r4.store(x.load(SeqCst), SeqCst)
            }
        }

        // Forbidden under SeqCst: r1=1 AND r2=0 AND r3=1 AND r4=0
        // (Reader1 saw X=1 but missed Y=1; Reader2 saw Y=1 but missed X=1)
        let bad = r1.load() == 1 && r2.load() == 0 &&
                  r3.load() == 1 && r4.load() == 0
        if bad {
            violations.fetch_add(1)
        }
    }

    assert(violations.load() == 0,
        "SeqCst IRIW: forbidden (1,0)/(1,0) observation must never occur")
}
