// Plan 103.8 — Property: Barrier all-or-none (epoch atomicity).
//
// Barrier.new(N): N fibers must all wait() before any proceeds.
// Property: every fiber that calls wait() eventually returns (no deadlock),
// and all N fibers receive arrival indices covering 0..N-1.
//
// The "all-or-none" property: if N fibers approach the barrier, all N pass
// or none pass. We verify over multiple rounds (cyclic barrier reuse).
//
// Note: wait_for(timeout) variant is tested but timeout is generous — we
// only verify API works, not time-bounded behavior (that's realtime domain).
//
// EXPECT_TIMEOUT_MS 120000

module nova_tests.plan103_8.prop_barrier_all_or_none

test "prop barrier all-or-none: 8 fibers × 10 rounds, all indices covered each round" {
    let n        = 8
    let n_rounds = 10
    let mut barrier = Barrier.new(n)
    let mut round_sum = AtomicI64.new(0)  // sum of all arrival indices across all rounds
    let mut wg = WaitGroup.new()
    wg.add(n)

    // Expected sum per round = 0+1+...+(n-1) = n*(n-1)/2
    // Expected total over all rounds = n_rounds * n*(n-1)/2
    let expected_sum = n_rounds * n * (n - 1) / 2

    parallel for _i in 0..n {
        for _r in 0..n_rounds {
            let idx = barrier.wait()
            assert(idx >= 0, "barrier index must be >= 0")
            assert(idx < n, "barrier index must be < n")
            round_sum.fetch_add(idx)
        }
        wg.done()
    }

    wg.wait()
    assert(round_sum.load() == expected_sum,
        "sum of all arrival indices over 10 rounds must equal expected")
}

test "prop barrier: cyclic reuse — two consecutive rounds both complete" {
    let n       = 4
    let mut barrier = Barrier.new(n)
    let mut r1_sum  = AtomicI64.new(0)
    let mut r2_sum  = AtomicI64.new(0)
    let mut wg = WaitGroup.new()
    wg.add(n)

    parallel for _i in 0..n {
        // Round 1
        let idx1 = barrier.wait()
        r1_sum.fetch_add(idx1)
        // Round 2 — barrier automatically reset
        let idx2 = barrier.wait()
        r2_sum.fetch_add(idx2)
        wg.done()
    }

    wg.wait()
    let expected = n * (n - 1) / 2
    assert(r1_sum.load() == expected, "round 1 index sum must equal n*(n-1)/2")
    assert(r2_sum.load() == expected, "round 2 index sum must equal n*(n-1)/2")
}

test "prop barrier: wait_with_action — action runs exactly once per round" {
    let n             = 4
    let mut barrier = Barrier.new(n)
    let mut action_count  = AtomicI64.new(0)
    let mut wg = WaitGroup.new()
    wg.add(n)

    parallel for _i in 0..n {
        barrier.wait_with_action() {
            action_count.fetch_add(1)
        }
        wg.done()
    }

    wg.wait()
    assert(action_count.load() == 1,
        "barrier action must run exactly once (by last-arrival fiber)")
}

test "prop barrier: is_broken stays false when no timeout" {
    let n       = 4
    let mut barrier = Barrier.new(n)
    let mut wg = WaitGroup.new()
    wg.add(n)

    parallel for _i in 0..n {
        barrier.wait()
        wg.done()
    }

    wg.wait()
    assert(!barrier.is_broken(), "barrier must not be broken after normal completion")
}
