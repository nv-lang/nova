// Plan 103.8 -- Litmus: Refcount drop -- fetch_sub(Release) + fence(Acquire).
//
// Classic refcount idiom (D167 fence example):
//   N producers increment refcount (Relaxed fetch_add).
//   Each fiber done: fetch_sub(1, Release) -- if result was 1, we're last.
//   Last fiber: fence(Acquire) then "free" -- guaranteed to see all prior stores.
//
// Property: exactly ONE fiber sees fetch_sub return 1 (previous value).
// The "free" operation happens exactly once.
//
// This validates the refcount-drop pattern from D167 sync.nv documentation.
//
// EXPECT_TIMEOUT_MS 300000

module nova_tests.plan103_8.litmus_refcount_drop

test "refcount drop: fetch_sub Release + fence Acquire -- exactly one last-fiber" {
    let n_iters   = 5
    let mut bad_frees = AtomicI64.new(0)  // != 1 total "last fiber" signals

    for _iter in 0..n_iters {
        let n_fibers = 8
        let mut refcount = AtomicI64.new(0)
        let mut freed_count = AtomicI64.new(0)  // how many fibers did "free"

        // All fibers: Relaxed add to refcount first
        // (simulates "take a reference")
        let mut init_wg = WaitGroup.new()
        init_wg.add(n_fibers)
        parallel for _i in 0..n_fibers {
            refcount.fetch_add(1, Relaxed)
            init_wg.done()
        }
        init_wg.wait()

        // All fibers "release": fetch_sub with Release ordering
        // Whoever sees previous_value == 1 is the "last" fiber
        let mut release_wg = WaitGroup.new()
        release_wg.add(n_fibers)
        parallel for _i in 0..n_fibers {
            let prev = refcount.fetch_sub(1, Release)
            if prev == 1 {
                // Last fiber: fence(Acquire) to synchronize with all releases
                fence(Acquire)
                // "Free" the shared resource exactly once
                freed_count.fetch_add(1, Relaxed)
            }
            release_wg.done()
        }
        release_wg.wait()

        // Exactly one fiber must have been "last"
        if freed_count.load() != 1 {
            bad_frees.fetch_add(1)
        }
    }

    assert(bad_frees.load() == 0,
        "refcount drop: exactly one fiber must be 'last' (freed_count == 1) per iter")
}

test "refcount drop: 16 fibers -- single free event" {
    let n_fibers    = 16
    let n_iters     = 5
    let mut violations  = AtomicI64.new(0)

    for _iter in 0..n_iters {
        let mut refcount    = AtomicI64.new(n_fibers)  // pre-initialized
        let mut freed_count = AtomicI64.new(0)
        let mut wg = WaitGroup.new()
        wg.add(n_fibers)

        parallel for _i in 0..n_fibers {
            let prev = refcount.fetch_sub(1, Release)
            if prev == 1 {
                fence(Acquire)
                freed_count.fetch_add(1, Relaxed)
            }
            wg.done()
        }
        wg.wait()

        if freed_count.load() != 1 {
            violations.fetch_add(1)
        }
    }

    assert(violations.load() == 0,
        "16-fiber refcount drop: exactly one 'free' per iteration")
}

test "fence(Relaxed) is valid syntax and no-op semantically" {
    // D167: fence(Relaxed) is valid syntactically but has no ordering effect.
    // This test verifies it compiles and runs without error.
    let mut a = AtomicI64.new(0)
    a.store(1, Relaxed)
    fence(Relaxed)   // no-op: no ordering guarantee
    fence(Acquire)   // real fence
    assert(a.load(Acquire) == 1, "fence(Relaxed) must not corrupt state")
}
