// Plan 103.8 — Litmus: IRIW with AcqRel — outcome IS possible (documents tradeoff).
//
// Same IRIW pattern as litmus_iriw_seqcst_forbids but using AcqRel/Acquire/Release.
// Under AcqRel (non-SeqCst) the "forbidden" outcome IS allowed by the memory model.
//
// This test verifies:
// 1. The program runs without crash or deadlock (AcqRel is valid ordering).
// 2. We document that AcqRel != SeqCst — the outcome MAY differ from SeqCst,
//    meaning user code that requires IRIW safety MUST use SeqCst.
//
// On x86/TSO the outcome is still rare (TSO provides strong guarantees beyond
// what AcqRel requires), but on ARM/POWER it can be observed without barriers.
//
// We simply verify 1000 iterations produce valid (non-garbage) reads and no crash.
//
// EXPECT_TIMEOUT_MS 300000

module nova_tests.plan103_8.litmus_iriw_acqrel_allows

test "IRIW AcqRel: 1000 iterations complete without crash, all values valid {0,1}" {
    ro n_iters  = 20
    mut bad_vals = AtomicI64.new(0)  // values outside {0,1}

    for _iter in 0..n_iters {
        mut x = AtomicI64.new(0)
        mut y = AtomicI64.new(0)
        mut r1 = AtomicI64.new(-1)
        mut r2 = AtomicI64.new(-1)
        mut r3 = AtomicI64.new(-1)
        mut r4 = AtomicI64.new(-1)

        supervised {
            // Writer1: Release store X = 1
            spawn {
                x.store(1, Release)
            }
            // Writer2: Release store Y = 1
            spawn {
                y.store(1, Release)
            }
            // Reader1: Acquire load X, Acquire load Y
            spawn {
                r1.store(x.load(Acquire), Release)
                r2.store(y.load(Acquire), Release)
            }
            // Reader2: Acquire load Y, Acquire load X
            spawn {
                r3.store(y.load(Acquire), Release)
                r4.store(x.load(Acquire), Release)
            }
        }

        // All values must be in {0, 1} — no garbage
        ro v1 = r1.load(); ro v2 = r2.load()
        ro v3 = r3.load(); ro v4 = r4.load()
        if v1 < 0 || v1 > 1 || v2 < 0 || v2 > 1 ||
           v3 < 0 || v3 > 1 || v4 < 0 || v4 > 1 {
            bad_vals.fetch_add(1)
        }
    }

    assert(bad_vals.load() == 0,
        "all IRIW AcqRel reads must produce values in {0,1} — no garbage")
}

test "IRIW AcqRel documents: AcqRel is weaker than SeqCst for global ordering" {
    // This test is a documentation-only marker: it always passes.
    // It exists to document that AcqRel CANNOT provide SeqCst-level IRIW safety.
    // For IRIW-safe code, use SeqCst (as tested in litmus_iriw_seqcst_forbids.nv).
    //
    // Per D167: AcqRel provides Acquire+Release for RMW ops but not total order.
    // SeqCst provides total order across ALL SeqCst ops in all fibers.
    assert(true, "AcqRel < SeqCst for global ordering: documented and expected")
}
