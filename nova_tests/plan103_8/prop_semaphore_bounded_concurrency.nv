// Plan 103.8 — Property: Semaphore bounded concurrency invariant.
//
// Semaphore.new(K); N >> K fibers; observable max-in-flight never exceeds K.
// Sampled continuously during run. Property: no violation observed.
//
// EXPECT_TIMEOUT_MS 300000

module nova_tests.plan103_8.prop_semaphore_bounded_concurrency

test "prop semaphore bounded: K=3, N=8 fibers — max in-flight never exceeds 3" {
    let sem       = Semaphore.new(3)
    let in_flight = AtomicI64.new(0)
    let violation = AtomicI64.new(0)
    let wg        = WaitGroup.new()
    wg.add(8)

    supervised {
        for _i in 0..8 {
            spawn {
                for _j in 0..3 {
                    sem.acquire()
                    let current = in_flight.fetch_add(1) + 1
                    if current > 3 {
                        violation.fetch_add(1)
                    }
                    // Hold permit briefly — allow interleaving
                    in_flight.fetch_add(-1)
                    sem.release()
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(violation.load() == 0,
        "semaphore bounded: never more than K=3 concurrent permit holders")
}

test "prop semaphore bounded: K=2, N=8 fibers — explicit acquire/release" {
    let sem       = Semaphore.new(2)
    let in_flight = AtomicI64.new(0)
    let violation = AtomicI64.new(0)
    let wg        = WaitGroup.new()
    wg.add(8)

    supervised {
        for _i in 0..8 {
            spawn {
                for _j in 0..3 {
                    sem.acquire()
                    let current = in_flight.fetch_add(1) + 1
                    if current > 2 {
                        violation.fetch_add(1)
                    }
                    in_flight.fetch_add(-1)
                    sem.release()
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(violation.load() == 0,
        "explicit acquire/release: never more than K=2 concurrent holders")
}

test "prop semaphore: available_permits stays in [0, initial] range" {
    // After a series of acquire/release pairs, permits must return to initial.
    let sem = Semaphore.new(5)
    let wg  = WaitGroup.new()
    wg.add(5)

    supervised {
        for _i in 0..5 {
            spawn {
                sem.acquire()
                sem.release()
                wg.done()
            }
        }

        wg.wait()
    }

    assert(sem.available_permits() == 5,
        "permits must return to initial after balanced acquire/release")
}

test "prop semaphore: batch acquire_n bounded — K=6, acquire 3 at a time" {
    let sem     = Semaphore.new(6)
    let in_use  = AtomicI64.new(0)
    let bad     = AtomicI64.new(0)
    let wg      = WaitGroup.new()
    wg.add(4)

    supervised {
        for _i in 0..4 {
            spawn {
                for _j in 0..2 {
                    sem.acquire_n(3)
                    let curr = in_use.fetch_add(3) + 3
                    if curr > 6 {
                        bad.fetch_add(1)
                    }
                    in_use.fetch_add(-3)
                    sem.release_n(3)
                }
                wg.done()
            }
        }

        wg.wait()
    }

    assert(bad.load() == 0,
        "batch acquire_n(3) from K=6 semaphore: never exceed K")
}
