// Plan 67 Ф.2 f4 — println(if/else expr returning str).
// infer_expr_c_type для if-expr должен вернуть nova_str (через then-block trailing).

module plan67.f4_if_expr_str

// EXPECT_STDOUT pos
// EXPECT_STDOUT neg

fn main() Io -> () {
    ro x = 5
    println(if x > 0 { "pos" } else { "neg" })
    ro y = -1
    println(if y > 0 { "pos" } else { "neg" })
}
