// Plan 67 Ф.2 f5 — println(match expr returning str).
// infer_expr_c_type для match-expr должен вернуть nova_str из arm type.

module plan67.f5_match_expr_str

// EXPECT_STDOUT one
// EXPECT_STDOUT other

fn main() Io -> () {
    ro n = 1
    println(match n {
        1 => "one"
        _ => "other"
    })
    ro m = 99
    println(match m {
        1 => "one"
        _ => "other"
    })
}
