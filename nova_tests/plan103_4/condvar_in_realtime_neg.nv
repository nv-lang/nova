// Plan 103.4 — Condvar.wait() inside #realtime fn → COMPILE_ERROR.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_4.condvar_in_realtime_neg

#realtime fn _rt_check_condvar_wait(cv mut Condvar, mu mut Mutex) {
    cv.wait(mu)
}

test "Condvar.wait banned inside #realtime fn" {
    mut mu = Mutex.new()
    mut cv = Condvar.new()
    _rt_check_condvar_wait(cv, mu)
}
