// Plan 103.4 — Semaphore acquire_n / release_n batch operations.
//
// acquire_n(3) / release_n(3); verify atomicity and correct permit accounting.
//
// EXPECT_TIMEOUT_MS 30000
// ENV NOVA_AUTOARM=0

module nova_tests.plan103_4.semaphore_batch_n

test "acquire_n(3) and release_n(3) basic accounting" {
    mut sem = Semaphore.new(5)
    sem.acquire_n(3)
    assert(sem.available_permits() == 2)
    sem.release_n(3)
    assert(sem.available_permits() == 5)
}

test "acquire_n(1) same as acquire" {
    mut sem = Semaphore.new(3)
    sem.acquire_n(1)
    assert(sem.available_permits() == 2)
    sem.release_n(1)
    assert(sem.available_permits() == 3)
}

test "batch acquire/release with multiple fibers" {
    // 4 fibers each take 2 permits from a pool of 8
    mut sem = Semaphore.new(8)
    mut acquired = AtomicInt.new(0)
    mut wg = WaitGroup.new()
    ro n        = 4
    wg.add(n)

    parallel for _i in 0..n {
        sem.acquire_n(2)
        acquired.fetch_add(1)
        sem.release_n(2)
        wg.done()
    }

    wg.wait()
    assert(acquired.load() == n)
    assert(sem.available_permits() == 8)
}

test "acquire_n blocks until N permits available" {
    // acquire_n(3) blocks when only 2 permits present; unblocks on release_n(1)
    mut sem = Semaphore.new(2)
    mut done = AtomicInt.new(0)
    mut wg = WaitGroup.new()
    wg.add(1)

    supervised {
        spawn {
            sem.acquire_n(3)   // needs 3 permits; blocks (only 2 available)
            done.store(1)
            sem.release_n(3)
            wg.done()
        }
        // Spawn runs fiber until it parks; fiber is waiting for 3 permits.
        // Available permits unchanged since fiber hasn't acquired yet.
        assert(sem.available_permits() == 2)
        sem.release_n(1)  // total = 3 → satisfies fiber's acquire_n(3)
    }

    wg.wait()
    assert(done.load() == 1)
}
