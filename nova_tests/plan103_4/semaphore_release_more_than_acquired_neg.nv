// Plan 103.4 — Semaphore over-release: documented behavior test.
//
// D170 §2: over-release (release without prior acquire) increments permits
// past initial (Java-compatible semantics, V1). No panic.
// This test verifies that documented behavior: available_permits() grows.

module nova_tests.plan103_4.semaphore_release_more_than_acquired_neg

test "over-release increments permits past initial (Java semantics, D170 §2)" {
    mut sem = Semaphore.new(2)
    assert(sem.available_permits() == 2)

    // Release without prior acquire: permits exceed initial
    sem.release()
    assert(sem.available_permits() == 3)

    // Verify the extra permit is usable
    ro ok1 = sem.try_acquire()
    ro ok2 = sem.try_acquire()
    ro ok3 = sem.try_acquire()
    assert(ok1 == true)
    assert(ok2 == true)
    assert(ok3 == true)
    assert(sem.available_permits() == 0)
}

test "release_n over-release increments by n" {
    mut sem = Semaphore.new(1)
    sem.release_n(3)
    // 1 + 3 = 4 permits
    assert(sem.available_permits() == 4)
}
