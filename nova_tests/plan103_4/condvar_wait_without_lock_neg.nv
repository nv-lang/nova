// Plan 103.4 — Condvar.wait() without locking mutex first → RUNTIME_PANIC.
//
// Unconditional precondition check (Plan 103.4 §«Discovery from 103.5»):
// fires in both Dev AND Release builds.
//
// EXPECT_RUNTIME_PANIC Condvar.wait(): mutex not locked

module plan103_4.condvar_wait_without_lock_neg

test "wait without prior mu.lock() panics" {
    mut mu = Mutex.new()
    mut cv = Condvar.new()
    // mu is NOT locked — cv.wait(mu) must panic.
    cv.wait(mu)
}
