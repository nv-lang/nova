// Plan 103.4 — Semaphore.try_acquire_for timeout.
//
// All permits taken; try_acquire_for(60ms) returns false after timeout.
// Tests fiber path (both acquirer and releaser are fibers).
//
// EXPECT_TIMEOUT_MS 60000
// ENV NOVA_AUTOARM=0

module nova_tests.plan103_4.semaphore_try_acquire_for_timeout

import std.time.duration

test "try_acquire_for times out when no permits available" {
    // Zero permits: any acquire blocks immediately
    let sem = Semaphore.new(0)
    let result = AtomicInt.new(0)

    supervised {
        spawn {
            let ok  = sem.try_acquire_for(Duration.from_millis(60))
            result.store(if ok { 1 } else { 0 })
        }
    }

    assert(result.load() == 0)
}

test "try_acquire_for succeeds when permits available" {
    let sem = Semaphore.new(1)
    let result = AtomicInt.new(0)

    supervised {
        spawn {
            let ok = sem.try_acquire_for(Duration.from_millis(100))
            result.store(if ok { 1 } else { 0 })
            if ok { sem.release() }
        }
    }

    assert(result.load() == 1)
    assert(sem.available_permits() == 1)
}

test "try_acquire_for with zero timeout behaves as try_acquire (no permits)" {
    let sem = Semaphore.new(0)
    let result = AtomicInt.new(0)

    supervised {
        spawn {
            let ok = sem.try_acquire_for(Duration.from_millis(0))
            result.store(if ok { 1 } else { 0 })
        }
    }

    assert(result.load() == 0)
}

test "try_acquire_for with zero timeout behaves as try_acquire (has permit)" {
    let sem = Semaphore.new(1)
    let result = AtomicInt.new(0)

    supervised {
        spawn {
            let ok = sem.try_acquire_for(Duration.from_millis(0))
            result.store(if ok { 1 } else { 0 })
            if ok { sem.release() }
        }
    }

    assert(result.load() == 1)
    assert(sem.available_permits() == 1)
}

test "try_acquire_for: permit released by other fiber → acquired" {
    // Fiber A releases permit; Fiber B acquires it via try_acquire_for
    let sem    = Semaphore.new(1)
    let result = AtomicInt.new(0)
    sem.acquire()   // take the only permit

    supervised {
        // Fiber A: releases permit after brief delay loop
        spawn {
            for _i in 0..100 { }
            sem.release()
        }
        // Fiber B: waits up to 500ms — fiber A will release in time
        spawn {
            let ok = sem.try_acquire_for(Duration.from_millis(500))
            result.store(if ok { 1 } else { 0 })
            if ok { sem.release() }
        }
    }

    assert(result.load() == 1)
}
