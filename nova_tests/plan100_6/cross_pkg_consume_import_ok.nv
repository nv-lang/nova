// Plan 100.6 (D164): consume-маркер propagates через границы пакетов.
// Package A exports Transaction consume; Package B imports + consumes.

module plan100_6.cross_pkg_consume_import_ok

// Simulated: in real test, would be 2 packages.
// Here single-package mock с export + import.

// "Package A":
export type Transaction consume {
    id int,
}

export fn Transaction consume @commit() -> () { () }
export fn Transaction consume @rollback() -> () { () }
export fn begin() -> Transaction => { id: 42 }

// "Package B" — would import Transaction.
test "cross-package consume — import работает; binding-form OK" {
    consume tx = begin()                        // consume-marker visible from A
    tx.commit()
}
