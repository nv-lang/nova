// EXPECT_COMPILE_ERROR Self type used outside
//
// NEGATIVE guard for [M-138.2-self-in-param] (Ф.6 / G-E, plan 138.4).
//
// The fix binds `Self` into `current_type_subst` ONLY after `current_receiver_type`
// is set (guarded by a mono receiver). This fixture proves that binding is correctly
// gated on HAVING a receiver: a free (non-method) function has no receiver, so `Self`
// has nothing to resolve to and MUST be rejected — the fix did NOT make `Self`
// universally injectable. Error: [E7001] "Self type used outside receiver".
module self_nested.self_no_receiver_fail

// No receiver → `Self` is meaningless here. Must be a compile error, not silently
// resolved to some default C type.
fn standalone() -> Self => standalone()

test "unreachable — codegen must fail before running" {
    assert(true)
}
