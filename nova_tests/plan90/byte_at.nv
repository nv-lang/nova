// Plan 90 Ф.4.1 — str.byte_at: O(1) доступ к байту строки.

module nova_tests.plan90


test "byte_at — ASCII байты" {
    ro s = "ABC"
    assert(s.as_bytes()[0] as int == 65)
    assert(s.as_bytes()[1] as int == 66)
    assert(s.as_bytes()[2] as int == 67)
}

test "byte_at — граница (последний байт)" {
    ro s = "xy"
    assert(s.as_bytes()[1] as int == 121)
}

test "byte_at — UTF-8 multibyte" {
    // 'Я' = U+042F → UTF-8: 0xD0 0xAF
    ro s = "Я"
    assert(s.as_bytes()[0] as int == 0xD0)
    assert(s.as_bytes()[1] as int == 0xAF)
}
