// EXPECT_RUNTIME_PANIC str.byte_at: index out of bounds
//
// Plan 90 Ф.4.6 — негатив: byte_at за границей строки → panic.
//
// `fn main` (не `test`-блок): panic должен дойти до runtime-frame
// (внутри test-блока он перехватывается harness'ом).

module nova_tests.plan90.neg_byte_at_oob

fn main() -> () {
    ro s = "AB"
    ro _ = s.byte_at(5)
}
