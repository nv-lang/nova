module nova_tests.plan91_7.sort_chain_test

import std.sort

// Plan 91.7: sort/sort_by возвращают @ (после Part A) — direct call работает.
// Chain `arr.sort().push(...)` пока CC-FAIL для Nova-method+builtin combo
// (см. [M-91.7-mixed-method-chain] followup).

test "arr.sort() возвращает receiver" {
    mut a []int = [3, 1, 4, 1, 5]
    ro r = a.sort()
    assert(r.len() == 5)
    assert(a[0] == 1)
    assert(a[1] == 1)
    assert(a[2] == 3)
    assert(a[3] == 4)
    assert(a[4] == 5)
}

test "arr.sort_by(cmp) возвращает receiver" {
    mut a []int = [3, 1, 4, 1, 5]
    ro r = a.sort_by(|x, y| y - x)    // descending (D183 int convention)
    assert(r.len() == 5)
    assert(a[0] == 5)
    assert(a[4] == 1)
}

test "builtin chain после sort (по шагам)" {
    mut a = []int.new()
    a.push(3).push(1).push(2)
    a.sort()
    assert(a.len() == 3)
    assert(a[0] == 1)
    assert(a[1] == 2)
    assert(a[2] == 3)
}
