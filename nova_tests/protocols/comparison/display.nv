// Plan 85.4 Ф.3 — Display протокол.
//
// `Display` (D109): `fmt(sb StringBuilder) -> ()`. User-defined через
// `fn Type @display(mut sb StringBuilder) -> ()` — пишет representation
// в переданный StringBuilder. Результат читается через `sb.into_str()`.

module comparison.display


type Point { x int, y int }

fn Point @display(mut w Write) -> () {
    w.write("(")
    w.write(str.from(@x))
    w.write(", ")
    w.write(str.from(@y))
    w.write(")")
}


test "Point @display — пишет representation в StringBuilder" {
    ro p = Point { x: 3, y: 4 }
    consume sb = StringBuilder.new()
    p.display(sb)
    assert(sb.into_str() == "(3, 4)")
}

test "Point @display — отрицательные координаты" {
    ro p = Point { x: -1, y: -20 }
    consume sb = StringBuilder.new()
    p.display(sb)
    assert(sb.into_str() == "(-1, -20)")
}

test "Point @display — в непустой буфер дописывает" {
    ro p = Point { x: 0, y: 0 }
    consume sb = StringBuilder.new()
    sb.append("origin: ")
    p.display(sb)
    assert(sb.into_str() == "origin: (0, 0)")
}


// ── вложенный Display: тип содержит другой Display-тип ────────────

type Segment { a Point, b Point }

fn Segment @display(mut w Write) -> () {
    w.write("[")
    @a.display(w)
    w.write(" -> ")
    @b.display(w)
    w.write("]")
}

test "вложенный Display — Segment делегирует Point.fmt" {
    ro seg = Segment {
        a: Point { x: 1, y: 1 },
        b: Point { x: 5, y: 9 },
    }
    consume sb = StringBuilder.new()
    seg.display(sb)
    assert(sb.into_str() == "[(1, 1) -> (5, 9)]")
}


// ── два fmt подряд в один буфер ───────────────────────────────────

test "Display — несколько объектов в один буфер" {
    ro p1 = Point { x: 1, y: 2 }
    ro p2 = Point { x: 3, y: 4 }
    consume sb = StringBuilder.new()
    p1.display(sb)
    sb.append(" ")
    p2.display(sb)
    assert(sb.into_str() == "(1, 2) (3, 4)")
}