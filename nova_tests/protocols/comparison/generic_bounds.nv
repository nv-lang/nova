// Plan 85.4 Ф.3 — protocol-bounds в generic-функциях.
// Plan 91.8a (D183): eq→equals, cmp→compare (int), Ordering удалён.
//
// `[T Hash]` / `[T Equal]` / `[T Compare]` — instance-метод
// протокола вызывается на type-параметре внутри generic-тела. В отличие
// от static-методов (`T.from` — см. 85.3 ограничение), instance-метод
// на typevar мономорфизируется корректно.

module comparison.generic_bounds


type Item { id int }

fn Item @hash() -> u64 => @id as u64
fn Item @equal(other Item) -> bool => @id == other.id
fn Item @compare(other Item) -> int =>
    if @id < other.id { -1 }
    else if @id > other.id { 1 }
    else { 0 }


// ── single bound: Hash ────────────────────────────────────────

fn same_hash[T Hash](a T, b T) -> bool => a.hash() == b.hash()

test "generic [T Hash] — instance-dispatch на typevar" {
    ro a = Item { id: 7 }
    ro b = Item { id: 7 }
    ro c = Item { id: 9 }
    assert(same_hash[Item](a, b))
    assert(!same_hash[Item](a, c))
}


// ── single bound: Equal ───────────────────────────────────────

fn are_equal[T Equal](a T, b T) -> bool => a.equal(b)

test "generic [T Equal] — instance-dispatch" {
    ro a = Item { id: 3 }
    ro b = Item { id: 3 }
    ro c = Item { id: 4 }
    assert(are_equal[Item](a, b))
    assert(!are_equal[Item](a, c))
}


// ── single bound: Compare ──────────────────────────────────────

fn cmp_of[T Compare](a T, b T) -> int => a.compare(b)

test "generic [T Compare] — instance-dispatch возвращает int (D183)" {
    ro lo = Item { id: 1 }
    ro hi = Item { id: 5 }
    assert(cmp_of[Item](lo, hi) < 0)
    assert(cmp_of[Item](hi, lo) > 0)
    assert(cmp_of[Item](lo, lo) == 0)
}


// ── multi-bound через именованный комбинированный protocol ────────
//
// Nova не использует `+` для нескольких bound'ов (это Rust). Способы:
// (а) анонимный inline `protocol { ... }` — bootstrap-парсер пока не
// поддерживает в bound-позиции; (б) именованный protocol, объединяющий
// несколько методов — работает.

type HashEq protocol {
    @hash() -> u64
    @equal(other Self) -> bool
}

fn hash_eq_match[T HashEq](a T, b T) -> bool =>
    a.hash() == b.hash() && a.equal(b)

test "multi-bound именованный protocol — hash + equals вместе" {
    ro a = Item { id: 11 }
    ro b = Item { id: 11 }
    ro c = Item { id: 12 }
    assert(hash_eq_match[Item](a, b))
    assert(!hash_eq_match[Item](a, c))
}