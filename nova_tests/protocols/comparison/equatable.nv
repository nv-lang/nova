// Plan 85.4 Ф.1 — Equatable протокол.
// Plan 91.8a.2 part 3 (D183 amendment): magic methods @eq/@lt/@le/@gt/@ge
// удалены. == operator synthesized через @equals OR @compare. Type-author
// пишет только @equals (для Equatable) или @compare (Comparable bound).

module comparison.equatable


type Point { x int, y int }

// Single explicit method — operators ==/!= synthesized.
fn Point @equals(other Point) -> bool => @x == other.x && @y == other.y


test "equals — рефлексивность: x.equals(x)" {
    ro p = Point { x: 3, y: 4 }
    assert(p.equals(p))
}

test "equals — равные значения" {
    ro a = Point { x: 1, y: 2 }
    ro b = Point { x: 1, y: 2 }
    assert(a.equals(b))
}

test "equals — неравенство" {
    ro a = Point { x: 1, y: 2 }
    ro b = Point { x: 9, y: 2 }
    assert(!a.equals(b))
}

test "equals — симметрия: a.equals(b) == b.equals(a)" {
    ro a = Point { x: 5, y: 5 }
    ro b = Point { x: 5, y: 5 }
    ro c = Point { x: 7, y: 1 }
    assert(a.equals(b) == b.equals(a))
    assert(a.equals(c) == c.equals(a))
}

test "equals — транзитивность: a==b, b==c => a==c" {
    ro a = Point { x: 2, y: 2 }
    ro b = Point { x: 2, y: 2 }
    ro c = Point { x: 2, y: 2 }
    assert(a.equals(b))
    assert(b.equals(c))
    assert(a.equals(c))
}


// ── оператор == / != через @eq (D46) — до 91.8b ──────────────────

test "оператор == использует @eq (D46)" {
    ro a = Point { x: 10, y: 20 }
    ro b = Point { x: 10, y: 20 }
    assert(a == b)
}

test "оператор == — false для разных" {
    ro a = Point { x: 0, y: 0 }
    ro b = Point { x: 0, y: 1 }
    assert(!(a == b))
}

test "оператор != выводится из @eq" {
    ro a = Point { x: 1, y: 1 }
    ro b = Point { x: 2, y: 2 }
    ro same = Point { x: 1, y: 1 }
    assert(a != b)
    assert(!(a != same))
}
