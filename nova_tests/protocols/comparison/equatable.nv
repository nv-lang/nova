// Plan 85.4 Ф.1 — Equatable протокол.
// Plan 91.8a (D183): protocol method renamed eq→equals.
// Operator `==` все ещё dispatches к `@eq` (D46) — будет изменено в 91.8b
// (D184). До 91.8b тип-author пишет оба: @equals (для protocol satisfaction)
// и @eq (для оператора `==`).

module comparison.equatable


type Point { x int, y int }

// Plan 91.8a: protocol method (D183).
fn Point @equals(other Point) -> bool => @x == other.x && @y == other.y

// Pre-91.8b: оператор `==` dispatches to @eq (D46). Boilerplate до 91.8b
// (когда operator dispatch перейдёт на @equals и @eq можно будет удалить).
fn Point @eq(other Point) -> bool => @equals(other)


test "equals — рефлексивность: x.equals(x)" {
    let p = Point { x: 3, y: 4 }
    assert(p.equals(p))
}

test "equals — равные значения" {
    let a = Point { x: 1, y: 2 }
    let b = Point { x: 1, y: 2 }
    assert(a.equals(b))
}

test "equals — неравенство" {
    let a = Point { x: 1, y: 2 }
    let b = Point { x: 9, y: 2 }
    assert(!a.equals(b))
}

test "equals — симметрия: a.equals(b) == b.equals(a)" {
    let a = Point { x: 5, y: 5 }
    let b = Point { x: 5, y: 5 }
    let c = Point { x: 7, y: 1 }
    assert(a.equals(b) == b.equals(a))
    assert(a.equals(c) == c.equals(a))
}

test "equals — транзитивность: a==b, b==c => a==c" {
    let a = Point { x: 2, y: 2 }
    let b = Point { x: 2, y: 2 }
    let c = Point { x: 2, y: 2 }
    assert(a.equals(b))
    assert(b.equals(c))
    assert(a.equals(c))
}


// ── оператор == / != через @eq (D46) — до 91.8b ──────────────────

test "оператор == использует @eq (D46)" {
    let a = Point { x: 10, y: 20 }
    let b = Point { x: 10, y: 20 }
    assert(a == b)
}

test "оператор == — false для разных" {
    let a = Point { x: 0, y: 0 }
    let b = Point { x: 0, y: 1 }
    assert(!(a == b))
}

test "оператор != выводится из @eq" {
    let a = Point { x: 1, y: 1 }
    let b = Point { x: 2, y: 2 }
    let same = Point { x: 1, y: 1 }
    assert(a != b)
    assert(!(a != same))
}
