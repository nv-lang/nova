// Plan 85.4 Ф.2 — Ordering — prelude sum-тип.
//
// `Ordering` = `Less | Equal | Greater` (prelude core). Используется
// как возврат `Comparable.cmp`. Здесь — Ordering как самостоятельное
// значение: pattern match, передача, хранение.

module comparison.ordering


test "Ordering — литералы вариантов" {
    let l = Less
    let e = Equal
    let g = Greater
    let ln = match l {
        Less => 1
        Equal => 0
        Greater => 2
    }
    let en = match e {
        Less => 1
        Equal => 0
        Greater => 2
    }
    let gn = match g {
        Less => 1
        Equal => 0
        Greater => 2
    }
    assert(ln == 1)
    assert(en == 0)
    assert(gn == 2)
}

test "Ordering — значение можно передать в функцию" {
    let o = Greater
    assert(describe(o) == "gt")
    assert(describe(Less) == "lt")
    assert(describe(Equal) == "eq")
}

test "Ordering — exhaustive match без wildcard" {
    let o = Equal
    let r = match o {
        Less => false
        Equal => true
        Greater => false
    }
    assert(r)
}

test "Ordering — возврат из функции" {
    assert(invert(Less) == 2)
    assert(invert(Greater) == 1)
    assert(invert(Equal) == 0)
}


fn describe(o Ordering) -> str =>
    match o {
        Less => "lt"
        Equal => "eq"
        Greater => "gt"
    }

// Возвращает «инвертированный» порядок как число (Less<->Greater).
fn invert(o Ordering) -> int =>
    match o {
        Less => 2
        Equal => 0
        Greater => 1
    }
