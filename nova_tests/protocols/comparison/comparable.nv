// Plan 85.4 Ф.2 — Comparable протокол.
// Plan 91.8a (D183): Comparable.compare возвращает int (memcmp-style).
// Sum-тип Ordering удалён; sign проверяется напрямую.
//
// `Comparable`: `compare(other Self) -> int`. User-defined через
// `fn Type @compare(other Type) -> int`. < 0 = less, 0 = equal, > 0 = greater.

module comparison.comparable


type Priority { level int }

fn Priority @compare(other Priority) -> int =>
    if @level < other.level { -1 }
    else if @level > other.level { 1 }
    else { 0 }


test "compare — less (negative)" {
    ro a = Priority { level: 1 }
    ro b = Priority { level: 5 }
    assert(a.compare(b) < 0)
}

test "compare — equal (zero)" {
    ro a = Priority { level: 3 }
    ro b = Priority { level: 3 }
    assert(a.compare(b) == 0)
}

test "compare — greater (positive)" {
    ro a = Priority { level: 9 }
    ro b = Priority { level: 2 }
    assert(a.compare(b) > 0)
}

test "compare — антисимметрия: a<b => b>a" {
    ro a = Priority { level: 1 }
    ro b = Priority { level: 2 }
    assert(a.compare(b) < 0)
    assert(b.compare(a) > 0)
}

test "compare — рефлексивность: x.compare(x) == 0" {
    ro p = Priority { level: 42 }
    assert(p.compare(p) == 0)
}

test "compare — отрицательные уровни" {
    ro a = Priority { level: -5 }
    ro b = Priority { level: -1 }
    assert(a.compare(b) < 0)
}


// ── транзитивность порядка ────────────────────────────────────────

fn is_less(a Priority, b Priority) -> bool => a.compare(b) < 0

test "compare — транзитивность: a<b, b<c => a<c" {
    ro a = Priority { level: 1 }
    ro b = Priority { level: 5 }
    ro c = Priority { level: 10 }
    assert(is_less(a, b))
    assert(is_less(b, c))
    assert(is_less(a, c))
}
