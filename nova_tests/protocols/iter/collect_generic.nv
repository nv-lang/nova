// Plan 85.5 Ф.3 — Iterable[T]: generic-функция собирает Iter в `[]int`.

module iter.collect_generic


type CountDown { mut current int }

fn CountDown.new(start int) -> CountDown => { current: start }

fn CountDown mut @next() -> Option[int] {
    if @current <= 0 {
        None
    } else {
        ro v = @current
        @current = @current - 1
        Some(v)
    }
}


// Generic-функция: собрать все элементы Iterable[int] в массив.
fn collect_all[T Iterable[int]](mut it T) -> []int {
    mut out []int = []
    for n in it {
        out.push(n)
    }
    out
}


test "collect_all — длина результата" {
    ro got = collect_all[CountDown](CountDown.new(4))
    assert(got.len() == 4)
}

test "collect_all — порядок элементов" {
    ro got = collect_all[CountDown](CountDown.new(3))
    assert(got[0] == 3)
    assert(got[1] == 2)
    assert(got[2] == 1)
}

test "collect_all — пустой итератор даёт пустой массив" {
    ro got = collect_all[CountDown](CountDown.new(0))
    assert(got.len() == 0)
}

test "collect_all — сумма собранного" {
    ro got = collect_all[CountDown](CountDown.new(5))
    mut sum = 0
    for x in got {
        sum = sum + x
    }
    assert(sum == 15)
}
