// Plan 85.5 Ф.2 — Iterable[T]: встроенный массив `[]T` в for-in.

module iter.array_iter


test "for-in over []int — сумма" {
    let xs []int = [10, 20, 30]
    let mut sum = 0
    for x in xs {
        sum = sum + x
    }
    assert(sum == 60)
}

test "for-in over []int — пустой массив" {
    let xs []int = []
    let mut count = 0
    for _ in xs {
        count = count + 1
    }
    assert(count == 0)
}

test "for-in over []int — порядок сохранён" {
    let xs []int = [1, 2, 3, 4]
    let mut first = -1
    let mut last = -1
    let mut seen = 0
    for x in xs {
        if seen == 0 { first = x }
        last = x
        seen = seen + 1
    }
    assert(first == 1)
    assert(last == 4)
    assert(seen == 4)
}

test "for-in over []str" {
    let names []str = ["a", "bb", "ccc"]
    let mut total_len = 0
    for n in names {
        total_len = total_len + n.len()
    }
    assert(total_len == 6)
}

test "for-in over []int — break" {
    let xs []int = [5, 10, 15, 20]
    let mut sum = 0
    for x in xs {
        if x == 15 { break }
        sum = sum + x
    }
    assert(sum == 15)        // 5 + 10
}
