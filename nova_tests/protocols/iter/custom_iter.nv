// Plan 85.5 Ф.1 — Iterable[T]: user-defined итератор с состоянием.
//
// `Iterable[T]` (D58, structural): тип с `mut @next() -> Option[T]`
// удовлетворяет Iterable[T]. Здесь — корректность next(), exhaustion,
// idempotent-None после исчерпания.

module iter.custom_iter


type CountDown { mut current int }

fn CountDown.new(start int) -> CountDown => { current: start }

fn CountDown mut @next() -> Option[int] {
    if @current <= 0 {
        None
    } else {
        ro v = @current
        @current = @current - 1
        Some(v)
    }
}


test "next() — последовательность значений" {
    mut cd = CountDown.new(3)
    assert(cd.next() == Some(3))
    assert(cd.next() == Some(2))
    assert(cd.next() == Some(1))
    assert(cd.next() == None)
}

test "next() после исчерпания безопасен (idempotent None)" {
    mut cd = CountDown.new(1)
    assert(cd.next() == Some(1))
    assert(cd.next() == None)
    assert(cd.next() == None)
    assert(cd.next() == None)
}

test "next() — старт с 1" {
    mut cd = CountDown.new(1)
    assert(cd.next() == Some(1))
    assert(cd.next() == None)
}

test "next() — состояние продвигается" {
    mut cd = CountDown.new(5)
    ro a = cd.next()
    ro b = cd.next()
    assert(a == Some(5))
    assert(b == Some(4))
    // следующий — Some(3), состояние не сбрасывается
    assert(cd.next() == Some(3))
}

test "два независимых итератора не делят состояние" {
    mut a = CountDown.new(2)
    mut b = CountDown.new(2)
    assert(a.next() == Some(2))
    // b не затронут чтением a
    assert(b.next() == Some(2))
    assert(a.next() == Some(1))
    assert(b.next() == Some(1))
}
