// Plan 85.3 Ф.3 / Plan 88 — generic bound `[T TryFrom[X, E]]` + прямой
// static-вызов `T.try_from(...)` внутри тела generic-функции.
//
// D72: bound с fallible-конверсией. Static-метод `try_from` вызывается
// ПРЯМО на type-параметре `T` внутри generic-тела — мономорфизируется
// (Plan 88); return-тип `Result[T, E]` с type-параметром в
// return-позиции тоже резолвится в concrete (`NovaRes_<ok>_<err>`).

module conversion.generic_try_bound


type Pos { v int }
fn Pos.try_from(n int) -> Result[Pos, str] =>
    if n >= 0 {
        Ok(Pos { v: n })
    } else {
        Err("negative")
    }


// Generic-функция: static-вызов `T.try_from` + `Result[T, E]` в return.
fn checked[T TryFrom[int, str]](n int) -> Result[T, str] => T.try_from(n)


test "generic TryFrom-bound — T.try_from Ok-ветка" {
    let r = checked[Pos](42)
    assert(r.is_ok())
}

test "generic TryFrom-bound — T.try_from Err-ветка" {
    let r = checked[Pos](-5)
    assert(r.is_err())
}

test "TryFrom-bound enforced — Pos удовлетворяет TryFrom[int, str]" {
    let r = checked[Pos](1)
    assert(r.is_ok())
}
