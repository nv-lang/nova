// Plan 85.3 Ф.2 — TryInto[U, E]: instance-метод fallible-конверсии.
//
// `TryInto[U, E]` реализуется instance-методом
// `fn Type @try_into() -> Result[U, E]` (D77, migration path b).
//
// Note: в bootstrap TryInto НЕ авто-выводится из TryFrom (auto-derive
// отложен, см. std/prelude/protocols.nv) — метод объявляется напрямую.

module conversion.try_into_test


type Meters { v int }
type Feet { v int }

// TryInto[Feet, str] — прямой instance-метод.
fn Meters @try_into() -> Result[Feet, str] =>
    if @v >= 0 {
        Ok(Feet { v: @v * 3 })
    } else {
        Err("negative meters")
    }


test "try_into Ok — положительное значение" {
    ro m = Meters { v: 10 }
    ro r = m.try_into()
    assert(r.is_ok())
}

test "try_into Ok — payload корректен" {
    ro m = Meters { v: 4 }
    ro r = m.try_into()
    ro f = r.unwrap_or(Feet { v: 0 })
    assert(f.v == 12)
}

test "try_into Err — отрицательное значение" {
    ro m = Meters { v: -1 }
    ro r = m.try_into()
    assert(r.is_err())
}

test "try_into Err — сообщение" {
    ro m = Meters { v: -5 }
    ro r = m.try_into()
    ro msg = match r {
        Ok(_) => ""
        Err(e) => e
    }
    assert(msg == "negative meters")
}

test "try_into ноль -> Ok (граница)" {
    ro m = Meters { v: 0 }
    ro r = m.try_into()
    assert(r.is_ok())
    assert(r.unwrap_or(Feet { v: 99 }).v == 0)
}

test "try_into Ok/Err дискриминация через match" {
    ro good = Meters { v: 1 }
    ro bad = Meters { v: -1 }
    ro g_ok = match good.try_into() {
        Ok(_) => true
        Err(_) => false
    }
    ro b_ok = match bad.try_into() {
        Ok(_) => true
        Err(_) => false
    }
    assert(g_ok)
    assert(!b_ok)
}
