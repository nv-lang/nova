// Plan 85.3 Ф.3 / Plan 88 — generic bound `[T From[X]]` + прямой
// static-вызов `T.from(...)` внутри тела generic-функции.
//
// D72: имя протокола в bound-позиции generic-параметра. Static-метод
// `from` вызывается ПРЯМО на type-параметре `T` внутри generic-тела —
// мономорфизируется (Plan 88: `T` подставляется в obj-позицию
// static-вызова). Bound enforced — `T` обязан реализовать `From[X]`
// (негатив — neg_missing_impl.nv).

module conversion.generic_from_bound


type Name { s str }
fn Name.from(v str) -> Name => { s: v }

type Boxed { n int }
fn Boxed.from(v int) -> Boxed => { n: v }


// Generic-функция со static-вызовом `T.from` на type-параметре.
fn make[T From[str]](s str) -> T => T.from(s)

// From[int]-bound — `T.from(int)`.
fn make_int[T From[int]](x int) -> T => T.from(x)


test "generic From[str]-bound — T.from внутри generic-тела" {
    let r = make[Name]("alpha")
    assert(r.s == "alpha")
}

test "generic From[str]-bound — повторный инстанс" {
    let r = make[Name]("beta")
    assert(r.s == "beta")
}

test "generic From[int]-bound — T.from(int)" {
    let b = make_int[Boxed](99)
    assert(b.n == 99)
}
