// Plan 85.3 Ф.1 — Into[U]: auto-derive и обе формы пары From/Into.
//
// D73: программист пишет ОДНУ сторону пары, компилятор синтезирует
// вторую. Здесь — обе ситуации:
//   (a) написан `Type.from(v)` → авто-доступен `v.into()`;
//   (b) написан `Type @into()` → авто-доступен `Target.from(v)`.

module conversion.into_derive


// ── (a) написан from → into синтезируется ─────────────────────────

type Meters { v f64 }
type Feet { v f64 }

fn Feet.from(m Meters) -> Feet => { v: m.v * 3.28084 }

test "into() выводится из .from — аннотация даёт целевой тип" {
    ro f Feet = (Meters { v: 1.0 }).into()
    assert(f.v == 3.28084)
}

test "from() и into() дают идентичный результат" {
    ro m = Meters { v: 10.0 }
    ro via_from = Feet.from(m)
    ro via_into Feet = m.into()
    assert(via_from.v == via_into.v)
}


// ── (b) написан @into → from синтезируется ────────────────────────

type Id { raw int }

fn Id @into() -> str => "id-" + str.from(@raw)

test "@into() — explicit instance-вызов" {
    ro id = Id { raw: 5 }
    ro s str = id.into()
    assert(s == "id-5")
}

test "str.from(Id) выводится из @into" {
    ro id = Id { raw: 77 }
    ro s = str.from(id)
    assert(s == "id-77")
}


// ── into() в return-позиции — целевой тип из -> T ─────────────────

fn to_feet(m Meters) -> Feet => m.into()

test "into() в return-позиции функции" {
    ro f = to_feet(Meters { v: 2.0 })
    assert(f.v == 6.56168)
}
