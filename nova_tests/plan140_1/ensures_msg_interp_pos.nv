// Plan 140.3: a SATISFIED interpolated `ensures` message runs clean (the message
// is built lazily, only on a postcondition violation — never here).

module nova_tests.plan140_1

fn must_return_positive() -> int
    ensures result > 0, "result was ${result}"
=> 7

test "satisfied interpolated ensures: value passes through, no panic" {
    assert(must_return_positive() == 7)
}
