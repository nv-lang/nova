// EXPECT_RUNTIME_PANIC f3_contract_msg_violation.nv:12: requires failed: amount must be positive (amount > 0)
//
// Plan 140.1 Ф.2/Ф.3 (D24 amend), acceptance F3+F7: a `requires` contract WITH
// a custom message, when violated, aborts with
// `<file>:<line>: <kind> failed: <msg> (<expr>)` — the user message is shown
// and the expression is parenthesised after it. The LOC prefix is auto-added.
// Combination: contract, with msg.

module plan140_1.f3_contract_msg_violation

fn withdraw(amount int) -> int
    requires amount > 0, "amount must be positive"
=> amount

fn main() Io -> () {
    ro _ = withdraw(-1)
    println("UNREACHABLE")
}
