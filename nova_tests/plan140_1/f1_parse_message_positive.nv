// EXPECT_STDOUT ok
//
// Plan 140.1 Ф.1 (D24 amend), acceptance F3 (parse-side): the optional
// contract message `requires <expr>, "<string-lit>"` parses for requires,
// ensures, AND invariant. The message is stored in the AST (`Contract.message`)
// and does NOT alter codegen behaviour in Ф.1 — the diagnostic wiring lands in
// Ф.2. Here every contract holds, so the program runs to completion and prints
// `ok`, confirming the new grammar is accepted (no parse error, no regression).

module plan140_1.f1_parse_message_positive

type Counter {
    n int
}
    invariant n >= 0, "counter must never go negative"

fn checked_add(a int, b int) -> int
    requires a >= 0, "a must be non-negative"
    requires b >= 0, "b must be non-negative"
    ensures result >= a, "sum cannot be smaller than a"
=> a + b

fn main() Io -> () {
    ro c = Counter { n: 3 }
    ro s = checked_add(c.n, 4)
    if s == 7 {
        println("ok")
    } else {
        println("bad")
    }
}
