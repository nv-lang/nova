// Plan 123.1 T2.7: while/for loops СЃ ro @field reads вЂ” cache valid
// РїРѕСЃРєРѕР»СЊРєСѓ ro fields immutable.

module plan123_1.loop_iteration_ok

type IterData {
    ro start int
    ro count int
}

fn IterData @sum_arithmetic() -> int {
    // @start used 2 times (in loop), @count used 2 times (1 in cond,
    // 1 in body via @count check). Both ro в†’ cache emitted.
    mut total = 0
    mut i = 0
    while i < @count {
        total += @start + i
        i += 1
    }
    // After loop вЂ” last accesses of @start, @count for verification.
    if @count == 0 {
        @start
    } else {
        total
    }
}

fn IterData.new(s int, c int) -> IterData {
    IterData { start: s, count: c }
}

test "ro caching across loops" {
    ro r = IterData.new(10, 3).sum_arithmetic()
    // i=0: total=10, i=1: total=21, i=2: total=33. Return 33.
    assert(r == 33)
    ro r2 = IterData.new(7, 0).sum_arithmetic()
    // count=0, loop skipped, return @start=7.
    assert(r2 == 7)
}
