// Plan 123.1 T2.2: write boundary — after `@F = ...`, cache invalidated.
// V1 first-region: reads BEFORE write — eligible for cache;
// reads AFTER write — stay as direct @F access.

module nova_tests.plan123_1

type Counter6 {
    mut value int
}

fn Counter6 mut @bump_and_check() -> int {
    // Two reads BEFORE write → cache eligible (count=2 ≥ threshold).
    ro doubled = @value + @value
    @value = doubled
    // Read AFTER write — stays as direct @value (no re-cache в V1).
    @value
}

fn Counter6.new(v int) -> Counter6 {
    Counter6 { value: v }
}

test "mut field write invalidates cache" {
    mut c = Counter6.new(5)
    ro r = c.bump_and_check()
    // initial=5, doubled = 5+5=10, @value=10, return @value=10.
    assert(r == 10)
}
