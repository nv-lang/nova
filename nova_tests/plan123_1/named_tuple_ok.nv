// Plan 123.1 T2.14 positive: D215 named tuple receiver — fields
// treated as ro (stack value immutable) → cached.

module nova_tests.plan123_1

type Vec32(x int, y int, z int)

fn Vec32 @magnitude_sq() -> int {
    @x * @x + @y * @y + @z * @z
}

test "named tuple ro caching" {
    ro v = Vec32(3, 4, 12)
    // 9 + 16 + 144 = 169
    assert(v.magnitude_sq() == 169)
}
