// Plan 83.7 (2026-05-25): runnext displacement test.
//
// Two consecutive same-worker wake'ов — second push displaces first
// runnext к deque. Verify no loss — both fibers eventually run.
//
// Test через channel ping-pong: producer wakes consumer; multiple
// pong cycles → runnext gets exercise displaced+restored.
//
// ALLOC_REQUIRES boehm
// ENV NOVA_AUTOARM=0
// Plan 83.7: channel ping-pong inherently cooperative-dependent; under
// armed M:N current channel routing has separate gaps (Plan 49 Ф.5).

module plan83_7.runnext_displaced_to_deque

test "consecutive wakes — both fibers run, no loss" {
    let n = 100
    let ch = Channel.new(1)
    let mut received = 0
    supervised {
        spawn {
            let mut i = 0
            while i < n {
                let _v = ch.rx.recv()
                received = received + 1
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < n {
                ch.tx.send(i)
                i = i + 1
            }
        }
    }
    assert(received == n)
}
