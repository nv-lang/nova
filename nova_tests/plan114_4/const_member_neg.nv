// Plan 114.4 Ф.1 NEG: const X = obj.member — non-constexpr (member access).

// EXPECT_COMPILE_ERROR E_CONST_NOT_CONSTEXPR

module nova_tests.plan114_4.const_member_neg

type Point { x f64, y f64 }

const ORIGIN Point = Point { x: 1.0, y: 2.0 }
const BAD f64 = ORIGIN.x

test "const member access retracted" {
    assert(BAD == 1.0)
}
