// Plan 100.4.5 (D151): supervised + spawn + cancel — errdefer fires
// на cancel-path, consume cleanup гарантирован.

module nova_tests.plan100_4_5.supervised_spawn_cancel_errdefer_ok

type Transaction consume { id int }

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

fn long_op() Time -> () {
    Time.sleep(1000)
}

fn process(cancel CancelToken) -> () {
    supervised(cancel: cancel) {
        spawn {
            consume tx = begin()
            errdefer { tx.rollback() }          // покрывает cancel-path (D90 §7 amend)
            long_op()                            // может cancel в любой момент
            tx.commit()                          // success-path
        }
    }
    // Если outer cancel: spawned fiber unwinding → errdefer → rollback ✅
}

test "supervised+spawn+cancel — errdefer covers consume на cancel" {
    let tok = CancelToken.new()
    process(tok)
}
