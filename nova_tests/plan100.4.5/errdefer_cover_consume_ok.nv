// Plan 100.4.5 (D162): canonical pattern — errdefer cover'ит consume на
// error-path; explicit commit на success-path.

module nova_tests.plan100_4_5.errdefer_cover_consume_ok

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

fn do_work() Fail[str] -> () { () }

// Canonical pattern:
//   - errdefer cover'ит error-path (rollback)
//   - explicit commit на success-path
//   - check_consume распознаёт оба пути (D162)
fn process() Fail[str] -> () {
    consume tx = begin()
    errdefer { tx.rollback() }                  // error-path cover
    do_work()?                                   // может throw
    tx.commit()                                  // success-path explicit
}

test "errdefer rollback + explicit commit — exhaustive cover" {
    process()
}
