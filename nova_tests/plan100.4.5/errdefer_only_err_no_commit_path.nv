// EXPECT_COMPILE_ERROR D162
//
// Plan 100.4.5 (D162): errdefer alone — success path tx Live не covered.
// Compiler ловит partial cover.

module nova_tests.plan100_4_5.errdefer_only_err_no_commit_path

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

fn do_work() Fail[str] -> () { () }

fn process() Fail[str] -> () {
    consume tx = begin()
    errdefer { tx.rollback() }                  // только error path
    do_work()?
    // ❌ success path: tx Live, no commit, no okdefer.
    // ОШИБКА D162-not-consumed-on-path: success path uncovered.
    // Suggest: add `tx.commit()` или `okdefer { tx.commit() }`.
}

test "errdefer без commit success-path — uncovered error" {
    process()
}
