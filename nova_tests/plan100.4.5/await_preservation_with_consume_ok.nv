// Plan 100.4.5 (D151): await не consume; errdefer пересекает await.

module nova_tests.plan100_4_5.await_preservation_with_consume_ok

type Transaction consume { id int }

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

fn long_async_op() Time -> int {
    Time.sleep(100)
    42
}

fn process() Time Fail -> () {
    consume tx = begin()
    errdefer { tx.rollback() }                  // covered across await
    let r = await long_async_op()               // suspend; tx still Live
    if r < 0 { throw "negative" }
    tx.commit()
}

test "await не consume; errdefer pereсekает await" {
    process()
}
