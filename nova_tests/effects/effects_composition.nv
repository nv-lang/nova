// 28_effects_composition.nv — композиция нескольких эффектов (D61).
//
// 13_effects.nv покрыл базовые случаи. Здесь:
// - функция с двумя эффектами в сигнатуре (Logger Counter)
// - вложенные with-блоки для разных эффектов
// - state-style эффект через get/set
// - reader/writer паттерн

module effects.effects_composition

type Logger effect {
    log(msg str) -> ()
}

type Counter effect {
    next() -> int
}

type State effect {
    get() -> int
    set(n int) -> ()
}

type Reader effect {
    read() -> str
}

type Writer effect {
    write(s str) -> ()
}

// --- Two effects ---

fn task(n int) Logger Counter -> int {
    ro id = Counter.next()
    Logger.log("processing")
    n * id
}

test "функция с двумя эффектами в сигнатуре (flat with)" {
    mut entries = []
    mut count = 0
    with Logger = effect Logger {
        log(msg) {
            entries.push(msg)
            return ()
        }
    }, Counter = effect Counter {
        next() {
            count += 1
            return count
        }
    } {
        ro a = task(10)
        ro b = task(20)
        assert(a == 10)
        assert(b == 40)
    }
    assert(entries.len() == 2)
    assert(count == 2)
}

// --- State effect ---

test "state effect — get/set" {
    mut s = 100
    with State = effect State {
        get() => s
        set(n) {
            s = n
            return ()
        }
    } {
        ro v1 = State.get()
        assert(v1 == 100)
        State.set(v1 + 5)
        ro v2 = State.get()
        assert(v2 == 105)
        State.set(v2 * 2)
        assert(State.get() == 210)
    }
    assert(s == 210)
}

test "state — accumulator pattern" {
    mut acc = 0
    with State = effect State {
        get() => acc
        set(n) {
            acc = n
            return ()
        }
    } {
        for i in 1..6 {
            ro cur = State.get()
            State.set(cur + i)
        }
    }
    assert(acc == 1 + 2 + 3 + 4 + 5)
}

// --- Reader/Writer pipe ---

fn echo() Reader Writer -> () {
    ro s = Reader.read()
    Writer.write(s + "!")
}

test "reader/writer композиция (flat with)" {
    mut output = ""
    ro input = "hello"
    with Reader = effect Reader {
        read() => input
    }, Writer = effect Writer {
        write(s) {
            output = s
            return ()
        }
    } {
        echo()
    }
    assert(output == "hello!")
}

// --- Counter с разной семантикой ---

fn three() Counter -> int {
    Counter.next() + Counter.next() + Counter.next()
}

test "константный counter" {
    with Counter = effect Counter {
        next() => 7
    } {
        ro total = three()
        assert(total == 21)
    }
}

test "нарастающий counter с state" {
    mut n = 0
    with Counter = effect Counter {
        next() {
            n += 1
            return n
        }
    } {
        ro total = three()
        assert(total == 1 + 2 + 3)
    }
    assert(n == 3)
}

test "decrementing counter" {
    mut n = 100
    with Counter = effect Counter {
        next() {
            n -= 10
            return n
        }
    } {
        ro r = Counter.next() + Counter.next() + Counter.next()
        assert(r == 90 + 80 + 70)
    }
    assert(n == 70)
}
