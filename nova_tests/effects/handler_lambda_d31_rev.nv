// handler_lambda_d31_rev.nv — Plan 19 C8: D31-rev handler-лямбда
// `with EffectName = |args| body { ... }`.
//
// Проверяет что handler-лямбда (closure-light в позиции `with X = `)
// для эффектов с одной операцией работает как handler-литерал-сахар.
//
// **Note**: codegen handler-лямбда D31-rev не реализован полностью
// в bootstrap (handler в emit_with ожидает NovaVtable struct).
// Если codegen pipeline не справляется, runtime через interp
// (`cargo run -- test ...`) подтверждает interp-side D31-rev.

module nova_tests.effects

type Logger3 effect {
    log(msg str) -> ()
}

fn make_msg() Logger3 -> str {
    Logger3.log("hi")
    "done"
}

test "handler-лямбда: handler-литерал baseline" {
    mut captured = ""
    with Logger3 = effect Logger3 {
        log(msg) {
            captured = msg
            return ()
        }
    } {
        ro r = make_msg()
        assert(r == "done")
    }
    assert(captured == "hi")
}

test "D31-rev sugar: with Logger3 = |msg| ... " {
    mut captured = ""
    with Logger3 = |msg| {
        captured = msg
    } {
        ro r = make_msg()
        assert(r == "done")
    }
    assert(captured == "hi")
}
