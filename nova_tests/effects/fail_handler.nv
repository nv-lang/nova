// 45_fail_handler.nv — Fail как обычный эффект, ловится через with-handler.
//
// Spec D25/D62/D65: `throw expr` — это операция эффекта Fail, не магия.
// «Никакой отдельной логики для throw нет; та же проверка, что для
//  Db.query, Net.get, Time.now».
//
// В bootstrap'е (2026-05-06): Fail pre-registered как built-in эффект,
// `throw msg` desugared to `Nova_Fail_fail(msg)`. Default handler в
// runtime — fall back на nova_throw (longjmp в test_frame или abort).
// User override: `with Fail = effect Fail { fail(msg) { ... } } { body }`.
//
// Spec явно отвергает try/catch синтаксис ([rejected.md]) — единственный
// способ перехватить throw это handler через with.

// Plan 83.4.5.4 (2026-05-23): cooperative Fail-handler test — armed mode
// Fail handler cross-mco-boundary interrupt failed (handler NULL on worker).
// Plan 83.4.5.8 (2026-05-24): AUTOARM=0 restored.
// Plan 83.10.1 (2026-05-26): STILL NEEDED — armed: "handler ловит throw из
// supervised" fails. [M-83.10.1-fail-handler-cross-mco-longjmp]: root cause
// same as TLS handler race — _nova_handler_Fail = NULL on worker threads.
// Plan 83.10.4 Ф.3 (2026-05-27): FIXED by per-thread TLS registry fix (same
// fix as per_fiber_handlers). Worker registers its own _nova_handler_Fail.
// Snapshot restore on first fiber run makes handler available on worker.
// AUTOARM=0 directive removed — all tests pass under full M:N armed mode.
//
// NOTE: The cooperative-ordering cancellation test (cancel via FIFO scheduling)
// was removed — it depended on cooperative FIFO semantics (spawn0 runs before
// spawn1) which don't hold in M:N parallel execution. Cancel semantics under
// concurrent M:N are tested separately in plan83_10_4 fixtures.


module effects.fail_handler

// Functions that throw via Fail.
fn parse_num(s str) -> int {
    if s == "ok" { return 42 }
    throw "parse failed"
}

fn divide(a int, b int) -> int {
    if b == 0 {
        throw "division by zero"
    }
    a / b
}

// ================================================================
// SECTION 1: handler ловит throw на main-flow
// ================================================================

test "with Fail: catches throw, body completes after handler" {
    let mut caught_msg = ""
    let mut handler_ran = false
    with Fail = effect Fail {
        fail(msg) {
            caught_msg = msg
            handler_ran = true
            interrupt ()
        }
    } {
        let _ = parse_num("bad")
    }
    assert(handler_ran)
    assert(caught_msg == "parse failed")
}

test "with Fail: ok-path doesn't trigger handler" {
    let mut handler_ran = false
    let mut got_value = 0
    with Fail = effect Fail {
        fail(_msg) {
            handler_ran = true
            interrupt ()
        }
    } {
        got_value = parse_num("ok")
    }
    assert(!handler_ran)
    assert(got_value == 42)
}

test "with Fail: divide by zero caught" {
    let mut caught = ""
    with Fail = effect Fail {
        fail(msg) {
            caught = msg
            interrupt ()
        }
    } {
        let _ = divide(10, 0)
    }
    assert(caught == "division by zero")
}

test "with Fail: divide ok-path returns value" {
    let mut value = 0
    with Fail = effect Fail {
        fail(_msg) {
            interrupt ()
        }
    } {
        value = divide(10, 2)
    }
    assert(value == 5)
}

// ================================================================
// SECTION 2: handler ловит throw из supervised
// ================================================================
//
// КЛЮЧЕВОЙ ТЕСТ: throw из fiber → spawn-entry catch → scope rethrow
// на main → with Fail handler ловит. Закрывает [H]-gap из roadmap [R10]
// (см. simplifications.md).

test "with Fail: throw from spawn caught by outer handler" {
    let mut caught = ""
    with Fail = effect Fail {
        fail(msg) {
            caught = msg
            interrupt ()
        }
    } {
        supervised {
            spawn {
                throw "from fiber"
            }
        }
    }
    assert(caught == "from fiber")
}

test "with Fail: handler ловит throw из supervised (cross-mco-boundary interrupt)" {
    // По spec D61/D65: handler-method для Fail (fail() -> never)
    // завершается через `interrupt v`, не через return/trailing.
    //
    // Когда throw случается в spawn-body, а with-handler установлен
    // снаружи supervised, `interrupt v` пересекает mco-coroutine-boundary.
    // Runtime обрабатывает через scope.interrupt_pending mechanism:
    //   1. nova_interrupt() detect'ит что нет fiber-local interrupt-frame.
    //   2. Записывает (pending=true, value) в scope, set'ит cancel_requested.
    //   3. longjmp на fiber-local fail-frame с sentinel-msg "__nova_interrupt__".
    //   4. spawn-entry catch detect'ит sentinel — НЕ вызывает report_error.
    //   5. supervised_run после drain re-issue'ит nova_interrupt(value)
    //      на main-flow, где with-frame достижим.
    let mut caught = ""
    let mut invocations = 0
    with Fail = effect Fail {
        fail(msg) {
            caught = msg
            invocations += 1
            interrupt ()
        }
    } {
        supervised {
            spawn { throw "boom" }
        }
    }
    assert(invocations == 1)
    assert(caught == "boom")
}

// NOTE: cooperative-ordering cancellation test removed (Plan 83.10.4 Ф.4).
// The "peer fiber cancelled by FIFO ordering" test relied on cooperative
// scheduling semantics (spawn0 always runs before spawn1). In armed M:N mode,
// both fibers can run on separate workers simultaneously — spawn1 may complete
// entirely before spawn0 even starts, or before cancel_requested is visible
// to spawn1's worker after spawn1's yield. This is a fundamental M:N race
// that cannot be resolved without making cancel propagation synchronous across
// all workers. Cancel-under-M:N semantics tested in plan83_10_4/ fixtures.
