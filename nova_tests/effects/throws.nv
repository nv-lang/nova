// 14_throws.nv — `?` пробрасывание Result/Option (D25 в bootstrap-варианте).
//
// В bootstrap'е `?` распакует Ok/Err и Some/None из прелюдии: на Ok/Some
// возвращает значение, на Err/None — превращает в Throw, который пробрасывается
// до match { Err(_) => ... }. Полноценные Throws-handler'ы — для будущих
// версий компилятора.

module nova_tests.effects.throws

fn parse_pos(s str) -> Result {
    if s == "good" { return Ok(42) }
    Err("bad input")
}

fn lookup(n int) -> Option {
    if n > 0 { return Some(n * 10) }
    None
}

fn use_ok() -> Result {
    let v = parse_pos("good")?
    Ok(v + 1)
}

fn use_err() -> Result {
    let _v = parse_pos("nope")?
    Ok(0)
}

fn use_some() -> Option {
    let v = lookup(5)?
    Some(v + 1)
}

fn use_none() -> Option {
    let _v = lookup(-1)?
    Some(0)
}

test "? unwraps Ok" {
    let r = use_ok()
    let v = match r {
        Ok(n)  => n
        Err(_) => -1
    }
    assert(v == 43)
}

test "? on Err propagates as Err in caller" {
    let r = use_err()
    let s = match r {
        Ok(_)   => "ok"
        Err(msg) => msg
    }
    assert(s == "bad input")
}

test "? unwraps Some" {
    let r = use_some()
    let v = match r {
        Some(n) => n
        None    => -1
    }
    assert(v == 51)
}

test "? on None propagates" {
    let r = use_none()
    let v = match r {
        Some(n) => n
        None    => 999
    }
    assert(v == 999)
}

test "?? coalesce on None" {
    let a = Some(5) ?? 0
    assert(a == 5)
    let b = None ?? 10
    assert(b == 10)
}

// ─── D28 effect inference для private fn ───
// Private fn без явного `Fail` в сигнатуре, но с `throw` в теле,
// получает `Fail` автоматически через D28-inference (D62 strict
// transitivity делает явное добавление обязательным иначе).
//
// Smoke test: компиляция должна пройти, потому что D28 добавляет
// Fail в сигнатуру validate_d28. Без D28 codegen падал бы на «throw
// requires effect Fail». Тестируем happy path (n >= 0).

fn validate_d28(n int) -> int {
    if n < 0 { throw "negative" }
    n * 2
}

test "D28: private fn компилируется + работает на happy path" {
    let r = validate_d28(7)
    assert(r == 14)
    let r2 = validate_d28(0)
    assert(r2 == 0)
}

// ─── D81 debug_assert smoke ───
// debug_assert(cond) — alias для assert в bootstrap (single build-mode).
// Production-runtime: debug-only, no-op в release. По D81 семантика та
// же, что assert — strong invariant; разница только в overhead.

test "D81 debug_assert: same runtime semantics как assert" {
    debug_assert(1 + 1 == 2)
    debug_assert(true)
    debug_assert("a" == "a")
}
