// 18_forbid_realtime.nv — D63 (forbid) + D64 (realtime).
//
// В bootstrap-интерпретаторе runtime барьер для forbid не реализован,
// и нет fiber-runtime'а для realtime — оба блока работают как обычные
// block-expression'ы. Эти тесты проверяют что **парсер** принимает
// синтаксис и блок исполняется.
//
// Production-компилятор будет делать compile-time + runtime проверки.

module nova_tests.effects.forbid_realtime

type Counter effect {
    next() -> int
}

test "forbid block — синтаксис парсится, body исполняется" {
    let r = forbid Counter {
        // body исполняется как обычный block;
        // в production здесь Counter.next() был бы запрещён
        42
    }
    assert(r == 42)
}

test "forbid с несколькими эффектами через запятую" {
    let r = forbid Counter, Fail {
        let x = 10
        let y = 20
        x + y
    }
    assert(r == 30)
}

test "realtime block — синтаксис парсится" {
    let r = realtime {
        let mut sum = 0
        for i in 1..6 {
            sum += i
        }
        sum
    }
    assert(r == 1 + 2 + 3 + 4 + 5)
}

test "realtime nogc block" {
    let r = realtime nogc {
        let mut x = 100
        x += 50
        x
    }
    assert(r == 150)
}

test "forbid вложенный в обычный код" {
    let mut total = 0
    for i in 1..4 {
        let v = forbid Counter {
            i * 10
        }
        total += v
    }
    assert(total == 10 + 20 + 30)
}

test "realtime в expression position" {
    let r = if true {
        realtime { 100 }
    } else {
        0
    }
    assert(r == 100)
}


// Plan 16: pure-fn внутри forbid — OK (нет effects, нет conflict'а).
fn pure_double(x int) -> int => x * 2

test "forbid с pure-fn внутри — type-check OK" {
    let r = forbid Counter, Fail {
        pure_double(21)
    }
    assert(r == 42)
}


// Plan 16 Ф.5: #realtime атрибут на функции (D64 §3697).
// Plan 33.1: миграция @ → # для разделения attribute-prefix от receiver-prefix.
#realtime
fn rt_compute(n int) -> int {
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum += i
        i += 1
    }
    sum
}

test "#realtime attribute — body работает как realtime block" {
    let s = rt_compute(10)
    // 0+1+2+...+9 = 45
    assert(s == 45)
}


// Plan 16 Ф.5 + Ф.4: #realtime nogc — то же + alloc-ban.
#realtime nogc
fn rt_nogc_compute(x int, y int) -> int {
    x + y
}

test "#realtime nogc attribute — pure body OK" {
    assert(rt_nogc_compute(7, 8) == 15)
}
