// 18_forbid_realtime.nv — D63 (forbid) + D64 (realtime).
// Plan 113: realtime { } block form removed; tests migrated to #realtime fn.
//
// forbid blocks still work as block-expressions.
// realtime semantics are now expressed via #realtime fn attribute.

module effects.forbid_realtime

type Counter effect {
    next() -> int
}

test "forbid block — syntax parsed, body executes" {
    ro r = forbid Counter {
        42
    }
    assert(r == 42)
}

test "forbid with multiple effects" {
    ro r = forbid Counter, Fail {
        ro x = 10
        ro y = 20
        x + y
    }
    assert(r == 30)
}

// Plan 113: realtime tests use #realtime fn form.
#realtime fn _rt_sum_to_n(n int) -> int {
    mut sum = 0
    mut i = 1
    while i <= n {
        sum += i
        i += 1
    }
    sum
}

test "#realtime fn — body works correctly" {
    ro s = _rt_sum_to_n(5)
    // 1+2+3+4+5 = 15
    assert(s == 15)
}

#realtime fn _rt_compute_nogc(x int, y int) -> int {
    x + y
}

test "#realtime fn with arithmetic — pure body OK" {
    assert(_rt_compute_nogc(7, 8) == 15)
}

test "forbid nested in loop" {
    mut total = 0
    for i in 1..4 {
        ro v = forbid Counter {
            i * 10
        }
        total += v
    }
    assert(total == 10 + 20 + 30)
}

test "forbid in expression position" {
    ro r = if true {
        forbid Counter {
            100
        }
    } else {
        0
    }
    assert(r == 100)
}

// Plan 16: pure-fn inside forbid — OK.
fn pure_double(x int) -> int => x * 2

test "forbid with pure-fn inside — type-check OK" {
    ro r = forbid Counter, Fail {
        pure_double(21)
    }
    assert(r == 42)
}

// Plan 16 Ф.5: #realtime attribute on fn (D64 §3697).
#realtime
fn rt_compute(n int) -> int {
    mut sum = 0
    mut i = 0
    while i < n {
        sum += i
        i += 1
    }
    sum
}

test "#realtime attribute — body executes correctly" {
    ro s = rt_compute(10)
    // 0+1+2+...+9 = 45
    assert(s == 45)
}

// Plan 16 Ф.5 + Ф.4: #realtime nogc.
#realtime nogc
fn rt_nogc_compute(x int, y int) -> int {
    x + y
}

test "#realtime nogc attribute — pure body OK" {
    assert(rt_nogc_compute(7, 8) == 15)
}
