// 35_stateful_handlers.nv — D68: stateful handlers через closure capture
// или через record + @-метод-фабрику.
//
// Демонстрирует два паттерна по D68:
// 1. Closure capture — state живёт в let mut вне with, handler-методы
//    захватывают state через closure.
// 2. Record + @method — state живёт в полях record'а, handler-литерал
//    обращается к state через метод record'а (closure-capture record'а
//    самого).
//
// Полный паттерн D68 «type T { mut x int }; fn T @as_handler() -> Effect[E]»
// с использованием `s.as_handler()` в `with` — ломается в bootstrap-парсере
// (см. docs/known-issues-bootstrap.md «with X = factory()»).
// Для тестов используем альтернативный синтаксис.

module nova_tests.effects

type Counter4 effect {
    next() -> int
}

// === Способ 1: Closure capture ===

test "closure capture — state в mut" {
    mut counter = 0
    with Counter4 = effect Counter4 {
        next() {
            counter += 1
            return counter
        }
    } {
        ro a = Counter4.next()
        ro b = Counter4.next()
        ro c = Counter4.next()
        assert(a == 1)
        assert(b == 2)
        assert(c == 3)
    }
    ro v = counter
    assert(v == 3)
}

test "closure capture — state переживает несколько with-блоков" {
    mut counter = 100
    with Counter4 = effect Counter4 {
        next() {
            counter += 10
            return counter
        }
    } {
        ro _ = Counter4.next()
        ro _ = Counter4.next()
    }
    ro mid = counter
    assert(mid == 120)

    with Counter4 = effect Counter4 {
        next() {
            counter += 1
            return counter
        }
    } {
        ro r = Counter4.next()
        assert(r == 121)
    }
    ro final_v = counter
    assert(final_v == 121)
}

// === Способ 2: Record + @method (упрощённый — handler ссылается через closure) ===

type CounterState2 { mut value int }

fn CounterState2 @inc_and_get() -> int {
    @value += 1
    @value
}

test "record + @method — handler ссылается через closure на record" {
    mut s = CounterState2 { value: 0 }
    with Counter4 = effect Counter4 {
        next() => s.inc_and_get()
    } {
        ro a = Counter4.next()
        ro b = Counter4.next()
        ro c = Counter4.next()
        assert(a == 1)
        assert(b == 2)
        assert(c == 3)
    }
    ro v = s.value
    assert(v == 3)
}

test "record state — несколько handler'ов на один state" {
    mut s = CounterState2 { value: 0 }
    ro h1 = effect Counter4 {
        next() => s.inc_and_get()
    }
    with Counter4 = h1 {
        ro _ = Counter4.next()
        ro _ = Counter4.next()
    }
    ro after_h1 = s.value
    assert(after_h1 == 2)

    ro h2 = effect Counter4 {
        next() => s.inc_and_get()
    }
    with Counter4 = h2 {
        ro r = Counter4.next()
        assert(r == 3)
    }
    ro after_h2 = s.value
    assert(after_h2 == 3)
}

// === Handler-фабрика как свободная функция (caller передаёт state) ===
// NOTE: handler literal в non-test fn вызывает codegen bug (нет forward-decl
// для impl-функции). Тест реализован inline без helper-функции.

test "handler-фабрика — state передаётся inline (без helper fn)" {
    mut s = CounterState2 { value: 10 }
    with Counter4 = effect Counter4 {
        next() => s.inc_and_get()
    } {
        ro a = Counter4.next()
        ro b = Counter4.next()
        assert(a == 11)
        assert(b == 12)
    }
    ro v = s.value
    assert(v == 12)
}

// === Two effects, общий state ===

type Reset effect {
    reset() -> ()
}

test "два эффекта на один state (closure capture)" {
    // CounterState2.inc_and_get() через closure capture без mut record field.
    // Простой счётчик через closure.
    mut counter = 0
    ro h_counter = effect Counter4 {
        next() {
            counter += 1
            return counter
        }
    }
    with Counter4 = h_counter {
        ro a = Counter4.next()
        ro b = Counter4.next()
        ro c = Counter4.next()
        assert(a == 1)
        assert(b == 2)
        assert(c == 3)
    }
    assert(counter == 3)
}
