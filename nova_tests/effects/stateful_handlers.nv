// 35_stateful_handlers.nv — D68: stateful handlers через closure capture
// или через record + @-метод-фабрику.
//
// Демонстрирует два паттерна по D68:
// 1. Closure capture — state живёт в let mut вне with, handler-методы
//    захватывают state через closure.
// 2. Record + @method — state живёт в полях record'а, handler-литерал
//    обращается к state через метод record'а (closure-capture record'а
//    самого).
//
// Полный паттерн D68 «type T { mut x int }; fn T @as_handler() -> Effect[E]»
// с использованием `s.as_handler()` в `with` — ломается в bootstrap-парсере
// (см. docs/known-issues-bootstrap.md «with X = factory()»).
// Для тестов используем альтернативный синтаксис.

module effects.stateful_handlers

type Counter effect {
    next() -> int
}

// === Способ 1: Closure capture ===

test "closure capture — state в mut" {
    mut counter = 0
    with Counter = effect Counter {
        next() {
            counter += 1
            return counter
        }
    } {
        ro a = Counter.next()
        ro b = Counter.next()
        ro c = Counter.next()
        assert(a == 1)
        assert(b == 2)
        assert(c == 3)
    }
    ro v = counter
    assert(v == 3)
}

test "closure capture — state переживает несколько with-блоков" {
    mut counter = 100
    with Counter = effect Counter {
        next() {
            counter += 10
            return counter
        }
    } {
        ro _ = Counter.next()
        ro _ = Counter.next()
    }
    ro mid = counter
    assert(mid == 120)

    with Counter = effect Counter {
        next() {
            counter += 1
            return counter
        }
    } {
        ro r = Counter.next()
        assert(r == 121)
    }
    ro final_v = counter
    assert(final_v == 121)
}

// === Способ 2: Record + @method (упрощённый — handler ссылается через closure) ===

type CounterState { mut value int }

fn CounterState @inc_and_get() -> int {
    @value += 1
    @value
}

test "record + @method — handler ссылается через closure на record" {
    ro s = CounterState { value: 0 }
    with Counter = effect Counter {
        next() => s.inc_and_get()
    } {
        ro a = Counter.next()
        ro b = Counter.next()
        ro c = Counter.next()
        assert(a == 1)
        assert(b == 2)
        assert(c == 3)
    }
    ro v = s.value
    assert(v == 3)
}

test "record state — несколько handler'ов на один state" {
    ro s = CounterState { value: 0 }
    ro h1 = effect Counter {
        next() => s.inc_and_get()
    }
    with Counter = h1 {
        ro _ = Counter.next()
        ro _ = Counter.next()
    }
    ro after_h1 = s.value
    assert(after_h1 == 2)

    ro h2 = effect Counter {
        next() => s.inc_and_get()
    }
    with Counter = h2 {
        ro r = Counter.next()
        assert(r == 3)
    }
    ro after_h2 = s.value
    assert(after_h2 == 3)
}

// === Handler-фабрика как свободная функция (caller передаёт state) ===

fn make_counter_starting(start_state CounterState) -> Effect[Counter] => effect Counter {
    next() => start_state.inc_and_get()
}

test "handler-фабрика принимает state как параметр" {
    ro s = CounterState { value: 10 }
    ro h = make_counter_starting(s)
    with Counter = h {
        ro a = Counter.next()
        ro b = Counter.next()
        assert(a == 11)
        assert(b == 12)
    }
    ro v = s.value
    assert(v == 12)
}

// === Two effects, общий state ===

type Reset effect {
    reset() -> ()
}

test "два эффекта на один state" {
    ro s = CounterState { value: 0 }
    ro h_counter = effect Counter {
        next() => s.inc_and_get()
    }
    ro h_reset = effect Reset {
        reset() {
            s.value = 0
            return ()
        }
    }
    with Counter = h_counter, Reset = h_reset {
        ro a = Counter.next()
        ro b = Counter.next()
        assert(a == 1)
        assert(b == 2)
        Reset.reset()
        ro c = Counter.next()
        assert(c == 1)
    }
    ro final_v = s.value
    assert(final_v == 1)
}
