// EXPECT_COMPILE_ERROR no field or method `compare`
module neg.neg_no_compare_method

type Weight { kg int }
fn Weight @equal(other Weight) -> bool => @kg == other.kg

test "type without @compare: .compare() is error" {
    ro a = Weight { kg: 60 }
    ro b = Weight { kg: 80 }
    assert(a.compare(b) < 0)
}
