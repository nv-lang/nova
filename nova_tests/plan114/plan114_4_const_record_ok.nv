// Plan 114.4 Ф.1: const X = record literal из constexpr-полей — constexpr-eligible.

module nova_tests.plan114

type Point_plan1144constrecordok { x f64, y f64 }

const ORIGIN Point_plan1144constrecordok = Point_plan1144constrecordok { x: 0.0, y: 0.0 }
const TARGET Point_plan1144constrecordok = Point_plan1144constrecordok { x: 7.0, y: 14.0 }

test "const record-literal" {
    assert(ORIGIN.x == 0.0)
    assert(ORIGIN.y == 0.0)
    assert(TARGET.x == 7.0)
    assert(TARGET.y == 14.0)
}
