// Plan 114.4.4 Ф.1 positive: #fn_eval_max_depth(N) override works —
// here we increase limit above modest depth to verify override is read.

module nova_tests.plan114

#fn_eval_max_depth(50)
fn sum_to1(const n int) -> const int =>
    if n <= 0 { 0 } else { n + sum_to1(n - 1) }

test "depth override allows recursion under custom limit" {
    const A_plan11444depthoverrideok = sum_to1(30)
    // 30 * 31 / 2 = 465
    assert(A_plan11444depthoverrideok == 465)
}
