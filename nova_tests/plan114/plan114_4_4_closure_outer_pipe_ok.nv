// Plan 114.4.4 V4.6 M2 POSITIVE: ClosureLight `|x| body` после Stmt::Const
// должен parse'иться как closure, не binary OR.

module nova_tests.plan114

fn make_thing2(const base int) -> const fn(int) -> int {
    const offset_plan11444closureouterpipeok = base + 10
    |x| x + offset_plan11444closureouterpipeok
}

test "ClosureLight after Stmt::Const" {
    ro t5 = make_thing2(5)
    assert(t5(3) == 18)
}
