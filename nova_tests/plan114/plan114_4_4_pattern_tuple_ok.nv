// Plan 114.4.4 Ф.4 positive: tuple destructuring pattern в const fn match.

module nova_tests.plan114

fn classify(const x int, const y int) -> const int =>
    match (x, y) {
        (0, 0) => 0
        (0, _) => 1
        (_, 0) => 2
        _ => 3
    }

test "tuple pattern" {
    const A_plan11444patterntupleok = classify(0, 0)
    const B_plan11444patterntupleok = classify(0, 5)
    const C_plan11444patterntupleok = classify(7, 0)
    const D = classify(3, 4)
    assert(A_plan11444patterntupleok == 0)
    assert(B_plan11444patterntupleok == 1)
    assert(C_plan11444patterntupleok == 2)
    assert(D == 3)
}
