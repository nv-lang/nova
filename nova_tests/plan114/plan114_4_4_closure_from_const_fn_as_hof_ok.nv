// Plan 114.4.4.4 V4.3 POSITIVE: specialized closure used as HOF arg —
// passed to apply1 directly без intermediate let binding.

module nova_tests.plan114

fn make_scaler1(const factor int) -> const fn(int) -> int =>
    |x| x * factor

fn apply1(f fn(int) -> int, x int) -> int => f(x)

test "specialized closure passed as HOF arg" {
    ro r1 = apply1(make_scaler1(4), 5)
    assert(r1 == 20)

    ro r2 = apply1(make_scaler1(10), 7)
    assert(r2 == 70)
}
