// Plan 114.4.2 T3.1: basic const fn — block body, local const, arith.

module nova_tests.plan114

fn calc(const a int, const b char) -> const int {
    const c_plan11442constfnbasicok = b as int
    a + c_plan11442constfnbasicok * 10
}

test "calc literal eval" {
    const RESULT = calc(5, 'A')
    // 'A' = 65 → c_plan11442constfnbasicok = 65 → a + c_plan11442constfnbasicok*10 = 5 + 650 = 655.
    assert(RESULT == 655)
}
