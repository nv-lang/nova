// Plan 114.4.4 V4.5 Ф.4 POSITIVE: generic closure-returning const fn.
// Closes [M-114.4.4-closure-generic]. Call site через TurboFish.

module nova_tests.plan114

fn make_id2[T]() -> const fn(T) -> T => fn(x T) -> T => x

test "generic closure-returning const fn" {
    // make_id2[int]() → specialized fn make_id__closure_int_0(x int) -> int { x }
    ro id_i = make_id2[int]()
    assert(id_i(42) == 42)

    // make_id2[bool]() → distinct spec make_id__closure_bool_1(x bool) -> bool { x }
    ro id_b = make_id2[bool]()
    assert(id_b(true) == true)
}
