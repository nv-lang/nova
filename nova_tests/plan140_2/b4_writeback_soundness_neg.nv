// Plan 140.2 B.4 / [M-140.2-elision-writeback] SOUNDNESS GUARD: запись `v[i]=val`
// в цикле, где `v` ТАКЖЕ мутируется длиной (`v.pop()`) → frame-check НЕ len-safe
// (length-changing метод) → write НЕ элидируется → bounds-check записи остаётся →
// OOB (i за усохшей длиной) ловится в runtime. Если бы write-элизия сработала
// ошибочно — был бы UB-write вместо чистого panic.
// EXPECT_RUNTIME_PANIC array: index

module plan140_2.b4_writeback_soundness_neg

import std.collections.vec_owned.{Vec}

fn writeback_then_shrink() -> int {
    mut v = Vec[int].from([1, 2, 3, 4, 5])
    for i in 0..v.len() {
        v.pop()
        v[i] = 99
    }
    0
}

test "write-back + shrink traps OOB write (not elided)" {
    ro r = writeback_then_shrink()
    assert(r == 0)
}
