// Plan 140.2 B.4 / [M-140.2-elision-writeback]: write-back элизия.
// `for i in 0..v.len() { v[i] = f(v[i]) }` — `v` используется лишь как `v[i]`
// (read в RHS + write-target) и `v.len()` → длина инвариантна (mut @index
// СОХРАНЯЕТ длину) → frame-safe → И write `v[i]=`, И read `v[i]` элидируются.
// Корректность не зависит от элизии (проходит и на Trivial).

module plan140_2.b4_writeback_elision_pos

import std.collections.vec.{Vec}

fn build_doubled() -> int {
    mut v = Vec[int].from([1, 2, 3, 4])
    for i in 0..v.len() {
        v[i] = v[i] * 2
    }
    v[0] + v[1] + v[2] + v[3]
}

test "write-back doubles each element (elided write+read)" {
    assert(build_doubled() == 20)
}
