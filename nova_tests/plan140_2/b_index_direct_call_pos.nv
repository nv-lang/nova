// Plan 140.2 Part B: прямой вызов @index (.index(i)) эмитит контракт-enforcement
// `requires 0 <= i && i < @len` корректно (instance-метод, nova_self в scope).
module nova_tests.plan140_2

import std.collections.vec.{Vec}

test "direct @index call in-bounds" {
    ro v = Vec[int].of(10, 20, 30)
    assert(v.index(0) == 10)
    assert(v.index(2) == 30)
}
