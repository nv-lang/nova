// Plan 140.2 (D256 follow-up): positive companion to
// contract_exprdisplay_selfaccess_neg — a SATISFIED `@field` contract runs
// clean (no violation), so the display fix is purely about the message text of
// the negative path and does not perturb the satisfied path.

module plan140_2.contract_exprdisplay_selfaccess_pos

type Counter { count int, limit int }

fn Counter @step() -> int
    requires @count > 0 && @count <= @limit
=> @count - 1

test "satisfied @field contract runs without panic" {
    ro c = Counter { count: 5, limit: 10 }
    assert(c.step() == 4)
}
