// Plan 167 Ф.4 NEG T5 — single-char value-record name → E_TYPE_NAME_TOO_SHORT.
//
// type S value { x int } — name length 1 → must be rejected.
//
// EXPECT_COMPILE_ERROR E_TYPE_NAME_TOO_SHORT

module neg.t5_neg_single_char_value

type S value {
    x int
}

test "single-char value-record type name — E_TYPE_NAME_TOO_SHORT" {
    ro s = S { x: 2 }
    assert(s.x == 2)
}
