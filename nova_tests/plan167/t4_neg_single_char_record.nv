// Plan 167 Ф.4 NEG T4 — single-char record name → E_TYPE_NAME_TOO_SHORT.
//
// type S { x int } — name length 1 → must be rejected.
//
// EXPECT_COMPILE_ERROR E_TYPE_NAME_TOO_SHORT

module plan167.t4_neg_single_char_record

type S {
    x int
}

test "single-char record type name — E_TYPE_NAME_TOO_SHORT" {
    ro s = S { x: 1 }
    assert(s.x == 1)
}
