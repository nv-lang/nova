// Plan 148 Ф.1 (D241 amend) — positive: `consume value` is the canonical order.
//
// D241 revised (Plan 91.12): ownership → representation → visibility.
//   consume (rank 0) precedes value (rank 1) — canonical.
// Previously this was a negative test (old order value→consume); flipped when
// D241 was updated to Rust-like ordering.
module nova_tests.plan148

type Token2 consume value {
    id int
}

fn Token2 consume @close() -> () { () }

test "consume value canonical order accepted" {
    consume t = Token2 { id: 1 }
    t.close()
    assert(true)
}
