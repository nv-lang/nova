// Plan 152.8 Layer 1 (Vec[u32] migration) — T3: grapheme segmentation after migration.
module plan152_8.t3_graphemes_ok

import std.unicode.{GraphemesView}

test "grapheme count: plain ASCII" {
    assert("Hello".as_graphemes().count() == 5)
    assert("".as_graphemes().count() == 0)
}

test "grapheme count: combining marks count as one cluster each" {
    assert("e\u{301}".as_graphemes().count() == 1)    // e + combining acute = 1
    assert("\u{e9}".as_graphemes().count() == 1)      // precomposed é = 1
    assert("cafe\u{301}".as_graphemes().count() == 4) // c a f é(decomposed) = 4
}

test "grapheme count: regional indicator flag = 1" {
    assert("\u{1f1fa}\u{1f1f8}".as_graphemes().count() == 1)                    // 🇺🇸
    assert("\u{1f1fa}\u{1f1f8}\u{1f1eb}\u{1f1f7}".as_graphemes().count() == 2) // 🇺🇸🇫🇷
}

test "grapheme count: ZWJ emoji sequence = 1" {
    assert("\u{1f468}\u{200d}\u{1f469}\u{200d}\u{1f467}".as_graphemes().count() == 1)
}

test "grapheme next() returns whole cluster" {
    mut g = "a\u{301}b".as_graphemes()
    match g.next() { Some(s) => assert(s == "a\u{301}"), None => assert(false) }
    match g.next() { Some(s) => assert(s == "b"), None => assert(false) }
    assert(g.next() == None)
}

test "for-in over graphemes" {
    mut n = 0
    for _ in "abc".as_graphemes() { n = n + 1 }
    assert(n == 3)
}
