// Plan 152.8 Layer 2 POS T6 — nova_char = uint32_t (D128 AMEND).
// Verifies: char values round-trip through store/load, char.hash() works,
// max codepoint U+10FFFF is representable, char comparison ordering.
module nova_tests.plan152_8

test "char stores and loads correctly" {
    ro a = 'A'
    ro z = 'Z'
    assert(a == 'A')
    assert(z != a)
}

test "emoji codepoint fits in uint32_t" {
    ro em = '😀'
    assert(em == '😀')
    assert(em != 'A')
}

test "max valid codepoint U+10FFFF is representable" {
    ro max_cp = '\u{10FFFF}'
    assert(max_cp != 'A')
    assert(max_cp != '\u{0}')
}

test "char hash works" {
    ro c = 'X'
    ro h = c.hash()
    assert(h != 0)
}

test "char comparison ordering" {
    assert('A' < 'Z')
    assert('a' > 'A')
    assert('0' < '9')
}

test "char is_ascii classification" {
    assert('A'.is_ascii())
    assert('😀'.is_ascii() == false)
    assert('5'.is_ascii_digit())
    assert('a'.is_ascii_lowercase())
    assert('Z'.is_ascii_uppercase())
}
