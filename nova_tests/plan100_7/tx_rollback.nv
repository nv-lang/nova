// Plan 100.7 (D165) pilot Transaction6 — rollback on error path.
//
// Pattern: consume tx + explicit rollback/commit по путям (D162).
// D157: plain param = view (non-consuming, default).

module nova_tests.plan100_7

type Db4 { id int }
type OrderErr2 { msg str }

type Transaction6 consume { id int }

// Infallible for simplicity — demonstrates the core pattern.
fn Transaction6 consume @commit() -> () { () }
fn Transaction6 consume @rollback() -> () { () }

fn Db4 @begin() -> Transaction6 => { id: 1 }

// db_insert2 is infallible — D157 view param, no D162 interference.
fn db_insert2(t Transaction6) -> int {
    0
}

// Failable process: error path consume via explicit rollback.
fn process(db Db4, should_fail bool) Fail[OrderErr2] -> int {
    consume tx Transaction6 = db.begin()          // explicit type annotation (D165)
    if should_fail {
        tx.rollback()                           // explicit consume on error path
        throw OrderErr2 { msg: "operation failed" }
    }
    ro r = db_insert2(tx)
    tx.commit()
    return r
}

test "Transaction6 rollback on error path" {
    ro db = Db4 { id: 1 }
    // Success path
    process(db, false)
}

test "Transaction6 rollback explicit on error path" {
    ro db2 = Db4 { id: 2 }
    // Error path — rollback fires, no leak
    with Fail[OrderErr2] = effect Fail { fail(_e) { interrupt () } } {
        process(db2, true)
    }
}
