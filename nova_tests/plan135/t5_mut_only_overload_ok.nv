// Plan 135 Ф.3 T5 (POS): method has only a mut overload, called from mut binding.
// Works fine — single overload, no dispatch ambiguity.
// Verifies A-135.e.

module nova_tests.plan135

type Tank5 { priv mut volume int }

fn Tank5.new(v int) -> Self => { volume: v }

// Only the mut overload exists — no ro counterpart.
fn Tank5 mut @fill(amount int) { @volume = @volume + amount }
fn Tank5 mut @drain(amount int) { @volume = @volume - amount }
fn Tank5 @level() -> int => @volume

test "mut binding calls single mut overload" {
    mut t = Tank5.new(0)
    t.fill(50)
    t.fill(30)
    t.drain(20)
    assert(t.level() == 60)
}
