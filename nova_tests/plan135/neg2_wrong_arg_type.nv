// EXPECT_CC_ERROR incompatible type
//
// Plan 135 Ф.3 NEG2: calling a method overload with wrong argument type.
// `Counter4 @add(n int)` expects int, but `str` is passed.
// The Nova checker propagates a str-typed argument into a C call expecting nova_int
// → CC-FAIL with incompatible type error.
// Verifies that overload resolution does not coerce mismatched argument types.

module nova_tests.plan135

type Counter4 { priv mut n int }

fn Counter4.new() -> Self => { n: 0 }
fn Counter4 @add(n int) -> int => @n + n
fn Counter4 mut @inc(n int) { @n = @n + n }

test "wrong arg type on ro overload" {
    ro c = Counter4.new()
    ro _ = c.add("not-an-int")   // str passed where int expected
}
