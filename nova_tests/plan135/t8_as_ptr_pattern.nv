// Plan 135 Ф.3 T8 (POS): canonical as_ptr() ro/mut dispatch pattern from §"Что".
// Uses int return (0=ro, 1=mut) to verify dispatch without pointer complexity.
// Verifies the end-to-end A-135.a..d acceptance criteria.
//
// Target pattern from spec:
//   fn Value4 @as_ptr()     -> int  { 0 }   // ro overload
//   fn Value4 mut @as_ptr() -> int  { 1 }   // mut overload
//   ro a Value4 = ...; a.as_ptr()  -> 0
//   mut b Value4 = ...; b.as_ptr() -> 1

module nova_tests.plan135

type Value4 { priv mut data int }

fn Value4.new(d int) -> Self => { data: d }

// ro overload — represents *ro u8 (returns marker 0)
fn Value4 @as_ptr() -> int => 0

// mut overload — represents *mut u8 (returns marker 1)
fn Value4 mut @as_ptr() -> int => 1

test "ro binding a.as_ptr() → ro overload (0)" {
    ro a = Value4.new(42)
    assert(a.as_ptr() == 0)
}

test "mut binding b.as_ptr() → mut overload (1)" {
    mut b = Value4.new(42)
    assert(b.as_ptr() == 1)
}

test "both in same scope — correct dispatch" {
    ro a = Value4.new(10)
    mut b = Value4.new(20)
    assert(a.as_ptr() == 0)
    assert(b.as_ptr() == 1)
    assert(a.as_ptr() != b.as_ptr())
}

test "re-binding mut to ro — dispatches to ro" {
    mut b = Value4.new(5)
    assert(b.as_ptr() == 1)   // mut binding → mut overload
    ro a = Value4.new(5)
    assert(a.as_ptr() == 0)   // ro binding → ro overload
}
