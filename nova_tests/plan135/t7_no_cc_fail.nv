// Plan 135 Ф.3 T7 (POS): both ro and mut overloads compile to different C names.
// Verifies no CC-FAIL when both overloads exist (A-135.a, A-135.d).
// Focused on compilation success: Nova_T_method_m vs Nova_T_method_m__mut.

module nova_tests.plan135

type Counter9 { priv mut count int }

fn Counter9.new() -> Self => { count: 0 }

fn Counter9 mut @inc() { @count = @count + 1 }

// Both overloads of @value: ro → 0, mut → @count
fn Counter9 @value() -> int => @count           // ro overload
fn Counter9 mut @value() -> int => @count * 2   // mut overload (returns doubled)

test "both overloads compile and produce different results" {
    ro a = Counter9.new()
    mut b = Counter9.new()
    b.inc()
    b.inc()
    b.inc()
    // ro binding: ro overload — returns count as-is
    assert(a.value() == 0)
    // mut binding: mut overload — returns count * 2
    assert(b.value() == 6)
}

test "compilation produces distinct C names — verified by no cc-fail" {
    mut c = Counter9.new()
    c.inc()
    ro d = Counter9.new()
    assert(c.value() == 2)   // mut: 1 * 2 = 2
    assert(d.value() == 0)   // ro: 0 * 1 = 0
}
