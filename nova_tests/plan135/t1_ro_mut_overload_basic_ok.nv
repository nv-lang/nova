// Plan 135 Ф.3 T1 (POS): type with both ro and mut overloads of same method.
// Both are callable: ro binding -> ro overload, mut binding -> mut overload.
// Verifies A-135.a, A-135.b, A-135.c, A-135.d.

module nova_tests.plan135

type Flag4 { priv mut state int }

fn Flag4.new(v int) -> Self => { state: v }

// ro overload: returns 0 as marker
fn Flag4 @kind() -> int => 0

// mut overload: returns 1 as marker
fn Flag4 mut @kind() -> int => 1

test "ro binding calls ro overload" {
    ro a = Flag4.new(42)
    assert(a.kind() == 0)
}

test "mut binding calls mut overload" {
    mut b = Flag4.new(42)
    assert(b.kind() == 1)
}

test "both overloads coexist without CC-FAIL" {
    ro a = Flag4.new(10)
    mut b = Flag4.new(20)
    assert(a.kind() == 0)
    assert(b.kind() == 1)
    assert(a.kind() != b.kind())
}
