// Plan 135 Ф.3 T6 (POS): method has only ro overload, called from mut binding.
// The dispatch must gracefully fall back to the ro overload (no error).
// Verifies A-135.e: single overload works for any receiver.

module plan135.t6_fallback_to_ro_when_no_mut

type Probe { priv mut n int }

fn Probe.new(v int) -> Self => { n: v }

// Only ro overload — no mut counterpart.
fn Probe @inspect() -> int => @n

test "mut binding falls back to ro overload when no mut overload exists" {
    mut p = Probe.new(77)
    // Calling inspect() on a mut binding — should use ro overload gracefully.
    assert(p.inspect() == 77)
}

test "ro binding also works with single ro overload" {
    ro p = Probe.new(33)
    assert(p.inspect() == 33)
}
