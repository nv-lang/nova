// Plan 135 Ф.3 T3 (POS): mut binding calling a method with both ro and mut overloads.
// Must dispatch to the mut overload (returns 1).
// Verifies A-135.c.

module nova_tests.plan135

type Actuator5 { priv mut level int }

fn Actuator5.new(v int) -> Self => { level: v }

fn Actuator5 mut @bump() { @level = @level + 1 }

fn Actuator5 @mode() -> int => 0         // ro overload: marker 0
fn Actuator5 mut @mode() -> int => 1     // mut overload: marker 1

test "mut binding dispatches to mut overload" {
    mut a = Actuator5.new(7)
    assert(a.mode() == 1)
}

test "mut binding — mut overload after mutation" {
    mut a = Actuator5.new(0)
    a.bump()
    assert(a.mode() == 1)
}
