// Plan 124.4 — positive: protocol satisfaction через type-method (NOT
// external impl). Recv tracking = "Vec3" → priv access OK inside method.
//
// Test verifies that когда named tuple implements protocol-style method
// declared as `fn Vec3 @method()`, body has priv access (canonical
// recv = T).
module plan124_4.named_tuple_protocol_method_inside_ok

type Vec3(priv x f64, priv y f64, priv z f64)

fn Vec3.unit_x() -> Vec3 =>
    Vec3(x: 1.0, y: 0.0, z: 0.0)

// Method-form impl — priv access OK (recv = Vec3).
fn Vec3 @sum_components() -> f64 =>
    @x + @y + @z

fn Vec3 @max_component() -> f64 {
    mut m = @x
    if @y > m { m = @y }
    if @z > m { m = @z }
    m
}

test "Plan 124.4: type-method protocol-form priv access OK" {
    ro v = Vec3.unit_x()
    assert(v.sum_components() == 1.0)
    assert(v.max_component() == 1.0)
}
