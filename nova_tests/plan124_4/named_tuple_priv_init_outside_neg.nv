// EXPECT_COMPILE_ERROR E_PRIV_FIELD_INIT
//
// Plan 124.4 — negative: init priv field named tuple via named-arg ctor
// outside type-method scope → E_PRIV_FIELD_INIT (D222).
module plan124_4.named_tuple_priv_init_outside_neg

type Vec3(priv x f64, priv y f64, priv z f64)

// External fn — directly calls Vec3(x:, y:, z:) constructor outside
// Vec3's own scope.
fn external_make() -> Vec3 =>
    Vec3(x: 1.0, y: 2.0, z: 3.0)
