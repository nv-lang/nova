// Plan 124.4 — positive: priv field access inside named tuple's method
// (instance + static) — OK.
module plan124_4.named_tuple_inside_method_ok

type Vec3(priv x f64, priv y f64, priv z f64)

fn Vec3.zero() -> Vec3 =>
    Vec3(x: 0.0, y: 0.0, z: 0.0)

fn Vec3.unit_x() -> Vec3 =>
    Vec3(x: 1.0, y: 0.0, z: 0.0)

// Instance method — @x/@y/@z OK.
fn Vec3 @magnitude_sq() -> f64 =>
    @x * @x + @y * @y + @z * @z

// Static method also OK.
fn Vec3.dot(a Vec3, b Vec3) -> f64 =>
    a.magnitude_sq()

test "Plan 124.4: Vec3 instance method @-access" {
    ro v = Vec3.unit_x()
    assert(v.magnitude_sq() == 1.0)
}

test "Plan 124.4: Vec3 static method OK" {
    ro a = Vec3.unit_x()
    ro b = Vec3.zero()
    assert(Vec3.dot(a, b) == 1.0)
}
