// EXPECT_COMPILE_ERROR E_IMPL_UNKNOWN_PROTOCOL
//
// Plan 162.1 Step 3: negative — using a completely unknown protocol as
// a generic bound must still emit E_IMPL_UNKNOWN_PROTOCOL. The sig_table
// only suppresses errors for types that ARE declared in some transitively-
// imported module; a truly unknown name (no import, no declaration) must
// still be rejected.
//
// Here SomeMadeUpProtocol is never declared nor imported → typecheck must
// still emit E_IMPL_UNKNOWN_PROTOCOL when it appears in #impl() on a method.

module plan162_1.f3_unknown_type_neg

type Widget {
    x int
}

#impl(SomeMadeUpProtocol)
fn Widget @describe() -> str => "widget"
