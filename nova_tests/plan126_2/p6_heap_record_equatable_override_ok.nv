// Plan 126.2 Р¤.3 вЂ” RUNTIME POS p6:
// Heap-record (default allocation) with `#impl(Equal)` вЂ” synthesized
// memberwise `@equal` OVERRIDES default identity-eq. Two distinct heap
// instances with equal fields compare true. D109 amend / AC-126.2.3.
module nova_tests.plan126_2

#impl(Equal)
type Node {
    id int
    weight int
}

test "memberwise eq overrides heap identity" {
    // Two separately-allocated heap records with identical fields.
    ro a = Node { id: 7, weight: 100 }
    ro b = Node { id: 7, weight: 100 }
    // Without auto-derive this would be identity-false; memberwise в†’ true.
    assert(a == b)
    ro c = Node { id: 7, weight: 101 }
    assert(a != c)
}
