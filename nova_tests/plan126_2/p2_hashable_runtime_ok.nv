// Plan 126.2 Р¤.3 вЂ” RUNTIME POS p2:
// `#impl(Hash)` auto-derive synthesizes `@hash() -> u64` (XOR+rotate
// combine). Equal objects must produce equal hashes; differing objects
// (very likely) differ. AC-126.2.5.
module nova_tests.plan126_2

#impl(Hash + Equal)
type Key {
    a int
    b int
}

test "equal objects produce equal hashes" {
    ro a = Key { a: 10, b: 20 }
    ro b = Key { a: 10, b: 20 }
    assert(a == b)
    assert(a.hash() == b.hash())
}

test "differing objects produce differing hashes" {
    ro a = Key { a: 10, b: 20 }
    ro c = Key { a: 99, b: 20 }
    assert(a.hash() != c.hash())
}
