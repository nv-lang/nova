// EXPECT_COMPILE_ERROR E_AUTO_DERIVE_FIELD_LACKS_PROTOCOL
//
// Plan 126.2 Р¤.3 вЂ” NEG n2:
// `#impl(Equal)` on a record whose field type does not implement
// Equal в†’ auto-derive synthesis fails at compile time. AC-126.2 (negative).
module neg.n2_field_lacks_protocol_neg

type BareInner {
    n int
}

#impl(Equal)
type WrapBare {
    inner BareInner
}

test "field lacks protocol fails compile" {
    ro w = WrapBare { inner: BareInner { n: 0 } }
    assert(w.inner.n == 0)
}
