// Plan 126.2 Р¤.3 вЂ” RUNTIME POS p4:
// `#impl(Compare)` auto-derive synthesizes `@compare(other) -> int`
// (lexicographic if-chain). Returns <0, 0, >0 per field-order. AC-126.2.6.
module nova_tests.plan126_2

#impl(Compare + Equal)
type Ver {
    major int
    minor int
}

test "lexicographic compare orders by major then minor" {
    ro a = Ver { major: 1, minor: 5 }
    ro b = Ver { major: 1, minor: 5 }
    ro c = Ver { major: 1, minor: 9 }
    ro d = Ver { major: 2, minor: 0 }
    // equal
    assert(a.compare(b) == 0)
    // first field equal, second smaller в†’ negative
    assert(a.compare(c) < 0)
    assert(c.compare(a) > 0)
    // first field decides в†’ negative regardless of second
    assert(a.compare(d) < 0)
    assert(d.compare(a) > 0)
}
