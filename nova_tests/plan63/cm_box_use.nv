module plan63.cm_box_use

// Plan 63 Fix C cross-module: import generic factory из folder-module,
// call с typeargs. Tests на anonymous record return mono enrollment
// при cross-module call site.

import nova_tests.plan63.cm_box.{Box}

test "cross-module Box[int].of" {
    ro m = Box[int].of(42)
    assert(m.v == 42, "cross-module factory mono'd correctly")
}

test "cross-module Box[str].of" {
    ro s = Box[str].of("hi")
    assert(s.v == "hi", "str-typed cross-module")
}
