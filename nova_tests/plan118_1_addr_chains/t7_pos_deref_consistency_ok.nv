// Plan 118.1 [M-118.1-addr-of-chains] — `&(p.field)` (auto-deref sugar)
// and `&((*p).field)` (explicit deref) are the SAME operation and must
// get the same verdict.
// (addr_of removed in Plan 118.6 — use & syntax directly.)
module plan118_1_addr_chains.t7_pos_deref_consistency_ok

type Sv {
    ro v i64
}

test "addr_of through a pointer (auto-deref and explicit *) both accepted" {
    ro s = Sv { v: 5 }
    unsafe {
        ro ps = &s
        ro a = &ps.v
        ro b = &(*ps).v
        assert(a.read() == 5)
        assert(b.read() == 5)
    }
}
