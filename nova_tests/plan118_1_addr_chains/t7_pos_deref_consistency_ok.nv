// Plan 118.1 [M-118.1-addr-of-chains] — `addr_of(p.field)` (auto-deref sugar)
// and `addr_of((*p).field)` (explicit deref) are the SAME operation and must
// get the same verdict: both root in the pointer's binding `p` (a named
// lvalue) and are accepted. The walker descends through the `(*p)` deref so
// the explicit and sugar forms stay consistent.
module plan118_1_addr_chains.t7_pos_deref_consistency_ok

type S {
    ro v i64
}

test "addr_of through a pointer (auto-deref and explicit *) both accepted" {
    ro s = S { v: 5 }
    unsafe {
        ro ps = addr_of(s)
        ro a = addr_of(ps.v)
        ro b = addr_of((*ps).v)
        assert(a.read() == 5)
        assert(b.read() == 5)
    }
}
