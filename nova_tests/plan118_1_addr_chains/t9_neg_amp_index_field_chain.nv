// Plan 118.1 [M-118.1-addr-of-chains] — bare `&arr[i].field` (parser path) must
// reject a field path through an array index (D216 §15), same code as the
// addr_of intrinsic form.
// EXPECT_COMPILE_ERROR E_ARRAY_INDEX_PTR_BANNED
module plan118_1_addr_chains.t9_neg_amp_index_field_chain

type S {
    ro v i64
}

test "bare & of a field reached through an array index is rejected" {
    ro arr = [S { v: 10 }, S { v: 20 }]
    unsafe {
        ro p = &arr[0].v
    }
}
