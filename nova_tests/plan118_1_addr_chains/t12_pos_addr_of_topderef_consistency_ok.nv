// Plan 118.1 [M-118.1-addr-of-chains] — TOP-LEVEL deref consistency: both
// `&(*p)` forms root in `p` (a named lvalue) and must be accepted.
// (addr_of removed in Plan 118.6 — use & syntax directly.)
module nova_tests.plan118_1_addr_chains

type Sv2 {
    ro v i64
}

test "addr_of(*p) and &(*p) are both accepted (top-level deref symmetry)" {
    ro s = Sv2 { v: 5 }
    unsafe {
        ro ps = &s
        ro a = &(*ps)
        ro b = &(*ps)
        assert(a.v == 5)
        assert(b.v == 5)
    }
}
