// Plan 118.6 — addr_of_mut() removed → E_ADDR_OF_REMOVED.
// EXPECT_COMPILE_ERROR E_ADDR_OF_REMOVED
module neg.t4_neg_addr_of_mut_ro_field

type Sv {
    v i64
}

test "addr_of_mut removed — ro field case gives E_ADDR_OF_REMOVED" {
    ro s = Sv { v: 1 }
    unsafe {
        ro p = addr_of_mut(s.v)
    }
}
