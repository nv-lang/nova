// EXPECT_COMPILE_ERROR D133
//
// Plan 100.3 (D133): consume-rvalue нельзя передать в view-param.
// View-param не consume'нет — rvalue после возврата остаётся не
// consumed и не bound к локальной переменной → flow-checker не имеет
// slot'а для tracking → ресурс утечёт молча. Запрет — единственное
// безопасное правило.

module nova_tests.plan100_3.view_err_rvalue_in_view

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }

fn begin() -> Transaction => { id: 1 }

fn show(t Transaction) -> () {                 // view-param (default)
    println(t.id)
}

test "consume-rvalue в view-param — error" {
    // ОШИБКА D133-consume-rvalue-in-view: rvalue → view-param.
    // Suggest: `consume tx = begin(); show(tx); tx.commit()`.
    show(begin())
}
