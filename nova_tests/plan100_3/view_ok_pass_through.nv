// Plan 100.3 (D157): view-param передаётся в другую view-fn без consume.

module nova_tests.plan100_3

type Transaction8 consume {
    id int,
}

fn Transaction8 consume @commit() -> () { () }

fn log_id(t Transaction8) -> () { println(t.id) }

fn print_and_log(t Transaction8) -> () {
    println("processing")
    log_id(t)                                    // ✅ view-передача в view-param
}

test "view pass-through через view-funcs" {
    consume tx = Transaction8 { id: 5 }
    print_and_log(tx)
    tx.commit()                                  // tx Live после view-uses
}
