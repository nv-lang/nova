// Plan 100.3 (D157): view-closure (FnMut/Fn analog) — multiple invokes OK.

module nova_tests.plan100_3

type Transaction4 consume {
    id int,
}

fn Transaction4 consume @commit() -> () { () }

test "view-closure — multiple invokes" {
    consume tx = Transaction4 { id: 10 }
    ro logger = || println(tx.id)              // view-capture (no consume в body)
    logger()                                     // ✅ OK
    logger()                                     // ✅ OK, multi-invoke
    logger()                                     // ✅ OK
    tx.commit()                                  // tx Live после view-closure scope
}
