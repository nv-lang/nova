// Plan 100.3 (D157): `match <expr>` — deep peek в Option[ConsumeType].
//
// Без D157 этот pattern невозможен в Plan 100.1 — match destructive,
// arm-binding'и Live linear, обязан consumed в arm. D157 решает через
// view-match: arm-binding'и — view, source остаётся Live.

module nova_tests.plan100_3

type File2 consume {
    fd int,
}

fn File2 consume @close() -> () { () }

type Service3 consume {
    consume file Option[File2],
}

fn Service3 consume @shutdown() -> () {
    match @file {
        Some(f) => f.close(),                   // consume arm
        None => (),
    }
}

// Deep peek через view-match: получить fd без consume File2.
fn Service3 @file_id() -> Option[int] {
    match @file {                          // ← view-match
        Some(f) => Some(f.fd),                  // f: view File2, read-only
        None => None,
    }
    // @file остаётся Live (не Consumed) ✅
}

test "match @file — deep peek без consume" {
    consume svc = Service3 { file: Some(File2 { fd: 7 }) }
    ro id = svc.file_id()
    assert(id == Some(7))
    svc.shutdown()                             // svc Live после view-match
}
