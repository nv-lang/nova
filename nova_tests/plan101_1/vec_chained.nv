// Plan 101.1 Ф.5 — positive: fn[T] []T chained map+filter.

module plan101_1.vec_chained

fn[T] []T @my_map[U](f fn(T) -> U) -> []U {
    mut out []U = []U.with_capacity(@len())
    for x in @ { out.push(f(x)) }
    out
}

fn[T] []T @my_filter(pred fn(T) -> bool) -> []T {
    mut out []T = []
    for x in @ { if pred(x) { out.push(x) } }
    out
}

test "chained map → filter" {
    ro v []int = [1, 2, 3, 4, 5]
    ro filtered = v.my_map(|x| x * 2).my_filter(|x| x > 4)
    assert(filtered.len() == 3)
    assert(filtered.get(0) == Some(6))
    assert(filtered.get(1) == Some(8))
    assert(filtered.get(2) == Some(10))
}
