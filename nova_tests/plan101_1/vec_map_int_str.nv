// Plan 101.1 Ф.5 — positive: fn[T] []T @map[U] T≠U (cross-type).

module nova_tests.plan101_1.vec_map_int_str

fn[T] []T @my_map[U](f fn(T) -> U) -> []U {
    mut out []U = []U.with_capacity(@len())
    for x in @ { out.push(f(x)) }
    out
}

test "fn[T] []T @map int → str (T≠U)" {
    ro v []int = [1, 2, 3]
    ro strs = v.my_map(|x| str.from(x))
    assert(strs.len() == 3)
    assert(strs.get(0) == Some("1"))
    assert(strs.get(2) == Some("3"))
}
