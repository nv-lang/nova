// Plan 131 Ф.3 — Vec[T] basics: new/push/pop/len/is_empty/clear.

module nova_tests.plan131

import std.collections.vec.{Vec}

test "new / push / pop / len / is_empty / clear" {
    mut v = Vec[int].new()
    assert(v.is_empty())
    assert(v.len() == 0)

    v.push(1); v.push(2); v.push(3)
    assert(v.len() == 3)
    assert(!v.is_empty())

    assert(v.pop() == Some(3))
    assert(v.len() == 2)
    assert(v.pop() == Some(2))
    assert(v.len() == 1)

    v.clear()
    assert(v.len() == 0)
    assert(v.is_empty())
    assert(v.pop() == None)
}
