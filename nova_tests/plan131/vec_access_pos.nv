// Plan 131 Ф.3 — access: get/get_mut/first/last (Some/None cases).

module plan131.vec_access_pos

import std.collections.vec_owned.{Vec}

test "get in-bounds and out-of-bounds" {
    mut v = Vec[int].from([10, 20, 30])
    assert(v.get(0) == Some(10))
    assert(v.get(1) == Some(20))
    assert(v.get(2) == Some(30))
    assert(v.get(3) == None)
    assert(v.get(-1) == None)
}

test "first / last" {
    mut v = Vec[int].from([10, 20, 30])
    assert(v.first() == Some(10))
    assert(v.last() == Some(30))

    ro empty = Vec[int].new()
    assert(empty.first() == None)
    assert(empty.last() == None)
}

test "get_mut writes through raw pointer" {
    mut v = Vec[int].from([1, 2, 3])
    if Some(p) = v.get_mut(1) {
        unsafe { *p = 99 }
    }
    assert(v.get(1) == Some(99))
    assert(v.get_mut(5) == None)
}
