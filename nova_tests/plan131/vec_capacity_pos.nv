// Plan 131 Ф.3 — capacity management: with_capacity/reserve/cap.

module plan131.vec_capacity_pos

import std.collections.vec_owned.{Vec}

test "with_capacity reserves up front" {
    mut v = Vec[int].with_capacity(16)
    assert(v.cap() >= 16)
    assert(v.len() == 0)
    assert(v.is_empty())
}

test "reserve grows capacity" {
    mut v = Vec[int].new()
    for i in 0..10 { v.push(i) }
    v.reserve(100)
    assert(v.cap() >= 110)
    assert(v.len() == 10)
}
