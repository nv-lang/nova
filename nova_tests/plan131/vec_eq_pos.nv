// Plan 131 Ф.4 — Vec[T] Equatable: pairwise element comparison.
// EXPECT_OUTPUT: true
// false

module plan131.vec_eq_pos

import std.collections.vec_owned.{Vec}

fn main() -> () {
    ro a = Vec[int].from([1, 2, 3])
    ro b = Vec[int].from([1, 2, 3])
    ro c = Vec[int].from([1, 2, 4])
    println(a.equals(b))
    println(a.equals(c))
}
