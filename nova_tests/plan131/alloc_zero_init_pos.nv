// Plan 131 Ф.1 — RawMem.alloc returns zeroed memory.
// nova_alloc CONTRACT: all bytes = 0x00 on allocation.
// EXPECT_OUTPUT: zero

module plan131.alloc_zero_init_pos

import std.runtime.raw_mem.{RawMem}

fn main() -> () {
    unsafe {
        // Allocate 8 bytes — should be zeroed by nova_alloc.
        ro p = RawMem.alloc(8 as usize)
        // Read the first byte — must be zero.
        ro v = *p
        assert(v as int == 0)
    }
    println("zero")
}
