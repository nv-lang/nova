// Plan 131 Ф.3 — conversion: Vec[T].from(iterable source).
// Plan 138.1 Ф.0.1a: as_slice removed; equality checked via @equal (`.equal`).

module plan131.vec_from_pos

import std.collections.vec_owned.{Vec}

test "from slice copies elements" {
    ro v = Vec[int].from([5, 10, 15, 20])
    assert(v.len() == 4)
    assert(v.get(0) == Some(5))
    assert(v.get(3) == Some(20))
}

test "from empty slice" {
    ro v = Vec[int].from([])
    assert(v.is_empty())
}

test "push sequence preserves element values" {
    mut v = Vec[int].new()
    for i in 0..5 { v.push(i * i) }
    assert(v.equal(Vec[int].from([0, 1, 4, 9, 16])))
}

test "from then mutate is independent of source" {
    ro src = [1, 2, 3]
    mut v = Vec[int].from(src)
    v.push(4)
    assert(v.equal(Vec[int].from([1, 2, 3, 4])))
    assert(src == [1, 2, 3])
}
