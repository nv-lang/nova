// Plan 96.1 Ф.1 — regression-pos: обычный arr.push() БЕЗ slice — no warning.
// Lint должен срабатывать только на push'е по slice-view binding'у.

module plan96_1.lint_no_view_push_no_warn

test "regular array push doesn't trigger lint" {
    mut arr []int = [1, 2, 3]
    arr.push(4)
    arr.push(5)
    assert(arr.len() == 5)
}
