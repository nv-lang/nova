// EXPECT_COMPILE_WARNING W_VIEW_PUSH_DETACH
//
// Plan 96.1 Ф.1 — позитив для W_VIEW_PUSH_DETACH lint:
// push на mut-view детачится от parent backing'а (cap == len). Lint
// предупреждает программиста, что parent НЕ модифицируется.

module plan96_1.lint_view_push_warns

fn main() -> () {
    mut parent []int = [1, 2, 3, 4, 5]
    mut view = parent[1..4]
    view.push(99)
}
