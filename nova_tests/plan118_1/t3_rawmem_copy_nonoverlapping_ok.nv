// Plan 118.1 Ф.1 T3 — RawMem.copy_nonoverlapping memcpy primitive.
//
// Tests faster non-overlap variant. Distinct buffers, no overlap.

module plan118_1.t3_rawmem_copy_nonoverlapping_ok

import std.runtime.raw_mem

test "RawMem.copy_nonoverlapping copies bytes between distinct buffers" {
    ro src []u8 = [100, 101, 102, 103]
    mut dst []u8 = [0, 0, 0, 0]
    unsafe {
        RawMem.copy_nonoverlapping(src.as_ptr(), dst.as_mut_ptr(), 4 as usize)
    }
    assert(dst[0] == (100 as u8))
    assert(dst[1] == (101 as u8))
    assert(dst[2] == (102 as u8))
    assert(dst[3] == (103 as u8))
}

test "RawMem.copy_nonoverlapping zero-length is no-op" {
    ro src []u8 = [1, 2, 3]
    mut dst []u8 = [99, 99, 99]
    unsafe {
        RawMem.copy_nonoverlapping(src.as_ptr(), dst.as_mut_ptr(), 0 as usize)
    }
    assert(dst[0] == (99 as u8))
    assert(dst[1] == (99 as u8))
    assert(dst[2] == (99 as u8))
}
