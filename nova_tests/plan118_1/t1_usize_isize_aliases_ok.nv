// Plan 118.1 T1 — int/int platform-pointer-width aliases.
//
// Per D226 §3 amend (2026-06-03): bootstrap 64-bit only,
//   int ≡ u64 (ABI bridge для C size_t)
//   int ≡ i64 (signed pointer difference, also alias для int)
//
// Verifies:
//   - int/int parse + type-check как primitives
//   - Arithmetic + comparison работают
//   - Cast `int` / `int as int` OK

module plan118_1.t1_usize_isize_aliases_ok

test "int is u64 alias — arithmetic" {
    ro a int = 1024
    ro b int = 512
    ro c = a + b
    assert(c == 1536)
}

test "int is i64/int alias — signed arithmetic" {
    ro a int = 100
    ro b int = -50
    ro diff = a + b
    assert(diff == 50)
}

test "int cast" {
    ro n int = 42
    ro u = n
    assert(u == 42)
}

test "int as int cast" {
    ro u int = 1000
    ro n = u as int
    assert(n == 1000)
}

test "int as int cast (identity для bootstrap 64-bit)" {
    ro i int = -42
    ro n = i as int
    assert(n == -42)
}
