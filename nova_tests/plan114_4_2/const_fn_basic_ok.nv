// Plan 114.4.2 T3.1: basic const fn — block body, local const, arith.

module nova_tests.plan114_4_2

fn calc(const a int, const b char) -> const int {
    const c = b as int
    a + c * 10
}

test "calc literal eval" {
    const RESULT = calc(5, 'A')
    // 'A' = 65 → c = 65 → a + c*10 = 5 + 650 = 655.
    assert(RESULT == 655)
}
