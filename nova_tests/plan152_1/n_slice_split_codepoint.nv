// Plan 152.1 Ф.1b (D249): a byte-range `str[a..b]` slice that cuts THROUGH a
// UTF-8 codepoint (a cut point lands on a continuation byte) panics — the
// resulting bytes would not be valid UTF-8 (R-UTF8 invariant).
// EXPECT_RUNTIME_PANIC slice splits a UTF-8 codepoint
module plan152_1.n_slice_split_codepoint

test "slice ending mid-codepoint panics" {
    ro s = "héllo"        // é occupies bytes 1..3; byte 2 is a continuation byte
    ro _ = s[1..2]        // end (byte 2) splits é → panic
}
