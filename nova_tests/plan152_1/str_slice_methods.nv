// Plan 152.1 Ф.1b (D249): str byte-range slice as contract methods (slice.nv).
// `@index(r Range)` carries a `requires` bounds CONTRACT (140.2); `@get(r Range)`
// is the safe (None-on-OOB / None-on-codepoint-split) counterpart. Both build the
// view via the inline `@[a..b]` byte-slice.
module plan152_1.str_slice_methods

test "get(Range): safe byte-range slice -> Some" {
    ro s = "héllo"            // h(0) é(1,2) l(3) l(4) o(5), byte_len=6
    assert(s.get(0..1) == Some("h"))
    assert(s.get(1..3) == Some("é"))     // byte range 1..3 = the 2 bytes of é
    assert(s.get(0..6) == Some("héllo"))
    assert(s.get(3..6) == Some("llo"))
}

test "get(Range): None on out-of-bounds / inverted" {
    ro s = "hello"
    assert(s.get(0..100) == None)         // end > byte_len
    assert(s.get(3..1) == None)           // end < start
    assert(s.get(0..6) == None)           // end == 6 > byte_len 5
}

test "get(Range): None when a cut splits a codepoint" {
    ro s = "héllo"
    assert(s.get(1..2) == None)           // byte 2 is é's continuation byte
    assert(s.get(2..4) == None)           // byte 2 is mid-é (start splits)
}

test "index(Range): direct contract-method call == sugar" {
    ro s = "hello"
    assert(s.index(0..2) == "he")
    assert(s.index(2..5) == "llo")
    assert(s.index(0..2) == s[0..2])
}
