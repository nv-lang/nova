// Plan 100.4.2 (D159): errdefer body может содержать suspend operations.
// D159 распространяется на все 4 defer-kind (defer / errdefer / okdefer /
// defer-with-result).

module nova_tests.plan100_4_2.errdefer_suspend_ok

fn rollback_async() Time -> () {
    Time.sleep(5)
}

fn process() Time Fail -> () {
    errdefer { rollback_async() }   // D159: suspend в errdefer — OK
    // body — success exit
}

test "errdefer suspend body — D159 compile pass" {
    with Fail = effect Fail { fail(_msg) { interrupt () } } {
        process()
    }
}
