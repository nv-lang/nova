// Plan 100.4.2 (D159): multiple LIFO defers с suspend bodies.
// D161 (Plan 100.4.4) wrap гарантирует LIFO continues.

module nova_tests.plan100_4_2

fn cleanup_a() Time -> () { Time.sleep(3) }
fn cleanup_b() Time -> () { Time.sleep(3) }
fn cleanup_c() Time -> () { Time.sleep(3) }

fn process3() Time -> () {
    defer { cleanup_a() }   // LIFO last
    defer { cleanup_b() }
    defer { cleanup_c() }   // LIFO first
}

test "multiple defer LIFO + suspend bodies — D159 + D161" {
    process3()
}
