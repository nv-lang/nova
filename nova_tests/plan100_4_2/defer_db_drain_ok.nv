// Plan 100.4.2 (D159): graceful DB-like drain через defer + Time-suspend.

module plan100_4_2.defer_db_drain_ok

fn drain(_timeout_ms int) Time -> () {
    Time.sleep(10)
}

fn process() Time -> () {
    defer { drain(50) }   // graceful drain — Time.sleep allowed (D159)
}

test "defer drain (async cleanup) — D159 compile pass" {
    process()
}
