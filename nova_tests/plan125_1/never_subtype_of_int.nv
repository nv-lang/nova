// Plan 125.1 Ф.1+Ф.2 positive — never <: int.
// Аналогично never_subtype_of_str, но int как target. Subtype-of-everything
// rule per spec 08-runtime.md «never — bottom-тип».

module plan125_1.never_subtype_of_int

fn rank(c bool) Fail -> int {
    if c {
        throw "bad input"
    } else {
        42
    }
}

test "never subtype of int via throw branch" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro n = rank(false)
        assert(n == 42)
    }
}
