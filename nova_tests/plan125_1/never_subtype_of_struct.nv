// Plan 125.1 Ф.1+Ф.2 positive — never <: user struct.
// Type-checker должен видеть `throw e` (тип never) как assignable к
// `Point2` через D25 bottom-rule.

module nova_tests.plan125_1

type Point2 {
    ro x int
    ro y int
}

fn Point2.new(x int, y int) -> Point2 => { x, y }

fn pick_point(c bool) Fail -> Point2 {
    if c {
        throw "no point"
    } else {
        Point2.new(3, 4)
    }
}

test "never subtype of user struct" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro p = pick_point(false)
        assert(p.x == 3)
        assert(p.y == 4)
    }
}
