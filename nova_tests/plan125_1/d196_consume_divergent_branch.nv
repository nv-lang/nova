// Plan 125.1 Ф.4 positive — D196 detector skips divergent branch.
// `consume X = if c { fresh() } else { throw E }` — раньше падало в
// "Consumable type conflict between FailableResource и never" / silent abort.
// Теперь Ф.4 распознаёт divergent ветку и возвращает None из
// detect_divergent_consumable — нет fake-conflict.

module nova_tests.plan125_1

type GuardR3 {
    ro id int
}

fn GuardR3.new(id int) -> GuardR3 => { id }

fn GuardR3 consume @on_exit(_outcome ScopeOutcome) -> () => ()

fn use_guard(c bool) Fail -> int {
    mut result = 0
    // if-init с divergent else — Ф.4 skip'ает throw-ветку.
    consume g = if c {
        GuardR3.new(7)
    } else {
        throw "no guard"
    } {
        result = g.id
    }
    result
}

test "D196 consume with divergent else compiles + works on happy path" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro n = use_guard(true)
        assert(n == 7)
    }
}
