// Plan 125.1 Ф.4 negative — D196 detector skips divergent, requires
// Consumable в live ветке. Если обе ветки divergent — None (no conflict).
// Если live ветка возвращает non-Consumable, error elsewhere — но Ф.4
// skip'нул бы divergent ветку и conflict-check проходит на single side.
//
// Этот fixture: live-ветка возвращает Consumable GuardR, divergent-ветка
// throw'ит. Ф.4 → None → consume init принимается. PASS expected.

module neg.d196_consume_required_in_live_branch

type GuardR {
    ro id int
}

fn GuardR.new(id int) -> GuardR => { id }

fn GuardR consume @on_exit(_outcome ScopeOutcome) -> () => ()

fn drive(c bool, k int) Fail -> int {
    mut out = 0
    // Both forms: throw в if-then, GuardR.new в else. Ф.4 skip'ает then,
    // detect_divergent_consumable возвращает None → conflict-check skipped.
    consume g = if c {
        throw "in then"
    } else {
        GuardR.new(k)
    } {
        out = g.id
    }
    out
}

test "D196 divergent-then + Consumable-else compiles + runs on happy path" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro n = drive(false, 11)
        assert(n == 11)
    }
}
