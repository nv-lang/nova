// Plan 125.1 Ф.1+Ф.2 positive — never <: bool.
// Дополнительный subtype check для primitive bool target.

module nova_tests.plan125_1

fn is_ready(c bool) Fail -> bool {
    if c {
        throw "not ready"
    } else {
        true
    }
}

test "never subtype of bool" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro b = is_ready(false)
        assert(b == true)
    }
}
