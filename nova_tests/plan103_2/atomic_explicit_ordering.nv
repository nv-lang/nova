// Plan 103.2 Ф.9 positive — explicit MemOrdering overloads on sized atomics.
//
// Each method has two overloads: default (SeqCst) and explicit ordering.
// This file exercises the explicit-ordering variants across multiple types.

module nova_tests.plan103_2.atomic_explicit_ordering

test "AtomicI64 load with Relaxed ordering" {
    let a = AtomicI64.new(99)
    assert(a.load(Relaxed) == 99)
}

test "AtomicI64 store with Release, load with Acquire" {
    let a = AtomicI64.new(0)
    a.store(42, Release)
    assert(a.load(Acquire) == 42)
}

test "AtomicI64 fetch_add with AcqRel" {
    let a = AtomicI64.new(10)
    let prev = a.fetch_add(5, AcqRel)
    assert(prev == 10)
    assert(a.load() == 15)
}

test "AtomicI64 compare_exchange with explicit success/failure orderings" {
    let a = AtomicI64.new(1)
    let ok = a.compare_exchange(1, 2, SeqCst, Acquire)
    assert(ok)
    assert(a.load() == 2)
}

test "AtomicU32 fetch_add with Relaxed — pipeline counter" {
    let counter = AtomicU32.new(0)
    let i = 0
    while i < 10 {
        counter.fetch_add(1, Relaxed)
        i = i + 1
    }
    assert(counter.load(SeqCst) == 10)
}

test "AtomicI32 swap with AcqRel" {
    let a = AtomicI32.new(100)
    let old = a.swap(200, AcqRel)
    assert(old == 100)
    assert(a.load() == 200)
}

test "AtomicI64 compare_exchange_weak with ordering — retry loop" {
    let a = AtomicI64.new(0)
    let i = 0
    let done = false
    while i < 100 {
        let ok = a.compare_exchange_weak(0, 1, AcqRel, Acquire)
        if ok {
            done = true
            i = 100
        }
        i = i + 1
    }
    assert(done)
    assert(a.load() == 1)
}
