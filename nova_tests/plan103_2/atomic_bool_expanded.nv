// Plan 103.2 Ф.9 positive — AtomicBool expanded API.
//
// Tests the new ordering-aware overloads and boolean bitwise ops.
// All 2-variant methods now have a _bool (SeqCst default) and a
// _MemOrdering (explicit) overload.

module nova_tests.plan103_2.atomic_bool_expanded

test "AtomicBool load with explicit ordering" {
    mut a = AtomicBool.new(true)
    assert(a.load(Acquire))
    assert(a.load(Relaxed))
    assert(a.load(SeqCst))
}

test "AtomicBool store with explicit ordering" {
    mut a = AtomicBool.new(false)
    a.store(true, Release)
    assert(a.load(Acquire))
    a.store(false, SeqCst)
    assert(!a.load())
}

test "AtomicBool swap with explicit ordering" {
    mut a = AtomicBool.new(false)
    ro old = a.swap(true, AcqRel)
    assert(!old)
    assert(a.load())
}

test "AtomicBool compare_exchange with ordering — success" {
    mut a = AtomicBool.new(false)
    ro ok = a.compare_exchange(false, true, SeqCst, Acquire)
    assert(ok)
    assert(a.load())
}

test "AtomicBool compare_exchange_weak — success path" {
    mut a = AtomicBool.new(true)
    // compare_exchange_weak may spuriously fail on some platforms;
    // retry until success for a deterministic test.
    ro i = 0
    ro ok = false
    while i < 100 {
        ro r = a.compare_exchange_weak(true, false)
        if r {
            ok = true
            i = 100
        }
        i = i + 1
    }
    assert(ok)
    assert(!a.load())
}

test "AtomicBool fetch_or" {
    mut a = AtomicBool.new(false)
    ro prev = a.fetch_or(true)
    assert(!prev)
    assert(a.load())
}

test "AtomicBool fetch_and" {
    mut a = AtomicBool.new(true)
    ro prev = a.fetch_and(false)
    assert(prev)
    assert(!a.load())
}

test "AtomicBool fetch_xor" {
    mut a = AtomicBool.new(true)
    ro prev = a.fetch_xor(true)
    assert(prev)
    assert(!a.load())
    // second xor restores to true
    ro prev2 = a.fetch_xor(true)
    assert(!prev2)
    assert(a.load())
}
