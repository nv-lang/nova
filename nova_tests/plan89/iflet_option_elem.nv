// Plan 89 Ф.2.1 — деструктуризация боксированного Option-элемента
// массива через `if let` в теле for-in.
//
// До Plan 89: `for o in []Option[int] { if let Some(v) = o }` → CC-FAIL
// (`.tag` на указателе `NovaOpt_T*`). Фикс Ф.1: emit_for деболксит
// value-sum элемент в значение.

module nova_tests.plan89.iflet_option_elem


test "for-in []Option + if let Some" {
    let opts []Option[int] = [Some(1), None, Some(3), Some(10)]
    let mut sum = 0
    for o in opts {
        if let Some(v) = o {
            sum = sum + v
        }
    }
    assert(sum == 14)
}

test "for-in []Option + if let с else" {
    let opts []Option[int] = [Some(5), None, None, Some(2)]
    let mut found = 0
    let mut missing = 0
    for o in opts {
        if let Some(v) = o {
            found = found + v
        } else {
            missing = missing + 1
        }
    }
    assert(found == 7)
    assert(missing == 2)
}

test "for-in []Option[str] — боксированный элемент с str payload" {
    let names []Option[str] = [Some("alice"), None, Some("bob")]
    let mut total_len = 0
    for o in names {
        if let Some(n) = o {
            total_len = total_len + n.len()
        }
    }
    assert(total_len == 8)
}
