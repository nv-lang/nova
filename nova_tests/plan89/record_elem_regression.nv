// Plan 89 Ф.2.6 — РЕГРЕСС-ГВАРД (soundness): массив record-типа.
//
// Records (`Nova_Point*`) — genuine heap-pointer; их codegen полагается
// на указатель (field-access, pattern-match через `->`). Фикс Plan 89
// деболксит ТОЛЬКО value-семантику sum'ов (Option/RuntimeError —
// `ValueOptionLike`/`ValueTagPayload`). Records под критерий не
// попадают и НЕ должны разбоксовываться. Этот тест ловит ошибочный
// разбокс genuine-pointer элементов.

module plan89.record_elem_regression


type Point { x int, y int }


test "for-in []Record + доступ к полям" {
    ro pts []Point = [
        Point { x: 1, y: 2 },
        Point { x: 3, y: 4 },
        Point { x: 10, y: 20 },
    ]
    mut sum = 0
    for p in pts {
        sum = sum + p.x + p.y
    }
    assert(sum == 40)
}

test "for-in []Record + match по record-паттерну" {
    ro pts []Point = [Point { x: 5, y: 5 }, Point { x: 1, y: 9 }]
    mut diag = 0
    for p in pts {
        match p {
            Point { x, y } => {
                if x == y { diag = diag + 1 }
            }
        }
    }
    assert(diag == 1)
}
