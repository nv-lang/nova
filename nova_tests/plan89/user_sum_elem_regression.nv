// Plan 89 Ф.2.5 — РЕГРЕСС-ГВАРД: массив пользовательского sum-типа.
//
// User-sum (`type Shape | Circle | Square`) — heap-pointer семантика
// (`Nova_Shape*`), codegen pattern-match использует `->`. Фикс Plan 89
// деболксит только value-семантику (Option) — user-sum не трогается.

module nova_tests.plan89.user_sum_elem_regression


type Shape
    | Circle(int)
    | Square(int)
    | Empty


test "for-in []UserSum + match" {
    let shapes []Shape = [Circle(2), Square(3), Circle(5), Empty]
    let mut total = 0
    for s in shapes {
        let area = match s {
            Circle(r)    => r * r
            Square(side) => side * side
            Empty        => 0
        }
        total = total + area
    }
    assert(total == 38)
}

test "for-in []UserSum + if let" {
    let shapes []Shape = [Circle(4), Empty, Square(1)]
    let mut circle_count = 0
    for s in shapes {
        if let Circle(_) = s {
            circle_count = circle_count + 1
        }
    }
    assert(circle_count == 1)
}
