// Plan 138.2 [M-138-vec-bulk-parity] — t1: []T extend-family bulk methods on Vec.
//
// Exercises the RawMem-backed bulk-parity methods added to Vec so the `[]T`
// API survives NovaArray retirement: copy_from / copy_within / fill /
// append_zero / compare. These were NovaArray C-builtins (Plan 90.1); they are
// now Nova-body methods on Vec[T] (std/collections/vec_owned.nv).

module plan138_2.t1_vec_bulk_parity

import std.collections.vec.{Vec}

test "copy_from — equal-length overwrite" {
    mut dst = Vec[int].from([0, 0, 0])
    ro src = Vec[int].from([1, 2, 3])
    dst.copy_from(src)
    assert(dst.equal(Vec[int].from([1, 2, 3])))
}

test "copy_within — overlapping move (forward)" {
    mut v = Vec[int].from([1, 2, 3, 4, 5])
    // copy 2 elems from index 0 to index 2: [1,2,3,4,5] -> [1,2,1,2,5]
    v.copy_within(0, 2, 2)
    assert(v.equal(Vec[int].from([1, 2, 1, 2, 5])))
}

test "copy_within — overlapping move (backward, memmove-safe)" {
    mut v = Vec[int].from([1, 2, 3, 4, 5])
    // copy 3 elems from index 2 to index 1: dst/src overlap -> [1,3,4,5,5]
    v.copy_within(2, 1, 3)
    assert(v.equal(Vec[int].from([1, 3, 4, 5, 5])))
}

test "fill — multi-byte element type (scalar loop path)" {
    mut v = Vec[int].from([1, 2, 3, 4])
    v.fill(7)
    assert(v.equal(Vec[int].from([7, 7, 7, 7])))
}

test "fill — single-byte element type (memset fast-path)" {
    // Typed binding drives the literal element type to u8 (a `Vec[u8].from`
    // call would leave the literal as Vec[int] — wrong stride).
    mut v []u8 = [1, 2, 3]
    v.fill(0xAB as u8)
    assert(v.len() == 3)
    assert(v[0] == (0xAB as u8))
    assert(v[1] == (0xAB as u8))
    assert(v[2] == (0xAB as u8))
}

test "append_zero — extend by zeroed tail" {
    mut v = Vec[int].from([1, 2])
    v.append_zero(3)
    assert(v.len() == 5)
    assert(v.equal(Vec[int].from([1, 2, 0, 0, 0])))
}

test "append_zero — zero count is a no-op" {
    mut v = Vec[int].from([9, 8])
    v.append_zero(0)
    assert(v.equal(Vec[int].from([9, 8])))
}

test "compare — byte vectors lexicographic -1/0/+1" {
    // Build via push so elements have the correct 1-byte u8 stride. NOTE: the
    // `[]u8 = [1,2,3]` literal form currently stores int64-strided elements
    // (sized-int literal typed-storage gap) — tracked as
    // [M-138.2-vec-u8-literal-stride]; using push isolates @compare from that bug.
    mut a = Vec[u8].new(); a.push(1 as u8); a.push(2 as u8); a.push(3 as u8)
    mut b = Vec[u8].new(); b.push(1 as u8); b.push(2 as u8); b.push(4 as u8)
    mut c = Vec[u8].new(); c.push(1 as u8); c.push(2 as u8)
    assert(a.compare(b) == -1)   // 3 < 4 at index 2
    assert(b.compare(a) == 1)    // 4 > 3
    assert(a.compare(a) == 0)    // identical
    assert(a.compare(c) == 1)    // a is longer, common prefix equal
    assert(c.compare(a) == -1)   // c is shorter
}
