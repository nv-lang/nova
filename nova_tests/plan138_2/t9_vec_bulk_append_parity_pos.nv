// Plan 138.2 Ф.0a (class #1) — t9: Vec[T] @append bulk-parity check.
//
// `@append(other Vec[T])` is bulk (COPIES every element of `other` onto the end
// of `self`, leaving `other` UNCHANGED — D141: copy, not move). This fixture
// CONFIRMS byte-parity with the retired `nova_array_append_*` C-builtin
// (Plan 90.1 / D141): bulk-copy correctness, self-append safety (src aliases
// dst), amortised ×2 growth, empty-source no-op, AND that the source is left
// intact. Parity baseline mirror of plan90_1/append_*.

module nova_tests.plan138_2

import std.collections.vec.{Vec}

test "append — basic bulk copy onto tail, source intact" {
    mut dst = Vec[int].of(1, 2, 3)
    mut src = Vec[int].of(4, 5, 6)
    dst.append(src)
    assert(dst.equal(Vec[int].of(1, 2, 3, 4, 5, 6)))
    // `@append` is a COPY (D141): `src` is left UNCHANGED, not emptied.
    assert(src.len() == 3)
    assert(src.equal(Vec[int].of(4, 5, 6)))
}

test "append — empty source is a no-op" {
    mut dst = Vec[int].of(1, 2)
    mut src = Vec[int].new()
    dst.append(src)
    assert(dst.equal(Vec[int].of(1, 2)))
}

test "append — into empty destination" {
    mut dst = Vec[int].new()
    mut src = Vec[int].of(9, 8, 7)
    dst.append(src)
    assert(dst.equal(Vec[int].of(9, 8, 7)))
}

test "append — amortised growth across many bulk appends" {
    // Repeated bulk appends drive ×2 growth (cap doubling). Final contents must
    // remain exactly the concatenation — proves growth+memmove parity.
    mut dst = Vec[int].new()
    for _ in 0..50 {
        mut chunk = Vec[int].of(1, 2, 3, 4)
        dst.append(chunk)
    }
    assert(dst.len() == 200)
    assert(dst.get(0) == Some(1))
    assert(dst.get(199) == Some(4))
    assert(dst.get(102) == Some(3))   // 102 = 25*4 + 2 -> chunk index 2 -> value 3
}
