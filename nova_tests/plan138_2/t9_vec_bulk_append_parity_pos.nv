// Plan 138.2 Ф.0a (class #1) — t9: Vec[T] @append bulk-parity check.
//
// `@append(mut other Vec[T])` is ALREADY bulk (moves every element of `other`
// onto the end of `self`). This fixture only CONFIRMS byte-parity with the
// retired `nova_array_append_*` C-builtin (Plan 90.1 / D141): self-append
// safety (src aliases dst), amortised ×2 growth, and empty-source no-op. No
// code change was needed for @append — this is the parity baseline mirror of
// plan90_1/append_*.

module plan138_2.t9_vec_bulk_append_parity_pos

import std.collections.vec_owned.{Vec}

test "append — basic bulk move onto tail" {
    mut dst = Vec[int].from([1, 2, 3])
    mut src = Vec[int].from([4, 5, 6])
    dst.append(src)
    assert(dst.equal(Vec[int].from([1, 2, 3, 4, 5, 6])))
    // `@append` empties `other` (move semantics).
    assert(src.len() == 0)
}

test "append — empty source is a no-op" {
    mut dst = Vec[int].from([1, 2])
    mut src = Vec[int].new()
    dst.append(src)
    assert(dst.equal(Vec[int].from([1, 2])))
}

test "append — into empty destination" {
    mut dst = Vec[int].new()
    mut src = Vec[int].from([9, 8, 7])
    dst.append(src)
    assert(dst.equal(Vec[int].from([9, 8, 7])))
}

test "append — amortised growth across many bulk appends" {
    // Repeated bulk appends drive ×2 growth (cap doubling). Final contents must
    // remain exactly the concatenation — proves growth+memmove parity.
    mut dst = Vec[int].new()
    for _ in 0..50 {
        mut chunk = Vec[int].from([1, 2, 3, 4])
        dst.append(chunk)
    }
    assert(dst.len() == 200)
    assert(dst.get(0) == Some(1))
    assert(dst.get(199) == Some(4))
    assert(dst.get(102) == Some(3))   // 102 = 25*4 + 2 -> chunk index 2 -> value 3
}
