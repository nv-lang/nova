// Plan 138.2 Ф.0c (class #5, suppress): `#allow(shadow)` before `module`
// suppresses W_PRELUDE_SHADOW (D174, Plan 107). Pre-flip, `Vec` is not in the
// prelude so the lint does not fire for the explicit `import vec_owned.{Vec}`
// anyway — but once `Vec` enters the prelude (Ф.0-final) the user `type Vec`
// shadow WILL surface W_PRELUDE_SHADOW, and `#allow(shadow)` is the sanctioned
// opt-out. This fixture pins that the attribute + user-Vec shadow compiles
// cleanly today and stays clean after the flip (user wins entirely, D29).

#allow(shadow)
module plan138_2.t16_user_vec_shadow_suppress_pos

import std.collections.vec_owned.{Vec}

type Vec { x int, y int }

test "user-Vec shadow under #allow(shadow) compiles clean" {
    ro v = Vec { x: 7, y: 11 }
    assert(v.x == 7)
    assert(v.y == 11)
}
