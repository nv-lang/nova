// EXPECT_RUNTIME_PANIC requires failed
//
// Plan 138.2 Ф.0a (class #1) — t11: bulk @splice out-of-bounds index panics.
//
// Valid range for the bulk-splice index is [0, len] (i == len is a bulk
// append). `i > len` (or `i < 0`) is a runtime panic — mirrors the retired
// `nova_array_insert_*` C-builtin OOB check (nv_panic_insert_oob) and
// plan90_1/insert_oob_above_len_neg.

module plan138_2.t11_vec_bulk_insert_oob_neg

import std.collections.vec.{Vec}

fn main() -> () {
    mut dst = Vec[int].of(1, 2, 3)
    dst.splice(4, Vec[int].of(10, 20))  // len=3, i=4 -> out of bounds
}
