module nova_tests.plan91_8a

// Plan 91.8a (D183): protocol renames вЂ” Iterв†’Iterable, Displayв†’Display,
// Equal.eqв†’equals, Compare.cmpв†’compare -> int.

type Counter { mut cur int, end int }
fn Counter mut @next() -> Option[int] {
    if @cur >= @end {
        None
    } else {
        ro v = @cur
        @cur = @cur + 1
        Some(v)
    }
}

test "Iterable[T] bound СЂРµР·РѕР»РІРёС‚СЃСЏ" {
    mut c = Counter { cur: 0, end: 3 }
    mut sum = 0
    for x in c {
        sum = sum + x
    }
    assert(sum == 3)    // 0 + 1 + 2
}

type Pt { x int, y int }

fn Pt @equal(other Pt) -> bool => @x == other.x && @y == other.y

test "Equal.equals вЂ” instance dispatch" {
    ro a = Pt { x: 1, y: 2 }
    ro b = Pt { x: 1, y: 2 }
    ro c = Pt { x: 3, y: 4 }
    assert(a.equals(b))
    assert(!a.equals(c))
}

type Money { cents int }
fn Money @compare(other Money) -> int =>
    if @cents < other.cents { -1 }
    else if @cents > other.cents { 1 }
    else { 0 }
fn Money @equal(other Money) -> bool => @compare(other) == 0

test "Compare.compare вЂ” int convention (D183)" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 200 }
    ro c = Money { cents: 100 }
    assert(a.compare(b) < 0)
    assert(b.compare(a) > 0)
    assert(a.compare(c) == 0)
    assert(a.equals(c))
}

test "Compare bound РЅР° T" {
    ro a = Money { cents: 50 }
    ro b = Money { cents: 75 }
    ro m = min_money(a, b)
    assert(m.cents == 50)
}

fn min_money[T Compare](a T, b T) -> T =>
    if a.compare(b) <= 0 { a } else { b }


type Buffer { data str }
fn Buffer @display(mut w Write) -> () {
    w.write("Buffer(")
    w.write(@data)
    w.write(")")
}

test "Display.fmt вЂ” StringBuilder formatting" {
    mut b = Buffer { data: "hello" }
    consume sb = StringBuilder.new()
    b.display(sb)
    assert(sb.into_str() == "Buffer(hello)")
}
