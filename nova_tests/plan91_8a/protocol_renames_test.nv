module plan91_8a.protocol_renames_test

// Plan 91.8a (D183): protocol renames ‚Äî Iter‚ÜíIterable, Display‚ÜíPrintable,
// Equatable.eq‚Üíequals, Comparable.cmp‚Üícompare -> int.

type Counter { mut cur int, end int }
fn Counter mut @next() -> Option[int] {
    if @cur >= @end {
        None
    } else {
        ro v = @cur
        @cur = @cur + 1
        Some(v)
    }
}

test "Iterable[T] bound —Ä–µ–∑–æ–ª–≤–∏—Ç—Å—è" {
    mut c = Counter { cur: 0, end: 3 }
    mut sum = 0
    for x in c {
        sum = sum + x
    }
    assert(sum == 3)    // 0 + 1 + 2
}

type Pt { x int, y int }

fn Pt @equals(other Pt) -> bool => @x == other.x && @y == other.y

test "Equatable.equals ‚Äî instance dispatch" {
    ro a = Pt { x: 1, y: 2 }
    ro b = Pt { x: 1, y: 2 }
    ro c = Pt { x: 3, y: 4 }
    assert(a.equals(b))
    assert(!a.equals(c))
}

type Money { cents int }
fn Money @compare(other Money) -> int =>
    if @cents < other.cents { -1 }
    else if @cents > other.cents { 1 }
    else { 0 }
fn Money @equals(other Money) -> bool => @compare(other) == 0

test "Comparable.compare ‚Äî int convention (D183)" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 200 }
    ro c = Money { cents: 100 }
    assert(a.compare(b) < 0)
    assert(b.compare(a) > 0)
    assert(a.compare(c) == 0)
    assert(a.equals(c))
}

test "Comparable bound –Ω–∞ T" {
    ro a = Money { cents: 50 }
    ro b = Money { cents: 75 }
    ro m = min_money(a, b)
    assert(m.cents == 50)
}

fn min_money[T Comparable](a T, b T) -> T =>
    if a.compare(b) <= 0 { a } else { b }


type Buffer { data str }
fn Buffer @fmt(mut sb StringBuilder) -> () {
    sb.append("Buffer(")
    sb.append(@data)
    sb.append(")")
}

test "Printable.fmt ‚Äî StringBuilder formatting" {
    mut b = Buffer { data: "hello" }
    consume sb = StringBuilder.new()
    b.fmt(sb)
    assert(sb.as_str() == "Buffer(hello)")
}
