module plan91_8a.default_body_parsed_test

// Plan 91.8a (D183): default body РІ protocol-decl РїР°СЂСЃРёС‚СЃСЏ.
// Codegen synthesis РґР»СЏ defaults вЂ” followup 91.8a.2.

// Probe: protocol СЃ default body РїР°СЂСЃРёС‚СЃСЏ Р±РµР· РѕС€РёР±РѕРє.
type MyProtocol protocol {
    @abstract_method() -> int
    @default_method() -> int => 42
}

// Р РµР°Р»РёР·СѓСЋС‰РёР№ С‚РёРї вЂ” Р·Р°РґР°С‘С‚ РѕР±Р° СЏРІРЅРѕ (С‚.Рє. codegen synthesis РѕС‚Р»РѕР¶РµРЅ).
type Impl { x int }
fn Impl @abstract_method() -> int => @x
fn Impl @default_method() -> int => 42

test "protocol СЃ default body РїР°СЂСЃРёС‚СЃСЏ + РёСЃРїРѕР»СЊР·СѓРµС‚СЃСЏ" {
    ro i = Impl { x: 7 }
    assert(i.abstract_method() == 7)
    assert(i.default_method() == 42)
}

// Compare РёР· prelude РёСЃРїРѕР»СЊР·СѓРµС‚ default body РґР»СЏ equals.
// РџСЂРѕРІРµСЂРєР°: prelude РїР°СЂСЃРёС‚СЃСЏ Р±РµР· E_PROTOCOL_EMBED_DUPLICATE.
type Sortable { weight int }
fn Sortable @compare(other Sortable) -> int =>
    if @weight < other.weight { -1 }
    else if @weight > other.weight { 1 }
    else { 0 }
fn Sortable @equal(other Sortable) -> bool => @compare(other) == 0

test "Compare use Equal + default equals body вЂ” РєРѕРјРїРёР»РёС‚СЃСЏ" {
    ro a = Sortable { weight: 5 }
    ro b = Sortable { weight: 10 }
    assert(a.compare(b) < 0)
    assert(a.equals(a))
}
