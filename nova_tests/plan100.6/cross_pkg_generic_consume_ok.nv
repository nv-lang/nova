// Plan 100.6 (D164) + (D133 D6 generic-заразность): Result[a.Transaction, IoErr]
// через границу пакетов — generic propagation работает.

module nova_tests.plan100_6.cross_pkg_generic_consume_ok

type IoErr { msg str }

// "Package A":
export type Transaction consume { id int }
export fn Transaction consume @commit() -> () { () }

// "Package B" — fn returns Result wrapping A.Transaction:
fn try_begin() -> Result[Transaction, IoErr] => Ok(Transaction { id: 1 })

test "generic-wrap consume через package boundary" {
    match try_begin() {
        Ok(t) => {
            consume tx = t                       // consume-marker propagates через Ok
            tx.commit()
        }
        Err(_) => println("failed"),
    }
}
