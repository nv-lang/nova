// Plan 108.2 (D36 enforcement): `let mut` для user-defined record с mut @method.

module plan108_2.let_mut_user_record_ok

type Counter {
    mut value int
}

fn Counter.new() -> Counter => { value: 0 }

fn Counter mut @inc() -> () {
    @value = @value + 1
}

fn Counter @get() -> int => @value

test "let mut + user record + mut @method" {
    mut c = Counter.new()
    c.inc()
    c.inc()
    c.inc()
    assert(c.get() == 3)
}
