// Plan 108.2 (D36 enforcement): `let` без mut — read-only OK.
// Доступны: read fields, len, iteration, non-mut методы.

module nova_tests.plan108_2.let_no_mut_read_ok

test "let no-mut + read operations" {
    let mut arr = [10, 20, 30]
    assert(arr.len() == 3)
    let mut sum = 0
    for x in arr { sum = sum + x }
    assert(sum == 60)
}
