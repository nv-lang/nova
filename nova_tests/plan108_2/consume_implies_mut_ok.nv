// Plan 108.2 (D36 enforcement): `consume X = ...` неявно подразумевает mut.

module nova_tests.plan108_2.consume_implies_mut_ok

test "consume binding can call mut method" {
    consume sb = StringBuilder.from("a")
    sb.append("b")              // ✓ consume → mut implicit
    let s = sb.as_str()
    assert(s == "ab")
}
