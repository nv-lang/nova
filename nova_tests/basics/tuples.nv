// 17_tuples.nv — кортежи

module basics.tuples

test "tuple literal" {
    ro t = (1, 2, 3)
    assert(t.0 == 1)
    assert(t.1 == 2)
    assert(t.2 == 3)
}

test "tuple of mixed types" {
    ro t = (42, "hi", true)
    assert(t.0 == 42)
    assert(t.1 == "hi")
    assert(t.2 == true)
}

test "tuple destructuring ro" {
    ro (a, b) = (10, 20)
    assert(a == 10)
    assert(b == 20)
}

test "tuple destructuring with wildcard" {
    ro (a, _, c) = (1, 2, 3)
    assert(a == 1)
    assert(c == 3)
}

test "nested tuple" {
    ro t = ((1, 2), (3, 4))
    assert(t.0.0 == 1)
    assert(t.0.1 == 2)
    assert(t.1.0 == 3)
    assert(t.1.1 == 4)
}

test "tuple equality" {
    assert((1, 2) == (1, 2))
    assert((1, 2) != (1, 3))
}

fn sum_pair(p (int, int)) -> int => p.0 + p.1

fn make_pair(a int, b int) -> (int, int) => (a, b)

test "tuple as function argument" {
    assert(sum_pair((3, 4)) == 7)
}

test "tuple returned from fn" {
    ro (x, y) = make_pair(7, 9)
    assert(x == 7)
    assert(y == 9)
}
