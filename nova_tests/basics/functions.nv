// 05_functions.nv — fn, expression-body, block-body, recursion, closures

module basics.functions

// Expression-body (D40)
fn double(x int) -> int => x * 2

fn square(x int) -> int => x * x

// Block-body
fn factorial(n int) -> int {
    if n <= 1 { return 1 }
    n * factorial(n - 1)
}

fn fib(n int) -> int {
    if n < 2 { return n }
    fib(n - 1) + fib(n - 2)
}

// Multiple parameters
fn add(a int, b int, c int) -> int => a + b + c

// No return type
fn greet(name str) {
    let _ = "hello, " + name
}

// Returning unit explicitly
fn tick() -> () => ()

test "simple function" {
    assert(double(5) == 10)
    assert(square(7) == 49)
}

test "recursion" {
    assert(factorial(0) == 1)
    assert(factorial(5) == 120)
    assert(factorial(7) == 5040)
}

test "mutual recursion via fib" {
    assert(fib(0) == 0)
    assert(fib(1) == 1)
    assert(fib(10) == 55)
}

test "multiple parameters" {
    assert(add(1, 2, 3) == 6)
    assert(add(0, 0, 0) == 0)
}

test "lambda inline" {
    let inc = |x| x + 1
    assert(inc(5) == 6)
    let mul = |a, b| a * b
    assert(mul(3, 4) == 12)
}

test "lambda passed as argument" {
    let apply = fn(f fn(int) -> int, x int) -> int => f(x)
    assert(apply(|n| n * 10, 5) == 50)
}

test "closure captures variable" {
    let n = 100
    let add_n = |x| x + n
    assert(add_n(7) == 107)
}

test "lambda with explicit param type" {
    let halve = fn(x int) -> int => x / 2
    assert(halve(20) == 10)
}

test "function returns unit" {
    let r = tick()
    assert(r == ())
}

test "higher-order: map-like" {
    let twice = fn(n int) -> int => n * 2
    assert(twice(5) == 10)
}
