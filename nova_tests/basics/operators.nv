// 02_operators.nv — все бинарные и унарные операторы

module nova_tests.basics.operators

test "int arithmetic" {
    assert(2 + 3 == 5)
    assert(10 - 4 == 6)
    assert(3 * 4 == 12)
    assert(20 / 5 == 4)
    assert(17 % 5 == 2)
}

test "int precedence" {
    assert(1 + 2 * 3 == 7)
    assert((1 + 2) * 3 == 9)
    assert(10 - 6 / 2 == 7)
    assert(2 + 3 * 4 - 1 == 13)
}

test "unary negation" {
    let x = 10
    assert(-x == 0 - 10)
    assert(-(-5) == 5)
}

test "float arithmetic" {
    assert(1.5 + 0.5 == 2.0)
    assert(2.0 * 3.0 == 6.0)
    assert(10.0 / 4.0 == 2.5)
}

test "string concat via +" {
    assert("foo" + "bar" == "foobar")
    assert("" + "x" == "x")
}

test "comparison int" {
    assert(1 < 2)
    assert(2 <= 2)
    assert(3 > 1)
    assert(3 >= 3)
    assert(!(5 < 5))
}

test "equality" {
    assert(1 == 1)
    assert(1 != 2)
    assert("a" == "a")
    assert("a" != "b")
    assert(true == true)
}

test "logical and/or" {
    assert(true && true)
    assert(!(true && false))
    assert(true || false)
    assert(false || false || true)
}

test "logical not" {
    assert(!false)
    assert(!!true)
}

test "compound assignment" {
    let mut x = 10
    x += 5
    assert(x == 15)
    x -= 3
    assert(x == 12)
    x *= 2
    assert(x == 24)
    x /= 4
    assert(x == 6)
}
