// 03_let_const.nv — let, mut, const

module basics.let_const

const PI int = 3
const GREETING str = "hello"

test "let binding" {
    ro x = 10
    assert(x == 10)
}

test "let with explicit type" {
    ro x int = 42
    assert(x == 42)
    ro s str = "abc"
    assert(s == "abc")
}

test "let mut allows reassign" {
    mut x = 1
    x = 100
    assert(x == 100)
    x = -5
    assert(x == -5)
}

test "const top-level" {
    assert(PI == 3)
    assert(GREETING == "hello")
}

test "let shadow in inner block" {
    ro x = 5
    ro inner = {
        ro x = 99
        x
    }
    assert(inner == 99)
    assert(x == 5)
}

test "let with tuple destructure" {
    ro (a, b, c) = (1, 2, 3)
    assert(a == 1)
    assert(b == 2)
    assert(c == 3)
}
