// 24_recursion.nv — рекурсивные функции и рекурсивные sum-типы.

module nova_tests.basics.recursion

fn fib(n int) -> int {
    if n < 2 { n }
    else { fib(n - 1) + fib(n - 2) }
}

fn factorial(n int) -> int {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

fn ack(m int, n int) -> int {
    if m == 0 { n + 1 }
    else if n == 0 { ack(m - 1, 1) }
    else { ack(m - 1, ack(m, n - 1)) }
}

fn gcd(a int, b int) -> int {
    if b == 0 { a } else { gcd(b, a % b) }
}

test "fibonacci" {
    assert(fib(0) == 0)
    assert(fib(1) == 1)
    assert(fib(2) == 1)
    assert(fib(10) == 55)
}

test "factorial" {
    assert(factorial(0) == 1)
    assert(factorial(1) == 1)
    assert(factorial(5) == 120)
    assert(factorial(7) == 5040)
}

test "ackermann small" {
    assert(ack(0, 0) == 1)
    assert(ack(1, 1) == 3)
    assert(ack(2, 2) == 7)
}

test "gcd euclidean" {
    assert(gcd(12, 18) == 6)
    assert(gcd(48, 36) == 12)
    assert(gcd(7, 13) == 1)
    assert(gcd(100, 0) == 100)
}

// --- Рекурсивный sum-type ---

type Tree
    | Leaf
    | Node(int, Tree, Tree)

fn tree_sum(t Tree) -> int => match t {
    Leaf            => 0
    Node(v, l, r)   => v + tree_sum(l) + tree_sum(r)
}

fn tree_depth(t Tree) -> int => match t {
    Leaf => 0
    Node(_, l, r) => {
        let dl = tree_depth(l)
        let dr = tree_depth(r)
        1 + (if dl > dr { dl } else { dr })
    }
}

fn tree_count(t Tree) -> int => match t {
    Leaf          => 0
    Node(_, l, r) => 1 + tree_count(l) + tree_count(r)
}

test "tree sum рекурсивный" {
    let t = Node(1, Node(2, Leaf, Leaf), Node(3, Leaf, Node(4, Leaf, Leaf)))
    assert(tree_sum(t) == 10)
}

test "tree depth — пустое и одиночное" {
    assert(tree_depth(Leaf) == 0)
    assert(tree_depth(Node(1, Leaf, Leaf)) == 1)
}

test "tree depth — несбалансированное" {
    let t = Node(1, Leaf, Node(2, Leaf, Node(3, Leaf, Leaf)))
    assert(tree_depth(t) == 3)
}

test "tree count nodes" {
    let t = Node(1, Node(2, Leaf, Leaf), Node(3, Node(4, Leaf, Leaf), Leaf))
    assert(tree_count(t) == 4)
}

// --- Взаимная рекурсия ---

fn is_even(n int) -> bool {
    if n == 0 { true } else { is_odd(n - 1) }
}

fn is_odd(n int) -> bool {
    if n == 0 { false } else { is_even(n - 1) }
}

test "взаимная рекурсия even/odd" {
    assert(is_even(0))
    assert(is_odd(1))
    assert(is_even(10))
    assert(is_odd(7))
    assert(!is_even(3))
}
