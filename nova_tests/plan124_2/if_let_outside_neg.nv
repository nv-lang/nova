// EXPECT_COMPILE_ERROR E_PRIV_FIELD_PATTERN
//
// Plan 124.2 — negative: if-let pattern на priv field outside
// type-method scope → E_PRIV_FIELD_PATTERN (D221 §2 — if-let site).
module plan124_2.if_let_outside_neg

export type Account {
    priv mut money f64
    ro name str
}

export fn Account.new(n str) -> Account =>
    { money: 0.0, name: n }

// External fn — if-let destructures priv `money`.
fn external_if_let(acc Account) -> f64 {
    mut got = 0.0
    if Account { money, .. } = acc {
        got = money
    }
    got
}
