// Plan 124.2 — positive: record literal spread `...other` ВНУТРИ
// type-method scope разрешён (recv = Account, has_priv allowed).
module plan124_2.spread_inside_method_ok

export type Account {
    priv mut money f64
    ro name str
}

export fn Account.new(n str) -> Account =>
    { money: 0.0, name: n }

// Static method scope — spread allowed (recv = Account).
export fn Account.rename(orig Account, new_name str) -> Account {
    Account { ...orig, name: new_name }
}

test "Plan 124.2: spread allowed внутри static метода" {
    ro a = Account.new("eve")
    ro b = Account.rename(a, "eve2")
    assert(b.name == "eve2")
}
