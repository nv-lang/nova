// Plan 124.2 — positive: match arm pattern на priv field внутри
// instance method body. Recv = Account → priv field PATTERN allowed.
module nova_tests.plan124_2

export type Account {
    priv mut money f64
    ro name str
}

export fn Account.new(n str) -> Account =>
    { money: 0.0, name: n }

// Instance method: match arm destructures priv field — OK.
export fn Account @debug_balance() -> f64 {
    ro tmp = @money
    match tmp {
        0.0 => 0.0
        _ => tmp
    }
}

test "Plan 124.2: match arm на priv внутри метода" {
    ro acc = Account.new("alice")
    assert(acc.debug_balance() == 0.0)
}
