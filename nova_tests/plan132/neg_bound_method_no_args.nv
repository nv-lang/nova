// EXPECT_COMPILE_ERROR E_BOUND_METHOD_REMOVED
//
// Plan 132 Ф.1.5 (NEG): bound method value without call — removed syntax.
// `c.@get` where c is an instance (not a type name) must emit
// E_BOUND_METHOD_REMOVED.

module plan132.neg_bound_method_no_args

type Counter { value int }

fn Counter.new() -> Self => { value: 0 }
fn Counter @get() -> int => @value
fn Counter @add(n int) -> int => @value + n

fn main() {
    ro c = Counter.new()
    ro _f = c.@get  // bound method value — removed
}
