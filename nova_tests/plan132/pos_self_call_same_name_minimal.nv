// Plan 132.1 regression guard: minimal repro for @name() self-call when field/method share name
module nova_tests.plan132

type MyObj5 { priv mut x int }

fn MyObj5.new() -> Self => { x: 0 }
fn MyObj5 @x() -> int => @x          // method @x() — returns field @x (no parens = field)
fn MyObj5 @call_x() -> int => @x()   // calls method @x() — was CC-FAIL before Plan 132.1 fix
fn MyObj5 @set_x(v int) { @x = v }

test "self-call @x() from @call_x() works" {
    mut t = MyObj5.new()
    t.set_x(42)
    assert(t.x() == 42)
    assert(t.call_x() == 42)
}
