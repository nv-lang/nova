// Plan 123 V*.followups 2026-06-05 marker 3 — chain-norm V2 user-fluent.
// Closes [M-123.4.4-user-fluent-detection].
// Positive: user `-> @` fluent builder chain triggers chain-norm
// hoisting via FnDecl.returns_receiver discovery (V1 hardcoded list
// would skip).

module plan123_followups_2026_06_05.m3_chain_norm_v2_user_fluent_ok

type Counter {
    mut n int
}

fn Counter.new() -> Counter => { n: 0 }

// User fluent builder: `-> @` return marker → registered в
// FluentMethodRegistry.
fn Counter mut @step(by int) -> @ {
    @n = @n + by
    @
}

fn Counter @get() -> int => @n

type Holder {
    mut c Counter
}

fn Holder.new() -> Holder => { c: Counter.new() }

fn Holder mut @use_chain() -> int {
    // V2: `@c.step(1).step(2).step(3)` — root `@c` (heap-record ref),
    // chain depth 3 of user-defined `step` `-> @`. V2 hoists root.
    @c.step(1).step(2).step(3)
    @c.get()
}

test "chain-norm V2 user fluent: depth-3 user step chain" {
    mut h = Holder.new()
    ro r = h.use_chain()
    // 0 → 1 → 3 → 6
    assert(r == 6)
    assert(h.c.get() == 6)
}
