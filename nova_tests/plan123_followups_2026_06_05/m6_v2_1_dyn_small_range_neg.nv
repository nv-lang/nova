// Plan 123 V*.followups 2026-06-05 marker 6 вЂ” V2.1 dynamic loop count negative.
// Negative: small literal range (`0..3`) gives weight=3 вЂ” below typical
// caching threshold вЂ” optimizer chooses NOT Рє cache, but observable
// behavior remains correct.

module nova_tests.plan123_followups_2026_06_05

type Cv13 {
    mut z int
}

fn Cv13.new() -> Cv13 => { z: 5 }

fn Cv13 @small_range_no_promote() -> int {
    // 0..3 вЂ” literal weight 3. Below default cache threshold (2 raw,
    // but with weight=3 from parse_loop_iter_count). Optimizer may
    // or may not cache; observable correctness must hold either way.
    mut acc = 0
    for i in 0..3 {
        acc = acc + @z
    }
    acc
}

test "V2.1 dyn small range: semantic preservation regardless of cache decision" {
    ro cv13 = Cv13.new()
    ro r = cv13.small_range_no_promote()
    // 3 Г— 5 = 15
    assert(r == 15)
}
