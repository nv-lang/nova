// Plan 103.3 — Writer-priority: writer eventually acquires despite active readers.
//
// EXPECT_TIMEOUT_MS 20000

module nova_tests.plan103_3.rwlock_writer_priority

test "writer-priority: writer acquires after readers finish, not starved" {
    mut rw = RwLock.new()
    mut writer_acquired = AtomicBool.new(false)

    // 2 readers hold the lock
    rw.read()
    rw.read()

    supervised {
        // Writer fiber: parks waiting for both readers to release
        spawn {
            rw.write()
            writer_acquired.store(true)
            rw.write_unlock()
        }

        // Release both readers (writer wakes when reader_count → 0)
        rw.read_unlock()
        rw.read_unlock()
    }

    assert(writer_acquired.load() == true)
}

test "writer-priority: try_read fails while write_locked" {
    mut rw = RwLock.new()
    rw.write()
    // Writer holds lock — new reader cannot acquire
    assert(rw.try_read() == false)
    rw.write_unlock()
    // After release, reader can acquire
    assert(rw.try_read() == true)
    rw.read_unlock()
}
