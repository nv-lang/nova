// Plan 103.3 — rw.read(); rw.write_unlock() → RUNTIME_PANIC (mismatched unlock).
//
// EXPECT_RUNTIME_PANIC RwLock.write_unlock() called without a matching write()

module nova_tests.plan103_3.rwlock_mix_read_write_lock_neg

test "read then write_unlock panics" {
    mut rw = RwLock.new()
    rw.read()
    rw.write_unlock()  // wrong unlock kind
}
