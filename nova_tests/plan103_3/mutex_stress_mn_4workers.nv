// Plan 103.3 — Stress: 8 fibers × 5000 iter M:N(4) — final counter = 40000.
//
// EXPECT_TIMEOUT_MS 60000

module plan103_3.mutex_stress_mn_4workers

test "Mutex stress: 8 fibers × 5000 iters, final counter=40000" {
    mut mu = Mutex.new()
    mut counter = AtomicInt.new(0)
    mut wg = WaitGroup.new()
    wg.add(8)

    parallel for _i in 0..8 {
        for _j in 0..5000 {
            mu.lock()
            ro v = counter.load()
            counter.store(v + 1)
            mu.unlock()
        }
        wg.done()
    }

    wg.wait()
    assert(counter.load() == 40000)
}
