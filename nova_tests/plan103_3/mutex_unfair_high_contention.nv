// Plan 103.3 — Mutex.new_unfair() smoke test: 8 fibers contend, no deadlock.
//
// EXPECT_TIMEOUT_MS 30000

module nova_tests.plan103_3.mutex_unfair_high_contention

test "unfair mutex: 8 fibers contend, no deadlock, counter correct" {
    mut mu = Mutex.new_unfair()
    mut counter = AtomicInt.new(0)
    mut wg = WaitGroup.new()
    wg.add(8)

    parallel for _i in 0..8 {
        for _j in 0..100 {
            mu.lock()
            ro v = counter.load()
            counter.store(v + 1)
            mu.unlock()
        }
        wg.done()
    }

    wg.wait()
    assert(counter.load() == 800)
}
