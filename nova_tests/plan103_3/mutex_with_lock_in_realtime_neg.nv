// Plan 103.3 — Mutex.lock inside realtime{} → COMPILE_ERROR.
//
// Fiber park/wait forbidden in realtime context (Plan 103.6: E_REALTIME_SYNC_PARK).
// Note: error code was E_EFFECT_REALTIME_VIOLATION before Plan 103.6 annotation sweep.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_3.mutex_with_lock_in_realtime_neg

test "Mutex.lock banned in realtime block" {
    let mu = Mutex.new()
    realtime {
        mu.lock()
    }
}
