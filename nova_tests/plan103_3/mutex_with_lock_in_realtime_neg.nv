// Plan 103.3 — Mutex.lock inside #realtime fn → COMPILE_ERROR.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_3.mutex_with_lock_in_realtime_neg

#realtime fn _rt_check_mutex_lock(mu mut Mutex) {
    mu.lock()
}

test "Mutex.lock banned in #realtime fn" {
    mut mu = Mutex.new()
    _rt_check_mutex_lock(mu)
}
