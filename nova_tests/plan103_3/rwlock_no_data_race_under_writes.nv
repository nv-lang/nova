// Plan 103.3 — Property: RwLock protects data — no torn reads under writes.
//
// Writers extend array; readers verify sum invariant.
//
// EXPECT_TIMEOUT_MS 30000

module plan103_3.rwlock_no_data_race_under_writes

test "RwLock: no torn reads while writers update counter" {
    mut rw = RwLock.new()
    mut counter = AtomicInt.new(0)
    mut torn_read = AtomicInt.new(0)
    mut wg = WaitGroup.new()
    ro n_writers = 2
    ro n_readers = 4
    ro iters = 100
    wg.add(n_writers + n_readers)

    // Writers: increment by 10 atomically under write lock
    parallel for _i in 0..n_writers {
        for _j in 0..iters {
            rw.write()
            ro v = counter.load()
            counter.store(v + 10)
            rw.write_unlock()
        }
        wg.done()
    }

    // Readers: verify counter is multiple of 10
    parallel for _i in 0..n_readers {
        for _j in 0..iters {
            rw.read()
            ro v = counter.load()
            if v % 10 != 0 { torn_read.fetch_add(1) }
            rw.read_unlock()
        }
        wg.done()
    }

    wg.wait()
    // No torn reads observed
    assert(torn_read.load() == 0)
    // Final counter is n_writers * iters * 10
    assert(counter.load() == n_writers * iters * 10)
}
