// Plan 103.3 — Mutex.unlock() without lock() → RUNTIME_PANIC.
//
// Unconditional check (Plan 103.3 pattern: fires in Dev AND Release).
//
// EXPECT_RUNTIME_PANIC Mutex.unlock() called on an unlocked mutex

module nova_tests.plan103_3.mutex_double_unlock_neg

test "unlock without lock panics" {
    let mu = Mutex.new()
    mu.unlock()
}
