// Plan 103.3 — Property: Mutex mutual exclusion observable interleave.
// N fibers × M iters; `inside` counter never > 1 (observable interleave).
//
// EXPECT_TIMEOUT_MS 30000

module nova_tests.plan103_3.mutex_mutual_exclusion_observed_interleave

test "mutual exclusion: inside counter never exceeds 1" {
    let mut mu = Mutex.new()
    let mut inside = AtomicInt.new(0)
    let violation = AtomicInt.new(0)
    let mut wg = WaitGroup.new()
    let n_fibers = 6
    let m_iters = 200
    wg.add(n_fibers)

    parallel for _i in 0..n_fibers {
        for _j in 0..m_iters {
            mu.lock()
            let prev = inside.fetch_add(1)
            if prev != 0 { violation.fetch_add(1) }
            inside.fetch_add(-1)
            mu.unlock()
        }
        wg.done()
    }

    wg.wait()
    assert(violation.load() == 0)
}
