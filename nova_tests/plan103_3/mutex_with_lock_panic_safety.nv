// Plan 103.3 — Mutex Fail-safety: Fail effect handler can unlock the mutex,
// demonstrating safe cleanup on error paths.
//
// throw "msg" desugars to Nova_Fail_fail() and is caught by with Fail handlers.
// panic() is a hard crash that bypasses Fail handlers (goes to fail-frame directly).
// This test uses throw to demonstrate the error-path unlock pattern.

module nova_tests.plan103_3.mutex_with_lock_panic_safety

test "mutex released via Fail handler on throw" {
    mut mu = Mutex.new()

    // Lock mutex, throw a Fail effect; handler unlocks and interrupts.
    with Fail = effect Fail {
        fail(_msg) { mu.unlock(); interrupt () }
    } {
        mu.lock()
        throw "trigger cleanup handler"
    }

    // Handler ran mu.unlock(), so mutex is now free.
    ro acquired = mu.try_lock()
    assert(acquired == true)
    mu.unlock()
}
