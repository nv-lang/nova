// Plan 65 R18 f2 / Ф.5: legacy `Time.after(...)` triggers E5101 diagnostic
// with machine-applicable fix-it suggestion.
// EXPECT_COMPILE_ERROR E5101

module plan65.f2_time_after_removed

test "Time.after rejected with E5101" {
    // This call must fail codegen with the structured Plan 65 diagnostic.
    ro _t = Time.after(50)
    assert(false)
}
