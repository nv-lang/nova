// Plan 65 R18 / Ф.14: concurrent stress test for ChanReader.close_after.
//
// Validates that 1000 concurrent close_after allocs across 10 fibers
// do not crash, deadlock, or leak. Each fiber alloc'ит 100 timers in
// sequence with short durations (1-3ms), recv's them, and increments
// a shared counter.
//
// Acceptance:
//   - All timers fire OR are cancelled (none leak).
//   - Time.timer_alloc_active returns to baseline after the scope exits.
//   - Test completes in < 5 seconds (no deadlock).
//
// Cross-toolchain: ASan/TSan/UBSan clean validation is done in Linux
// Docker (Plan 44.1 infra) — not exercised here on Windows.

module plan65.f11_concurrent_timer_alloc

import std.time.duration

const TIMERS_PER_FIBER int = 100
const N_FIBERS int = 10
const TIMEOUT_BUDGET_MS i64 = 5000

test "1000 concurrent close_after allocs, no leak, no crash" {
    ro baseline = Time.timer_alloc_active()
    ro t0 = Time.now()
    supervised {
        mut f int = 0
        while f < N_FIBERS {
            spawn {
                mut i int = 0
                while i < TIMERS_PER_FIBER {
                    // Vary the duration to exercise short/medium-path
                    // bucketing in libuv's heap. Sub-ms values trigger
                    // the round-up path; multi-ms trigger natural fire.
                    ro ms i64 = ((i % 3) as i64) + 1
                    ro t = ChanReader.close_after(Duration.from_millis(ms))
                    ro _ = t.recv()
                    i = i + 1
                }
            }
            f = f + 1
        }
    }
    ro elapsed = Time.now() - t0
    // Test must complete in well under the 5s budget; otherwise we
    // deadlocked or fell back to a serial schedule.
    assert(elapsed < TIMEOUT_BUDGET_MS)
    // All allocated timers must have fired naturally — alloc_active
    // returns to baseline.
    ro after = Time.timer_alloc_active()
    assert(after == baseline)
}
