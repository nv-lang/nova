// Plan 65 R24 / Ф.11: Time.timer_*() observability counters.
//
// Validates that NOVA_TIMER_METRICS counters are always live (not
// gated on the env var, which only controls atexit dump). The counters
// returned by Time.timer_alloc_total / _alloc_active / _fired /
// _cancelled / _longest_pending_ms are maintained per close_after
// allocation and per fire/cancel cleanup path.

// Plan 83.11 Ф.3 (2026-06-08): armed M:N works — centralized driver eliminates cancel-timer race.
// cancel_resource_cb now executes reliably before scope exit under armed M:N.

module plan65.f11a_timer_metrics

import std.time.duration

test "Time.timer_alloc_total increments on each close_after alloc" {
    ro before = Time.timer_alloc_total()
    supervised {
        spawn {
            // 5 separate alloc calls.
            ro _t1 = ChanReader.close_after(Duration.from_millis(1))
            ro _t2 = ChanReader.close_after(Duration.from_millis(1))
            ro _t3 = ChanReader.close_after(Duration.from_millis(1))
            ro _t4 = ChanReader.close_after(Duration.from_millis(1))
            ro _t5 = ChanReader.close_after(Duration.from_millis(1))
            // drain so scope can exit cleanly.
            ro _ = _t1.recv()
            ro _ = _t2.recv()
            ro _ = _t3.recv()
            ro _ = _t4.recv()
            ro _ = _t5.recv()
        }
    }
    ro after = Time.timer_alloc_total()
    // Zero-duration fast-path doesn't increment; only real alloc counts.
    // 5 timers actually allocated.
    assert(after - before == 5)
}

test "Time.timer_alloc_active returns to baseline after natural fire" {
    ro baseline = Time.timer_alloc_active()
    supervised {
        spawn {
            ro t = ChanReader.close_after(Duration.from_millis(10))
            ro _ = t.recv()
        }
    }
    // After scope exit, all timers fired naturally → alloc_active back to baseline.
    ro after = Time.timer_alloc_active()
    assert(after == baseline)
}

test "Time.timer_fired increments on natural fire" {
    ro before = Time.timer_fired()
    supervised {
        spawn {
            ro t = ChanReader.close_after(Duration.from_millis(5))
            ro _ = t.recv()
        }
    }
    ro after = Time.timer_fired()
    assert(after - before >= 1)
}

test "Time.timer_cancelled increments on cancel-token cleanup" {
    ro before = Time.timer_cancelled()
    ro tok = CancelToken.new()
    with Fail = effect Fail {
        fail(_msg) => interrupt ()
    } {
        supervised(cancel: tok) {
            spawn {
                ro t = ChanReader.close_after(Duration.from_millis(10_000))
                ro _ = t.recv()
            }
            spawn {
                Time.sleep(20)
                tok.cancel()
            }
        }
    }
    ro after = Time.timer_cancelled()
    assert(after - before >= 1)
}

test "Time.timer_longest_pending_ms is rolling max" {
    ro before = Time.timer_longest_pending_ms()
    supervised {
        spawn {
            // Allocate a 7-second timer (but cancel immediately) — the
            // metric should reflect the 7000 ms upper bound.
            ro _t = ChanReader.close_after(Duration.from_millis(7_000))
            // Don't wait for it; let scope-exit cleanup close it via on_select_lost-like path.
        }
    }
    ro after = Time.timer_longest_pending_ms()
    assert(after >= 7_000)
    // Rolling: it never decreases.
    assert(after >= before)
}
