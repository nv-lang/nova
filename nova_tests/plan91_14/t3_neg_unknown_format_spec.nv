// Plan 91.14 Ф.2 NEG T3 — unknown format spec → E_FORMAT_SPEC_UNKNOWN.
//
// V1 supports только `?` (debug). Future extensions (`hex`, `pad-N`, `.N`)
// → [M-91.14-format-dsl-extensions] followup.
//
// EXPECT_COMPILE_ERROR E_FORMAT_SPEC_UNKNOWN

module plan91_14.t3_neg_unknown_format_spec

test "unknown format spec hex rejects in V1" {
    ro x = 42
    ro s = "${x:hex}"
    assert(s == "0x2a")
}
