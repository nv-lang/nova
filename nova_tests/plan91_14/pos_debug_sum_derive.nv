// Plan 91.14 (A7) — #impl(Debug) auto-derive on sum types
//
// #impl(Debug) on a sum type produces a V1 placeholder (type name) per
// auto_derive::synthesize_debug — full variant-level synthesis is tracked
// in [M-91.14-sum-debug-variants] followup.
//
// V1: output = type name (e.g., "Color" for any variant of Color).

module plan91_14.pos_debug_sum_derive

#impl(Debug)
type Color | Red | Green | Blue

#impl(Debug)
type Status | Active | Inactive | Pending

test "Color sum debug — any variant produces type name (V1)" {
    ro c = Red as Color
    ro s = "${c:?}"
    // V1 sum-type debug: writes type name
    assert(s == "Color")
}

test "Status sum debug (V1 placeholder)" {
    ro st = Active as Status
    ro s = "${st:?}"
    assert(s == "Status")
}
