// Plan 91.14 Ph.6 POS T12 - 3-level nested struct debug recursion.
// Verifies AC.f nested struct (2+ levels).
// Plan 152.7.1 (D258 AMEND): migrated sb StringBuilder -> w Write, debug_fmt -> debug.
module plan91_14.t12_pos_3_level_nested

type Inner { v int }
fn Inner @debug(mut w Write) -> () {
    w.write("Inner { v: ")
    w.write(str.from(@v))
    w.write(" }")
}

type Middle { id int, inner Inner }
fn Middle @debug(mut w Write) -> () {
    w.write("Middle { id: ")
    w.write(str.from(@id))
    w.write(", inner: ")
    @inner.debug(w)
    w.write(" }")
}

type Outer { label str, middle Middle }
fn Outer @debug(mut w Write) -> () {
    w.write("Outer { label: \"")
    w.write(@label)
    w.write("\", middle: ")
    @middle.debug(w)
    w.write(" }")
}

test "3-level nested struct debug" {
    ro o = Outer { label: "top", middle: Middle { id: 7, inner: Inner { v: 42 } } }
    ro s = "${o:?}"
    assert(s == "Outer { label: \"top\", middle: Middle { id: 7, inner: Inner { v: 42 } } }")
}
