// Plan 91.14 Ф.6 POS T12 — 3-level nested struct debug recursion.
// Verifies AC.f «nested struct (2+ levels)».
module plan91_14.t12_pos_3_level_nested

type Inner { v int }
fn Inner @debug_fmt(mut sb StringBuilder) -> () {
    sb.append("Inner { v: ")
    sb.append(str.from(@v))
    sb.append(" }")
}

type Middle { id int, inner Inner }
fn Middle @debug_fmt(mut sb StringBuilder) -> () {
    sb.append("Middle { id: ")
    sb.append(str.from(@id))
    sb.append(", inner: ")
    @inner.debug_fmt(sb)
    sb.append(" }")
}

type Outer { label str, middle Middle }
fn Outer @debug_fmt(mut sb StringBuilder) -> () {
    sb.append("Outer { label: \"")
    sb.append(@label)
    sb.append("\", middle: ")
    @middle.debug_fmt(sb)
    sb.append(" }")
}

test "3-level nested struct debug" {
    ro o = Outer { label: "top", middle: Middle { id: 7, inner: Inner { v: 42 } } }
    ro s = "${o:?}"
    assert(s == "Outer { label: \"top\", middle: Middle { id: 7, inner: Inner { v: 42 } } }")
}
