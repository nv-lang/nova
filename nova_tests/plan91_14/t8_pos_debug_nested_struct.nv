// Plan 91.14 Р¤.6 POS T8 вЂ” nested struct debug.
//
// Verify recursive @debug invocation вЂ” outer Container calls
// inner Point's @debug via manual impl.

module plan91_14.t8_pos_debug_nested_struct

type Point {
    x int
    y int
}

fn Point @debug(mut sb StringBuilder) -> () {
    sb.append("Point { x: ")
    sb.append(str.from(@x))
    sb.append(", y: ")
    sb.append(str.from(@y))
    sb.append(" }")
}

type Container {
    label str
    origin Point
}

fn Container @debug(mut sb StringBuilder) -> () {
    sb.append("Container { label: \"")
    sb.append(@label)
    sb.append("\", origin: ")
    @origin.debug_fmt(sb)
    sb.append(" }")
}

test "nested struct debug recursion" {
    ro c = Container { label: "main", origin: Point { x: 10, y: 20 } }
    ro s = "${c:?}"
    assert(s == "Container { label: \"main\", origin: Point { x: 10, y: 20 } }")
}
