// Plan 91.14 Ph.6 POS T8 - nested struct debug.
//
// Verify recursive @debug invocation - outer Container calls
// inner Point's @debug via manual impl.
// Plan 152.7.1 (D258 AMEND): migrated sb StringBuilder -> w Write, debug_fmt -> debug.

module plan91_14.t8_pos_debug_nested_struct

type Point {
    x int
    y int
}

fn Point @debug(mut w Write) -> () {
    w.write("Point { x: ")
    w.write(str.from(@x))
    w.write(", y: ")
    w.write(str.from(@y))
    w.write(" }")
}

type Container {
    label str
    origin Point
}

fn Container @debug(mut w Write) -> () {
    w.write("Container { label: \"")
    w.write(@label)
    w.write("\", origin: ")
    @origin.debug(w)
    w.write(" }")
}

test "nested struct debug recursion" {
    ro c = Container { label: "main", origin: Point { x: 10, y: 20 } }
    ro s = "${c:?}"
    assert(s == "Container { label: \"main\", origin: Point { x: 10, y: 20 } }")
}
