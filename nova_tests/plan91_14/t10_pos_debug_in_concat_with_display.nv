// Plan 91.14 Р¤.6 POS T10 вЂ” mixed ${x} (Display) Рё ${x:?} (Debug)
// РІ РѕРґРЅРѕР№ interp-string.
//
// Per D229: spec routes independently per-part. `"${x} vs ${x:?}"` РґР»СЏ str
// РІС‹РґР°С‘С‚ `hello vs "hello"` вЂ” display + debug side-by-side.

module plan91_14.t10_pos_debug_in_concat_with_display

test "mixed display + debug in same interp" {
    ro hi = "world"
    ro s = "say ${hi} or ${hi:?}"
    assert(s == "say world or \"world\"")
}

test "int mixed" {
    ro n = 42
    ro s = "${n} vs ${n:?}"
    // int display Рё debug СЃРѕРІРїР°РґР°СЋС‚
    assert(s == "42 vs 42")
}
