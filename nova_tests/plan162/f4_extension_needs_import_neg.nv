// EXPECT_COMPILE_ERROR E_EXTENSION_METHOD_NEEDS_IMPORT
//
// Plan 162 Ф.5: negative — calling an extension method without importing
// the module that defines it must emit E_EXTENSION_METHOD_NEEDS_IMPORT.
//
// plan162_proxy imports both plan162_ext_type (Widget type) AND
// plan162_ext_methods (extension @doubled()). By importing only
// plan162_proxy here, @doubled() is in the method_table (merged
// transitively), but plan162_ext_methods is NOT a direct import.
// Therefore w.doubled() must be rejected with E_EXTENSION_METHOD_NEEDS_IMPORT.

module plan162.f4_extension_needs_import_neg

import nova_tests.plan162.plan162_proxy.{Widget}

fn check(w Widget) -> int => w.doubled()
