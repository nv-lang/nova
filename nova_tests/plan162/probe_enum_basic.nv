module plan162.probe_enum_basic
import std.prelude.collections.{Next}

fn[I Next[T]] I mut @enumerate_probe() -> Option[(int, T)] {
    match @next() {
        Some(x) => Some((0, x)),
        None => None,
    }
}

test "tuple parametric return in blanket method" {
    ro v = Vec[int].of(10, 20, 30)
    mut it = v.iter()
    ro r = it.enumerate_probe()
    assert(r == Some((0, 10)))
}
