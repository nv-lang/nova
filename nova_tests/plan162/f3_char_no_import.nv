// Plan 162 Ф.4: char Unicode-aware methods without `import std.unicode`.
// After moving char @methods to std/prelude/core.nv, they are part of the
// prelude and available to every module without an explicit import.
// This test verifies that `'A'.is_alphabetic()` and non-ASCII `'Ω'.is_alphabetic()`
// work without any `import std.unicode` statement.
// EXPECT_STDOUT char no-import ok

module plan162.f3_char_no_import

fn main() {
    // ASCII alphabetic — 'A' (U+0041)
    ro x = 'A'
    // Non-ASCII alphabetic — GREEK CAPITAL OMEGA 'Ω' (U+03A9)
    ro y = 'Ω'
    if x.is_alphabetic() && y.is_alphabetic() {
        println("char no-import ok")
    } else {
        println("FAIL")
    }
}
