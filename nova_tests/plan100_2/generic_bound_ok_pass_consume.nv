// Plan 100.2 (D156): передача T в consume-param внутри generic-body.
//
// `delegate[T consume]` receives consume x T and passes to `finish1(consume t
// Transaction12)`. Since `finish1` has param[0] as consume, x is consumed
// through the call. Demonstrates consume tracking inside generic body.

module nova_tests.plan100_2

type Transaction12 consume {
    id int,
}
fn Transaction12 consume @commit() -> () { () }

fn begin3() -> Transaction12 => { id: 3 }

// External concrete consume-param function.
fn finish1(consume t Transaction12) -> () {
    t.commit()
}

// Generic body: passes x through consume-param — obligation satisfied.
fn delegate[T consume](consume x T) -> () {
    finish1(x)                                   // x consumed via finish1's consume-param
}

test "pass consume param within generic body" {
    consume tx = begin3()
    // delegate has consume-param[0] → tx consumed at call.
    delegate(tx)
}
