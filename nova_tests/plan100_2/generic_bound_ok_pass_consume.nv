// Plan 100.2 (D156): передача T в consume-param внутри generic-body.
//
// `delegate[T consume]` receives consume x T and passes to `finish(consume t
// Transaction)`. Since `finish` has param[0] as consume, x is consumed
// through the call. Demonstrates consume tracking inside generic body.

module nova_tests.plan100_2.generic_bound_ok_pass_consume

type Transaction consume {
    id int,
}
fn Transaction consume @commit() -> () { () }

fn begin() -> Transaction => { id: 3 }

// External concrete consume-param function.
fn finish(consume t Transaction) -> () {
    t.commit()
}

// Generic body: passes x through consume-param — obligation satisfied.
fn delegate[T consume](consume x T) -> () {
    finish(x)                                   // x consumed via finish's consume-param
}

test "pass consume param within generic body" {
    consume tx = begin()
    // delegate has consume-param[0] → tx consumed at call.
    delegate(tx)
}
