// EXPECT_COMPILE_ERROR D156-iter-maybe-consumed
//
// Plan 100.2 (D156): for-loop iteration body — каждый tx обязан Consumed.
// Branch только на одной ветке (no else) → MaybeConsumed на arm exit → error.

module plan100_2.for_consume_err_branch_forget

type Transaction consume {
    id int,
}
fn Transaction consume @commit() -> () { () }

test "for + branch только на then — каждая iteration теряет tx" {
    ro txs = [Transaction { id: 1 }, Transaction { id: 2 }]
    ro condition = true
    for consume tx in txs {
        if condition {
            tx.commit()
            // then: tx Consumed
        }
        // else (implicit): tx Live
        // ОШИБКА D156-iter-maybe-consumed: tx MaybeConsumed на arm-exit.
    }
}
