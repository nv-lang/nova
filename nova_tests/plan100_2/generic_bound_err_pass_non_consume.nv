// EXPECT_COMPILE_ERROR D156-strict-forget
//
// Plan 100.2 (D156) + Plan 100.3 (D157): передача T (consume-obligation) в
// view-param fn внутри [T consume] generic-body — view-borrow разрешён (D157),
// но x всё равно НЕ consumed при выходе из fn → D156-strict-forget.
//
// D157: `log_tx(x)` — view-borrow. x остаётся Live.
// D156-strict-forget: x — consume-obligation (от [T consume] bound + `consume x T`).
// На exit'е функции x Live → D156-strict-forget error (generic-consume obligation).

module nova_tests.plan100_2.generic_bound_err_pass_non_consume

type Transaction consume {
    id int,
}
fn Transaction consume @commit() -> () { () }

// View-param (D157): non-consume param of consume type — read-only borrow.
fn log_tx(t Transaction) -> () { () }

// ❌ x is consume-obligation (via [T consume] bound); log_tx does view-borrow (D157 — OK).
// But x remains Live at exit → D156-strict-forget.
fn log_generic[T consume](consume x T) -> () {
    log_tx(x)                                   // view-borrow OK (D157)
    // ОШИБКА D156-strict-forget: x — consume-obligation (generic bound), не consumed.
}

test "generic consume-param view-borrowed but not consumed — D156-strict-forget" {
    consume tx = Transaction { id: 5 }
    log_generic(tx)
}
