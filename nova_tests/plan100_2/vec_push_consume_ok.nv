// Plan 100.2 (D156): consume iteration over inline-constructed array —
// demonstrates that `for consume tx in vec` correctly consumes each element.
//
// Inline Transaction19 literals avoid named consume-obligations outside loop.
// After for-consume: txs is Consumed (pragmatic D156 marking).

module nova_tests.plan100_2

type Transaction19 consume {
    id int,
}
fn Transaction19 consume @commit() -> () { () }
fn Transaction19 consume @rollback() -> () { () }

test "for consume — inline array, каждый element consume'ится" {
    // Inline literals: no named consume-bindings before the loop.
    ro txs = [Transaction19 { id: 1 }, Transaction19 { id: 2 }, Transaction19 { id: 3 }]
    for consume tx in txs {
        tx.commit()                             // consume obligation satisfied ✅
    }
    // txs Consumed after for (pragmatic — even with early break, D156).
}
