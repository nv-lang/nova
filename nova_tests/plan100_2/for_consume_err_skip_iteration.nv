// EXPECT_COMPILE_ERROR D156-iter-not-consumed
//
// Plan 100.2 (D156): `for consume tx in vec` — arm body does NOT consume tx.
// Accessing a field without calling a consume method → tx stays Live → error.

module nova_tests.plan100_2.for_consume_err_skip_iteration

type Transaction consume {
    id int,
}
fn Transaction consume @commit() -> () { () }

test "for consume — skip consume in arm → D156-iter-not-consumed" {
    ro txs = [Transaction { id: 1 }, Transaction { id: 2 }]
    for consume tx in txs {
        // Read tx.id but do NOT call any consume method.
        // ОШИБКА D156-iter-not-consumed: tx is Live on arm exit.
    }
}
