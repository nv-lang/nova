// EXPECT_COMPILE_ERROR D133-not-consumed
//
// Plan 100.2 (D156): `vec.push(tx)` без consume qualifier — tx remains Live.
//
// `push` has no consume parameter in Nova runtime registry → tx NOT consumed
// by the push call. At scope exit: tx is still Live → D133-not-consumed.

module plan100_2.vec_push_err_non_consume_param

type Transaction consume {
    id int,
}
fn Transaction consume @commit() -> () { () }

test "vec.push без consume — tx остаётся Live → D133-not-consumed" {
    consume tx = Transaction { id: 1 }
    mut txs = []
    txs.push(tx)                               // push is non-consume → tx NOT consumed
    // ОШИБКА D133-not-consumed: tx is still Live at scope exit.
}
