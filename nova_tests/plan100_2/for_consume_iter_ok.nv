// Plan 100.2 (D156): `for consume tx in []Transaction5` — consume iteration.
//
// Каждый element tx в arm-теле обязан consumed (consume-obligation).
// После for — vec considered Consumed (pragmatic: `for consume` marks iter).
// Uses inline Transaction5 literals (не consume-let) — no loose obligations.

module nova_tests.plan100_2

type Transaction5 consume {
    id int,
}
fn Transaction5 consume @commit() -> () { () }

test "for consume tx in vec — каждый element consume'ится в arm'е" {
    // Inline literals → no named consume-obligations outside loop.
    ro txs = [Transaction5 { id: 1 }, Transaction5 { id: 2 }, Transaction5 { id: 3 }]
    for consume tx in txs {
        tx.commit()                             // consume obligation satisfied ✅
    }
    // txs Consumed after for (pragmatic — D156) ✅
}
