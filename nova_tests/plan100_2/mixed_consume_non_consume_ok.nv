// Plan 100.2 (D156): backward-compat — generic без `[T consume]` bound
// продолжает работать как раньше (silent-ignore).
//
// `fn drop[T](x T) -> ()` — без bound, silent-ignore. При T=int
// валидно (int не consume). Это документирует backward-compat policy.

module plan100_2.mixed_consume_non_consume_ok

// Generic без bound — silent-ignore mode (Plan 100.1 default).
// При T=int (не consume) — forget валиден.
fn drop[T](x T) -> () { () }

test "generic без bound + T=int — silent-ignore работает" {
    drop(42)                                    // ✅ int не consume, forget OK
    drop(true)
    drop("hello")
}
