// Plan 100.2 (D156): identity-функция с strict consume bound.
//
// `fn id_consume[T consume](consume x T) -> T => x` — FnBody::Expr trailing
// ident satisfies consume-obligation of x. Return value discarded by caller
// (no `consume` let-binding on call site → no caller obligation).

module nova_tests.plan100_2

type Transaction10 consume {
    id int,
}
fn Transaction10 consume @commit() -> () { () }

fn begin2() -> Transaction10 => { id: 42 }

// Identity: x returned as trailing FnBody::Expr ident — obligation satisfied.
fn id_consume[T consume](consume x T) -> T => x

test "identity with consume bound — FnBody::Expr form" {
    consume tx = begin2()
    // id_consume has consume-param[0] → tx marked consumed at call.
    // Return value discarded (no `consume` let → no obligation for caller).
    id_consume(tx)
}
