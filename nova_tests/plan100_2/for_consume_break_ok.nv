// Plan 100.2 (D156): for + early break — обе ветки arm body должны
// consume tx (Consumed на любом arm-exit).
// Uses inline Transaction3 literals to avoid loose consume-obligations.

module nova_tests.plan100_2

type Transaction3 consume {
    id int,
}
fn Transaction3 consume @commit() -> () { () }
fn Transaction3 consume @rollback() -> () { () }

test "for + break — обе arm-ветки consume" {
    ro txs = [Transaction3 { id: 1 }, Transaction3 { id: 2 }, Transaction3 { id: 3 }]
    for consume tx in txs {
        if tx.id == 2 {
            tx.commit()
            break                                // arm consume + break OK ✅
        } else {
            tx.rollback()                       // arm consume (else path) ✅
        }
    }
    // После for — vec considered Consumed (D156 pragmatic).
}
