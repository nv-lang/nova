// Plan 100.4.1 (D158): MultiError prelude type — caller inspects via
// .primary() / .suppressed() API. Runtime composite materialize —
// partial в bootstrap (chain пустой пока emit_defer wrap не done);
// этот тест verify-it только type-checker level.

module nova_tests.plan100_4_1.multi_error_inspect_ok

// Construct MultiError directly — verify prelude type экспортирован и
// accessors callable.
fn make_composite() -> MultiError =>
    { primary: "operation failed", suppressed: ["cleanup1 failed", "cleanup2 failed"] }

test "MultiError API: .primary() / .suppressed() — compile + runtime" {
    ro e = make_composite()
    ro p = e.primary()
    assert(p == "operation failed")
    ro chain = e.suppressed()
    assert(chain.len() == 2)
}
