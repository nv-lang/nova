// Plan 100.4.1 (D158): errdefer fail во время propagation — compile pass.
// Runtime composite chain — Plan 100.4.4 followup.

module nova_tests.plan100_4_1.errdefer_fail_ok_propagation

type WorkErr { msg str }
type RollbackErr { msg str }

fn rollback() Fail[RollbackErr] -> () { () }

fn process() Fail -> () {
    errdefer { rollback() }                     // failable cleanup (D158)
    throw WorkErr { msg: "primary work failed" }
}

test "errdefer fail composes с primary — compile pass" {
    with Fail = effect Fail { fail(_msg) { interrupt () } } {
        process()
    }
}
