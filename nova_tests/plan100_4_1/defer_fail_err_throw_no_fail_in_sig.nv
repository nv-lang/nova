module plan100_4_1.defer_fail_err_throw_no_fail_in_sig

type Err { msg str }

// ❌ fn-sig без Fail.
fn process() -> () {
    defer {
        throw Err { msg: "cleanup-fail" }       // D158: throw requires Fail в enclosing sig
    }
}

test "throw в defer body без Fail в sig — D158 error" {
    process()
}
