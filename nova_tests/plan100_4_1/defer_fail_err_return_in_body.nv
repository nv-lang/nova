// unchanged by D158).

module plan100_4_1.defer_fail_err_return_in_body

fn process() -> int {
    defer {
        return 42                               // ❌ D90 §6 — top-level return hijacks scope exit
    }
    100
}

test "return в defer body — D90 §6 error (unchanged by D158)" {
    process()
}
