// Plan 100.4.1 (D158): `?` operator в defer body — разрешён если
// enclosing fn-sig declares Fail[E].

module nova_tests.plan100_4_1

type CommitErr3 { msg str }

fn commit4() Fail[CommitErr3] -> () { () }

fn process5() Fail[CommitErr3] -> () {
    defer { commit4()? }                         // ? operator в defer body (D158)
}

test "?-operator in defer body — D158 compile pass" {
    process5()
}
