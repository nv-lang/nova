// EXPECT_COMPILE_ERROR D158
//
// Plan 100.4.1 (D158): `?` operator в defer body без Fail[E] в fn-sig —
// compile error.

module plan100_4_1.defer_fail_err_try_no_fail_in_sig

type Err { msg str }

fn cleanup() Fail[Err] -> () { () }

// ❌ fn-sig без Fail.
fn process() -> () {
    defer { cleanup()? }                        // D158: ? requires Fail в enclosing sig
}

test "?-operator в defer body без Fail в sig — D158 error" {
    process()
}
