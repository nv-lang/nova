// Plan 100.4.1 (D158): defer-fail во время error-propagation — compile
// pass. Runtime composite chain — partial в bootstrap (Plan 100.4.4
// followup для full composite materialize'а).

module nova_tests.plan100_4_1

type WorkErr { msg str }
type CommitErr1 { msg str }

fn commit1() Fail[CommitErr1] -> () { () }

fn do_work_that_fails() Fail[WorkErr] -> () {
    throw WorkErr { msg: "operation failed" }
}

// fn-sig объявляет generic Fail (union для WorkErr | CommitErr1).
fn process1() Fail -> () {
    defer { commit1() }                          // failable cleanup (D158)
    do_work_that_fails()?                        // throws WorkErr
}

test "do_work fails + failable-defer compile pass" {
    with Fail = effect Fail { fail(_msg) { interrupt () } } {
        process1()
    }
}
