// Plan 103.5 — OnceCell.get_or_init is banned inside realtime{}.
//
// Plan 103.6: error code changed from E_EFFECT_REALTIME_VIOLATION to E_REALTIME_SYNC_PARK.
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_5.oncecell_in_realtime_neg

test "OnceCell.get_or_init banned in realtime block" {
    let cell = OnceCell[int].new()
    realtime {
        let _ = cell.get_or_init() { 42 }
    }
}
