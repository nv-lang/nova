// Plan 103.5 — OnceCell.get_or_init is banned inside #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module nova_tests.plan103_5.oncecell_in_realtime_neg

#realtime fn _rt_check_oncecell_get_or_init(cell mut OnceCell[int]) -> int {
    cell.get_or_init() { 42 }
}

test "OnceCell.get_or_init banned in #realtime fn" {
    let mut cell = OnceCell[int].new()
    let _ = _rt_check_oncecell_get_or_init(cell)
}
