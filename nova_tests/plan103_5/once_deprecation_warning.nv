// Plan 103.5 — Once.run()/done() deprecated; emits W_ONCE_RUN_DONE_DEPRECATED.
//
// EXPECT_COMPILE_WARNING W_ONCE_RUN_DONE_DEPRECATED
//
// Runtime behavior: deprecated API still works (backward compat).

module plan103_5.once_deprecation_warning

// EXPECT_COMPILE_WARNING W_ONCE_RUN_DONE_DEPRECATED

test "Once: deprecated run/done still works (backward compat)" {
    mut once = Once.new()
    mut count = 0
    if once.run() {
        count = count + 1
        once.done()
    }
    assert(count == 1)
}
