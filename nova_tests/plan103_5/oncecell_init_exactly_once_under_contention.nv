// Plan 103.5 — Property: OnceCell.get_or_init executes init exactly once
// under high contention (32 fibers competing).

module plan103_5.oncecell_init_exactly_once_under_contention

test "OnceCell.get_or_init: init runs exactly once across 32 concurrent fibers" {
    mut cell = OnceCell[int].new()
    mut init_count = AtomicInt.new(0)

    parallel for _i in 0..32 {
        ro v = cell.get_or_init() {
            init_count.fetch_add(1)
            777
        }
        assert(v == 777)
    }

    assert(init_count.load() == 1)
    // value is stable after all fibers done
    ro v2 = cell.get_or_init() { 999 }
    assert(v2 == 777)
}

test "OnceCell.get_or_init: all 32 fibers observe the same value" {
    mut cell = OnceCell[int].new()
    mut mismatches = AtomicInt.new(0)

    parallel for _i in 0..32 {
        ro v = cell.get_or_init() { 42 }
        if v != 42 {
            mismatches.fetch_add(1)
        }
    }

    assert(mismatches.load() == 0)
}
