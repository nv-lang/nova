// Plan 103.5 — Once.call_once: exactly-once execution across 5 concurrent fibers.
//
// 5 fibers all call call_once concurrently. The init body should execute exactly
// once. Counter must equal 1 after all fibers complete.

module plan103_5.once_call_once_exactly_once

test "Once.call_once: init body executes exactly once across 5 concurrent fibers" {
    mut once = Once.new()
    mut counter = AtomicInt.new(0)

    parallel for _i in 0..5 {
        once.call_once() { counter.fetch_add(1) }
    }

    assert(counter.load() == 1)
}

test "Once.call_once: no-op on subsequent calls after init" {
    mut once = Once.new()
    mut ran = 0

    once.call_once() { ran = ran + 1 }
    once.call_once() { ran = ran + 100 }  // should not run
    once.call_once() { ran = ran + 100 }  // should not run

    assert(ran == 1)
}

test "Once.call_once: is_completed returns true after successful call" {
    mut once = Once.new()
    assert(once.is_completed() == false)
    once.call_once() { () }
    assert(once.is_completed() == true)
}
