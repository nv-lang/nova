// Plan 103.5 — OnceCell[T].get_or_init: exactly-once initialization across 5 fibers.

module nova_tests.plan103_5.oncecell_get_or_init_exactly_once

test "OnceCell.get_or_init: init runs exactly once across 5 concurrent fibers" {
    let cell = OnceCell[int].new()
    let init_count = AtomicInt.new(0)

    supervised {
        spawn {
            let v = cell.get_or_init() {
                init_count.fetch_add(1)
                42
            }
            assert(v == 42)
        }
        spawn {
            let v = cell.get_or_init() {
                init_count.fetch_add(1)
                42
            }
            assert(v == 42)
        }
        spawn {
            let v = cell.get_or_init() {
                init_count.fetch_add(1)
                42
            }
            assert(v == 42)
        }
        spawn {
            let v = cell.get_or_init() {
                init_count.fetch_add(1)
                42
            }
            assert(v == 42)
        }
        spawn {
            let v = cell.get_or_init() {
                init_count.fetch_add(1)
                42
            }
            assert(v == 42)
        }
    }

    assert(init_count.load() == 1)
    let v = cell.get_or_init() { 99 }
    assert(v == 42)  // cached
}
