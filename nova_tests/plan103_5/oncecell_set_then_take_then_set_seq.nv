// Plan 103.5 — OnceCell: set → take → set sequence (boundary-case positive).
//
// Verifies that take() resets cell to empty and set() works again.

module nova_tests.plan103_5.oncecell_set_then_take_then_set_seq

test "OnceCell: set(a) take() set(b) get() == Some(b)" {
    mut cell = OnceCell[int].new()

    ro r1 = cell.set(100)
    assert(r1 == true)

    ro taken = cell.take()
    assert(match taken { Some(x) => x == 100, None => false })

    ro r2 = cell.set(200)
    assert(r2 == true)   // after take(), cell is empty again

    ro v = cell.get()
    assert(match v { Some(x) => x == 200, None => false })
}
