// Plan 103.5 — Property: Lazy.force executes init closure exactly once.
//
// Sequential property tests; concurrent Lazy stress is in once_stress_mn_4workers
// (Lazy test block: 16 fibers × 100 force() calls passes there).

module nova_tests.plan103_5.lazy_no_double_init_prop

test "Lazy.force: init runs exactly once across N sequential calls" {
    mut init_count = AtomicInt.new(0)
    ro lazy = Lazy[int].new() {
        init_count.fetch_add(1)
        555
    }

    // 100 sequential force() calls — init must run exactly once
    for _i in 0..100 {
        ro v = lazy.force()
        assert(v == 555)
    }

    assert(init_count.load() == 1)
    assert(lazy.is_forced() == true)
}

test "Lazy.force: all callers observe the same value regardless of call order" {
    ro lazy = Lazy[int].new() { 123 }

    ro v1 = lazy.force()
    ro v2 = lazy.force()
    ro v3 = lazy.force()

    assert(v1 == 123)
    assert(v2 == 123)
    assert(v3 == 123)
}
