// Plan 103.5 — Once.is_completed(): observability transitions.

module plan103_5.once_is_completed_observable

test "Once.is_completed: false initially, true after call_once" {
    mut once = Once.new()
    assert(once.is_completed() == false)
    once.call_once() { () }
    assert(once.is_completed() == true)
}

test "Once.state: transitions Fresh → Done" {
    mut once = Once.new()
    ro s0 = once.state()
    assert(match s0 { OnceState.Fresh => true, _ => false })
    once.call_once() { () }
    ro s1 = once.state()
    assert(match s1 { OnceState.Done => true, _ => false })
}

test "Once.is_completed: returns false while still fresh" {
    mut once = Once.new()
    assert(once.is_completed() == false)
    // Call it — now it should be true
    once.call_once() { () }
    assert(once.is_completed() == true)
    // Second call — still true
    once.call_once() { () }
    assert(once.is_completed() == true)
}
