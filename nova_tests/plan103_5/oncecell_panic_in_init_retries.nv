// Plan 103.5 — OnceCell[T]: panic in init closure keeps cell empty; retry works.
//
// Unlike Once.call_once (which poisons), OnceCell.get_or_init allows retry
// if the init closure panics.

module plan103_5.oncecell_panic_in_init_retries

test "OnceCell.get_or_init: panic in init keeps cell empty; retry succeeds" {
    mut cell = OnceCell[int].new()

    // First attempt: init panics
    mut first_panicked = false
    with Fail = effect Fail {
        fail(_msg) { first_panicked = true; interrupt () }
    } {
        ro _ = cell.get_or_init() { throw "init-failed"; 0 }
    }
    assert(first_panicked == true)
    // Cell must still be empty
    assert(cell.is_initialized() == false)

    // Second attempt: succeeds
    ro v = cell.get_or_init() { 42 }
    assert(v == 42)
    assert(cell.is_initialized() == true)
}
