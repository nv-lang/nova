// Plan 103.5 — Lazy.force is banned inside #realtime fn.
// Plan 113 migration: realtime { } → #realtime fn.
//
// EXPECT_COMPILE_ERROR E_REALTIME_SYNC_PARK

module plan103_5.lazy_in_realtime_neg

#realtime fn _rt_check_lazy_force(lazy mut Lazy[int]) -> int {
    lazy.force()
}

test "Lazy.force banned in #realtime fn" {
    ro lazy = Lazy[int].new() { 42 }
    ro _ = _rt_check_lazy_force(lazy)
}
