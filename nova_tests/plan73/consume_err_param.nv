// EXPECT_COMPILE_ERROR D131
//
// Plan 73 (D131): use-after-consume через consume-параметр.
// После передачи переменной в `consume`-параметр она недоступна.

module plan73.consume_err_param

type Token { val int }

fn Token.new(v int) -> Token => { val: v }

fn consume_it(consume t Token) -> int => t.val

test "use after consume-param — отвергается" {
    ro tok = Token.new(3)
    ro a = consume_it(tok)
    // ОШИБКА D131: tok потреблён передачей в consume-параметр выше.
    ro b = consume_it(tok)
    assert(a + b == 6)
}
