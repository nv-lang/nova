// Plan 73 followup: реассайн развязывает alias-класс — НЕ false positive.
//
// `twin = sb`, затем `sb` переназначается на новый объект. consume
// `twin` (старый объект) и `sb` (новый объект) — независимы, ошибки нет.

module nova_tests.plan73.consume_ok_reassign

test "реассайн aliased-переменной — alias корректно развязан" {
    let mut sb = StringBuilder.new()
    sb.append("first")
    let twin = sb                  // twin — алиас sb (старый объект)
    sb = StringBuilder.new()       // sb → новый объект; alias развязан
    sb.append("second")
    let a = twin.as_str()            // consume старого объекта через twin
    let b = sb.as_str()              // consume нового объекта — НЕ ошибка
    assert(a == "first")
    assert(b == "second")
}
