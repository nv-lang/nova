// Plan 73 (D131): user-defined consume — метод и параметр.
//
// `fn Token19 consume @release()` — consuming receiver.
// `fn drain(consume t Token19)` — consuming параметр.

module nova_tests.plan73

type Token19 { val int }

fn Token19.new(v int) -> Token19 => { val: v }

// consume-метод: после @release() Token19 недоступен.
fn Token19 consume @release() -> int => @val

// consume-параметр: после drain(t) переменная-источник недоступна.
fn drain(consume t Token19) -> int => t.release()

test "user consume-метод — release потребляет Token19" {
    ro tok = Token19.new(7)
    ro v = tok.release()
    // tok после release() не используется — ok.
    assert(v == 7)
}

test "user consume-параметр — drain потребляет аргумент" {
    ro tok = Token19.new(9)
    ro v = drain(tok)
    // tok после drain(tok) не используется — ok.
    assert(v == 9)
}
