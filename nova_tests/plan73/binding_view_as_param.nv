// Plan 73.1 (D180): view как parameter (D157 carry-over).
// Function принимает view-borrow consume-type; owner остаётся Live.

module nova_tests.plan73

type Token16 consume { val int }

fn Token16.new(v int) -> Token16 => { val: v }

fn Token16 consume @release() -> int => @val

// Параметр без `consume` — view-borrow (D157).
fn read_val(t Token16) -> int => t.val

test "view-param сохраняет ownership у caller'а" {
    consume tok = Token16.new(42)
    ro r1 = read_val(tok)        // view-borrow
    ro r2 = read_val(tok)        // view-borrow again — tok всё ещё Live
    ro consumed = tok.release()  // consume в конце scope
    assert(r1 == 42)
    assert(r2 == 42)
    assert(consumed == 42)
}
