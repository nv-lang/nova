// Plan 73.1 (D180): consume binding simple positive case.
// `consume X = Type.new()` где Type — consume-type; X owns; X consumes via метод.

module nova_tests.plan73

type Token10 consume { val int }

fn Token10.new(v int) -> Token10 => { val: v }

fn Token10 consume @release() -> int => @val

test "consume binding + consume method release" {
    consume tok = Token10.new(7)
    ro v = tok.release()
    assert(v == 7)
}
