// Plan 73.1 (D180): E_CONSUME_KEYWORD_MISSING — let X = ctor() где X consume.

// EXPECT_COMPILE_ERROR E_CONSUME_KEYWORD_MISSING

module plan73.binding_let_consume_obligated_ctor_neg

type Token consume { val int }

fn Token.new(v int) -> Token => { val: v }

fn Token consume @release() -> int => @val

test "let X = ctor consume-type → E_CONSUME_KEYWORD_MISSING" {
    ro tok = Token.new(1)         // ОШИБКА D180 Rule 1
    ro v = tok.release()
    assert(v == 1)
}
