// EXPECT_COMPILE_ERROR E_VIEW_BINDING_FORBIDDEN
//
// Plan 73 followup: use-after-consume через alias.
// Plan 73.1 V3: D180 Rule 2 catches alias `let twin = sb` syntactically
// (E_VIEW_BINDING_FORBIDDEN) — dangling-view impossible by construction.
// Previously this fixture relied on D131-use-after-consume firing later;
// V3 cross-module enforcement detects alias-binding earlier.

module nova_tests.plan73.consume_err_alias

test "use after consume через alias" {
    consume sb = StringBuilder.new()
    sb.append("hi")
    ro twin = sb              // ОШИБКА E_VIEW_BINDING_FORBIDDEN: alias на consume-var
    ro s = twin.as_str()
    sb.append("oops")
    assert(s == "hi")
}
