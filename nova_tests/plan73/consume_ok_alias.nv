// Plan 73 + 73.1 (D180): move-semantics — позитивный случай.
//
// Старый pattern `let view = sb` (alias) теперь запрещён D180
// (E_VIEW_BINDING_FORBIDDEN). Эквивалент с move: `consume view = sb`
// transfers ownership; sb становится dead, view — owner; consume через view.

module plan73.consume_ok_alias

fn build_via_move() -> str {
    consume sb = make_sb()
    consume moved = sb              // move (Rule 3 D180); sb dead
    moved.as_str()                   // consume через moved
}

fn make_sb() -> StringBuilder {
    consume sb = StringBuilder.new()
    sb.append("from-factory")
    sb                              // implicit fluent return (Plan 77 D132)
}

test "move-semantics + factory-return — корректный consume" {
    assert(build_via_move() == "from-factory")
}
