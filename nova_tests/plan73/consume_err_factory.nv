// EXPECT_COMPILE_ERROR D131
//
// Plan 73 followup: тип переменной выводится из return-типа свободной
// функции (`let sb = make_builder()`), не только из явного конструктора —
// поэтому consume-метод `into()` корректно распознаётся.

module nova_tests.plan73.consume_err_factory

fn make_builder() -> StringBuilder => StringBuilder.new()

test "use after consume — тип из return-типа функции" {
    ro sb = make_builder()
    ro s = sb.as_str()
    sb.append("oops")          // ОШИБКА D131: sb потреблён @into()
    assert(s == "")
}
