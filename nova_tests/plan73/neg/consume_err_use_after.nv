// EXPECT_COMPILE_ERROR D131
//
// Plan 73 (D131): use-after-consume — использование StringBuilder
// после consume-метода `@into()` должно давать compile error.

module neg.consume_err_use_after

test "use after into — отвергается" {
    consume sb = StringBuilder.new()
    sb.append("hi")
    ro s = sb.into_str()
    // ОШИБКА D131: sb потреблён вызовом @into() выше.
    sb.append("oops")
    assert(s == "hi")
}
