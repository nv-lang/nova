// Plan 73 (D131): consume-qualifier — позитивный базовый случай.
//
// `StringBuilder consume @into()` — после @into() переменная не
// используется → ошибки нет, программа компилируется и работает.

module plan73.consume_ok_basic

test "StringBuilder.into — consume без последующего использования" {
    consume sb = StringBuilder.new()
    sb.append("hi")
    sb.append(" there")
    ro s = sb.as_str()
    // sb после @into() НЕ используется — D131 не нарушен.
    assert(s == "hi there")
}

test "into сразу после new — пустой буфер" {
    consume sb = StringBuilder.new()
    ro s = sb.as_str()
    assert(s == "")
}
