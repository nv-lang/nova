// Plan 70.3 — negative: char literal в Option[int] slot.
//
// Зеркало f3: char-литерал `Some('a')` производит `NovaOpt_nova_char`;
// присваивание в `Option[int]`-переменную — incompatible struct types
// → clang отвергает. Подтверждает что distinction симметричен (оба
// направления collapse предотвращены).
//
// Параллель Rust: `let i: Option<i64> = Some('a')` — compile error.
//
// EXPECT_CC_ERROR incompatible type

module nova_tests.plan70_3.f4_char_in_int_slot_neg

test "char literal rejected in Option[int] slot" {
    let i Option[int] = Some('a')
    match i {
        Some(n) => assert(n == 97)
        None => assert(false)
    }
}
