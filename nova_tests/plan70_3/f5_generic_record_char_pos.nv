// Plan 70.3 — positive: char distinct в user generic record.
//
// Расширяет f1 (Option) / f2 (array): подтверждает что distinct
// `nova_char` typedef корректно прокидывается в user-defined generic
// type instantiation. `Box[char]` mono'ится в `Nova_Box____nova_char`,
// `Box[int]` — в `Nova_Box____nova_int` — independent C structs.

module plan70_3.f5_generic_record_char_pos

type Box[T] {
    value T
}

fn unwrap_box[T](b Box[T]) -> T => b.value

test "Box[char] holds char field" {
    ro bc Box[char] = { value: 'z' }
    assert(bc.value == 'z')
    assert(unwrap_box(bc) == 'z')
}

test "Box[int] holds int field — distinct mono instance" {
    ro bi Box[int] = { value: 100 }
    assert(bi.value == 100)
    assert(unwrap_box(bi) == 100)
}

test "char + int Box coexist без collapse" {
    ro bc Box[char] = { value: 'A' }
    ro bi Box[int] = { value: 65 }
    // Underlying codepoint совпадает (A = 65), но C-типы distinct.
    assert(bc.value == 'A')
    assert(bi.value == 65)
}
