// Plan 123.2.1 (V2.1, 2026-06-04): loop-body LICM coordination.
// Closes [M-123.1.2-loop-body-licm-coordination].
//
// V1.1 top-level region scanner weights reads inside loop bodies
// by NOVA_FC_LOOP_ITERS (default 8). Semantic preservation
// проверяется: cached path equals uncached.

module plan123_2_1.v2_1_loop_body_weighted_ok

type Counter {
    mut x int
}

fn Counter.new(start int) -> Counter => { x: start }

fn Counter mut @sum_in_loop(n int) -> int {
    mut acc = 0
    mut i = 0
    while i < n {
        acc = acc + @x
        i = i + 1
    }
    acc
}

test "V2.1: loop-body read accumulates correctly" {
    mut c = Counter.new(3)
    ro r = c.sum_in_loop(5)
    // 3 * 5 = 15
    assert(r == 15)
}
