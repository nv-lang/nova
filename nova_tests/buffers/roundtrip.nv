// Plan 85.2 Ф.5 — WriteBuffer → ReadBuffer round-trip для всех типов.
//
// Ключевой тест целостности: write_X → into() → ReadBuffer.from() →
// read_X должен вернуть исходное значение для каждого типа.

module buffers.roundtrip


// ── целые числа ────────────────────────────────────────────────────

test "round-trip byte" {
    mut wb = WriteBuffer.new()
    wb.write_byte(0xA5)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_byte() == 0xA5)
}

test "round-trip i8" {
    mut wb = WriteBuffer.new()
    wb.write_i8(-77)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_i8() == -77)
}

test "round-trip u16 LE и BE" {
    mut wb = WriteBuffer.new()
    wb.write_u16_le(0xBEEF)
    wb.write_u16_be(0xBEEF)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_u16_le() == 0xBEEF)
    assert(rb.read_u16_be() == 0xBEEF)
}

test "round-trip i16 LE и BE — отрицательное" {
    mut wb = WriteBuffer.new()
    wb.write_i16_le(-12345)
    wb.write_i16_be(-12345)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_i16_le() == -12345)
    assert(rb.read_i16_be() == -12345)
}

test "round-trip u32 LE и BE" {
    mut wb = WriteBuffer.new()
    wb.write_u32_le(0xDEADBEEF)
    wb.write_u32_be(0xDEADBEEF)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_u32_le() == 0xDEADBEEF)
    assert(rb.read_u32_be() == 0xDEADBEEF)
}

test "round-trip i32 LE и BE — отрицательное" {
    mut wb = WriteBuffer.new()
    wb.write_i32_le(-1000000)
    wb.write_i32_be(-1000000)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_i32_le() == -1000000)
    assert(rb.read_i32_be() == -1000000)
}

test "round-trip u64 LE и BE" {
    mut wb = WriteBuffer.new()
    wb.write_u64_le(0x0102030405060708)
    wb.write_u64_be(0x0102030405060708)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_u64_le() == 0x0102030405060708)
    assert(rb.read_u64_be() == 0x0102030405060708)
}

test "round-trip i64 BE — отрицательное" {
    mut wb = WriteBuffer.new()
    wb.write_i64_be(-1000000)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_i64_be() == -1000000)
}


// ── float ──────────────────────────────────────────────────────────

test "round-trip f32 LE и BE" {
    mut wb = WriteBuffer.new()
    wb.write_f32_le(0.125)
    wb.write_f32_be(0.125)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f32_le() == 0.125)
    assert(rb.read_f32_be() == 0.125)
}

test "round-trip f64 LE — IEEE 754 bit-perfect" {
    mut wb = WriteBuffer.new()
    wb.write_f64_le(3.14159)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_le() == 3.14159)
}

test "round-trip f64 BE — IEEE 754 bit-perfect" {
    mut wb = WriteBuffer.new()
    wb.write_f64_be(2.71828)
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_be() == 2.71828)
}


// ── char ───────────────────────────────────────────────────────────

test "round-trip char ASCII" {
    mut wb = WriteBuffer.new()
    wb.write_char('Q')
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_char() == 'Q')
}

test "round-trip char Cyrillic" {
    mut wb = WriteBuffer.new()
    wb.write_char('Я')
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_char() == 'Я')
}

test "round-trip char emoji" {
    mut wb = WriteBuffer.new()
    wb.write_char('🎉')
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_char() == '🎉')
}


// ── str ────────────────────────────────────────────────────────────

test "round-trip str ASCII" {
    mut wb = WriteBuffer.new()
    wb.write_str("hello")
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_str(5) == "hello")
}

test "round-trip str Unicode" {
    mut wb = WriteBuffer.new()
    wb.write_str("Привет мир")
    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_str(10) == "Привет мир")
}


// ── bytes ──────────────────────────────────────────────────────────

test "round-trip bytes — write_bytes / read_bytes" {
    ro src []u8 = [0x11, 0x22, 0x33, 0x44]
    mut wb = WriteBuffer.new()
    wb.write_bytes(src)
    mut rb = ReadBuffer.from(wb.into())
    ro got = rb.read_bytes(4)
    assert(got.len() == 4)
    assert(got[0] == 0x11)
    assert(got[3] == 0x44)
}


// ── смешанная гетерогенная запись/чтение ──────────────────────────

test "round-trip гетерогенный пакет" {
    mut wb = WriteBuffer.new()
    wb.write_byte(0x01)
    wb.write_u16_be(0x0203)
    wb.write_i32_le(-42)
    wb.write_f64_le(1.5)
    wb.write_char('Ё')
    wb.write_str("end")

    mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_byte() == 0x01)
    assert(rb.read_u16_be() == 0x0203)
    assert(rb.read_i32_le() == -42)
    assert(rb.read_f64_le() == 1.5)
    assert(rb.read_char() == 'Ё')
    assert(rb.read_str(3) == "end")
    assert(rb.remaining() == 0)
}
