// Plan 85.2 Ф.4 — WriteBuffer запись float (IEEE 754).
//
// write_f32_le/be, write_f64_le/be — 4 метода. Проверка длины
// записанного и round-trip через ReadBuffer (Fail-form read).

module buffers.write_floats


// ── длина записи ───────────────────────────────────────────────────

test "write_f32_le — 4 байта" {
    let mut wb = WriteBuffer.new()
    wb.write_f32_le(1.5)
    assert(wb.len() == 4)
}

test "write_f32_be — 4 байта" {
    let mut wb = WriteBuffer.new()
    wb.write_f32_be(1.5)
    assert(wb.len() == 4)
}

test "write_f64_le — 8 байт" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_le(3.14159)
    assert(wb.len() == 8)
}

test "write_f64_be — 8 байт" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_be(3.14159)
    assert(wb.len() == 8)
}


// ── round-trip через ReadBuffer (Fail-form, IEEE 754 bit-perfect) ──

test "write_f64_le -> read_f64_le round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_le(2.718281828)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_le() == 2.718281828)
}

test "write_f64_be -> read_f64_be round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_be(-0.5)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_be() == -0.5)
}

test "write_f32_le -> read_f32_le round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f32_le(0.25)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f32_le() == 0.25)
}

test "write_f32_be -> read_f32_be round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f32_be(0.5)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f32_be() == 0.5)
}


// ── LE и BE дают разный порядок байт ──────────────────────────────

test "f64 LE и BE — обратный порядок байт" {
    let mut wb_le = WriteBuffer.new()
    wb_le.write_f64_le(1.0)
    let le = wb_le.into()

    let mut wb_be = WriteBuffer.new()
    wb_be.write_f64_be(1.0)
    let be = wb_be.into()

    assert(le.len() == 8)
    assert(be.len() == 8)
    // LE байт[i] == BE байт[7-i]
    assert(le[0] == be[7])
    assert(le[7] == be[0])
}


// ── специальные значения ──────────────────────────────────────────

test "f64 нулевое значение round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_le(0.0)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_le() == 0.0)
}

test "f64 большое значение round-trip" {
    let mut wb = WriteBuffer.new()
    wb.write_f64_be(1234567890.123)
    let mut rb = ReadBuffer.from(wb.into())
    assert(rb.read_f64_be() == 1234567890.123)
}
