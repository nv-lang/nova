// Plan 138.5 POS — the `unsafe T` value-wrapper (§V2.3, MaybeUninit-style)
// is KEPT. It is orthogonal to pointers: it marks a maybe-uninit VALUE, not
// a pointer, so the prefix-pointer ban does not touch it (its modifier chain
// bottoms out at a non-pointer base).

module nova_tests.plan138_5

type Acc2 {
    id i64
}

extern "nova" fn p_unsafe_int(x unsafe int) -> ()
extern "nova" fn p_unsafe_acc(x unsafe Acc2) -> ()

test "unsafe T value-wrapper transparent layout" {
    assert(size_of[unsafe int]() == 8)
    assert(size_of[unsafe u8]() == 1)
    assert(size_of[unsafe Acc2]() == 8)
}
