// Plan 138.5 NEG — prefix `mut *` pointer modifier is forbidden.
//
// Pointer modifiers go on the pointee (`*mut T`) or the binding (`mut x *T`);
// `mut` immediately before `*` in type position is a hard error. Migrate
// `mut * T` → `*mut T`.
//
// EXPECT_COMPILE_ERROR E_POINTER_PREFIX_MODIFIER

module plan138_5.neg_mut_prefix_ptr

// Return position: in a PARAM, a post-name `mut` is eaten as binding-mut
// (D6 legacy form), so we use return position to force the type-position
// `mut *` arm and exercise E_POINTER_PREFIX_MODIFIER.
extern "nova" fn p() -> mut * int
