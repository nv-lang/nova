// Plan 138.5 POS — canonical postfix pointee modifiers compile.
//
// `*T ≡ *ro T` (read-only target — bare `*T` is the canon, explicit `*ro T`
// is a hard error per Plan 147 / D246), `*mut T` (writable target),
// `*unsafe T` (ptr to possibly-uninit pointee). The modifier is on the
// pointee (postfix, after `*`).

module nova_tests.plan138_5

type Acc1 {
    id i64
}

extern "nova" fn p_default(p * Acc1) -> ()
extern "nova" fn p_ro(p *Acc1) -> ()
extern "nova" fn p_mut(p *mut Acc1) -> ()
extern "nova" fn p_unsafe(p *unsafe Acc1) -> ()
extern "nova" fn r_default() -> * Acc1
extern "nova" fn r_mut() -> *mut Acc1

test "postfix pointee modifiers parse + typecheck" {
    assert(size_of[*mut Acc1]() == 8)
    assert(size_of[*Acc1]() == 8)
    assert(size_of[*unsafe Acc1]() == 8)
    assert(size_of[* Acc1]() == 8)
}
