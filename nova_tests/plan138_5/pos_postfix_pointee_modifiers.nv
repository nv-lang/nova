// Plan 138.5 POS — canonical postfix pointee modifiers compile.
//
// `*T ≡ *ro T` (read-only target — bare `*T` is the canon, explicit `*ro T`
// is a hard error per Plan 147 / D246), `*mut T` (writable target),
// `*unsafe T` (ptr to possibly-uninit pointee). The modifier is on the
// pointee (postfix, after `*`).

module plan138_5.pos_postfix_pointee_modifiers

type Acc {
    id i64
}

extern "nova" fn p_default(p * Acc) -> ()
extern "nova" fn p_ro(p *Acc) -> ()
extern "nova" fn p_mut(p *mut Acc) -> ()
extern "nova" fn p_unsafe(p *unsafe Acc) -> ()
extern "nova" fn r_default() -> * Acc
extern "nova" fn r_mut() -> *mut Acc

test "postfix pointee modifiers parse + typecheck" {
    assert(size_of[*mut Acc]() == 8)
    assert(size_of[*Acc]() == 8)
    assert(size_of[*unsafe Acc]() == 8)
    assert(size_of[* Acc]() == 8)
}
