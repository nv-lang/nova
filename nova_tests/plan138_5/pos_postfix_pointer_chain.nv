// Plan 138.5 POS — postfix pointer CHAINS compile (the modifier always sits
// after a `*`, on its pointee level).
//
// `*mut *Node` — writable-target ptr to (read-only-target ptr to Node).
// The ro pointee is the bare canon `*T` (`*T ≡ *ro T` per Plan 147 / D246;
// explicit `*ro T` is a hard error, migrated here).

module plan138_5.pos_postfix_pointer_chain

type Node {
    id i64
}

extern "nova" fn p_chain(x *mut *Node) -> ()
extern "nova" fn p_chain2(x **mut Node) -> ()

test "postfix pointer chains parse + uniform 8-byte layout" {
    assert(size_of[*mut *Node]() == 8)
    assert(size_of[**mut Node]() == 8)
    assert(size_of[* * Node]() == 8)
}
