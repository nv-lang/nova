// Plan 153.x [M-154.1-chained-vec-f32-method-misdispatch]: chained
// `Vec[f32].new().debug(a)` / `.from([...]).debug(a)` must dispatch `.debug` on
// the Vec[f32] receiver (not on str). Root: infer_expr_c_type for a Call whose
// obj is a TurboFish{Vec,[f32]} static-returning `.new()/.from()` did not resolve
// the return type to `Nova_Vec____nova_f32*` (it worked for int), so `.debug`
// fell through to the str overload and a Vec[f32]* was passed into a str method.
module nova_tests.plan153_3

import std.collections.vec.{Vec}

test "Vec[f32].new() chained .debug (empty)" {
    consume a = StringBuilder.new()
    Vec[f32].new().debug(a)
    assert(a.into_str() == "Vec[]")
}

test "Vec[f32].from([...]) chained .debug" {
    consume a = StringBuilder.new()
    Vec[f32].from([1.5, 2.5]).debug(a)
    assert(a.into_str() == "Vec[1.5, 2.5]")
}

test "Vec[f32].from([...]) chained .display" {
    consume a = StringBuilder.new()
    Vec[f32].from([1.5, 2.5]).display(a)
    assert(a.into_str() == "Vec[1.5, 2.5]")
}

// Control: Vec[int] chained already works.
test "Vec[int].from([...]) chained .debug (control)" {
    consume a = StringBuilder.new()
    Vec[int].from([1, 2]).debug(a)
    assert(a.into_str() == "Vec[1, 2]")
}

test "Vec[int].new() chained .debug (control)" {
    consume a = StringBuilder.new()
    Vec[int].new().debug(a)
    assert(a.into_str() == "Vec[]")
}
