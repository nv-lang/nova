// Plan 153.3 — select_nth_unstable (introselect): k-th order statistic.
module plan153_3.select_nth

test "select_nth k-th smallest + partition invariant" {
    mut v = Vec[int].from([7, 3, 9, 1, 5, 2, 8])
    ro m = v.select_nth_unstable(3)
    assert(m == 5)
    assert(v[3] == 5)
    assert(v[0] <= 5 && v[1] <= 5 && v[2] <= 5)
    assert(v[4] >= 5 && v[5] >= 5 && v[6] >= 5)
}

test "select_nth min and max" {
    mut a = Vec[int].from([5, 2, 8, 1, 9])
    assert(a.select_nth_unstable(0) == 1)
    mut b = Vec[int].from([5, 2, 8, 1, 9])
    assert(b.select_nth_unstable(4) == 9)
}

test "select_nth duplicates" {
    mut v = Vec[int].from([3, 3, 1, 3, 2, 3])
    assert(v.select_nth_unstable(2) == 3)
    assert(v.select_nth_unstable(0) == 1)
}

test "select_nth reverse-sorted worst-shape" {
    mut v = Vec[int].new()
    mut i = 30
    while i > 0 {
        i = i - 1
        v.push(i)
    }
    assert(v.select_nth_unstable(10) == 10)
    assert(v.select_nth_unstable(29) == 29)
    assert(v.select_nth_unstable(0) == 0)
}
