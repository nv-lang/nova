// Plan 153.3 [M-153-result-eq-literal-expected-type]: `result == Ok(x)` /
// `== Err(x)` for a Result with NON-default E (e.g. binary_search -> Result[int,int]).
// The bare Ok/Err literal is re-emitted against the other operand's concrete type.
// Covers literal on BOTH sides (the fix is symmetric) + negative (inequality) cases.
module plan153_3.result_eq_literal

test "literal on RHS: binary_search == Ok/Err (non-default E=int)" {
    ro v = Vec[int].of(1, 3, 5, 7)
    assert(v.binary_search(5) == Ok(2))
    assert(v.binary_search(1) == Ok(0))
    assert(v.binary_search(4) == Err(2))
    assert(v.binary_search(9) == Err(4))
    assert(!(v.binary_search(5) == Err(2)))
    assert(!(v.binary_search(5) == Ok(3)))
}

test "literal on LHS: Ok/Err == binary_search (symmetric branch)" {
    ro v = Vec[int].of(1, 3, 5, 7)
    assert(Ok(2) == v.binary_search(5))
    assert(Err(2) == v.binary_search(4))
    assert(!(Ok(3) == v.binary_search(5)))
    assert(!(Err(9) == v.binary_search(5)))
}

test "explicit Result[int,int] == Ok/Err literal (both sides)" {
    ro a Result[int, int] = Ok(7)
    assert(a == Ok(7))
    assert(Ok(7) == a)
    assert(!(a == Ok(8)))
    assert(!(a == Err(7)))
    ro e Result[int, int] = Err(3)
    assert(e == Err(3))
    assert(Err(3) == e)
    assert(!(e == Ok(3)))
}

test "default-E Result[int,str] == literal still works (no re-emit)" {
    ro a Result[int, str] = Ok(5)
    assert(a == Ok(5))
    ro x Result[int, str] = Err("boom")
    assert(x == Err("boom"))
    assert(!(x == Err("bang")))
}
