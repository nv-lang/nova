// Plan 153.3 — search & query (read-only): index_of/position/rposition,
// is_sorted/is_sorted_by, binary_search/_by/_by_key.
//
// NB: binary_search returns Result[int, int]; asserted via `match` helpers
// because structural `Result ==` is a pre-existing prelude gap (Ok(2)==Ok(2)
// is false — Result degrades to reference identity, unlike Option) —
// [M-153.3-result-equal-derive]. binary_search itself is correct.
module plan153_3.search

fn bs_ok(r Result[int, int], want int) -> bool {
    match r {
        Ok(i) => i == want,
        Err(_) => false,
    }
}
fn bs_err(r Result[int, int], want int) -> bool {
    match r {
        Ok(_) => false,
        Err(i) => i == want,
    }
}

test "index_of / position / rposition" {
    ro v = Vec[int].from([10, 20, 30, 20])
    assert(v.index_of(20) == Some(1))
    assert(v.index_of(99) == None)
    assert(v.position(|x| x > 25) == Some(2))
    assert(v.rposition(|x| x == 20) == Some(3))
    assert(v.position(|x| x > 100) == None)
}

test "is_sorted / is_sorted_by" {
    assert(Vec[int].from([1, 2, 2, 3]).is_sorted())
    assert(!Vec[int].from([1, 3, 2]).is_sorted())
    assert(Vec[int].new().is_sorted())
    assert(Vec[int].from([5]).is_sorted())
    ro d = Vec[int].from([3, 2, 1])
    assert(d.is_sorted_by(|a, b| b - a))
}

test "binary_search found / insertion point" {
    ro v = Vec[int].from([1, 3, 5, 7])
    assert(bs_ok(v.binary_search(5), 2))
    assert(bs_ok(v.binary_search(1), 0))
    assert(bs_ok(v.binary_search(7), 3))
    assert(bs_err(v.binary_search(4), 2))
    assert(bs_err(v.binary_search(0), 0))
    assert(bs_err(v.binary_search(9), 4))
}

test "binary_search_by / by_key" {
    ro v = Vec[int].from([1, 3, 5, 7])
    assert(bs_ok(v.binary_search_by(|e| e - 5), 2))
    assert(bs_err(v.binary_search_by(|e| e - 4), 2))
    assert(bs_ok(v.binary_search_by_key(|e| e, 5), 2))
}
