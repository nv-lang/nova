// Plan 100.4.4 (D150): MultiError API — caller inspects chain.

module nova_tests.plan100_4_4.multi_error_inspect_chain_ok

type ErrA { tag str }
type ErrB { tag str }
type ErrMain { tag str }

fn cleanup_a() Fail[ErrA] -> () { throw ErrA { tag: "A" } }
fn cleanup_b() Fail[ErrB] -> () { throw ErrB { tag: "B" } }

fn process() Fail -> () {
    defer { cleanup_a() }
    defer { cleanup_b() }
    throw ErrMain { tag: "main" }
}

test "caller inspects composite chain via MultiError API" {
    match process() {
        Ok(_) => println("unreachable"),
        Err(e) => {
            println("primary: ${e.primary()}")
            println("chain length: ${e.suppressed().len()}")
            for s in e.suppressed() {
                println("  ${s}")
            }
        }
    }
}
