// Plan 100.4.4 (D150): 3 defers all fail — composite chain length 3,
// LIFO continues после partial failure (Rust-superior — no abort).

module nova_tests.plan100_4_4.multi_defer_all_fail_ok_chain

type ErrA { tag str }
type ErrB { tag str }
type ErrC { tag str }
type ErrMain { tag str }

fn cleanup_a() Fail[ErrA] -> () { throw ErrA { tag: "A" } }
fn cleanup_b() Fail[ErrB] -> () { throw ErrB { tag: "B" } }
fn cleanup_c() Fail[ErrC] -> () { throw ErrC { tag: "C" } }

fn body() Fail[ErrMain] -> () { throw ErrMain { tag: "main" } }

fn process() Fail -> () {
    defer { cleanup_a() }                       // outer (runs LAST LIFO)
    defer { cleanup_b() }                       // middle
    defer { cleanup_c() }                       // inner (runs FIRST LIFO)
    body()?                                      // throws ErrMain
    // Exit semantics:
    //   1. body throws ErrMain
    //   2. unwinding starts
    //   3. cleanup_c fails ErrC → suppressed [C]
    //   4. cleanup_b fails ErrB → suppressed [C, B]
    //   5. cleanup_a fails ErrA → suppressed [C, B, A]
    //   6. caller: MultiError { primary: ErrMain, suppressed: [C, B, A] }
}

test "all 3 defers fail — chain length 3 (LIFO continues)" {
    process()
}
