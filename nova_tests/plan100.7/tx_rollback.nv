// Plan 100.7 (D165) pilot Transaction — rollback on error path.

module nova_tests.plan100_7.tx_rollback

type Db { }
type CommitErr { msg str }
type RollbackErr { msg str }
type OrderErr { msg str }

type Transaction consume { id int }

fn Transaction consume @commit() Fail[CommitErr] -> () { () }
fn Transaction consume @rollback() Fail[RollbackErr] -> () { () }

fn Db @begin() -> Transaction => Transaction { id: 1 }

fn db_insert(view t Transaction) Fail[OrderErr] -> int {
    throw OrderErr { msg: "constraint violation" }
}

fn process(db Db) Fail -> int {
    consume tx = db.begin()
    errdefer { tx.rollback()? }                 // failable rollback
    okdefer { tx.commit()? }
    let r = db_insert(tx)?                  // throws → errdefer rollback
    return r
}

test "Transaction rollback on error path (errdefer fires)" {
    let db = Db { }
    let r = process(db)                          // errdefer (rollback)
}
