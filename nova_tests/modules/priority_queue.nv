// Тесты std.collections.priority_queue.PriorityQueue[T] — binary min-heap.
// Позитивные: push/pop порядок, peek, len, is_empty.

module modules.priority_queue

import std._experimental.collections.priority_queue.{PriorityQueue}

test "PriorityQueue: push и pop в порядке возрастания" {
    let mut pq = PriorityQueue[int].new()
    pq.push(5)
    pq.push(1)
    pq.push(3)
    pq.push(8)
    pq.push(2)
    assert(pq.pop() == Some(1))
    assert(pq.pop() == Some(2))
    assert(pq.pop() == Some(3))
    assert(pq.pop() == Some(5))
    assert(pq.pop() == Some(8))
    assert(pq.pop() == None)
}

test "PriorityQueue: peek не удаляет минимум" {
    let mut pq = PriorityQueue[int].new()
    pq.push(10)
    pq.push(1)
    pq.push(5)
    assert(pq.peek() == Some(1))
    assert(pq.peek() == Some(1))
    assert(pq.len() == 3)
}

test "PriorityQueue: is_empty и len" {
    let mut pq = PriorityQueue[int].new()
    assert(pq.is_empty() == true)
    assert(pq.len() == 0)
    pq.push(42)
    assert(pq.is_empty() == false)
    assert(pq.len() == 1)
}

test "PriorityQueue: pop из пустой — None" {
    let mut pq = PriorityQueue[int].new()
    assert(pq.pop() == None)
    assert(pq.peek() == None)
}

test "PriorityQueue: один элемент" {
    let mut pq = PriorityQueue[int].new()
    pq.push(99)
    assert(pq.peek() == Some(99))
    assert(pq.pop() == Some(99))
    assert(pq.pop() == None)
}

test "PriorityQueue: дублирующиеся элементы" {
    let mut pq = PriorityQueue[int].new()
    pq.push(3)
    pq.push(1)
    pq.push(1)
    pq.push(2)
    assert(pq.pop() == Some(1))
    assert(pq.pop() == Some(1))
    assert(pq.pop() == Some(2))
    assert(pq.pop() == Some(3))
}

test "PriorityQueue: heap sort через последовательный pop" {
    let mut pq = PriorityQueue[int].new()
    for x in [7, 3, 9, 1, 5, 2, 8, 4, 6] {
        pq.push(x)
    }
    assert(pq.len() == 9)
    let mut prev = 0
    for _ in 0..9 {
        let v = match pq.pop() {
            Some(x) => x
            None    => 0
        }
        assert(v >= prev)
        prev = v
    }
}
