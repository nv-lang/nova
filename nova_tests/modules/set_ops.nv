// Тесты Set.or / Set.and / Set.minus — Plan 70 acceptance (Set-operation acceptance criteria).
// Ранее пропущены из-за generic Set* return type (D117-area limitation).
// Проверяет: .contains() на результате or/and/minus работает корректно.

module modules.set_ops

import std.collections.set.{Set}

test "Set.or — объединение" {
    mut a = Set[int].new()
    mut b = Set[int].new()
    a.insert(1)
    a.insert(2)
    b.insert(2)
    b.insert(3)
    ro c = a | b
    assert(c.contains(1) == true)
    assert(c.contains(2) == true)
    assert(c.contains(3) == true)
    assert(c.len() == 3)
}

test "Set.and — пересечение" {
    mut a = Set[int].new()
    mut b = Set[int].new()
    a.insert(1)
    a.insert(2)
    b.insert(2)
    b.insert(3)
    ro c = a & b
    assert(c.contains(1) == false)
    assert(c.contains(2) == true)
    assert(c.contains(3) == false)
    assert(c.len() == 1)
}

test "Set.minus — разность" {
    mut a = Set[int].new()
    mut b = Set[int].new()
    a.insert(1)
    a.insert(2)
    a.insert(3)
    b.insert(2)
    ro c = a - b
    assert(c.contains(1) == true)
    assert(c.contains(2) == false)
    assert(c.contains(3) == true)
    assert(c.len() == 2)
}
