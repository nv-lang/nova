// Plan 42 Sub-plan 42.1: file-level #forbid attribute.
// Этот файл объявляет `#forbid Net, Fs` — все functions
// гарантированно не используют Net/Fs effects.
// Содержит только pure операции — должен compile.

#forbid Net, Fs
module modules.file_forbid_clean

export fn pure_double(x int) -> int => x * 2

export fn sum_list(xs []int) -> int {
    mut s = 0
    for x in xs { s = s + x }
    s
}

test "pure operations work with #forbid Net, Fs" {
    assert(pure_double(21) == 42)
    assert(sum_list([1, 2, 3, 4, 5]) == 15)
}
