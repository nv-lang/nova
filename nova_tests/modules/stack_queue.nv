// 33_stack_queue.nv — реализация Stack и Queue через record + методы
// (как в реальном data-structure коде).

module modules.stack_queue

// --- Generic Stack[T] (LIFO) ---

type Stack[T] {
    mut items []T
}

fn Stack[T] @push(v T) {
    @items.push(v)
}

fn Stack[T] @pop() -> Option[T] {
    @items.pop()
}

fn Stack[T] @len() -> int => @items.len()

fn Stack[T] @peek() -> Option[T] {
    if @items.len() == 0 {
        return None
    }
    Some(@items[@items.len() - 1])
}

fn Stack[T] @is_empty() -> bool => @items.len() == 0

test "stack push and len" {
    mut s Stack[int] = { items: [] }
    s.push(1)
    s.push(2)
    s.push(3)
    assert(s.len() == 3)
}

test "stack LIFO порядок через pop" {
    mut s Stack[int] = { items: [] }
    s.push(10)
    s.push(20)
    s.push(30)
    ro p1 = s.pop()
    ro v1 = match p1 {
        Some(x) => x
        None    => 0
    }
    ro p2 = s.pop()
    ro v2 = match p2 {
        Some(x) => x
        None    => 0
    }
    assert(v1 == 30)
    assert(v2 == 20)
    assert(s.len() == 1)
}

test "stack peek не модифицирует" {
    mut s Stack[int] = { items: [] }
    s.push(99)
    ro pk = s.peek()
    ro p = match pk {
        Some(x) => x
        None    => 0
    }
    assert(p == 99)
    assert(s.len() == 1)
}

test "stack pop из пустого даёт None" {
    mut s Stack[int] = { items: [] }
    ro popped = s.pop()
    ro r = match popped {
        Some(_) => false
        None    => true
    }
    assert(r)
}

test "stack is_empty" {
    mut s Stack[int] = { items: [] }
    assert(s.is_empty())
    s.push(1)
    assert(!s.is_empty())
}

test "stack для строк" {
    mut s Stack[str] = { items: [] }
    s.push("a")
    s.push("b")
    s.push("c")
    ro popped = s.pop()
    ro top = match popped {
        Some(x) => x
        None    => ""
    }
    assert(top == "c")
}

// --- Реверс через stack ---

test "стек реверсирует массив (через known size)" {
    mut s Stack[int] = { items: [] }
    for x in [1, 2, 3, 4, 5] {
        s.push(x)
    }
    mut r = []
    for _ in 0..5 {
        ro popped = s.pop()
        ro v = match popped {
            Some(x) => x
            None    => 0
        }
        r.push(v)
    }
    assert(r[0] == 5)
    assert(r[4] == 1)
    assert(r.len() == 5)
}
