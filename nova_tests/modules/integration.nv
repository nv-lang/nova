// 29_integration.nv — integration-style тесты: программы которые
// используют связку features (sum-types + recursion + match +
// arrays + side-effects). Это smoke-тесты bootstrap'а на realistic
// мини-программах.

module modules.integration

// ===== Toy expression evaluator =====

type Expr
    | Num(int)
    | Add(Expr, Expr)
    | Mul(Expr, Expr)
    | Sub(Expr, Expr)

fn eval(e Expr) -> int => match e {
    Num(n)    => n
    Add(a, b) => eval(a) + eval(b)
    Mul(a, b) => eval(a) * eval(b)
    Sub(a, b) => eval(a) - eval(b)
}

test "expr eval: число" {
    assert(eval(Num(42)) == 42)
}

test "expr eval: сложение" {
    let e = Add(Num(2), Num(3))
    assert(eval(e) == 5)
}

test "expr eval: вложенное (2+3)*4-1" {
    let e = Sub(Mul(Add(Num(2), Num(3)), Num(4)), Num(1))
    assert(eval(e) == 19)
}

test "expr eval: глубокое дерево" {
    let e = Add(Num(1), Add(Num(2), Add(Num(3), Num(4))))
    assert(eval(e) == 10)
}

// ===== Stack-based mini-VM =====

type Op
    | Push(int)
    | OpAdd
    | OpMul
    | OpDup

fn pop_or_zero(stack []int) -> int {
    let v = stack.pop()
    match v {
        Some(x) => x
        None    => 0
    }
}

fn run(program []Op) -> int {
    let stack = []
    for op in program {
        match op {
            Push(n) => stack.push(n)
            OpAdd => {
                let b = pop_or_zero(stack)
                let a = pop_or_zero(stack)
                stack.push(a + b)
            }
            OpMul => {
                let b = pop_or_zero(stack)
                let a = pop_or_zero(stack)
                stack.push(a * b)
            }
            OpDup => {
                let v = pop_or_zero(stack)
                stack.push(v)
                stack.push(v)
            }
        }
    }
    pop_or_zero(stack)
}

test "stack VM: 2 + 3" {
    let prog = [Push(2), Push(3), OpAdd]
    assert(run(prog) == 5)
}

test "stack VM: (2 + 3) * 4" {
    let prog = [Push(2), Push(3), OpAdd, Push(4), OpMul]
    assert(run(prog) == 20)
}

test "stack VM: dup-then-mul = square" {
    let prog = [Push(7), OpDup, OpMul]
    assert(run(prog) == 49)
}

// ===== Linked list (immutable cons) =====

type LinkedList
    | Nil
    | Cons(int, LinkedList)

fn list_len(l LinkedList) -> int => match l {
    Nil          => 0
    Cons(_, rest) => 1 + list_len(rest)
}

fn list_sum(l LinkedList) -> int => match l {
    Nil           => 0
    Cons(v, rest) => v + list_sum(rest)
}

fn list_of_three() -> LinkedList {
    Cons(1, Cons(2, Cons(3, Nil)))
}

test "linked list length" {
    assert(list_len(Nil) == 0)
    assert(list_len(list_of_three()) == 3)
}

test "linked list sum" {
    assert(list_sum(Nil) == 0)
    assert(list_sum(list_of_three()) == 6)
}

// ===== Bank account через handler =====

type Account effect {
    deposit(n int) -> ()
    withdraw(n int) -> bool
    balance() -> int
}

fn make_transactions() Account -> int {
    Account.deposit(100)
    Account.deposit(50)
    let _ = Account.withdraw(30)
    let _ = Account.withdraw(200)  // overdraft, должен быть false
    Account.balance()
}

test "account effect через handler" {
    let mut bal = 0
    with Account = effect Account {
        deposit(n) {
            bal += n
            return ()
        }
        withdraw(n) {
            let enough = bal >= n
            if enough {
                bal -= n
                return true
            }
            false
        }
        balance() => bal
    } {
        let final_balance = make_transactions()
        // 100 + 50 - 30 = 120 (вторая withdraw отклонена)
        assert(final_balance == 120)
    }
    assert(bal == 120)
}
