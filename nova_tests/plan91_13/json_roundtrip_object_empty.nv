// Plan 91.3 Ф.3 (composites conformance): JSON roundtrip — empty object.
//
// Validates encode/decode/roundtrip для `{}`. format_object не должен
// эмитить trailing comma при empty map; parser принимает `{}` как
// `Object(HashMap.new())` без полей.

module plan91_13.json_roundtrip_object_empty

import std.encoding.json.{JsonValue, Json}
import std.collections.hashmap.{HashMap}

test "encode empty object" {
    ro m = HashMap[str, JsonValue].new()
    ro v = JsonValue.object(m)
    ro encoded = v.into()
    assert(encoded == "{}")
}

test "parse empty object" {
    ro parsed = Json.parse("{}")!!
    assert(parsed.is_object())
    match parsed.as_object() {
        Some(m) => assert(m.len() == 0)
        None    => assert(false)
    }
}

test "roundtrip empty object" {
    ro m = HashMap[str, JsonValue].new()
    ro orig = JsonValue.object(m)
    ro encoded = orig.into()
    ro decoded = Json.parse(encoded)!!
    assert(decoded == orig)
}
