// Plan 91.3 Ф.3 (composites conformance): JSON roundtrip — flat object.
//
// `{"k": "v", "n": 42}` — простой объект с двумя полями разного типа.
// HashMap iteration order не гарантирован → используем if-let semantic
// field checks (JsonValue без structural ==, nested match триггерит
// codegen edge case).

module nova_tests.plan91_13

import std.encoding.json.{JsonValue, Json}
import std.collections.hashmap.{HashMap}

test "parse flat object — keys present" {
    ro parsed = Json.parse("{\"k\": \"v\", \"n\": 42}")!!
    ro m_opt = parsed.as_object()
    assert(m_opt.is_some())
}

test "parse flat object — len = 2" {
    ro parsed = Json.parse("{\"k\": \"v\", \"n\": 42}")!!
    if let Some(m) = parsed.as_object() {
        assert(m.len() == 2)
    } else {
        assert(false)
    }
}

test "roundtrip flat object preserves len + key existence" {
    mut m = HashMap[str, JsonValue].new()
    m.insert("k", JsonValue.str("v"))
    m.insert("n", JsonValue.num(42.0))
    ro orig = JsonValue.object(m)
    ro encoded = orig.into()
    ro decoded = Json.parse(encoded)!!
    if let Some(dm) = decoded.as_object() {
        assert(dm.len() == 2)
        assert(dm.contains("k"))
        assert(dm.contains("n"))
    } else {
        assert(false)
    }
}
