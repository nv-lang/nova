// Plan 91.3 Ф.3 (composites conformance): JSON roundtrip — flat object.
//
// `{"k": "v", "n": 42}` — простой объект с двумя полями разного типа.
// Encode-then-parse roundtrip проверяет HashMap-based Object равенство;
// порядок keys в encoded form не гарантирован (HashMap iteration),
// поэтому проверяем через parse-then-compare (структурное равенство).

module plan91_13.json_roundtrip_object_flat

import std.encoding.json.{JsonValue, Json}
import std.collections.hashmap.{HashMap}

test "parse flat object" {
    ro parsed = Json.parse("{\"k\": \"v\", \"n\": 42}")!!
    match parsed.as_object() {
        Some(m) => {
            assert(m.len() == 2)
            assert(m.get("k") == Some(JsonValue.str("v")))
            assert(m.get("n") == Some(JsonValue.num(42.0)))
        }
        None => assert(false)
    }
}

test "roundtrip flat object via parse equivalence" {
    // HashMap iteration order не гарантирован => не сравниваем encoded
    // строки byte-for-byte. Вместо этого: encode + reparse → должно
    // быть == исходному value (структурное равенство).
    mut m = HashMap[str, JsonValue].new()
    m.insert("k", JsonValue.str("v"))
    m.insert("n", JsonValue.num(42.0))
    ro orig = JsonValue.object(m)
    ro encoded = orig.into()
    ro decoded = Json.parse(encoded)!!
    assert(decoded == orig)
}

test "object preserves all keys" {
    mut m = HashMap[str, JsonValue].new()
    m.insert("first", JsonValue.bool(true))
    m.insert("second", JsonValue.bool(false))
    m.insert("third", JsonValue.null())
    ro orig = JsonValue.object(m)
    ro encoded = orig.into()
    ro decoded = Json.parse(encoded)!!
    match decoded.as_object() {
        Some(dm) => {
            assert(dm.len() == 3)
            assert(dm.get("first") == Some(JsonValue.bool(true)))
            assert(dm.get("second") == Some(JsonValue.bool(false)))
            assert(dm.get("third") == Some(JsonValue.null()))
        }
        None => assert(false)
    }
}
