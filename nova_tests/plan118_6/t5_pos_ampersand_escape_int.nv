// Plan 118.6 Ф.5 POS T5 — &x escaping from function: int heap-promoted.
//
// Escape analysis detects return-position &x → primitive promoted to heap.
// GC owns it → pointer not dangling after function returns.
// (Plan 118.6 Ф.1: escape analysis extended to primitive types.)

module nova_tests.plan118_6

fn get_ptr() -> *int {
    ro x = 42
    return &x
}

test "&x escape int — auto-promote, not dangling" {
    ro p = get_ptr()
    unsafe {
        assert(p.read() == 42)
    }
}
