// Plan 118.6 Ф.5 POS T4 — unsafe { &x } gives raw stack pointer for FFI.
//
// Inside unsafe block: &x = raw stack pointer without escape analysis / promote.
// Programmer takes responsibility. Typical pattern: pass int* to C function.
// Here we verify read-back inside the same unsafe scope (pointer valid on stack).

module plan118_6.t4_pos_unsafe_raw_stack_ptr

test "unsafe { &x } raw stack pointer — valid in same scope" {
    ro x = 99
    unsafe {
        ro p = &x
        assert(p.read() == 99)
    }
}
