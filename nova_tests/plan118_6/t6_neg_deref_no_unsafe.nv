// Plan 118.6 Ф.5 NEG T6 — *p deref outside unsafe block → E_UNSAFE_REQUIRED.
//
// Deref remains unsafe after Plan 118.6 (only AddrOf became safe).
// E_UNSAFE_REQUIRED enforced by check_unsafe_context_in_module.
//
// EXPECT_COMPILE_ERROR E_UNSAFE_REQUIRED

module plan118_6.t6_neg_deref_no_unsafe

test "deref *p outside unsafe → E_UNSAFE_REQUIRED" {
    ro x = 42
    ro p = &x
    // *p dereference outside unsafe block — must fail
    ro v = *p
    assert(v == 42)
}
