// Plan 118.6 — &x on value-record without unsafe block (safe after Ф.2).
// EXPECT_PASS

module plan118_6.t2_addr_of_vr_safe

type Point value { x int, y int }

test "addr_of value-record is safe" {
    ro pt = Point { x: 1, y: 2 }
    ro p = &pt
    unsafe {
        assert(p.x == 1)
        assert(p.y == 2)
    }
}
