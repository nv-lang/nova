// Plan 118.7 migration: `unsafe { &x }` → `unsafe { raw &x }`.
// `raw &x` = сырой стек-адрес без escape analysis / promote.
// EXPECT_PASS

module nova_tests.plan118_6

test "unsafe raw &x gives raw pointer" {
    ro x = 99
    unsafe {
        ro p = raw &x
        assert(p.read() == 99)
    }
}
