// EXPECT_COMPILE_ERROR E_PRIV_FIELD_READ
//
// Plan 124.6 — negative: regular fn in same module CANNOT access priv(type)
// field. Rule-2 (implicit same-module grant) only applies to test blocks,
// NOT to regular fns. Free fns and non-method fns remain blocked (D224 §2).
module plan124_6.neg_regular_fn_same_module

export type Counter {
    pub label str
    priv(type) mut count int
}

export fn Counter.new(lbl str) -> Counter =>
    { label: lbl, count: 0 }

export fn Counter mut @inc() {
    @count = @count + 1
}

// Regular fn in same module — NOT a test block.
// priv(type) field access is NOT granted by same-module rule-2.
fn peek_count(c Counter) -> int =>
    c.count
