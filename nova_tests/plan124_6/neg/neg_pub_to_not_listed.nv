// EXPECT_COMPILE_ERROR E_PRIV_FIELD_READ
//
// Plan 124.6 — negative: type NOT listed in #pub_to(...) cannot access
// priv(type) fields even if another type IS listed (D224 §4 rule-4).
// #pub_to is selective — unlisted types remain blocked.
module neg.neg_pub_to_not_listed

#pub_to(Bank)
export type Account {
    pub owner str
    priv(type) mut balance f64
}

export type Bank {
    pub name str
}

export type Auditor {
    pub firm str
}

export fn Account.new(owner str) -> Account =>
    { owner, balance: 0.0 }

export fn Bank.new(name str) -> Bank =>
    { name }

export fn Auditor.new(firm str) -> Auditor =>
    { firm }

// Auditor is NOT listed in #pub_to(Bank) — access must be blocked.
export fn Auditor @check_balance(a Account) -> f64 =>
    a.balance
