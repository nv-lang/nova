// EXPECT_COMPILE_ERROR E_PRIV_FIELD_READ
//
// Plan 124.6 — negative: #test_access on a fn covers one type; accessing
// a DIFFERENT type's priv(type) field from the same fn is blocked (D224 §3).
// Models the "cross-module: #test_access for type A ≠ grant for type B".
module plan124_6.neg_test_cross_module_no_attr

export type Account {
    pub name str
    priv(type) mut balance f64
}

export type Vault {
    pub id str
    priv(type) mut secret int
}

export fn Account.new(n str) -> Account =>
    { name: n, balance: 0.0 }

export fn Vault.new(id str) -> Vault =>
    { id, secret: 0 }

// Helper fn has #test_access for Account only.
// Accessing Vault.secret from here must be blocked — no #test_access(Vault).
#test_access(Account)
fn inspect(a Account, v Vault) -> int =>
    v.secret
