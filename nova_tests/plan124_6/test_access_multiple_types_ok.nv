// Plan 124.6 — positive: #test_access(TypeA, TypeB) grants access к
// нескольким types одновременно.
module nova_tests.plan124_6

export type Account_testaccessmultipletypesok {
    ro name str
    priv(type) mut balance f64
}

export type Vault {
    ro id str
    priv(type) mut amount f64
}

export fn Account_testaccessmultipletypesok.new(n str) -> Account_testaccessmultipletypesok =>
    { name: n, balance: 0.0 }

export fn Vault.new(id str) -> Vault =>
    { id, amount: 0.0 }

#test_access(Account_testaccessmultipletypesok, Vault)
fn verify_zero(a Account_testaccessmultipletypesok, v Vault) -> bool =>
    a.balance == 0.0 && v.amount == 0.0

test "Plan 124.6: #test_access supports multiple types" {
    ro a = Account_testaccessmultipletypesok.new("bob")
    ro v = Vault.new("v1")
    assert(verify_zero(a, v))
}
