// Plan 123.7.7 (V7.7, 2026-06-04): deeper chain receiver
// `@a.b.cv6.method()` still sibling-safe.

module nova_tests.plan123_7_7

type Leaf2 {
    mut store []int
}

type Mid2 {
    mut leaf Leaf2
}

type Inner4 {
    mut mid Mid2
}

type Cv6 {
    mut tag int
    mut inner Inner4
}

fn Leaf2.new() -> Leaf2 => { store: []int.new() }
fn Mid2.new() -> Mid2 => { leaf: Leaf2.new() }
fn Inner4.new() -> Inner4 => { mid: Mid2.new() }

fn Cv6.new() -> Cv6 => { tag: 0, inner: Inner4.new() }

fn Cv6 mut @cycle(v int) -> int {
    ro a = @tag
    ro b = @tag
    // depth-3 chain: @inner.mid.leaf.store.push(v)
    @inner.mid.leaf.store.push(v)
    ro cv6 = @tag
    ro d = @tag
    a + b + cv6 + d
}

test "V7.7: depth-3 chain doesn't invalidate sibling cache" {
    mut cv6 = Cv6.new()
    cv6.tag = 5
    ro r = cv6.cycle(99)
    // tag = 5 throughout вЂ” 5*4 = 20
    assert(r == 20)
    assert(cv6.inner.mid.leaf.store.len() == 1)
    assert(cv6.inner.mid.leaf.store[0] == 99)
}
