// Plan 123.7.7 (V7.7, 2026-06-04): chain receiver IPA refinement.
// Closes [M-123.7.5-chain-receiver].
//
// Extends V7.5 sibling-safe rule k chains: `@F0.F1.....Fn.method()`
// preserves caches of fields outside the chain root.

module nova_tests.plan123_7_7

type Inner2 {
    mut sub []int
}

type Cv3 {
    mut counter int
    mut inner Inner2
}

fn Inner2.new() -> Inner2 => { sub: []int.new() }

fn Cv3.new() -> Cv3 => { counter: 0, inner: Inner2.new() }

fn Cv3 mut @sample_and_grow(v int) -> int {
    // V7.7: chain `@inner.sub.push(v)` doesn't invalidate sibling
    // `@counter` cache. Read counter twice before Рё twice after.
    ro c1 = @counter
    ro c2 = @counter
    @inner.sub.push(v)
    ro c3 = @counter
    ro c4 = @counter
    c1 + c2 + c3 + c4
}

test "V7.7: chain receiver doesn't invalidate sibling cache" {
    mut Cv3 = Cv3.new()
    Cv3.counter = 13
    ro r = Cv3.sample_and_grow(42)
    // counter = 13 throughout вЂ” 13*4 = 52
    assert(r == 52)
    // Verify chain mutation:
    assert(Cv3.inner.sub.len() == 1)
    assert(Cv3.inner.sub[0] == 42)
}
