// EXPECT_COMPILE_ERROR E_ARRAY_ELEM_NARROW
//
// Plan 154.1 [M-154.1-f32-literal-coercion] guard: numeric LITERALS coerce to
// f32 from context (Vec[f32].from([1.5, 2.5]) works), but a f64 VARIABLE in a
// []f32 context is an implicit narrowing — must fail loudly, not silently
// reinterpret bits → garbage (D44/D54: no silent narrowing of variables).
module plan154_1.neg_array_elem_narrow

import std.collections.vec.{Vec}

fn main() -> () {
    ro x f64 = 1.5
    ro v = Vec[f32].from([x])
    println("${v.len()}")
}
