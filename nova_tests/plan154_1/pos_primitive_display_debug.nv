// Plan 154.1 (D269): concrete Display/Debug for primitives + Vec[primitive]
// + typed StringBuilder @append overloads. Closes the vec_debug_pos
// primitive-element mis-dispatch.
module plan154_1.pos_primitive_display_debug

import std.collections.vec.{Vec}

test "primitive display direct" {
    consume a = StringBuilder.new()
    ro i = 7
    i.display(a)
    assert(a.as_str() == "7")
    consume b = StringBuilder.new()
    ro f = 2.5
    f.display(b)
    assert(b.as_str() == "2.5")
    consume c = StringBuilder.new()
    ro bo = true
    bo.display(c)
    assert(c.as_str() == "true")
    consume d = StringBuilder.new()
    ro ch = 'z'
    ch.display(d)
    assert(d.as_str() == "z")
    consume e = StringBuilder.new()
    ro s = "hey"
    s.display(e)
    assert(e.as_str() == "hey")
}

test "primitive debug quotes/escapes" {
    consume c = StringBuilder.new()
    ro ch = 'z'
    ch.debug(c)
    assert(c.as_str() == "'z'")
    consume e = StringBuilder.new()
    ro s = "hey"
    s.debug(e)
    assert(e.as_str() == "\"hey\"")
    consume i = StringBuilder.new()
    ro n = 42
    n.debug(i)
    assert(i.as_str() == "42")
}

test "Vec[primitive] display + debug" {
    ro vi = Vec[int].of(1, 2, 3)
    consume a = StringBuilder.new()
    vi.display(a)
    assert(a.as_str() == "Vec[1, 2, 3]")
    consume b = StringBuilder.new()
    vi.debug(b)
    assert(b.as_str() == "Vec[1, 2, 3]")
}

test "StringBuilder typed append fluent" {
    consume sb = StringBuilder.new()
    sb.append(1).append(true).append(2.5)
    assert(sb.as_str() == "1true2.5")
}
