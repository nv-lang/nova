// Plan 168 negative: pushing an int literal into Vec[u8] without cast
// must fail at compile time — type mismatch int vs u8.
//
// EXPECT_COMPILE_ERROR

module plan168.neg_vec_u8_type_mismatch

test "Vec[u8] push int without cast — type error" {
    mut v = Vec[u8].new()
    v.push(255)    // E_TYPE_MISMATCH: int is not u8
}
