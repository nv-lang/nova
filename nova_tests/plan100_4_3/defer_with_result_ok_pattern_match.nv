// Plan 100.4.3 (D160): defer |result| — reason-aware форма.
// result-binding пока не инжектируется в scope (реализуется вместе с DeferResult[T,E]).
// Тест проверяет: синтаксис распознан, тело выполняется как plain defer.

module nova_tests.plan100_4_3.defer_with_result_ok_pattern_match

test "defer |_result| — тело выполняется на normal exit" {
    mut fired = false
    ro _ = {
        defer |_result| { fired = true }
        42
    }
    assert(fired)
}

test "defer |_result| — LIFO с обычным defer" {
    mut step = 0
    mut a = 0
    mut b = 0
    ro _ = {
        defer         { step = step + 1; a = step }  // registered first
        defer |_res|  { step = step + 1; b = step }  // registered last, fires first
        0
    }
    assert(b == 1)
    assert(a == 2)
}

test "defer |_result| fires на interrupt-path (plain defer semantics)" {
    mut fired = false
    mut caught = false
    with Fail = effect Fail {
        fail(_) { caught = true; interrupt () }
    } {
        ro _ = {
            defer |_result| { fired = true }
            throw "fail"
            0
        }
    }
    // defer |result| ведёт себя как plain defer — fires даже на interrupt
    assert(caught)
    assert(fired)
}
