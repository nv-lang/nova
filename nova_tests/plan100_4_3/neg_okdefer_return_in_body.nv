// EXPECT_COMPILE_ERROR `return` is not allowed at the top level of `okdefer` body
//
// Plan 100.4.3 (D160): top-level `return` в okdefer body запрещён —
// он hijack'нул бы scope-exit окружающей функции.
// Same constraint что и для defer/errdefer (D90 §6).

module nova_tests.plan100_4_3.neg_okdefer_return_in_body

fn f() -> int {
    okdefer {
        return 42       // ❌ return в okdefer body
    }
    7
}
