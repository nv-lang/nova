// Plan 100.4.3 (D160): okdefer не выполняется при panic exit-path.
// panic() — non-recoverable; по D160 okdefer skipped.
// errdefer FIRES на panic path (как на throw); plain defer FIRES.

module nova_tests.plan100_4_3.okdefer_skip_on_panic

// Проверяем через expected_runtime: panic выводит backgroud message
// и завершает процесс — прямо тестировать сложно.
// Используем expected_runtime pattern с defer-tracking.
//
// УПРОЩЕНИЕ: тестируем через EXPECT_RUNTIME_PANIC fixture
// для случая "errdefer fires on panic" — он уже тестируется
// в expected_runtime/errdefer_on_panic.nv.
// Здесь тестируем только что окdefer НЕ НАРУШАЕТ normal flow
// когда panic НЕ происходит (позитивный контроль).

test "okdefer не мешает normal flow (нет panic)" {
    mut ok_count = 0
    mut err_count = 0
    ro _ = {
        errdefer { err_count = err_count + 1 }
        okdefer  { ok_count  = ok_count  + 1 }
        99
    }
    assert(ok_count == 1)
    assert(err_count == 0)
}

test "несколько okdefer на success — все срабатывают LIFO" {
    mut count = 0
    ro _ = {
        okdefer { count = count + 1 }
        okdefer { count = count + 1 }
        okdefer { count = count + 1 }
        0
    }
    assert(count == 3)
}
