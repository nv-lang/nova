// EXPECT_COMPILE_ERROR `return` is not allowed at the top level of `defer |result|` body
//
// Plan 100.4.3 (D160): top-level `return` в defer |result| body запрещён —
// те же constraints что и для plain defer body (D90 §6).

module nova_tests.plan100_4_3.neg_defer_with_result_return_in_body

fn f() -> int {
    defer |_res| {
        return 42       // ❌ return в defer |result| body
    }
    7
}
