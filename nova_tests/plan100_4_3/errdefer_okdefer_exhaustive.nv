// Plan 100.4.3 (D160): errdefer + okdefer = exhaustive coverage.
// Один и только один из них срабатывает на любом non-exit() выходе:
//   - normal exit: okdefer fires, errdefer skipped
//   - error exit (interrupt): errdefer skipped, okdefer skipped (interrupt path)
//   - plain defer: fires always (orthogonal)

module nova_tests.plan100_4_3.errdefer_okdefer_exhaustive

test "normal exit: okdefer fires, errdefer skipped" {
    let mut ok = 0
    let mut err = 0
    let _ = {
        errdefer { err = err + 1 }
        okdefer  { ok  = ok  + 1 }
        42
    }
    assert(ok == 1)
    assert(err == 0)
}

test "defer orthogonal: fires на normal exit вместе с okdefer" {
    let mut plain = 0
    let mut ok = 0
    let mut err = 0
    let _ = {
        defer    { plain = plain + 1 }
        errdefer { err   = err   + 1 }
        okdefer  { ok    = ok    + 1 }
        0
    }
    assert(plain == 1)
    assert(ok    == 1)
    assert(err   == 0)
}

test "interrupt path: plain defer fires, errdefer+okdefer skipped" {
    let mut plain = 0
    let mut ok = 0
    let mut err = 0
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        let _ = {
            defer    { plain = plain + 1 }
            errdefer { err   = err   + 1 }
            okdefer  { ok    = ok    + 1 }
            throw "fail"
            0
        }
    }
    assert(plain == 1)
    assert(ok    == 0)
    assert(err   == 0)
}

test "symmetric resource pattern: одна и только одна операция" {
    let mut commit_count = 0
    let mut rollback_count = 0

    // Success path
    let _ = {
        errdefer { rollback_count = rollback_count + 1 }
        okdefer  { commit_count   = commit_count   + 1 }
        "done"
    }
    assert(commit_count   == 1)
    assert(rollback_count == 0)
}
