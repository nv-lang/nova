// Plan 100.4.3 (D160): mixed defer/errdefer/okdefer LIFO ordering.
//
// Success-path LIFO: E -> D -> B -> A (defer+okdefer; errdefer skipped)
// Interrupt-path LIFO: E -> A (only plain defer; errdefer+okdefer skipped)

module nova_tests.plan100_4_3.mixed_defer_family_lifo

test "mixed family LIFO — success path" {
    mut step = 0
    mut a_step = 0
    mut b_step = 0
    mut c_step = 0
    mut d_step = 0
    mut e_step = 0
    ro _ = {
        defer    { step = step + 1; a_step = step }  // outer
        okdefer  { step = step + 1; b_step = step }
        errdefer { step = step + 1; c_step = step }
        okdefer  { step = step + 1; d_step = step }
        defer    { step = step + 1; e_step = step }  // inner
        0
    }
    // Normal exit LIFO: E -> D -> B -> A; C(errdefer) skipped
    assert(e_step == 1)
    assert(d_step == 2)
    assert(b_step == 3)
    assert(a_step == 4)
    assert(c_step == 0)
}

test "mixed family LIFO — interrupt path (only plain defer)" {
    mut step = 0
    mut a_step = 0
    mut b_step = 0
    mut c_step = 0
    mut d_step = 0
    mut e_step = 0
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro _ = {
            defer    { step = step + 1; a_step = step }
            okdefer  { step = step + 1; b_step = step }
            errdefer { step = step + 1; c_step = step }
            okdefer  { step = step + 1; d_step = step }
            defer    { step = step + 1; e_step = step }
            throw "fail"
            0
        }
    }
    // Interrupt path: only plain defer fires: E(1), A(2)
    assert(e_step == 1)
    assert(a_step == 2)
    assert(b_step == 0)   // okdefer did NOT fire
    assert(c_step == 0)   // errdefer did NOT fire
    assert(d_step == 0)   // okdefer did NOT fire
}
