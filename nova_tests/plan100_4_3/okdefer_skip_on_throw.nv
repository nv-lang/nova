// Plan 100.4.3 (D160): okdefer не выполняется при throw exit-path.
//
// С interrupt-handler throw превращается в handled (interrupt) exit.
// По D160: okdefer skipped на interrupt-path — только plain defer.

module nova_tests.plan100_4_3.okdefer_skip_on_throw

test "okdefer skipped при throw (interrupt-handler)" {
    let mut fired = false
    let mut caught = false
    with Fail = effect Fail {
        fail(_msg) { caught = true; interrupt () }
    } {
        let _ = {
            okdefer { fired = true }
            throw "fail"
            0
        }
    }
    assert(caught)
    assert(!fired)    // okdefer не сработал на interrupt-path
}

test "okdefer срабатывает на success-path (control)" {
    let mut fired = false
    let _ = {
        okdefer { fired = true }
        0
    }
    assert(fired)
}
