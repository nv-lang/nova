// Plan 136.1 F2 T3 (POS): (a,b,c,d)=(b,a,d,c) is two independent cycles.
// Decomposed into two 2-cycles: (a<->b) and (c<->d). Each needs 1 tmp.
// A3: two independent 2-cycles in a single tuple assign.

module plan136_1.t3_double_swap

test "double swap: 1,2,3,4 -> 2,1,4,3" {
    mut a = 1
    mut b = 2
    mut c = 3
    mut d = 4
    (a, b, c, d) = (b, a, d, c)
    assert(a == 2)
    assert(b == 1)
    assert(c == 4)
    assert(d == 3)
}
