// Plan 136.1 F2 T4 (POS): (a,b)=(a,b) identity, values unchanged.
// All self-dependencies: zero cycles, 0 tmps needed.
// A4: identity assignment leaves every variable unchanged.

module plan136_1.t4_identity_0tmp

test "identity 2-tuple: 5 and 7 unchanged" {
    mut a = 5
    mut b = 7
    (a, b) = (a, b)
    assert(a == 5)
    assert(b == 7)
}

test "identity 3-tuple: 1,2,3 unchanged" {
    mut x = 1
    mut y = 2
    mut z = 3
    (x, y, z) = (x, y, z)
    assert(x == 1)
    assert(y == 2)
    assert(z == 3)
}
