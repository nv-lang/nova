// Plan 136.1 F2 T5 (POS): mixed case falls back correctly.
// (a,b)=(b+1,0): R0 reads lhs var b (cross-dep), R1 is literal 0.
// (x,y)=(42,77): both rhs are literals, fully independent.
// A5: verify fallback path for non-pure-permutation assignments.

module nova_tests.plan136_1

test "mixed: a=b+1, b=0 from a=10,b=5" {
    mut a = 10
    mut b = 5
    (a, b) = (b + 1, 0)
    assert(a == 6)
    assert(b == 0)
}

test "all independent literals: x=42, y=77" {
    mut x = 0
    mut y = 0
    (x, y) = (42, 77)
    assert(x == 42)
    assert(y == 77)
}
