// EXPECT_COMPILE_ERROR E7201
//
// Plan 72 P0 (E7201): method call on erased protocol type — negative test.
//
// Erased protocol types (existential) are void* in codegen — there is no
// vtable at this stage (Plan 03 / Plan 56 Ф.3 deferred). Calling a method
// on such a variable silently returned NULL (wrong result) before this fix.
//
// This test must produce compile error E7201 instead of silently
// generating broken C code.
//
// Regression: prior behaviour was `compile OK, runtime WRONG (None instead of Some)`.

module plan72.p0_erased_method_call_neg

type IntCounter {
    mut cur int
    end int
}

fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        let v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}

// This should fail: x is declared as the erased protocol type Iter[int].
// Calling x.next() has no vtable — must produce E7201.
test "E7201 — method call on existential Iter[int] is compile error" {
    let c = IntCounter { cur: 0, end: 3 }
    let mut x Iter[int] = c
    let _r = x.next()   // E7201: method call on erased protocol type `Iter[int]`
}
