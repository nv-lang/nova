// Plan 72 P0 (historical) — E7201 diagnostic for erased protocol method call.
//
// ORIGINAL STATUS (before P3-B): This fixture was a NEGATIVE test.
// `let mut x Iter[int] = c; x.next()` produced compile error E7201 —
// "method call on erased protocol type" — instead of silently generating
// broken C code. E7201 replaced the silent miscompilation of P0.
//
// UPDATED STATUS (Plan 72 P3-B, 2026-05-19): P3-B implements full vtable
// codegen for protocol-as-value (existential) dispatch. The E7201 block now
// dispatches through the generated vtable when a concrete type is known.
// This fixture is now a POSITIVE test — the same code that was E7201 in P0
// now compiles and runs correctly via vtable dispatch.
//
// The Rust unit test `e7201_erased_protocol_method_call_fails` is updated
// to `p0_erased_now_dispatches_via_vtable` — verifying P3-B success.
//
// Canonical P3-B positive tests: nova_tests/plan72/p3b_vtable_dispatch_pos.nv

module plan72.p0_erased_method_call_neg

type IntCounter {
    mut cur int
    end int
}

fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        let v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}

// P3-B: this now compiles and dispatches via NovaVtable_Iter_nova_int.
test "P0→P3-B — method call on existential Iter[int] now works via vtable" {
    let c = IntCounter { cur: 0, end: 3 }
    let mut x Iter[int] = c
    let r = x.next()
    assert(r.is_some())
}
