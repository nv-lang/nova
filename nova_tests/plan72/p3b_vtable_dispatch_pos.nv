// Plan 72 P3-B: Full vtable codegen for protocol-as-value (existential dispatch).
//
// Before this fix, calling a method on a variable declared with a protocol type
// (`let x Iterable[int] = c; x.next()`) would produce compile error E7201 (Plan 72 P0).
//
// With P3-B, the compiler generates a NovaVtable_Iter_nova_int struct, thunk functions,
// and a companion vtable variable, then dispatches through __vt_x->next(x).
//
// Cases B and C from `protocol_as_value_probe.nv` now work instead of E7201.

module plan72.p3b_vtable_dispatch_pos

type IntCounter {
    mut cur int
    end int
}

fn IntCounter mut @next() -> Option[int] => {
    if @cur < @end {
        ro v = @cur
        @cur += 1
        Some(v)
    } else {
        None
    }
}

fn consume_iter(mut x Iterable[int]) -> int => {
    mut count = 0
    mut go = true
    loop {
        if !go { break }
        ro r = x.next()
        if r.is_some() {
            count += 1
        } else {
            go = false
        }
    }
    count
}

test "P3-B — method call on existential Iterable[int] (Case B)" {
    ro c = IntCounter { cur: 0, end: 3 }
    mut x Iterable[int] = c
    ro r = x.next()
    assert(r.is_some())
}

test "P3-B — protocol-as-value next() returns None after exhaustion" {
    ro c = IntCounter { cur: 0, end: 1 }
    mut x Iterable[int] = c
    ro r0 = x.next()
    ro r1 = x.next()
    assert(r0.is_some())
    assert(r1.is_none())
}

test "P3-B — consume_iter via protocol-as-value (Case C)" {
    ro c = IntCounter { cur: 0, end: 3 }
    ro n = consume_iter(c)
    assert(n == 3)
}
