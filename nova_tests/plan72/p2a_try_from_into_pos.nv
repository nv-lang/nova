// Plan 72 P2-A: TryFrom[T, E] and TryInto[U, E] protocols.
//
// Previously deferred (Plan 62.E, Plan 56 Ф.2.7): the `Fail[E]` effect row
// in protocol methods is blocked because vtable dispatch cannot propagate
// effect handlers. Unblocked via migration path (b): use `Result[Self, E]`
// return type instead of `Fail[E]` effect row.
//
// Protocol declarations are now live in std/prelude/protocols.nv (stable 0.1).
// Callers must match/unwrap the Result instead of using try-propagation "?".

module nova_tests.plan72

type Celsius2 { deg int }
type Fahrenheit2 { deg int }

fn Celsius2.try_from(f Fahrenheit2) -> Result[Celsius2, str] => {
    ro c = (f.deg - 32) * 5 / 9
    if c < -273 { Err("below absolute zero") } else { Ok(Celsius2 { deg: c }) }
}

fn Fahrenheit2.try_from(c Celsius2) -> Result[Fahrenheit2, str] => {
    ro f = c.deg * 9 / 5 + 32
    Ok(Fahrenheit2 { deg: f })
}

test "P2-A — TryFrom Fahrenheit2 → Celsius2 Ok path" {
    ro r = Celsius2.try_from(Fahrenheit2 { deg: 212 })
    assert(r.is_ok())
    ro c = r.unwrap_or(Celsius2 { deg: 0 })
    assert(c.deg == 100)
}

test "P2-A — TryFrom Fahrenheit2 → Celsius2 Err path (below abs zero)" {
    ro r = Celsius2.try_from(Fahrenheit2 { deg: -1000 })
    assert(r.is_err())
}

test "P2-A — TryFrom Celsius2 → Fahrenheit2 Ok path" {
    ro r = Fahrenheit2.try_from(Celsius2 { deg: 100 })
    assert(r.is_ok())
    ro f = r.unwrap_or(Fahrenheit2 { deg: 0 })
    assert(f.deg == 212)
}

test "P2-A — TryInto via try_from symmetry" {
    ro r = Celsius2.try_from(Fahrenheit2 { deg: 32 })
    assert(r.is_ok())
    ro c = r.unwrap_or(Celsius2 { deg: -1 })
    assert(c.deg == 0)
}
