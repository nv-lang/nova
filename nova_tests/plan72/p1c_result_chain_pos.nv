// Plan 72 P1-C followup: Result[T,E] method chains.
//
// Tests chained calls like parse_bool1("true").map(...).unwrap_or(false)
// where the intermediate Result is anonymous (no let binding).
// The compiler must correctly infer T through the chain.

module nova_tests.plan72

fn parse_int1(s str) -> Result[int, str] => {
    if s == "42" { Ok(42) } else { Err("bad") }
}

fn parse_bool1(s str) -> Result[bool, str] => {
    if s == "true" { Ok(true) } else { Err("not a bool") }
}

test "P1-C chain — map on Result[int,str] Ok path" {
    ro r = parse_int1("42")
    ro mapped = r.map(fn(x int) -> int => x + 1)
    assert(mapped.unwrap_or(0) == 43)
}

test "P1-C chain — map on Result[int,str] Err path" {
    ro r = parse_int1("bad")
    ro mapped = r.map(fn(x int) -> int => x + 1)
    assert(mapped.unwrap_or(0) == 0)
}

test "P1-C chain — map_err on Result[int,str]" {
    ro r = parse_int1("bad")
    ro mapped = r.map_err(fn(e str) -> str => "error: " + e)
    assert(mapped.is_err())
}

test "P1-C chain — unwrap_or on inline Result[bool,str]" {
    ro b = parse_bool1("true").unwrap_or(false)
    assert(b)
}

test "P1-C chain — unwrap_or on inline Result[bool,str] Err" {
    ro b = parse_bool1("nope").unwrap_or(false)
    assert(!b)
}

test "P1-C chain — map then unwrap_or on Result[bool,str]" {
    ro r = parse_bool1("true")
    ro mapped = r.map(fn(b bool) -> bool => !b)
    assert(mapped.unwrap_or(true) == false)
}
