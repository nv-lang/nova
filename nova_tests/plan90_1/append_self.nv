// Plan 90.1 — позитив: append self-extend dst.append(dst).
// D141 amend: snapshot src_data/src_len before potential realloc handles
// self-extend correctly. With Boehm GC, old allocation retained until collected.

module nova_tests.plan90_1.append_self

test "append self — doubles prefix" {
    mut dst []int = [1, 2, 3]
    dst.append(dst)
    // [1, 2, 3, 1, 2, 3]
    assert(dst.len() == 6)
    assert(dst[0] == 1)
    assert(dst[1] == 2)
    assert(dst[2] == 3)
    assert(dst[3] == 1)
    assert(dst[4] == 2)
    assert(dst[5] == 3)
}

test "append self — single element" {
    mut dst []int = [42]
    dst.append(dst)
    assert(dst.len() == 2)
    assert(dst[0] == 42)
    assert(dst[1] == 42)
}
