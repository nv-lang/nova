// Plan 90.1 — property: insert preserves element order.
// Insert segments and verify final order consistent with reference.

module nova_tests.plan90_1.insert_preserves_order

test "insert order preservation — sequential inserts" {
    let mut arr []int = [1, 5]
    // Insert [2, 3, 4] at position 1: [1, 2, 3, 4, 5]
    arr.insert(1, [2, 3, 4])
    assert(arr.len() == 5)
    assert(arr[0] == 1)
    assert(arr[1] == 2)
    assert(arr[2] == 3)
    assert(arr[3] == 4)
    assert(arr[4] == 5)

    // Now insert [6, 7] at the end: [1, 2, 3, 4, 5, 6, 7]
    arr.insert(5, [6, 7])
    assert(arr.len() == 7)
    assert(arr[5] == 6)
    assert(arr[6] == 7)
}

test "insert — interleaved inserts build sorted sequence" {
    // Build [10, 20, 30, 40, 50] by inserting pairs
    let mut arr []int = [10, 50]
    arr.insert(1, [20, 30, 40])
    assert(arr.len() == 5)
    let mut i = 0
    let expected []int = [10, 20, 30, 40, 50]
    while i < 5 {
        assert(arr[i] == expected[i])
        i = i + 1
    }
}
