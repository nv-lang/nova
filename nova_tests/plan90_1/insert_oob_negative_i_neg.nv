// EXPECT_RUNTIME_PANIC insert: index
//
// Plan 90.1 — негатив: insert — negative index → panic.
// D141 amend: i < 0 → panic "insert: index N out of bounds".

module nova_tests.plan90_1.insert_oob_negative_i_neg

fn main() -> () {
    let mut dst []int = [1, 2, 3]
    let src []int = [10, 20]
    dst.insert(-1, src)
}
