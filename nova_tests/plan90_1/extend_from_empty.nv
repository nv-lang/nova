// Plan 90.1 — позитив: extend_from empty src — no-op, no realloc.
// D141 amend: extend_from([]) leaves dst unchanged (len == 0 * sizeof(T) = 0 memmove).

module nova_tests.plan90_1.extend_from_empty

test "extend_from empty src — no-op" {
    let mut dst []int = [1, 2, 3]
    let src []int = []
    dst.extend_from(src)
    assert(dst.len() == 3)
    assert(dst[0] == 1)
    assert(dst[1] == 2)
    assert(dst[2] == 3)
}

test "extend_from into empty dst" {
    let mut dst []int = []
    let src []int = [10, 20, 30]
    dst.extend_from(src)
    assert(dst.len() == 3)
    assert(dst[0] == 10)
    assert(dst[2] == 30)
}

test "extend_from both empty — no-op" {
    let mut dst []int = []
    let src []int = []
    dst.extend_from(src)
    assert(dst.len() == 0)
}
