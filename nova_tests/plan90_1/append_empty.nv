// Plan 90.1 — позитив: append empty src — no-op, no realloc.
// D141 amend: append([]) leaves dst unchanged (len == 0 * sizeof(T) = 0 memmove).

module nova_tests.plan90_1.append_empty

test "append empty src — no-op" {
    let mut dst []int = [1, 2, 3]
    let src []int = []
    dst.append(src)
    assert(dst.len() == 3)
    assert(dst[0] == 1)
    assert(dst[1] == 2)
    assert(dst[2] == 3)
}

test "append into empty dst" {
    let mut dst []int = []
    let src []int = [10, 20, 30]
    dst.append(src)
    assert(dst.len() == 3)
    assert(dst[0] == 10)
    assert(dst[2] == 30)
}

test "append both empty — no-op" {
    let mut dst []int = []
    let src []int = []
    dst.append(src)
    assert(dst.len() == 0)
}
