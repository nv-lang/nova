// Plan 90.1 — property: extend_from amortized O(1) growth (2x doubling).
// N=1000 extends by 1, verify total elements = N, final array consistent.

module nova_tests.plan90_1.extend_from_grows_amortized

test "extend_from amortized growth N=1000" {
    let mut dst []int = []
    let one []int = [0]
    let mut i = 0
    while i < 1000 {
        dst.extend_from(one)
        i = i + 1
    }
    assert(dst.len() == 1000)
    // Verify all elements are 0 (the value we extended with)
    let mut j = 0
    while j < 1000 {
        assert(dst[j] == 0)
        j = j + 1
    }
}

test "extend_from repeated doubling correctness" {
    let mut dst []int = [1]
    let mut expected_len = 1
    let mut iter = 0
    while iter < 10 {
        dst.extend_from(dst)  // self-extend doubles length each time
        expected_len = expected_len * 2
        assert(dst.len() == expected_len)
        iter = iter + 1
    }
    // After 10 doublings: 1 * 2^10 = 1024 elements
    assert(dst.len() == 1024)
}
