// EXPECT_COMPILE_WARNING W_VIEW_EXTEND_DETACH
//
// Plan 90.1 Ф.5 — W_VIEW_EXTEND_DETACH lint: warning when append/insert/reserve
// is called on parent array after creating a slice-view of it.
// View may become dangling if append triggers realloc.

module nova_tests.plan90_1.view_extend_detach_warn

fn main() -> () {
    mut parent []int = [1, 2, 3, 4, 5]
    ro view = parent[1..4]
    parent.append([6, 7, 8])  // W_VIEW_EXTEND_DETACH: view may dangle after realloc
    ro _ = view.len()
}
