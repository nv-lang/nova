// Plan 90.1 — позитив: copy_from memmove overlap safety.
// D141 amend: copy_from uses memmove (not memcpy) — overlap-safe by default.
// Паритет с Go (всегда memmove), без runtime-детекции.

module nova_tests.plan90_1.copy_from_overlap_via_view

test "copy_from view into same array — memmove handles overlap" {
    // dst и src[1..4] перекрываются в памяти.
    // memmove корректно обрабатывает overlap (в отличие от memcpy UB).
    mut arr []int = [1, 2, 3, 4, 5]
    ro view = arr[1..4]   // [2, 3, 4], len=3
    mut dst []int = [0, 0, 0]
    dst.copy_from(view)
    assert(dst[0] == 2)
    assert(dst[1] == 3)
    assert(dst[2] == 4)
}

test "copy_from dst is slice view" {
    ro src []u8 = [0xAA, 0xBB, 0xCC, 0xDD]
    mut buf []u8 = [0, 0, 0, 0, 0, 0]
    mut middle = buf[2..4]  // len=2 slice of buf
    ro src_slice = src[1..3]   // [0xBB, 0xCC], len=2
    middle.copy_from(src_slice)
    assert(buf[2] == 0xBB)
    assert(buf[3] == 0xCC)
}
