// Plan 90.1 — stress: extend_from bulk 1M elements smoke perf test.
// Single extend_from of 1M elements — verify correctness, should complete < 5s.

module nova_tests.plan90_1.extend_from_bulk_1M

test "extend_from 1M elements" {
    // Build source array of 1M elements
    let mut src []int = []
    src.reserve(1000000)
    let mut i = 0
    while i < 1000000 {
        src.push(i)
        i = i + 1
    }
    assert(src.len() == 1000000)

    // Extend empty dst by 1M elements in one call
    let mut dst []int = []
    dst.extend_from(src)
    assert(dst.len() == 1000000)
    assert(dst[0] == 0)
    assert(dst[999999] == 999999)
}
