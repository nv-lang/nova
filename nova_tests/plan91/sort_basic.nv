// Plan 91 Ф.4 conformance — sort / search basic operations.
//
// Plan 153.x consolidation: `@binary_search` now resolves to the canonical
// prelude `collections.vec` family (`[]T ≡ Vec[T]`, D239) and returns
// `Result[int,int]` — `Ok(i)` found / `Err(insertion_point)` not found — NOT
// the old `Option[int]`. `@sort` / `@sort_by` / `@min` / `@max` still come from
// `std.sort` (concrete `[]int` ops; the prelude eager-min/max counterpart is
// gated on the `[]int.new()→Vec` codegen fix, [M-153.x-array-new-not-vec]).
module nova_tests.plan91

import std.sort

test "sort: empty array no-op" {
    mut xs []int = []
    xs.sort()
    assert(xs.len() == 0)
}

test "sort: single element no-op" {
    mut xs []int = [42]
    xs.sort()
    assert(xs == [42])
}

test "sort: already sorted" {
    mut xs []int = [1, 2, 3, 4, 5]
    xs.sort()
    assert(xs == [1, 2, 3, 4, 5])
}

test "sort: reverse sorted" {
    mut xs []int = [5, 4, 3, 2, 1]
    xs.sort()
    assert(xs == [1, 2, 3, 4, 5])
}

test "sort: random with duplicates" {
    mut xs []int = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]
    xs.sort()
    assert(xs == [1, 1, 2, 3, 3, 4, 5, 5, 5, 6, 9])
}

test "sort: negative numbers" {
    mut xs []int = [-3, 0, 5, -1, 2]
    xs.sort()
    assert(xs == [-3, -1, 0, 2, 5])
}

test "sort_by: reverse order" {
    mut xs []int = [1, 2, 3, 4, 5]
    xs.sort_by(|a, b| b - a)    // descending; b-a > 0 means a < b → swap (per D183 int convention)
    assert(xs == [5, 4, 3, 2, 1])
}

test "binary_search: found -> Ok(index)" {
    ro xs []int = [1, 3, 5, 7, 9, 11]
    assert(xs.binary_search(5) == Ok(2))
    assert(xs.binary_search(1) == Ok(0))
    assert(xs.binary_search(11) == Ok(5))
}

test "binary_search: not found -> Err(insertion_point)" {
    ro xs []int = [1, 3, 5, 7, 9]
    // Insertion point keeps the array sorted: 0 < 1 -> idx 0; 3 < 4 < 5 -> idx 2;
    // 9 < 10 -> idx 5 (past the end).
    assert(xs.binary_search(0) == Err(0))
    assert(xs.binary_search(4) == Err(2))
    assert(xs.binary_search(10) == Err(5))
}

test "binary_search: empty -> Err(0)" {
    ro xs []int = []
    assert(xs.binary_search(42) == Err(0))
}

test "min: non-empty" {
    ro xs []int = [3, 1, 4, 1, 5]
    assert(xs.min() == Some(1))
}

test "min: empty" {
    ro xs []int = []
    assert(xs.min() == None)
}

test "max: non-empty" {
    ro xs []int = [3, 1, 4, 1, 5]
    assert(xs.max() == Some(5))
}

test "max: empty" {
    ro xs []int = []
    assert(xs.max() == None)
}

test "sort then binary_search property" {
    mut xs []int = [9, 4, 7, 1, 8, 3, 2, 6, 5]
    xs.sort()
    mut i = 0
    mut all_found = true
    while i < xs.len() {
        ro target = xs[i]
        ro ok = match xs.binary_search(target) {
            Ok(_) => true,
            Err(_) => false,
        }
        if !ok { all_found = false }
        i = i + 1
    }
    assert(all_found)
}
