// Plan 91 Ф.4 conformance — std.sort basic operations.
module nova_tests.plan91.sort_basic

import std.sort

test "sort: empty array no-op" {
    let mut xs []int = []
    xs.sort()
    assert(xs.len() == 0)
}

test "sort: single element no-op" {
    let mut xs []int = [42]
    xs.sort()
    assert(xs == [42])
}

test "sort: already sorted" {
    let mut xs []int = [1, 2, 3, 4, 5]
    xs.sort()
    assert(xs == [1, 2, 3, 4, 5])
}

test "sort: reverse sorted" {
    let mut xs []int = [5, 4, 3, 2, 1]
    xs.sort()
    assert(xs == [1, 2, 3, 4, 5])
}

test "sort: random with duplicates" {
    let mut xs []int = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]
    xs.sort()
    assert(xs == [1, 1, 2, 3, 3, 4, 5, 5, 5, 6, 9])
}

test "sort: negative numbers" {
    let mut xs []int = [-3, 0, 5, -1, 2]
    xs.sort()
    assert(xs == [-3, -1, 0, 2, 5])
}

test "sort_by: reverse order" {
    let mut xs []int = [1, 2, 3, 4, 5]
    xs.sort_by(|a, b| if a > b { Less } else if a < b { Greater } else { Equal })
    assert(xs == [5, 4, 3, 2, 1])
}

test "binary_search: found" {
    let xs []int = [1, 3, 5, 7, 9, 11]
    assert(xs.binary_search(5) == Some(2))
    assert(xs.binary_search(1) == Some(0))
    assert(xs.binary_search(11) == Some(5))
}

test "binary_search: not found" {
    let xs []int = [1, 3, 5, 7, 9]
    assert(xs.binary_search(0) == None)
    assert(xs.binary_search(4) == None)
    assert(xs.binary_search(10) == None)
}

test "binary_search: empty" {
    let xs []int = []
    assert(xs.binary_search(42) == None)
}

test "min: non-empty" {
    let xs []int = [3, 1, 4, 1, 5]
    assert(xs.min() == Some(1))
}

test "min: empty" {
    let xs []int = []
    assert(xs.min() == None)
}

test "max: non-empty" {
    let xs []int = [3, 1, 4, 1, 5]
    assert(xs.max() == Some(5))
}

test "max: empty" {
    let xs []int = []
    assert(xs.max() == None)
}

test "sort then binary_search property" {
    let mut xs []int = [9, 4, 7, 1, 8, 3, 2, 6, 5]
    xs.sort()
    let mut i = 0
    let mut all_found = true
    while i < xs.len() {
        let target = xs[i]
        let ok = match xs.binary_search(target) {
            Some(_) => true,
            None => false,
        }
        if !ok { all_found = false }
        i = i + 1
    }
    assert(all_found)
}
