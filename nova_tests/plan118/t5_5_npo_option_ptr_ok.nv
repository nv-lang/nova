// Plan 118 Ф.5.4 T5.5 / A21 partial — NPO для Option[*()] (Plan 115
// D214 opaque pointer). nova_ptr typedef'd как void* — semantically
// pointer-sized, ABI-equivalent. NPO single-pointer layout dropped
// tag field, sizeof == 8.
//
// Verifies:
//   - Option[*()] uses NPO layout (struct { nova_ptr value; })
//   - None constructor для Option[*()] emits NULL
//   - is None / is Some checks work
//   - Backward-compat с Plan 115 fixtures preserved

module nova_tests.plan118

extern "nova" fn p118_try_alloc_raw(size i64) -> Option[*()]

test "Option[*()] None type-checks via NPO" {
    ro p Option[*()] = None
    assert(p is None)
}

test "Option[*()] Some((0 as *())) via NPO — backward compat" {
    // (0 as *()) literal still works (Plan 115 D214); NPO layout
    // means Some((0 as *())).value == NULL → is None semantically.
    // Edge case: Some((0 as *())) is ambiguous под NPO (V2 retraction
    // closes this — A23 follow-on).
    ro p = Some((0 as *()))
    assert(p is None) // под NPO: NULL = None convention
}
