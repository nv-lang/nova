// Plan 118 Ф.5.4 T5.5 / A21 partial — Option[*()] layout (Plan 115
// D214 opaque pointer). NovaOpt_nova_int tagged layout via void* fallback
// (void_p slot pre-declared with tagged struct in array.h — closures).
//
// Verifies:
//   - Option[*()] None constructor works (tagged: tag = None)
//   - Some((0 as *())) compiles and is Some (tagged: tag = Some)
//   - Plan 115 D214 backward-compat: (0 as *()) is a valid *() value
//
// NOTE: NPO single-pointer layout NOT applied to Option[*()] — conflict
// with NovaOpt_void_p pre-declared in array.h (closure array tagged layout).
// NPO retraction for *() edge case — A23 V2 follow-on.

module nova_tests.plan118

extern "nova" fn p118_try_alloc_raw(size i64) -> Option[*()]

test "Option[*()] None type-checks" {
    ro p Option[*()] = None
    assert(p is None)
}

test "Option[*()] Some((0 as *())) compiles and is Some" {
    // (0 as *()) literal still works (Plan 115 D214); tagged layout
    // means Some((0 as *())).tag == Some (not None).
    // Edge case Some(null_ptr) == None under NPO — A23 V2 follow-on.
    ro p = Some((0 as *()))
    assert(!(p is None)) // tagged: Some != None
}
