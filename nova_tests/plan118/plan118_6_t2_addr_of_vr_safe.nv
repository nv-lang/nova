// Plan 118.6 — &x on value-record without unsafe block (safe after Ф.2).
// EXPECT_PASS

module nova_tests.plan118

type Point1 value { x int, y int }

test "addr_of value-record is safe" {
    ro pt = Point1 { x: 1, y: 2 }
    ro p = &pt
    unsafe {
        assert(p.x == 1)
        assert(p.y == 2)
    }
}
