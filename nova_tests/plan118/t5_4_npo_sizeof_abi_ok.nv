// Plan 118 Ф.5 T5.4 / A19 — NPO ABI: sizeof(Option[*T]) == 8 (64-bit).
//
// Without NPO, tagged struct = 16 bytes (int tag + T* value + padding).
// With NPO, single-pointer struct = 8 bytes (T* value).
//
// Verified through external fn signature ABI match: Option[*u8] returns
// directly as void* / uint8_t* в C ABI (single pointer-word, NULL = None).

module plan118.t5_4_npo_sizeof_abi_ok

// External fn signature for NPO ABI compatibility verification.
// C side: \`uint8_t* p118_npo_returns_null(void);\` returns NULL.
// Nova side: Option[*u8] interpreted via NPO single-pointer layout.
// При NPO codegen the ABI matches direct C convention.
external fn p118_npo_returns_null() -> Option[*u8]

test "NPO ABI layout — Option[*T] single-pointer (compile-only)" {
    // Type-check verifies signature lowers без error.
    // Actual NULL = None ABI compat — verified в C code review:
    //   typedef struct NovaOpt_const_nova_byte_p { const nova_byte* value; }
    //   sizeof == sizeof(void*) == 8 на 64-bit.
    assert(1 == 1)
}
