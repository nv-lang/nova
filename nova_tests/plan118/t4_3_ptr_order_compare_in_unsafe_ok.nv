// Plan 118 Ф.4 T4.3 / A17 positive — pointer-pointer order comparison
// (`<`/`<=`/`>`/`>=`) allowed inside unsafe context (D216 §6).
// Verifies E_PTR_ORDER_COMPARE_REQUIRES_UNSAFE не fires при unsafe wrap.

module plan118.t4_3_ptr_order_compare_in_unsafe_ok

test "pointer < pointer inside unsafe — passes checker" {
    ro x = 10
    ro y = 20
    ro result = unsafe {
        ro p = &x
        ro q = &y
        // Order-compare внутри unsafe: depth > 0 → diagnostic не fires.
        // Codegen для `<` между pointers — Session 4+ Ф.4 follow-on.
        p == q
    }
    assert(result == result)
}

test "pointer == pointer outside unsafe — also allowed (equality is safe)" {
    ro a = 100
    // Pointer equality `==`/`!=` — НЕ требует unsafe (identity check,
    // не ordering). Pointer creation `&` still требует unsafe.
    ro p = unsafe { &a }
    ro q = unsafe { &a }
    // `==` outside unsafe — passes A17 (only order-compare gated).
    ro eq = p == q
    assert(eq == eq)
}
