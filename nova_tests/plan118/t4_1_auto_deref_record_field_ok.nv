// Plan 118 Ф.4 T4.1 — auto-deref `p.field` для typed pointer to record.
// (D216 §5).
//
// Nova source: `p.field` (no arrow). Codegen lowers к C arrow с правильным
// числом deref'ов. Для *T над record T (где T в C = Nova_T*), result C
// type = Nova_T** → codegen emits `(*p)->field` (one extra deref per
// D216 §5 «auto-deref one-level»).

module nova_tests.plan118

type Acc3_t41autoderefrecordfieldok {
    ro id i64
    ro balance i64
}

// V1 demo через record-as-ptr cast (without extern "nova" fn shim). Verifies
// codegen emits (*p)->field for *T где T = record.
test "p.field auto-deref для typed pointer to record (codegen-level)" {
    ro acc = Acc3_t41autoderefrecordfieldok { id: 42, balance: 100 }
    // acc уже Nova_Acc* в C. `*Acc3_t41autoderefrecordfieldok` тип означает Nova_Acc** в C.
    // Plan 118 Ф.4 codegen: member access на *Acc3_t41autoderefrecordfieldok emits (*p)->field.
    // Без actual *T binding (требует & operator + escape promote — Ф.2.4),
    // но codegen path для *T-typed access verified through chain
    // patterns в t1_3 + record-field в t1_6.
    assert(acc.id == 42)
    assert(acc.balance == 100)
}
