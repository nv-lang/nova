// Plan 118.5 Ф.4 T3 — `*unsafe T` (Pointer wrapping Unsafe pointee) form.
// MIGRATED by Plan 138.5 (2026-06-11): the prefix `unsafe * T` outer form
// (`Unsafe(Pointer(T))`, possibly-null ptr) is RETIRED — nullable ptr is now
// `Option[*T]`. Only the postfix pointee-unsafe form `*unsafe T` survives.
//
//   *unsafe T  → Pointer(Unsafe(T))   — valid ptr to possibly-uninit T
//   *mut unsafe T → Pointer(Mut(Unsafe(T))) — writable ptr to uninit T
//   *unsafe * T → Pointer(Unsafe(Pointer(T))) — ptr to (uninit ptr to T)
//
// C ABI: T* (transparent). Read of an unsafe-T binding requires unsafe block.

module nova_tests.plan118

type Buf {
    n i64
}

extern "nova" fn p118_5_t3_a(p * unsafe Buf) -> ()
extern "nova" fn p118_5_t3_b(p *mut unsafe Buf) -> ()
extern "nova" fn p118_5_t3_c(p * unsafe * Buf) -> ()

test "parses pointer-to-uninit forms" {
    assert(1 == 1)
}
