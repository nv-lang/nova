// Plan 118.1 [M-118.1-addr-of-chains] — &(s.field) on a `mut s` binding
// is accepted.
// (addr_of_mut removed in Plan 118.6 — use & syntax directly.)
module nova_tests.plan118

type Sv1 {
    v i64
}

test "addr_of_mut on a field of a mut binding is accepted" {
    mut s = Sv1 { v: 1 }
    unsafe {
        ro p = &s.v
        assert(p.read() == 1)
    }
}
