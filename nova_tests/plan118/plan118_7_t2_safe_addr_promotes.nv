// Plan 118.7 POS-T2 — `&x` (safe addr-of) promotes to heap and can escape scope.
// Contrasts with `raw &x` which does NOT promote.
// D216 §4 amend: &x = safe + escape-analysis + auto-promote.
// EXPECT_PASS

module nova_tests.plan118

fn get_ptr_plan1187t2safeaddrpromotes(n int) -> *int {
    ro tmp = n
    // `&tmp` escapes via return → escape analysis auto-promotes to heap.
    // Using `unsafe { &tmp }` form for explicit unsafe context.
    unsafe { &tmp }
}

test "safe &x auto-promotes when escaping scope" {
    ro p = get_ptr_plan1187t2safeaddrpromotes(77)
    unsafe {
        assert(*p == 77)
    }
}
