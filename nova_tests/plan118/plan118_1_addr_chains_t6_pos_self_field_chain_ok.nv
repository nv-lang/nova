// Plan 118.1 [M-118.1-addr-of-chains] — &(@a.b): a field chain rooted in
// `self` (SelfAccess) is a valid lvalue → accepted.
// (addr_of removed in Plan 118.6 — use & syntax directly.)
module nova_tests.plan118

type Inner3 {
    ro z i64
}

type Holder2 {
    ro inner Inner3
}

fn Holder2 @peek() -> i64 {
    unsafe {
        ro p = &@inner.z
        p.read()
    }
}

test "addr_of of a self-rooted field chain is accepted" {
    ro h = Holder2 { inner: Inner3 { z: 9 } }
    assert(h.peek() == 9)
}
