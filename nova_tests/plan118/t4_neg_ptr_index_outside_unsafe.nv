// Plan 118 [M-118-ptr-index-unsafe] negative — `ptr[i]` outside unsafe
// context rejected with E_UNSAFE_REQUIRED (D216 §8).
//
// ptr[i] ≡ *(ptr + i) — same unsafe requirement as `*ptr` explicit deref.
// Without `unsafe { }` wrap → E_UNSAFE_REQUIRED must fire.
//
// EXPECT_COMPILE_ERROR E_UNSAFE_REQUIRED

module plan118.t4_neg_ptr_index_outside_unsafe

import std.runtime.raw_mem.{RawMem}

test "ptr[i] outside unsafe — rejected E_UNSAFE_REQUIRED" {
    // Type annotation makes pointer type syntactically visible to the
    // unsafe-context checker (syntactic ptr_vars tracking). Without it
    // a method-call RHS is opaque at the syntactic level.
    // Nova type annotation syntax: `mut name Type = value` (no colon).
    mut buf *mut u8 = unsafe { RawMem.alloc(4) }
    // Index on *mut u8 without unsafe block → E_UNSAFE_REQUIRED
    ro v = buf[0]
    assert(v == v)
}
