// Plan 118.1 Ф.1 T5 — RawMem.fill (memset).
//
// Plan 138.2 [M-138-rawmem-dedup-fill]: the `write_bytes` alias was removed
// (identical memset dupe of `fill`); this fixture now exercises `fill` alone.

module nova_tests.plan118

import std.runtime.raw_mem

test "RawMem.fill writes a byte-pattern across the buffer" {
    mut a []u8 = [0, 0, 0, 0]
    unsafe {
        RawMem.fill(a.as_mut_ptr(), 0x42 as u8, 4)
    }
    assert(a[0] == (0x42 as u8))
    assert(a[1] == (0x42 as u8))
    assert(a[2] == (0x42 as u8))
    assert(a[3] == (0x42 as u8))
}
