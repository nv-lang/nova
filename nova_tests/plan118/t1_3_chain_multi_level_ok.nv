// Plan 118 Ф.1 T1.3 — chain order для multi-level pointers (D216 §3).
//
// Pointer model (Plan 147 / D246): pointee-mut is POSTFIX (after each `*`),
// and the ro pointee is the bare canon (`*T ≡ *ro T`; explicit `*ro` is a
// hard error, migrated to `*`).
//   `*mut *Node`     = pointer-to-mut (pointer-to-ro Node)
//   `* *mut Node`    = ro pointer to a mut-pointer (`**mut Node`)

module plan118.t1_3_chain_multi_level_ok

type Node {
    ro value i64
}

// Two-level chain — mut/ro mixed (pointee-mut postfix per level; ro = bare `*`).
extern "nova" fn p118_chain_mut_ro(pp *mut *Node) -> i64
extern "nova" fn p118_chain_ro_mut(pp **mut Node) -> i64

// Three-level form collapses to two levels here (outer/inner pointee-mut
// expressed postfix at each `*`).
extern "nova" fn p118_chain_triple(ppp *mut *Node) -> i64

// Chain в return position.
extern "nova" fn p118_return_chain() -> *mut *Node

test "multi-level pointer chains parse + type-check" {
    assert(1 == 1)
}
