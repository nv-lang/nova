// Plan 118 Ф.5.8 T5.6 / A20 — newtype-over-pointer handles (canonical FFI
// handle pattern). `type Handle(*T)` — transparent typedef alias.
//
// Verifies:
//   - Option[SqHandle] None constructor works (tagged: tag = None)
//   - Option[SqHandle] Some(handle) compiles and is Some
//   - None equality: two None values are equal
//
// NOTE: NPO single-pointer layout NOT applied here — Option[SqHandle] maps
// to NovaOpt_nova_int (void* fallback, tagged layout). NPO for newtype
// transparent typedef is gated on resolving void_p/closure array conflict.

module nova_tests.plan118

// Canonical FFI pattern — opaque handle wrapping *() (Plan 115 D214).
type SqHandle(*())

extern "nova" fn p118_open_sqlite(path str) -> Option[SqHandle]
extern "nova" fn p118_close_sqlite(h SqHandle) -> i64

test "Option[SqHandle] None type-checks" {
    // Tagged layout: Option[SqHandle] = NovaOpt_nova_int, tag = None.
    ro h Option[SqHandle] = None
    assert(h is None)
}

test "newtype handle wrapping (0 as *()) compiles and is Some" {
    ro raw = (0 as *())
    ro h = SqHandle(raw)
    // Tagged layout: Some(h).tag == Some (not None).
    // NPO: Some(SqHandle(null)) == None — A23 V2 follow-on.
    ro opt = Some(h)
    assert(!(opt is None)) // tagged: Some != None
}

test "Option[SqHandle] equality identity-check" {
    ro h1 Option[SqHandle] = None
    ro h2 Option[SqHandle] = None
    assert(h1 == h2)
}
