// Plan 118 Ф.1 T1.1 — parse `*T` / `*mut T` / `*unsafe T` typed
// pointer family в TYPE positions (declarations).
//
// Coverage:
//   - `*T` (canonical ro pointer; `*T ≡ *ro T` per Plan 147 / D246 — the
//     explicit `*ro T` form is a hard error E_REDUNDANT_POINTER_RO, migrated)
//   - `*mut T` (mutable pointee)
//   - `*unsafe T` (ptr to uninit T)
//
// V1 scope: parse + type-check declarations only. Pointer ops (deref,
// `&value`, auto-deref) — landing в Ф.2-Ф.4 unsafe model.

module nova_tests.plan118

type Acc1 {
    ro id i64
    ro balance i64
}

// All modifier variants в extern "nova" fn signatures (Plan 147: `*T` is the ro
// canon; no separate `*ro T` form).
extern "nova" fn p118_take_ptr_default(p *Acc1) -> i64
extern "nova" fn p118_take_ptr_ro(p *Acc1) -> i64
extern "nova" fn p118_take_ptr_mut(p *mut Acc1) -> i64
extern "nova" fn p118_take_ptr_unsafe(p *unsafe Acc1) -> i64

extern "nova" fn p118_return_ptr_default() -> *Acc1
extern "nova" fn p118_return_ptr_ro() -> *Acc1
extern "nova" fn p118_return_ptr_mut() -> *mut Acc1
extern "nova" fn p118_return_ptr_unsafe() -> *unsafe Acc1

test "typed pointer family parses + type-checks в extern nova fn signatures" {
    // Declarations alone exercise parser + type-checker. Runtime ops
    // (& / *) — landing в Ф.2-Ф.4 unsafe model.
    assert(1 == 1)
}
