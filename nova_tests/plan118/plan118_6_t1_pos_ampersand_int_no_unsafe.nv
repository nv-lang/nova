// Plan 118.6 Ф.5 POS T1 — &x on int binding without unsafe block.
//
// After Plan 118.6 Ф.2: AddrOf is safe — no unsafe { } required.
// GC + escape analysis guarantee pointer validity.

module nova_tests.plan118

test "&x on int — safe, no unsafe required" {
    ro x = 42
    ro p = &x
    unsafe {
        assert(p.read() == 42)
    }
}
