// Plan 118 / 138.5 — chained pointee-mut modifiers (postfix, final model).
//
// Final pointer model (Plan 138.5): pointee-mut is POSTFIX (`*ro T`/`*mut T`),
// reassignability of the pointer is binding (`let`/`mut name`), NOT a type
// property. Former outer-pointer-mut forms (`mut * ro Acc`) collapse to their
// pointee form (`*ro Acc`) since the reassignability axis left the type.

module plan118.t1_9_chain_modifiers_ok

type Acc {
    ro id i64
}

// Pointer to ro Acc (pointee read-only).
external fn p118_chain_a(p *ro Acc) -> ()

// Former `mut * ro Acc` (reassignable pointer to ro Acc). The pointer
// reassignability is now binding-only, so as a *type* this is `*ro Acc`.
external fn p118_chain_b(p *ro Acc) -> ()

// Two-level chain: pointer-to-mut (pointer-to-ro Acc).
external fn p118_chain_c(p *mut *ro Acc) -> ()

test "chained right-binding modifiers parse + typecheck" {
    assert(1 == 1)
}
