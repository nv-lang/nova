// Plan 118 / 118.5 V3 — chained type-level modifiers under right-binding rule.
//
// Per D216 V3 §V3.1: ro+mut adjacency forbidden в nested constructor
// position (no binding context для disambiguation). V2-era chain forms
// `*ro mut T` (Pointer(Readonly(Mut(T)))) и `ro * mut T` migrated к
// alternatives that respect V3 constraints.

module plan118.t1_9_chain_modifiers_ok

type Acc {
    ro id i64
}

// Single modifier chain — ro pointer к Acc (no nested ro+mut conflict).
external fn p118_chain_a(p ro * Acc) -> ()

// Mut pointer outer; inner ro Acc (binding modifier wraps separate from
// content modifier — both are mut+ro но no nested-constructor conflict).
external fn p118_chain_b(p mut * ro Acc) -> ()

// Triple chain: mut pointer к ro pointer к Acc.
external fn p118_chain_c(p mut * ro * Acc) -> ()

test "chained right-binding modifiers parse + typecheck" {
    assert(1 == 1)
}
