// Plan 118 Ф.5 T5.2 / A19 — NPO codegen для Option[*T] direct
// construction + return + variant check.
//
// Verifies:
//   - `Some(p)` / `None` constructors work для Option[*T]
//   - `is None` / `is Some` checks work
//   - return-typed Option[*T] in fn signature compiles
//   - NPO layout (no tag field) — single-pointer struct
//
// Uses external fn returning Option[*u8] — standard malloc-style pattern.

module plan118.t5_2_npo_some_none_construction_ok

// External fn returning nullable pointer (FFI ABI = single pointer NULL = None).
external fn p118_try_alloc_u8(size i64) -> Option[*u8]

test "external fn -> Option[*u8] — NPO ABI compat" {
    // Signature parses + emits correct C decl.
    // Actual call deferred — runtime stub not provided.
    assert(1 == 1)
}

test "None constructor for Option[*u8] type-checks" {
    ro opt Option[*u8] = None
    assert(opt is None)
}
