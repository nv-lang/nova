// Plan 152.6 (D255): UTF-16 / code-point interop — encode_utf16 / from_utf16 /
// code_points + surrogate helpers. Roundtrip ASCII/BMP/supplementary + neg.
module plan152_6.utf16_interop

import std.encoding.utf16.{Utf16Error, LoneHighSurrogate, LoneLowSurrogate, TruncatedSurrogatePair, is_high_surrogate, is_low_surrogate, decode_surrogate_pair}

test "encode_utf16: ASCII = 1 unit per char" {
    ro u = "ABC".encode_utf16()
    assert(u.len() == 3)
    assert(u[0] as int == 0x41)
    assert(u[1] as int == 0x42)
    assert(u[2] as int == 0x43)
}

test "encode_utf16: BMP non-ASCII = 1 unit" {
    // 'é' = U+00E9, 'λ' = U+03BB — оба BMP → один code unit каждый.
    ro u = "éλ".encode_utf16()
    assert(u.len() == 2)
    assert(u[0] as int == 0xE9)
    assert(u[1] as int == 0x3BB)
}

test "encode_utf16: supplementary = surrogate pair (2 units)" {
    // '😀' = U+1F600 → surrogate pair D83D DE00.
    ro u = "😀".encode_utf16()
    assert(u.len() == 2)
    assert(u[0] as int == 0xD83D)
    assert(u[1] as int == 0xDE00)
    assert(is_high_surrogate(u[0] as int))
    assert(is_low_surrogate(u[1] as int))
}

test "from_utf16: roundtrip ASCII / BMP / supplementary" {
    ro samples = ["", "ABC", "éλ", "😀", "a😀b", "héllo λ 😀!"]
    for s in samples {
        match str.from_utf16(s.encode_utf16()) {
            Ok(back) => assert(back == s),
            Err(_)   => assert(false),
        }
    }
}

test "from_utf16: explicit supplementary decode" {
    ro u = [0x61 as u16, 0xD83D as u16, 0xDE00 as u16, 0x62 as u16]   // "a😀b"
    match str.from_utf16(u) {
        Ok(s) => assert(s == "a😀b"),
        Err(_) => assert(false),
    }
}

test "from_utf16: lone high surrogate -> Err" {
    ro u = [0x41 as u16, 0xD83D as u16, 0x42 as u16]   // high not followed by low
    match str.from_utf16(u) {
        Ok(_) => assert(false),
        Err(LoneHighSurrogate(cu)) => assert(cu == 0xD83D),
        Err(_) => assert(false),
    }
}

test "from_utf16: lone low surrogate -> Err" {
    ro u = [0x41 as u16, 0xDE00 as u16]   // low without preceding high
    match str.from_utf16(u) {
        Ok(_) => assert(false),
        Err(LoneLowSurrogate(cu)) => assert(cu == 0xDE00),
        Err(_) => assert(false),
    }
}

test "from_utf16: truncated surrogate pair at end -> Err" {
    ro u = [0x41 as u16, 0xD83D as u16]   // high surrogate is last unit
    match str.from_utf16(u) {
        Ok(_) => assert(false),
        Err(TruncatedSurrogatePair(cu)) => assert(cu == 0xD83D),
        Err(_) => assert(false),
    }
}

test "code_points: raw int codepoints" {
    ro cp = "a😀".code_points()
    assert(cp.len() == 2)
    assert(cp[0] == 0x61)
    assert(cp[1] == 0x1F600)
}

test "code_points == as_chars values as int" {
    ro s = "héλ😀"
    ro cp = s.code_points()
    mut chars_as_int = []int.with_capacity(4)
    for c in s.as_chars() { chars_as_int.push(c as int) }
    assert(cp.len() == chars_as_int.len())
    mut i = 0
    while i < cp.len() {
        assert(cp[i] == chars_as_int[i])
        i = i + 1
    }
}

test "decode_surrogate_pair helper" {
    assert(decode_surrogate_pair(0xD83D, 0xDE00) == 0x1F600)
}
