// Plan 18 std.sync: AtomicInt + AtomicBool tests.
//
// Verifies lock-free integer and boolean operations.
// Concurrent tests confirm no data race — final values must be exact.

module nova_tests.concurrency.sync_atomic

// ─── AtomicInt: single-fiber baseline ──────────────────────────

test "AtomicInt: new and load" {
    mut a = AtomicInt.new(42)
    assert(a.load() == 42)
}

test "AtomicInt: store and load" {
    mut a = AtomicInt.new(0)
    a.store(99)
    assert(a.load() == 99)
}

test "AtomicInt: fetch_add returns previous, updates value" {
    mut a = AtomicInt.new(10)
    ro prev = a.fetch_add(5)
    assert(prev == 10)
    assert(a.load() == 15)
}

test "AtomicInt: fetch_sub returns previous, updates value" {
    mut a = AtomicInt.new(20)
    ro prev = a.fetch_sub(7)
    assert(prev == 20)
    assert(a.load() == 13)
}

test "AtomicInt: compare_exchange success" {
    mut a = AtomicInt.new(5)
    ro ok = a.compare_exchange(5, 100)
    assert(ok == true)
    assert(a.load() == 100)
}

test "AtomicInt: compare_exchange failure (wrong expected)" {
    mut a = AtomicInt.new(5)
    ro ok = a.compare_exchange(99, 100)
    assert(ok == false)
    assert(a.load() == 5)
}

// ─── AtomicInt: concurrent ──────────────────────────────────────

// Two fibers each do 200 atomic fetch_adds of 1. Without atomic ops,
// a plain `mut n = n + 1` would race and produce < 400. With AtomicInt,
// the final value must be exactly 400.
test "AtomicInt: concurrent fetch_add — no data race" {
    mut counter = AtomicInt.new(0)
    supervised {
        spawn {
            mut i = 0
            while i < 200 {
                counter.fetch_add(1)
                i = i + 1
            }
        }
        spawn {
            mut i = 0
            while i < 200 {
                counter.fetch_add(1)
                i = i + 1
            }
        }
    }
    assert(counter.load() == 400)
}

// CAS-based increment loop: each fiber increments via CAS retry.
// Verifies compare_exchange is usable as a building block.
test "AtomicInt: CAS loop — cooperative increment" {
    mut val = AtomicInt.new(0)
    supervised {
        spawn {
            mut i = 0
            while i < 10 {
                mut cur = val.load()
                mut ok = false
                while ok == false {
                    ok = val.compare_exchange(cur, cur + 1)
                    if ok == false {
                        cur = val.load()
                    }
                }
                runtime.yield()
                i = i + 1
            }
        }
        spawn {
            mut i = 0
            while i < 10 {
                mut cur = val.load()
                mut ok = false
                while ok == false {
                    ok = val.compare_exchange(cur, cur + 1)
                    if ok == false {
                        cur = val.load()
                    }
                }
                runtime.yield()
                i = i + 1
            }
        }
    }
    assert(val.load() == 20)
}

// ─── AtomicBool: single-fiber baseline ─────────────────────────

test "AtomicBool: new false and load" {
    mut a = AtomicBool.new(false)
    assert(a.load() == false)
}

test "AtomicBool: new true and load" {
    mut b = AtomicBool.new(true)
    assert(b.load() == true)
}

test "AtomicBool: store and load" {
    mut a = AtomicBool.new(false)
    a.store(true)
    assert(a.load() == true)
    a.store(false)
    assert(a.load() == false)
}

test "AtomicBool: compare_exchange success" {
    mut a = AtomicBool.new(false)
    ro ok = a.compare_exchange(false, true)
    assert(ok == true)
    assert(a.load() == true)
}

test "AtomicBool: compare_exchange failure (wrong expected)" {
    mut a = AtomicBool.new(false)
    ro ok = a.compare_exchange(true, false)
    assert(ok == false)
    assert(a.load() == false)
}

// swap() sets new value, returns previous.
test "AtomicBool: swap false→true returns previous" {
    mut a = AtomicBool.new(false)
    ro prev = a.swap(true)
    assert(prev == false)
    assert(a.load() == true)
}

test "AtomicBool: swap true→false returns previous" {
    mut a = AtomicBool.new(true)
    ro prev = a.swap(false)
    assert(prev == true)
    assert(a.load() == false)
}

// ─── AtomicBool: concurrent ─────────────────────────────────────

// Two fibers race to set a flag via swap(). Only one can see false as
// the previous value — the "winner" of the one-shot ownership race.
// This is the canonical once-flag pattern without Once.
test "AtomicBool: swap one-shot ownership — exactly one winner" {
    mut flag = AtomicBool.new(false)
    mut winners = AtomicInt.new(0)
    supervised {
        spawn {
            ro was_false = flag.swap(true)
            if was_false == false {
                winners.fetch_add(1)
            }
        }
        spawn {
            ro was_false = flag.swap(true)
            if was_false == false {
                winners.fetch_add(1)
            }
        }
        spawn {
            ro was_false = flag.swap(true)
            if was_false == false {
                winners.fetch_add(1)
            }
        }
    }
    assert(winners.load() == 1)
}
