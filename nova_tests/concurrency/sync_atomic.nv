// Plan 18 std.sync: AtomicInt tests.
//
// Verifies lock-free integer operations: new/load/store/fetch_add/fetch_sub/
// compare_exchange. Concurrent test shows two fibers incrementing atomically
// without data race — final value must equal sum of both fibers' contributions.

module nova_tests.concurrency.sync_atomic

// ─── Single-fiber baseline ──────────────────────────────────────

test "AtomicInt: new and load" {
    let a = AtomicInt.new(42)
    assert(a.load() == 42)
}

test "AtomicInt: store and load" {
    let a = AtomicInt.new(0)
    a.store(99)
    assert(a.load() == 99)
}

test "AtomicInt: fetch_add returns previous, updates value" {
    let a = AtomicInt.new(10)
    let prev = a.fetch_add(5)
    assert(prev == 10)
    assert(a.load() == 15)
}

test "AtomicInt: fetch_sub returns previous, updates value" {
    let a = AtomicInt.new(20)
    let prev = a.fetch_sub(7)
    assert(prev == 20)
    assert(a.load() == 13)
}

test "AtomicInt: compare_exchange success" {
    let a = AtomicInt.new(5)
    let ok = a.compare_exchange(5, 100)
    assert(ok == true)
    assert(a.load() == 100)
}

test "AtomicInt: compare_exchange failure (wrong expected)" {
    let a = AtomicInt.new(5)
    let ok = a.compare_exchange(99, 100)
    assert(ok == false)
    assert(a.load() == 5)
}

// ─── Concurrent increment ───────────────────────────────────────

// Two fibers each do 200 atomic fetch_adds of 1. Without atomic ops,
// a plain `mut n = n + 1` would race and produce < 400. With AtomicInt,
// the final value must be exactly 400.
test "AtomicInt: concurrent fetch_add — no data race" {
    let counter = AtomicInt.new(0)
    supervised {
        spawn {
            let mut i = 0
            while i < 200 {
                counter.fetch_add(1)
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < 200 {
                counter.fetch_add(1)
                i = i + 1
            }
        }
    }
    assert(counter.load() == 400)
}

// CAS-based increment loop: each fiber increments via CAS retry.
// Verifies compare_exchange is usable as a building block.
test "AtomicInt: CAS loop — cooperative increment" {
    let val = AtomicInt.new(0)
    supervised {
        spawn {
            let mut i = 0
            while i < 10 {
                let mut cur = val.load()
                let mut ok = false
                while ok == false {
                    ok = val.compare_exchange(cur, cur + 1)
                    if ok == false {
                        cur = val.load()
                    }
                }
                runtime.yield()
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < 10 {
                let mut cur = val.load()
                let mut ok = false
                while ok == false {
                    ok = val.compare_exchange(cur, cur + 1)
                    if ok == false {
                        cur = val.load()
                    }
                }
                runtime.yield()
                i = i + 1
            }
        }
    }
    assert(val.load() == 20)
}
