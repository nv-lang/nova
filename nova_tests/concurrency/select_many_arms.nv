// Plan 40 Ф.3-extended: select без cap'а — 100 arms на стеке.
//
// Storage = SelectSlot[100] + SelectWaiter[100] = ~8 KB на одну
// select-операцию. На default minicoro 56 KB stack — безопасно.
//
// Подтверждает что compound-literal storage в emit_select работает
// для значений >>32 без silent zero-fill или зависания.

module nova_tests.concurrency.select_many_arms

test "select: 100 arms (way beyond former cap=32)" {
    let c00 = Channel.new(1); let c01 = Channel.new(1); let c02 = Channel.new(1); let c03 = Channel.new(1)
    let c04 = Channel.new(1); let c05 = Channel.new(1); let c06 = Channel.new(1); let c07 = Channel.new(1)
    let c08 = Channel.new(1); let c09 = Channel.new(1); let c10 = Channel.new(1); let c11 = Channel.new(1)
    let c12 = Channel.new(1); let c13 = Channel.new(1); let c14 = Channel.new(1); let c15 = Channel.new(1)
    let c16 = Channel.new(1); let c17 = Channel.new(1); let c18 = Channel.new(1); let c19 = Channel.new(1)
    let c20 = Channel.new(1); let c21 = Channel.new(1); let c22 = Channel.new(1); let c23 = Channel.new(1)
    let c24 = Channel.new(1); let c25 = Channel.new(1); let c26 = Channel.new(1); let c27 = Channel.new(1)
    let c28 = Channel.new(1); let c29 = Channel.new(1); let c30 = Channel.new(1); let c31 = Channel.new(1)
    let c32 = Channel.new(1); let c33 = Channel.new(1); let c34 = Channel.new(1); let c35 = Channel.new(1)
    let c36 = Channel.new(1); let c37 = Channel.new(1); let c38 = Channel.new(1); let c39 = Channel.new(1)
    let c40 = Channel.new(1); let c41 = Channel.new(1); let c42 = Channel.new(1); let c43 = Channel.new(1)
    let c44 = Channel.new(1); let c45 = Channel.new(1); let c46 = Channel.new(1); let c47 = Channel.new(1)
    let c48 = Channel.new(1); let c49 = Channel.new(1); let c50 = Channel.new(1); let c51 = Channel.new(1)
    let c52 = Channel.new(1); let c53 = Channel.new(1); let c54 = Channel.new(1); let c55 = Channel.new(1)
    let c56 = Channel.new(1); let c57 = Channel.new(1); let c58 = Channel.new(1); let c59 = Channel.new(1)
    let c60 = Channel.new(1); let c61 = Channel.new(1); let c62 = Channel.new(1); let c63 = Channel.new(1)
    let c64 = Channel.new(1); let c65 = Channel.new(1); let c66 = Channel.new(1); let c67 = Channel.new(1)
    let c68 = Channel.new(1); let c69 = Channel.new(1); let c70 = Channel.new(1); let c71 = Channel.new(1)
    let c72 = Channel.new(1); let c73 = Channel.new(1); let c74 = Channel.new(1); let c75 = Channel.new(1)
    let c76 = Channel.new(1); let c77 = Channel.new(1); let c78 = Channel.new(1); let c79 = Channel.new(1)
    let c80 = Channel.new(1); let c81 = Channel.new(1); let c82 = Channel.new(1); let c83 = Channel.new(1)
    let c84 = Channel.new(1); let c85 = Channel.new(1); let c86 = Channel.new(1); let c87 = Channel.new(1)
    let c88 = Channel.new(1); let c89 = Channel.new(1); let c90 = Channel.new(1); let c91 = Channel.new(1)
    let c92 = Channel.new(1); let c93 = Channel.new(1); let c94 = Channel.new(1); let c95 = Channel.new(1)
    let c96 = Channel.new(1); let c97 = Channel.new(1); let c98 = Channel.new(1); let c99 = Channel.new(1)

    let mut got = 0
    supervised {
        spawn { c77.tx.send(7777) }  // одно из «средних»
        spawn {
            select {
                Some(v) = c00.rx => { got = v } Some(v) = c01.rx => { got = v } Some(v) = c02.rx => { got = v } Some(v) = c03.rx => { got = v }
                Some(v) = c04.rx => { got = v } Some(v) = c05.rx => { got = v } Some(v) = c06.rx => { got = v } Some(v) = c07.rx => { got = v }
                Some(v) = c08.rx => { got = v } Some(v) = c09.rx => { got = v } Some(v) = c10.rx => { got = v } Some(v) = c11.rx => { got = v }
                Some(v) = c12.rx => { got = v } Some(v) = c13.rx => { got = v } Some(v) = c14.rx => { got = v } Some(v) = c15.rx => { got = v }
                Some(v) = c16.rx => { got = v } Some(v) = c17.rx => { got = v } Some(v) = c18.rx => { got = v } Some(v) = c19.rx => { got = v }
                Some(v) = c20.rx => { got = v } Some(v) = c21.rx => { got = v } Some(v) = c22.rx => { got = v } Some(v) = c23.rx => { got = v }
                Some(v) = c24.rx => { got = v } Some(v) = c25.rx => { got = v } Some(v) = c26.rx => { got = v } Some(v) = c27.rx => { got = v }
                Some(v) = c28.rx => { got = v } Some(v) = c29.rx => { got = v } Some(v) = c30.rx => { got = v } Some(v) = c31.rx => { got = v }
                Some(v) = c32.rx => { got = v } Some(v) = c33.rx => { got = v } Some(v) = c34.rx => { got = v } Some(v) = c35.rx => { got = v }
                Some(v) = c36.rx => { got = v } Some(v) = c37.rx => { got = v } Some(v) = c38.rx => { got = v } Some(v) = c39.rx => { got = v }
                Some(v) = c40.rx => { got = v } Some(v) = c41.rx => { got = v } Some(v) = c42.rx => { got = v } Some(v) = c43.rx => { got = v }
                Some(v) = c44.rx => { got = v } Some(v) = c45.rx => { got = v } Some(v) = c46.rx => { got = v } Some(v) = c47.rx => { got = v }
                Some(v) = c48.rx => { got = v } Some(v) = c49.rx => { got = v } Some(v) = c50.rx => { got = v } Some(v) = c51.rx => { got = v }
                Some(v) = c52.rx => { got = v } Some(v) = c53.rx => { got = v } Some(v) = c54.rx => { got = v } Some(v) = c55.rx => { got = v }
                Some(v) = c56.rx => { got = v } Some(v) = c57.rx => { got = v } Some(v) = c58.rx => { got = v } Some(v) = c59.rx => { got = v }
                Some(v) = c60.rx => { got = v } Some(v) = c61.rx => { got = v } Some(v) = c62.rx => { got = v } Some(v) = c63.rx => { got = v }
                Some(v) = c64.rx => { got = v } Some(v) = c65.rx => { got = v } Some(v) = c66.rx => { got = v } Some(v) = c67.rx => { got = v }
                Some(v) = c68.rx => { got = v } Some(v) = c69.rx => { got = v } Some(v) = c70.rx => { got = v } Some(v) = c71.rx => { got = v }
                Some(v) = c72.rx => { got = v } Some(v) = c73.rx => { got = v } Some(v) = c74.rx => { got = v } Some(v) = c75.rx => { got = v }
                Some(v) = c76.rx => { got = v } Some(v) = c77.rx => { got = v } Some(v) = c78.rx => { got = v } Some(v) = c79.rx => { got = v }
                Some(v) = c80.rx => { got = v } Some(v) = c81.rx => { got = v } Some(v) = c82.rx => { got = v } Some(v) = c83.rx => { got = v }
                Some(v) = c84.rx => { got = v } Some(v) = c85.rx => { got = v } Some(v) = c86.rx => { got = v } Some(v) = c87.rx => { got = v }
                Some(v) = c88.rx => { got = v } Some(v) = c89.rx => { got = v } Some(v) = c90.rx => { got = v } Some(v) = c91.rx => { got = v }
                Some(v) = c92.rx => { got = v } Some(v) = c93.rx => { got = v } Some(v) = c94.rx => { got = v } Some(v) = c95.rx => { got = v }
                Some(v) = c96.rx => { got = v } Some(v) = c97.rx => { got = v } Some(v) = c98.rx => { got = v } Some(v) = c99.rx => { got = v }
            }
        }
    }
    assert(got == 7777)
}
