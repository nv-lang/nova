// Plan 83.11 §8.1 P11 — fibers_10k_sleep_cancel
//
// Production-scale regression guard for the sleep_bench cliff
// (Plan 83.10.4 Ф.6 [M-83.10.4-sleep-bench-scale-cliff]): N concurrent
// sleeps under default M:N previously SEGFAULTed / went flaky between
// 7k-10k due to UV timer storm + worker contention.
//
// Scenario: N fibers each Time.sleep(10_000) (10s — заведомо never fires),
// + 1 cancel-fiber waits 30ms then tok.cancel(). All N sleepers must wake
// within budget via cancel_all_pending → close_cb chain (Ф.8 ASYNC + Plan
// 83.10.2 cross-thread dispatch).
//
// **2026-06-05 Plan 83.11 [M-83.11-cancel-token-bound-race-2k] fix.**
// Bump-back N=2k → 10_000 restored. Closed by uncollectable token
// allocation в fibers.h::nova_cancel_token_new (Plan 83.11 V2 cancel
// races fix). Pre-fix Boehm GC reclaimed token under high fiber count
// → memory reuse corrupted bound_scope → bind panic.
//
// Stress kind: positive_stress_heavy — 10k fibers, 10k timer handles,
// 10k park/wake. External harness `tools/stress_bisect.sh` repeats the
// binary 3-5x only.
module concurrency.fibers_10k_sleep_cancel

test "10000 parked fibers — cancel wakes all within 5 seconds" {
    ro tok = CancelToken.new()
    ro t0 = Time.now()
    supervised(cancel: tok) {
        for _ in 0..10_000 {
            spawn { Time.sleep(10_000) }
        }
        spawn {
            Time.sleep(30)
            tok.cancel()
        }
    }
    ro elapsed = Time.now() - t0
    ro after_cancel = elapsed - 30

    // Wake budget: cancel_all_pending iterates 10k handles, uv_close each;
    // close_cb's batched в один-два uv_run pass. Measured ~1-3s on
    // 16-CPU dev hardware. If after_cancel > 5000ms — wake-batch regression.
    // If TIMEOUT — hung в uv_run (cancel-dispatch race или shield regression).
    assert(after_cancel < 5_000)
}
