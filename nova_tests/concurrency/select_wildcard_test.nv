// select_wildcard_test.nv — Plan 31 Ф.6: wildcard vs Some semantics.
//
// Тесты для SelectSlot.wildcard — изменение Ф.6:
//   - `_ = rx` fires on closed+empty channel (wildcard=true)
//   - `Some(v) = rx` does NOT fire on closed+empty (wildcard=false)
//   - Multi-arm: open channel beats closed when Some arm
//   - Wildcard prevents all-closed deadlock (immediate path, park не нужен)

module concurrency.select_wildcard_test

// ================================================================
// SECTION 1: Some(v) = rx — не срабатывает на closed+empty
// ================================================================

test "Some arm skips closed+empty, picks open channel with data" {
    // ch1 closed+empty, ch2 has data.
    // Some(v) = rx1 must NOT fire — no data.
    // Some(v) = rx2 must fire.
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx1.close()
    tx2.send(42)

    let mut result = 0
    select {
        Some(v) = rx1 => { result = -1 }
        Some(v) = rx2 => { result = v }
    }
    assert(result == 42)
}

test "Some arm picks data over closed: tx2.send then tx1.close" {
    // ch1 closed+empty, ch2 has data (different order of setup)
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx2.send(77)
    tx1.close()

    let mut result = 0
    select {
        Some(a) = rx1 => { result = -99 }
        Some(b) = rx2 => { result = b }
    }
    assert(result == 77)
}

// ================================================================
// SECTION 2: wildcard `_ = rx` — срабатывает на closed+empty
// ================================================================

test "wildcard fires immediately on closed+empty channel" {
    let ch = Channel.new(1)
    let tx = ch.tx
    let rx = ch.rx
    tx.close()

    let mut fired = false
    select {
        _ = rx => { fired = true }
    }
    assert(fired)
}

test "wildcard wins in multi-arm when Some channel is empty and wildcard channel is closed" {
    // ch1 open+empty, ch2 closed → only wildcard ch2 is immediately ready
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx2.close()

    let mut branch = 0
    select {
        Some(v) = rx1 => { branch = 1 }   // not ready — ch1 empty+open
        _ = rx2       => { branch = 2 }   // ready — ch2 closed (wildcard)
    }
    assert(branch == 2)
}

test "wildcard fires on closed channel even when Some arm present" {
    // ch1 closed, ch2 closed — wildcard ch2 fires
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx1.close()
    tx2.close()

    let mut branch = 0
    select {
        Some(v) = rx1 => { branch = 1 }  // closed+empty, Some → not immediate
        _ = rx2       => { branch = 2 }  // closed, wildcard → immediate
    }
    assert(branch == 2)
}

// ================================================================
// SECTION 3: смешанные сценарии — data vs closed
// ================================================================

test "Some arm data wins over wildcard closed when both arms ready" {
    // ch1 has data, ch2 closed → try_immediate may pick either (random order).
    // Valid outcomes: result==55 (Some arm) or result==-1 (wildcard arm).
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx1.send(55)
    tx2.close()

    let mut result = 0
    select {
        Some(v) = rx1 => { result = v }
        _ = rx2       => { result = -1 }
    }
    assert(result == 55 || result == -1)
}

test "wildcard in multi-arm prevents all-closed deadlock" {
    // All channels closed. Wildcard arm fires immediately — no park, no panic.
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    tx1.close()
    tx2.close()

    let mut branch = 0
    select {
        Some(v) = rx1 => { branch = 1 }  // closed+empty, Some — skipped
        _ = rx2       => { branch = 2 }  // closed, wildcard — immediate
    }
    assert(branch == 2)
}

// ================================================================
// SECTION 4: park path — Some arms на открытых пустых каналах
// ================================================================

test "Some arm parks and wakes when data arrives from another fiber" {
    // Two Some arms, both channels initially empty.
    // Fiber sends to ch2 after sleep → rx2 arm should fire.
    let ch1 = Channel.new(1)
    let ch2 = Channel.new(1)
    let tx1 = ch1.tx
    let tx2 = ch2.tx
    let rx1 = ch1.rx
    let rx2 = ch2.rx

    let mut result = 0
    supervised {
        spawn {
            Time.sleep(20)
            tx2.send(88)
        }
        spawn {
            select {
                Some(v) = rx1 => { result = -1 }
                Some(v) = rx2 => { result = v }
            }
        }
    }
    assert(result == 88)
}
