// gc_differential.nv — Plan 32: differential тест, демонстрирующий что
// Boehm реально собирает мусор.
//
// Сценарий: создаём 100k короткоживущих объектов, явно вызываем gc.collect(),
// измеряем heap_size до и после.
//
// Под --gc boehm: heap_size должен оставаться bounded (не растёт линейно с
//   числом аллокаций — большинство собрано).
// Под --gc malloc: heap_size возвращает 0 (нет introspection) — тест
//   эффективно skipped через early-return.
//
// Тест НЕ имеет ALLOC_REQUIRES — работает с любым backend'ом, потому что
// поведение разделяется через runtime check `heap_size() == 0`.

module concurrency.gc_differential

type Junk { a int, b int, c int, d int }

fn make_junk(i int) -> Junk =>
    Junk { a: i, b: i + 1, c: i + 2, d: i + 3 }

test "gc differential: heap bounded после 100k короткоживущих + collect()" {
    // Прогрев + baseline
    gc.collect()
    let h0 = gc.heap_size()

    if h0 == 0 {
        // malloc backend: skip
        println("(skip: heap_size unsupported under current backend)")
        assert(true)
    } else {
        // 100k Junk-объектов × 32 bytes = ~3.2 MB если бы все жили.
        // После gc.collect() ожидаем heap << 3.2 MB.
        let mut sum = 0
        for i in 0..100_000 {
            let j = make_junk(i)
            sum = sum + j.a
        }
        let h_peak = gc.heap_size()
        gc.collect()
        let h_after = gc.heap_size()

        println("baseline=${h0} peak=${h_peak} after_collect=${h_after}")

        // Главное assertion: после collect heap не больше peak'а
        // (collect либо уменьшил, либо оставил как есть).
        assert(h_after <= h_peak)

        // Sanity: 100k Junk без collect — heap должен быть значительно > h0
        // (Boehm не collect'ит в hot loop без давления).
        // Conservative: peak > h0.
        assert(h_peak >= h0)

        // sum sanity
        assert(sum == 4_999_950_000)
    }
}

test "gc differential: 10 раундов аллокация+collect — heap не растёт линейно" {
    gc.collect()
    let h0 = gc.heap_size()

    if h0 == 0 {
        // malloc backend: skip
        println("(skip: heap_size unsupported)")
        assert(true)
    } else {
        let mut total = 0
        let mut max_heap = h0
        for round in 0..10 {
            for i in 0..50_000 {
                let j = make_junk(i + round * 100_000)
                total = total + j.a
            }
            gc.collect()
            let h = gc.heap_size()
            if h > max_heap {
                max_heap = h
            }
        }

        println("h0=${h0} max_heap_after_collect=${max_heap}")

        // Если linear leak: 10 раундов × 50k × 32 bytes = 16 MB ростом.
        // С GC: heap должен быть bounded — у меня consery: < h0 + 4 MB.
        let bound = h0 + 4_194_304  // 4 MB headroom
        assert(max_heap < bound)
        assert(total > 0)
    }
}
