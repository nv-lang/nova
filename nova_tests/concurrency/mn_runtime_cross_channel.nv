// Plan 44.5 Layer 5 acceptance: Channel send/recv в M:N worker context.
//
// Проверяет что dispatch_ready hook корректно re-queue'ит fiber после
// Channel.recv park: sender на worker A вызывает nova_sched_wake(receiver_scope,
// slot) → dispatch_ready → receiver попадает обратно в worker deque.

module concurrency.mn_runtime_cross_channel

// --- Базовый: 1 producer, 1 consumer ---
// Consumer park'ится на recv, producer присылает значение → dispatch_ready wake.
test "M:N: Channel basic send/recv — park/wake через workers" {
    runtime.init(2)
    ro ch = Channel.new(1)
    mut received = 0
    supervised {
        spawn {
            ro v = match ch.rx.recv() {
                Some(x) => x
                None    => -1
            }
            received = v
        }
        spawn { ch.tx.send(42) }
    }
    assert(received == 42)
    runtime.shutdown()
}

// --- Pipeline: 4 producers → capacity-1 channel → 1 consumer ---
// Capacity 1 гарантирует что ≥3 из 4 producers park'атся ожидая recv.
// Это упражняет park/wake path через dispatch_ready.
test "M:N: Channel pipeline — 4 producers park/wake" {
    runtime.init(2)
    ro ch = Channel.new(1)
    mut count = 0
    supervised {
        spawn { ch.tx.send(1) }
        spawn { ch.tx.send(2) }
        spawn { ch.tx.send(3) }
        spawn { ch.tx.send(4) }
        spawn {
            mut got = 0
            while got < 4 {
                match ch.rx.recv() {
                    Some(_) => { got = got + 1; count = count + 1 }
                    None    => { got = 4 }
                }
            }
        }
    }
    assert(count == 4)
    runtime.shutdown()
}

// --- Channel + Time.sleep: комбо park/wake от таймера И от channel ---
test "M:N: Channel + Time.sleep в одном supervised" {
    runtime.init(2)
    ro ch = Channel.new(4)
    mut done = 0
    supervised {
        spawn { Time.sleep(5); ch.tx.send(1) }
        spawn { Time.sleep(5); ch.tx.send(2) }
        spawn { Time.sleep(5); ch.tx.send(3) }
        spawn { Time.sleep(5); ch.tx.send(4) }
        spawn {
            mut n = 0
            while n < 4 {
                match ch.rx.recv() {
                    Some(_) => { n = n + 1; done = done + 1 }
                    None    => { n = 4 }
                }
            }
        }
    }
    assert(done == 4)
    runtime.shutdown()
}
