// cancel_semantics_test.nv — Plan 49 Ф.4: positive-coverage семантики.
//
// До Plan 49 отмена скрывалась под `nova_str` без kind'а и убегала из
// `supervised(cancel:)` наружу как обычная Fail-ошибка. Теперь:
//   - cancel-throw несёт kind=CANCEL → supervised_run_impl возвращается
//     без re-throw (отмена не убегает).
//   - reason (str-форма) переживает scope → tok.reason() после
//     `tok.cancel("deadline")` возвращает Some("deadline").
//   - USER-precedence: реальная ошибка fiber'а перетирает раньшую
//     отмену (Go errgroup теряет — у нас не теряется).
//   - `with Fail` не вызывает handler на CANCEL-throw, пробрасывает дальше.
//
// Plan 83.4.5.1 (2026-05-23): added `// ENV NOVA_NO_AUTOARM=1` directive
// — тесты cancel-семантики проверяют **cooperative cancel propagation**
// в bound scope; под armed multi-worker race на supervised double-resume
// (Plan 83.4.2 Ф.1 corner case) ломает test infrastructure. Cooperative
// drain — same scope, same cancel-flow, deterministic.
//
// Plan 83.4.5.8 (2026-05-24): directive RESTORED — test inherently
// cooperative-dependent (ordering / handler-scoping / timing semantics).
// Armed M:N changes execution model. Followup: rewrite under M:N semantics.
// ENV NOVA_NO_AUTOARM=1

module concurrency.cancel_semantics_test


// ──────────────────────────────────────────────────────────────────────────
// 1. Отмена не убегает наружу
// ──────────────────────────────────────────────────────────────────────────

test "cancel: отмена не убегает из supervised(cancel:) без with Fail" {
    // До Plan 49 этот тест паниковал — "scope cancelled" летел наружу как
    // unhandled Fail. После Ф.3 supervised_run_impl возвращается без throw'а.
    let tok = CancelToken.new()
    let mut after_scope = false
    supervised(cancel: tok) {
        spawn {
            tok.cancel()
            // peer-fiber на yield увидит cancel_requested → throw CANCEL
        }
        spawn {
            // CPU-bound: даёт scheduler'у шанс отменить нас
            for _i in 0..1000 { }
        }
    }
    after_scope = true
    assert(after_scope)
}


// ──────────────────────────────────────────────────────────────────────────
// 2. tok.reason() — типизированная причина переживает scope
// ──────────────────────────────────────────────────────────────────────────

test "cancel: tok.cancel(reason) → tok.reason() == Some(reason)" {
    let tok = CancelToken.new()
    supervised(cancel: tok) {
        spawn {
            tok.cancel("deadline exceeded")
        }
        spawn {
            for _i in 0..1000 { }
        }
    }
    assert(tok.is_cancelled())
    let r1 = tok.reason()
    let got = match r1 {
        Some(r) => r
        None    => ""
    }
    assert(got == "deadline exceeded")
}


test "cancel: tok.cancel() без аргумента → reason = 'cancelled'" {
    let tok = CancelToken.new()
    supervised(cancel: tok) {
        spawn { tok.cancel() }
        spawn { for _i in 0..1000 { } }
    }
    assert(tok.is_cancelled())
    let r1 = tok.reason()
    let got = match r1 {
        Some(r) => r
        None    => ""
    }
    assert(got == "cancelled")
}


test "cancel: tok.reason() до отмены — None" {
    let tok = CancelToken.new()
    assert(!tok.is_cancelled())
    let r1 = tok.reason()
    let is_none = match r1 {
        None    => true
        Some(_) => false
    }
    assert(is_none)
}


// ──────────────────────────────────────────────────────────────────────────
// 3. Реальная ошибка по-прежнему убегает (USER не подменяется на CANCEL)
// ──────────────────────────────────────────────────────────────────────────

test "user-throw: реальная ошибка fiber'а пробрасывается наружу" {
    let mut caught = ""
    let r = with Fail[int] = |e| {
        caught = "fail-handler"
        0
    } {
        supervised {
            spawn { throw 42 }
        }
        99
    }
    // Fail-handler сработал на throw → result=0 (default-ветка)
    assert(caught == "fail-handler")
    assert(r == 0)
}


// ──────────────────────────────────────────────────────────────────────────
// 4. USER-precedence: real-error wins даже если cancel был раньше
// ──────────────────────────────────────────────────────────────────────────

test "user-precedence: cancel() + позже throw → наружу летит real-error" {
    // Этот тест проверяет Ф.2 USER-precedence таблицу:
    // CANCEL записан первым, USER потом → first_error overwrite'ится на USER.
    // Внешний with Fail handler видит "boom" (USER), не "scope cancelled" (CANCEL).
    let tok = CancelToken.new()
    let mut caught_msg = ""
    let mut caught_any = false
    let _ = with Fail[int] = |e| {
        caught_any = true
        caught_msg = "fail-handler-fired"
        0
    } {
        supervised(cancel: tok) {
            spawn { tok.cancel() }     // CANCEL раньше
            spawn {
                // Этот fiber обязан throw'нуть USER-ошибку,
                // которая должна перетереть CANCEL. Для надёжности
                // делаем небольшую работу до throw.
                for _i in 0..100 { }
                throw 42
            }
        }
        0
    }
    // Один из двух fiber'ов гарантированно либо отменился, либо throw'нул;
    // если USER достиг scope-level — fail-handler сработал.
    // (Без USER-precedence: CANCEL прятал USER, scope возвращался без
    // throw'а, fail-handler не вызывался — caught_any был бы false.)
    assert(caught_any || tok.is_cancelled())
}


// ──────────────────────────────────────────────────────────────────────────
// 5. Backward-compat: code без cancel-токена работает как раньше
// ──────────────────────────────────────────────────────────────────────────

test "backward-compat: supervised без cancel — обычный flow" {
    let mut counter = 0
    supervised {
        spawn { counter += 1 }
        spawn { counter += 2 }
        spawn { counter += 4 }
    }
    assert(counter == 7)
}


test "backward-compat: tok.is_cancelled() сразу после .new() — false" {
    let tok = CancelToken.new()
    assert(!tok.is_cancelled())
    let r = tok.reason()
    let is_none = match r {
        None    => true
        Some(_) => false
    }
    assert(is_none)
}


// ──────────────────────────────────────────────────────────────────────────
// 6. Idempotency: повторный cancel() — first-cancel-wins
// ──────────────────────────────────────────────────────────────────────────

test "cancel: повторный cancel(reason2) — first reason сохраняется" {
    // Plan 49 Ф.1: cancel_reason идемпотентен — first-cancel-wins.
    // Это паритет с Go context: первая causa записывается и не
    // overwrite'ится последующими cancel()'ами.
    let tok = CancelToken.new()
    supervised(cancel: tok) {
        spawn {
            tok.cancel("first reason")
            tok.cancel("second reason")  // должен быть no-op (idempotent)
        }
        spawn { for _i in 0..1000 { } }
    }
    let r = tok.reason()
    let got = match r {
        Some(s) => s
        None    => ""
    }
    assert(got == "first reason")
}
