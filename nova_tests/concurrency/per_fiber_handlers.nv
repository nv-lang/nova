// per_fiber_handlers.nv — D-handler-scope: handlers per-fiber, не shared.
//
// Проверяет что разные fibers внутри supervised могут устанавливать
// собственные `with X = handler { ... }` биндинги, и handler одного
// fiber'а НЕ видим другому.
//
// Без per-fiber snapshot (см. effects.h NovaEffectSnapshot +
// fibers.h::nova_supervised_step) handlers лежали бы в shared
// __declspec(thread) globals — fiber A установил handler, yield,
// fiber B перезаписал — A после resume увидел бы handler от B.
// Это классический bug кооперативной shared-state модели.
//
// Реализация (см. effects.h): nova_register_effect_storage регистрирует
// все handler-storages при старте. supervised_step save/restore
// snapshot вокруг mco_resume.

// Plan 83.4.5.4 (2026-05-23): cooperative handler-scoping test — armed
// multi-worker double-resume race ломает test infrastructure.
// Plan 83.4.5.8 (2026-05-24): directive RESTORED — test inherently
// cooperative-dependent (ordering / handler-scoping / timing semantics).
// Plan 83.10.1 (2026-05-26): AUTOARM=0 needed — [M-83.10.1-per-fiber-handler-tls-race]:
// _nova_effect_registry was a global singleton storing main-thread TLS addresses;
// workers wrote to main's TLS variables, not their own.
// Plan 83.10.4 Ф.3 (2026-05-27): FIXED — _nova_effect_registry now per-thread TLS;
// each worker registers its own TLS handler addresses at startup;
// pre-preamble restore of _nova_init_snapshot on first fiber run.
// AUTOARM=0 directive removed — test passes under full M:N armed mode.


module concurrency.per_fiber_handlers

// ================================================================
// SECTION 1: Разные Time handlers в разных fiber'ах
// ================================================================

fn helper_with_clock_100() -> int {
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 100 }
    } {
        Time.now()
    }
}

fn helper_with_clock_200() -> int {
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 200 }
    } {
        Time.now()
    }
}

test "per-fiber Time handlers — разные значения в разных fibers" {
    mut a = -1
    mut b = -1
    supervised {
        spawn { a = helper_with_clock_100() }
        spawn { b = helper_with_clock_200() }
    }
    assert(a == 100)
    assert(b == 200)
}

// ================================================================
// SECTION 2: Outer handler наследуется в spawn'ах через snapshot save
// ================================================================

test "spawn наследует outer with-handler" {
    mut got = -1
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 42 }
    } {
        supervised {
            spawn {
                got = Time.now()         // должен видеть outer handler = 42
            }
        }
    }
    assert(got == 42)
}

// ================================================================
// SECTION 3: Inner with в spawn перекрывает outer
// ================================================================

fn helper_with_nested() -> int {
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 999 }
    } {
        Time.now()
    }
}

test "inner with в spawn перекрывает outer для своего fiber" {
    mut outer_seen = -1
    mut inner_seen = -1
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 111 }
    } {
        supervised {
            spawn { outer_seen = Time.now() }      // видит outer = 111
            spawn { inner_seen = helper_with_nested() }  // inner with → 999
        }
    }
    assert(outer_seen == 111)
    assert(inner_seen == 999)
}

// ================================================================
// SECTION 4: Outer handler сохраняется после spawn-завершения
// ================================================================

test "outer handler не затирается завершившимися fibers" {
    mut outer_after = -1
    with Time = effect Time {
        sleep(_ms) { return () }
        now() { return 555 }
    } {
        supervised {
            spawn { ro _ = helper_with_clock_100() }
            spawn { ro _ = helper_with_clock_200() }
        }
        // Здесь, после supervised, outer handler должен снова быть 555.
        // Без правильного snapshot restore — затёрся бы последним fiber'ом.
        outer_after = Time.now()
    }
    assert(outer_after == 555)
}
