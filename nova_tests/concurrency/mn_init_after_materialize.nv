// Plan 83.1 Ф.4: runtime.init ПОСЛЕ материализации пула (после первого
// spawn) — диагностируемый no-op на stderr: тюнер опоздал, цель уже
// зафиксирована и пул поднят. Не abort — существующий пул корректен.
// EXPECT_STDERR already materialized
module concurrency.mn_init_after_materialize

test "init after first spawn is a diagnosed no-op" {
    runtime.init(2)
    mut x = 0
    supervised {
        spawn { x = 1 }
    }
    assert(x == 1)
    // Пул материализован — повторный init опоздал, диагностируется.
    runtime.init(8)
    // Пул не пересоздан: worker_count() остаётся 2, не 8.
    assert(runtime.worker_count() == 2)
    runtime.shutdown()
}
