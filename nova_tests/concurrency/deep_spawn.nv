// deep_spawn_test.nv — Nova-level deep spawn/fiber tests
//
// Verifies: execution ordering, capture semantics, mutation visibility,
// pipeline chaining, state-machine patterns, nested spawns, and
// correctness under high spawn count.
//
// C-level counterpart: compiler-codegen/nova_rt/test_fibers_deep.c
// That file tests stack addresses, yield/resume ordering, fib(30), etc.
// This file tests the observable Nova semantics built on top of that runtime.

module concurrency.deep_spawn

type Counter {
    val int
}

type Stage {
    input  int
    output int
}

fn make_counter(val int) -> Counter => { val }
fn make_stage(input int, output int) -> Stage => { input, output }

fn fib(n int) -> int {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < n {
        let t = a + b
        a = b
        b = t
        i += 1
    }
    a
}

fn sum_range(n int) -> int {
    let mut acc = 0
    let mut i = 1
    while i <= n {
        acc += i
        i += 1
    }
    acc
}

fn factorial(n int) -> int {
    let mut acc = 1
    let mut i = 1
    while i <= n {
        acc = acc * i
        i += 1
    }
    acc
}

// ================================================================
// SECTION 1: execution ordering — spawn body completes before scope exit
//
// Spec D50/D71: spawn внутри supervised — fire-and-forget statement,
// возвращает unit. Результаты — через mut-захваты (см. ниже).
// scope-exit ждёт всех spawn'ов, поэтому assert после supervised
// видит уже-применённые мутации.
// ================================================================

test "supervised: single spawn mutation visible after scope exit" {
    let mut log = 0
    supervised {
        spawn { log = 1 }
    }
    assert(log == 1)
}

test "supervised: three spawns mutate shared state" {
    // No yields inside fibers → cooperative-only scheduler runs them
    // sequentially in FIFO order: 1, 2, 3.
    let mut seq = 0
    supervised {
        spawn { seq = seq * 10 + 1 }
        spawn { seq = seq * 10 + 2 }
        spawn { seq = seq * 10 + 3 }
    }
    assert(seq == 123)
}

test "supervised: 10 spawns in loop, mutations accumulate" {
    let mut acc = 0
    supervised {
        let mut i = 0
        while i < 10 {
            let cur = i
            spawn { acc += cur + 1 }   // adds 1,2,...,10
            i += 1
        }
    }
    // 1+2+...+10 = 55
    assert(acc == 55)
}

test "supervised: result via mut capture (no spawn-result needed)" {
    let x = 7
    let mut r = 0
    supervised {
        spawn { r = x * x * x }   // 343
    }
    let r2 = r + 1
    assert(r == 343)
    assert(r2 == 344)
}

// ================================================================
// SECTION 2: capture semantics
// ================================================================

test "supervised: captures immutable int, writes via mut" {
    let n = 42
    let mut r = 0
    supervised { spawn { r = n * 2 } }
    assert(r == 84)
}

test "supervised: captures multiple immutable vars" {
    let a = 3
    let b = 4
    let c = 5
    let mut r = 0
    supervised { spawn { r = a * a + b * b + c * c } }   // 9 + 16 + 25 = 50
    assert(r == 50)
}

test "supervised: captures mutable var, mutation visible" {
    let mut x = 10
    supervised { spawn { x = x * 3 } }
    assert(x == 30)
}

test "supervised: two fibers capture same mutable var, both mutations apply" {
    let mut n = 0
    supervised {
        spawn { n += 5 }
        spawn { n += 3 }
    }
    assert(n == 8)
}

test "supervised: captures result of function call" {
    let n = 10
    let mut r = 0
    supervised { spawn { r = sum_range(n) } }   // 55
    assert(r == 55)
}

test "supervised: captures result of expensive function" {
    let mut r = 0
    supervised { spawn { r = fib(20) } }   // 6765
    assert(r == 6765)
}

// ================================================================
// SECTION 3: pipeline chaining via sequential supervised scopes.
//
// Note: spawn-результат не передаётся между fiber'ами. Поэтому
// pipeline стадии — отдельные supervised-блоки с mut-захватами,
// либо просто прямые вызовы (async прозрачный — D62).
// ================================================================

test "pipeline: 2 stages via prior values" {
    let x = 6
    let mut s1 = 0
    let mut s2 = 0
    supervised { spawn { s1 = x * x } }            // 36
    supervised { spawn { s2 = s1 + s1 } }          // 72
    assert(s1 == 36)
    assert(s2 == 72)
}

test "pipeline: 3 stages doubling-squared" {
    let base = 2
    let mut s1 = 0; let mut s2 = 0; let mut s3 = 0
    supervised { spawn { s1 = base * base } }       // 4
    supervised { spawn { s2 = s1 * s1 } }          // 16
    supervised { spawn { s3 = s2 * s2 } }          // 256
    assert(s1 == 4)
    assert(s2 == 16)
    assert(s3 == 256)
}

test "pipeline: 5 stages doubling" {
    let start = 1
    let mut v1 = 0; let mut v2 = 0; let mut v3 = 0; let mut v4 = 0; let mut v5 = 0
    supervised { spawn { v1 = start + 1 } }   // 2
    supervised { spawn { v2 = v1 * 2 } }      // 4
    supervised { spawn { v3 = v2 * 2 } }      // 8
    supervised { spawn { v4 = v3 * 2 } }      // 16
    supervised { spawn { v5 = v4 * 2 } }      // 32
    assert(v1 == 2)
    assert(v3 == 8)
    assert(v5 == 32)
}

test "pipeline: fork and join (two parallel + one combiner)" {
    let x = 10
    let mut left = 0
    let mut right = 0
    supervised {
        spawn { left = x + 1 }      // 11
        spawn { right = x * x }     // 100
    }
    let mut joined = 0
    supervised { spawn { joined = left + right } }   // 111
    assert(left == 11)
    assert(right == 100)
    assert(joined == 111)
}

// ================================================================
// SECTION 4: state machine via mutation
// ================================================================

test "state machine: 3-state protocol" {
    let mut state = 0
    let mut partial = 0
    let mut result = 0
    let input = 7

    supervised {
        spawn {
            state = 1
            partial = input * 2   // 14
        }
    }
    assert(state == 1)
    assert(partial == 14)
    assert(result == 0)

    supervised {
        spawn {
            result = partial + input   // 14 + 7 = 21
            state = 2
        }
    }
    assert(state == 2)
    assert(result == 21)
}

test "state machine: 5-step accumulator" {
    let mut step = 0
    let mut total = 0

    supervised { spawn { step = 1; total += 1 } }
    assert(step == 1); assert(total == 1)

    supervised { spawn { step = 2; total += 2 } }
    assert(step == 2); assert(total == 3)

    supervised { spawn { step = 3; total += 4 } }
    assert(step == 3); assert(total == 7)

    supervised { spawn { step = 4; total += 8 } }
    assert(step == 4); assert(total == 15)

    supervised { spawn { step = 5; total += 16 } }
    assert(step == 5); assert(total == 31)
}

// ================================================================
// SECTION 5: many fibers
// ================================================================

test "supervised: 100 fibers, sum correct" {
    let mut total = 0
    supervised {
        let mut i = 1
        while i <= 100 {
            let cur = i
            spawn { total += cur }
            i += 1
        }
    }
    assert(total == 5050)
}

test "supervised: 500 fibers, sum of squares" {
    let mut total = 0
    supervised {
        let mut i = 0
        while i < 500 {
            let cur = i
            spawn { total += cur * cur }
            i += 1
        }
    }
    // sum(i^2, i=0..499) = 41541750
    assert(total == 41541750)
}

// ================================================================
// SECTION 6: factorial and recursive calls inside spawn
// ================================================================

test "spawn: factorial(10) via mut capture" {
    let n = 10
    let mut r = 0
    supervised { spawn { r = factorial(n) } }
    assert(r == 3628800)
}

test "spawn: fib(25) via mut capture" {
    let mut r = 0
    supervised { spawn { r = fib(25) } }
    assert(r == 75025)
}

test "spawn: sum_range(1000) via mut capture" {
    let n = 1000
    let mut r = 0
    supervised { spawn { r = sum_range(n) } }
    assert(r == 500500)
}

// ================================================================
// SECTION 7: mutation accumulates across many fibers
// ================================================================

test "spawn: factorial via sequential spawn mutations" {
    let mut acc = 1
    supervised {
        let mut i = 1
        while i <= 12 {
            let cur = i
            spawn { acc = acc * cur }
            i += 1
        }
    }
    assert(acc == 479001600)   // 12!
}

test "spawn: alternating add/multiply pattern" {
    let mut val = 1
    supervised {
        let mut i = 0
        while i < 10 {
            let cur = i
            spawn {
                if cur * 2 == cur + cur {
                    val = val + cur + 1
                }
            }
            i += 1
        }
    }
    assert(val == 56)   // 1 + sum(1..10)
}

// ================================================================
// SECTION 8: captures of records inside spawn
// ================================================================

test "spawn: record field accessed via mut capture" {
    let c = make_counter(42)
    let mut r = 0
    supervised { spawn { r = c.val * 2 } }
    assert(r == 84)
}

test "spawn: int captured from record before spawn" {
    let c = make_counter(100)
    let cap = c.val
    let mut result = 0
    supervised { spawn { result = cap + 1 } }
    assert(result == 101)
}

test "pipeline: records through sequential spawn stages" {
    let s1_in = 5
    let s1 = make_stage(s1_in, 0)
    let mut r1 = 0
    supervised { spawn { r1 = s1.input * s1.input } }   // 25

    let s2_in = r1
    let s2 = make_stage(s2_in, 0)
    let mut r2 = 0
    supervised { spawn { r2 = s2.input + 1 } }          // 26

    assert(r1 == 25)
    assert(r2 == 26)
}

// ================================================================
// SECTION 9: independence — two mutable vars, each touched by one fiber
// ================================================================

test "supervised: independent mutations don't interfere" {
    let mut a = 0
    let mut b = 0
    supervised {
        spawn { a = 111 }
        spawn { b = 222 }
    }
    assert(a == 111)
    assert(b == 222)
}

test "supervised: 10 independent pairs, no cross-contamination" {
    let mut r0 = 0
    let mut r1 = 0
    let mut r2 = 0
    let mut r3 = 0
    let mut r4 = 0
    let mut r5 = 0
    let mut r6 = 0
    let mut r7 = 0
    let mut r8 = 0
    let mut r9 = 0

    supervised {
        spawn { r0 = 0 * 7 + 1 }
        spawn { r1 = 1 * 7 + 1 }
        spawn { r2 = 2 * 7 + 1 }
        spawn { r3 = 3 * 7 + 1 }
        spawn { r4 = 4 * 7 + 1 }
        spawn { r5 = 5 * 7 + 1 }
        spawn { r6 = 6 * 7 + 1 }
        spawn { r7 = 7 * 7 + 1 }
        spawn { r8 = 8 * 7 + 1 }
        spawn { r9 = 9 * 7 + 1 }
    }

    assert(r0 == 1)
    assert(r1 == 8)
    assert(r2 == 15)
    assert(r3 == 22)
    assert(r4 == 29)
    assert(r5 == 36)
    assert(r6 == 43)
    assert(r7 == 50)
    assert(r8 == 57)
    assert(r9 == 64)
}

// ================================================================
// SECTION 10: cooperative scheduling — REAL coroutine interleave
// via supervised + Time.sleep(0).
//
// Spec: D14, D50, D62 — Time.sleep is a yield-point. Without
// timer-wheel, sleep(0) just yields control to scheduler. Inside
// `supervised { }`, multiple spawns coexist in a queue; the
// scheduler runs round-robin until all complete. With deterministic
// FIFO order, observable interleaving is exact.
//
// Encoding: each fiber writes single decimal digits into a shared
// `mut log` via `log = log * 10 + N`. The final value reveals the
// exact order of writes.
// ================================================================

test "supervised: two fibers interleave at every yield" {
    // A writes 1, yield, 2, yield, 3.
    // B writes 4, yield, 5, yield, 6.
    // FIFO scheduler with sleep(0) yields after each write:
    //   A1 → B4 → A2 → B5 → A3 → B6
    // Encoded: 1,4,2,5,3,6 → 142536
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2"); log = log * 10 + 2
            Time.sleep(0)
            println("A: 3"); log = log * 10 + 3
        }
        spawn {
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 5"); log = log * 10 + 5
            Time.sleep(0)
            println("B: 6"); log = log * 10 + 6
        }
    }
    println("two-fibers final log = ", log)
    assert(log == 142536)
}

test "supervised: three fibers interleave round-robin" {
    // Three fibers, each writes 2 digits with one yield between:
    //   A: 1, yield, 2
    //   B: 3, yield, 4
    //   C: 5, yield, 6
    // Round-robin: A1, B3, C5, A2, B4, C6 → 135246
    let mut log = 0
    supervised {
        spawn {
            println("A first"); log = log * 10 + 1
            Time.sleep(0)
            println("A second"); log = log * 10 + 2
        }
        spawn {
            println("B first"); log = log * 10 + 3
            Time.sleep(0)
            println("B second"); log = log * 10 + 4
        }
        spawn {
            println("C first"); log = log * 10 + 5
            Time.sleep(0)
            println("C second"); log = log * 10 + 6
        }
    }
    println("three-fibers final log = ", log)
    assert(log == 135246)
}

test "supervised: fiber without yield runs to completion before others" {
    // Without Time.sleep, a fiber runs straight through — no preemption
    // (cooperative-only). A writes 1,2,3 first; only after A dies does
    // B get scheduled and write 4,5,6.
    //   Encoded: 1,2,3,4,5,6 → 123456
    let mut log = 0
    supervised {
        spawn {
            println("A runs all 3 (no yield)")
            log = log * 10 + 1
            log = log * 10 + 2
            log = log * 10 + 3
        }
        spawn {
            println("B runs all 3 (after A done)")
            log = log * 10 + 4
            log = log * 10 + 5
            log = log * 10 + 6
        }
    }
    println("no-yield final log = ", log)
    assert(log == 123456)
}

test "supervised: yield count equals interleave depth" {
    // A yields twice: writes 1, 3, 5
    // B yields twice: writes 2, 4, 6
    // After every write, yield → strictly alternating: 1,2,3,4,5,6 → 123456
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("A: 5"); log = log * 10 + 5
        }
        spawn {
            println("B: 2"); log = log * 10 + 2
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 6"); log = log * 10 + 6
        }
    }
    println("strict-alternation log = ", log)
    assert(log == 123456)
}

test "supervised: yields uneven, fiber A finishes first" {
    // A: 1, yield, 2 (one yield)
    // B: 3, yield, 4, yield, 5 (two yields)
    // Order: A1, B3, A2 (A done), B4, B5 → 13245
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2 (done)"); log = log * 10 + 2
        }
        spawn {
            println("B: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 5 (done)"); log = log * 10 + 5
        }
    }
    println("uneven log = ", log)
    assert(log == 13245)
}

test "supervised: producer-consumer pattern via shared mut + yields" {
    // Producer fiber writes values 1..5 to `slot`, yields after each.
    // Consumer fiber reads `slot` after each yield, accumulates `received`.
    // Because producer writes BEFORE its yield, then consumer is scheduled,
    // consumer sees each fresh value exactly once.
    let mut slot = 0
    let mut received = 0
    let mut producer_done = false
    supervised {
        spawn {
            let mut i = 1
            while i <= 5 {
                slot = i
                println("  producer: slot = ", i)
                Time.sleep(0)   // hand off to consumer
                i += 1
            }
            producer_done = true
        }
        spawn {
            let mut count = 0
            while count < 5 {
                println("  consumer: read ", slot)
                received += slot   // pick up current value
                Time.sleep(0)      // wait for next produce
                count += 1
            }
        }
    }
    println("producer-consumer received = ", received)
    // Consumer sees slot at: 1, 2, 3, 4, 5 → sum = 15
    assert(received == 15)
    assert(producer_done)
}

test "supervised: 4 fibers, 1 yield each, round-robin order" {
    // FIFO scheduler: A,B,C,D each write a digit, yield, write next.
    //   A1, B3, C5, D7, A2, B4, C6, D8 → 13572468
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2"); log = log * 10 + 2
        }
        spawn {
            println("B: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
        }
        spawn {
            println("C: 5"); log = log * 10 + 5
            Time.sleep(0)
            println("C: 6"); log = log * 10 + 6
        }
        spawn {
            println("D: 7"); log = log * 10 + 7
            Time.sleep(0)
            println("D: 8"); log = log * 10 + 8
        }
    }
    println("4-fibers log = ", log)
    assert(log == 13572468)
}

test "supervised: yield inside loop, fiber lifetime spans many iterations" {
    // A counts 0..3 with yield between each step; B counts 10,20,30 likewise.
    // Each fiber visits 3 write-yield cycles. Total writes: 6, fully alternating.
    //   A0, B10, A1, B20, A2, B30 → log records sum at each step on B side.
    let mut a_steps = 0
    let mut b_steps = 0
    let mut order = 0
    supervised {
        spawn {
            let mut i = 0
            while i < 3 {
                a_steps += 1
                println("  A iteration ", i)
                order = order * 10 + 1   // A marker
                Time.sleep(0)
                i += 1
            }
        }
        spawn {
            let mut j = 0
            while j < 3 {
                b_steps += 1
                println("  B iteration ", j)
                order = order * 10 + 2   // B marker
                Time.sleep(0)
                j += 1
            }
        }
    }
    println("loop-spans order = ", order)
    assert(a_steps == 3)
    assert(b_steps == 3)
    assert(order == 121212)   // strict alternation A,B,A,B,A,B
}

test "supervised: nested supervised — inner scope completes before outer continues" {
    // Outer supervised has fiber X. X itself contains an inner supervised
    // with fibers Y1, Y2 that interleave; Y must finish before X continues.
    let mut order = 0
    supervised {
        spawn {
            println("X starts"); order = order * 10 + 1
            supervised {
                spawn {
                    println("  Y1 first"); order = order * 10 + 2
                    Time.sleep(0)
                    println("  Y1 second"); order = order * 10 + 4
                }
                spawn {
                    println("  Y2 first"); order = order * 10 + 3
                    Time.sleep(0)
                    println("  Y2 second"); order = order * 10 + 5
                }
            }
            // Inner finished: 2,3,4,5 appended (interleaved)
            println("X resumes"); order = order * 10 + 6     // X resumes
        }
    }
    println("nested order = ", order)
    // 1 (X), 2,3,4,5 (Y1+Y2 interleaved), 6 (X) → 123456
    assert(order == 123456)
}
