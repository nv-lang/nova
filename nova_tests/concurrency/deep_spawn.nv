// deep_spawn_test.nv — Nova-level deep spawn/fiber tests
//
// Verifies: execution ordering, capture semantics, mutation visibility,
// pipeline chaining, state-machine patterns, nested spawns, and
// correctness under high spawn count.
//
// C-level counterpart: compiler-codegen/nova_rt/test_fibers_deep.c
// That file tests stack addresses, yield/resume ordering, fib(30), etc.
// This file tests the observable Nova semantics built on top of that runtime.

module concurrency.deep_spawn

type Counter {
    val int
}

type Stage {
    input  int
    output int
}

fn make_counter(val int) -> Counter => { val }
fn make_stage(input int, output int) -> Stage => { input, output }

fn fib(n int) -> int {
    mut a = 0
    mut b = 1
    mut i = 0
    while i < n {
        ro t = a + b
        a = b
        b = t
        i += 1
    }
    a
}

fn sum_range(n int) -> int {
    mut acc = 0
    mut i = 1
    while i <= n {
        acc += i
        i += 1
    }
    acc
}

fn factorial(n int) -> int {
    mut acc = 1
    mut i = 1
    while i <= n {
        acc = acc * i
        i += 1
    }
    acc
}

// ================================================================
// SECTION 1: execution ordering — spawn body completes before scope exit
//
// Spec D50/D71: spawn внутри supervised — fire-and-forget statement,
// возвращает unit. Результаты — через mut-захваты (см. ниже).
// scope-exit ждёт всех spawn'ов, поэтому assert после supervised
// видит уже-применённые мутации.
// ================================================================

test "supervised: single spawn mutation visible after scope exit" {
    mut log = 0
    supervised {
        spawn { log = 1 }
    }
    assert(log == 1)
}

test "supervised: three spawns mutate shared state" {
    // No yields inside fibers → cooperative-only scheduler runs them
    // sequentially in FIFO order: 1, 2, 3.
    mut seq = 0
    supervised {
        spawn { seq = seq * 10 + 1 }
        spawn { seq = seq * 10 + 2 }
        spawn { seq = seq * 10 + 3 }
    }
    assert(seq == 123)
}

test "supervised: 10 spawns in loop, mutations accumulate" {
    mut acc = 0
    supervised {
        mut i = 0
        while i < 10 {
            ro cur = i
            spawn { acc += cur + 1 }   // adds 1,2,...,10
            i += 1
        }
    }
    // 1+2+...+10 = 55
    assert(acc == 55)
}

test "supervised: result via mut capture (no spawn-result needed)" {
    ro x = 7
    mut r = 0
    supervised {
        spawn { r = x * x * x }   // 343
    }
    ro r2 = r + 1
    assert(r == 343)
    assert(r2 == 344)
}

// ================================================================
// SECTION 2: capture semantics
// ================================================================

test "supervised: captures immutable int, writes via mut" {
    ro n = 42
    mut r = 0
    supervised { spawn { r = n * 2 } }
    assert(r == 84)
}

test "supervised: captures multiple immutable vars" {
    ro a = 3
    ro b = 4
    ro c = 5
    mut r = 0
    supervised { spawn { r = a * a + b * b + c * c } }   // 9 + 16 + 25 = 50
    assert(r == 50)
}

test "supervised: captures mutable var, mutation visible" {
    mut x = 10
    supervised { spawn { x = x * 3 } }
    assert(x == 30)
}

test "supervised: two fibers capture same mutable var, both mutations apply" {
    mut n = 0
    supervised {
        spawn { n += 5 }
        spawn { n += 3 }
    }
    assert(n == 8)
}

test "supervised: captures result of function call" {
    ro n = 10
    mut r = 0
    supervised { spawn { r = sum_range(n) } }   // 55
    assert(r == 55)
}

test "supervised: captures result of expensive function" {
    mut r = 0
    supervised { spawn { r = fib(20) } }   // 6765
    assert(r == 6765)
}

// ================================================================
// SECTION 3: pipeline chaining via sequential supervised scopes.
//
// Note: spawn-результат не передаётся между fiber'ами. Поэтому
// pipeline стадии — отдельные supervised-блоки с mut-захватами,
// либо просто прямые вызовы (async прозрачный — D62).
// ================================================================

test "pipeline: 2 stages via prior values" {
    ro x = 6
    mut s1 = 0
    mut s2 = 0
    supervised { spawn { s1 = x * x } }            // 36
    supervised { spawn { s2 = s1 + s1 } }          // 72
    assert(s1 == 36)
    assert(s2 == 72)
}

test "pipeline: 3 stages doubling-squared" {
    ro base = 2
    mut s1 = 0; mut s2 = 0; mut s3 = 0
    supervised { spawn { s1 = base * base } }       // 4
    supervised { spawn { s2 = s1 * s1 } }          // 16
    supervised { spawn { s3 = s2 * s2 } }          // 256
    assert(s1 == 4)
    assert(s2 == 16)
    assert(s3 == 256)
}

test "pipeline: 5 stages doubling" {
    ro start = 1
    mut v1 = 0; mut v2 = 0; mut v3 = 0; mut v4 = 0; mut v5 = 0
    supervised { spawn { v1 = start + 1 } }   // 2
    supervised { spawn { v2 = v1 * 2 } }      // 4
    supervised { spawn { v3 = v2 * 2 } }      // 8
    supervised { spawn { v4 = v3 * 2 } }      // 16
    supervised { spawn { v5 = v4 * 2 } }      // 32
    assert(v1 == 2)
    assert(v3 == 8)
    assert(v5 == 32)
}

test "pipeline: fork and join (two parallel + one combiner)" {
    ro x = 10
    mut left = 0
    mut right = 0
    supervised {
        spawn { left = x + 1 }      // 11
        spawn { right = x * x }     // 100
    }
    mut joined = 0
    supervised { spawn { joined = left + right } }   // 111
    assert(left == 11)
    assert(right == 100)
    assert(joined == 111)
}

// ================================================================
// SECTION 4: state machine via mutation
// ================================================================

test "state machine: 3-state protocol" {
    mut state = 0
    mut partial = 0
    mut result = 0
    ro input = 7

    supervised {
        spawn {
            state = 1
            partial = input * 2   // 14
        }
    }
    assert(state == 1)
    assert(partial == 14)
    assert(result == 0)

    supervised {
        spawn {
            result = partial + input   // 14 + 7 = 21
            state = 2
        }
    }
    assert(state == 2)
    assert(result == 21)
}

test "state machine: 5-step accumulator" {
    mut step = 0
    mut total = 0

    supervised { spawn { step = 1; total += 1 } }
    assert(step == 1); assert(total == 1)

    supervised { spawn { step = 2; total += 2 } }
    assert(step == 2); assert(total == 3)

    supervised { spawn { step = 3; total += 4 } }
    assert(step == 3); assert(total == 7)

    supervised { spawn { step = 4; total += 8 } }
    assert(step == 4); assert(total == 15)

    supervised { spawn { step = 5; total += 16 } }
    assert(step == 5); assert(total == 31)
}

// ================================================================
// SECTION 5: many fibers
// ================================================================

test "supervised: 100 fibers, sum correct" {
    mut total = 0
    supervised {
        mut i = 1
        while i <= 100 {
            ro cur = i
            spawn { total += cur }
            i += 1
        }
    }
    assert(total == 5050)
}

test "supervised: 500 fibers, sum of squares" {
    mut total = 0
    supervised {
        mut i = 0
        while i < 500 {
            ro cur = i
            spawn { total += cur * cur }
            i += 1
        }
    }
    // sum(i^2, i=0..499) = 41541750
    assert(total == 41541750)
}

// ================================================================
// SECTION 6: factorial and recursive calls inside spawn
// ================================================================

test "spawn: factorial(10) via mut capture" {
    ro n = 10
    mut r = 0
    supervised { spawn { r = factorial(n) } }
    assert(r == 3628800)
}

test "spawn: fib(25) via mut capture" {
    mut r = 0
    supervised { spawn { r = fib(25) } }
    assert(r == 75025)
}

test "spawn: sum_range(1000) via mut capture" {
    ro n = 1000
    mut r = 0
    supervised { spawn { r = sum_range(n) } }
    assert(r == 500500)
}

// ================================================================
// SECTION 7: mutation accumulates across many fibers
// ================================================================

test "spawn: factorial via sequential spawn mutations" {
    mut acc = 1
    supervised {
        mut i = 1
        while i <= 12 {
            ro cur = i
            spawn { acc = acc * cur }
            i += 1
        }
    }
    assert(acc == 479001600)   // 12!
}

test "spawn: alternating add/multiply pattern" {
    mut val = 1
    supervised {
        mut i = 0
        while i < 10 {
            ro cur = i
            spawn {
                if cur * 2 == cur + cur {
                    val = val + cur + 1
                }
            }
            i += 1
        }
    }
    assert(val == 56)   // 1 + sum(1..10)
}

// ================================================================
// SECTION 8: captures of records inside spawn
// ================================================================

test "spawn: record field accessed via mut capture" {
    ro c = make_counter(42)
    mut r = 0
    supervised { spawn { r = c.val * 2 } }
    assert(r == 84)
}

test "spawn: int captured from record before spawn" {
    ro c = make_counter(100)
    ro cap = c.val
    mut result = 0
    supervised { spawn { result = cap + 1 } }
    assert(result == 101)
}

test "pipeline: records through sequential spawn stages" {
    ro s1_in = 5
    ro s1 = make_stage(s1_in, 0)
    mut r1 = 0
    supervised { spawn { r1 = s1.input * s1.input } }   // 25

    ro s2_in = r1
    ro s2 = make_stage(s2_in, 0)
    mut r2 = 0
    supervised { spawn { r2 = s2.input + 1 } }          // 26

    assert(r1 == 25)
    assert(r2 == 26)
}

// ================================================================
// SECTION 9: independence — two mutable vars, each touched by one fiber
// ================================================================

test "supervised: independent mutations don't interfere" {
    mut a = 0
    mut b = 0
    supervised {
        spawn { a = 111 }
        spawn { b = 222 }
    }
    assert(a == 111)
    assert(b == 222)
}

test "supervised: 10 independent pairs, no cross-contamination" {
    mut r0 = 0
    mut r1 = 0
    mut r2 = 0
    mut r3 = 0
    mut r4 = 0
    mut r5 = 0
    mut r6 = 0
    mut r7 = 0
    mut r8 = 0
    mut r9 = 0

    supervised {
        spawn { r0 = 0 * 7 + 1 }
        spawn { r1 = 1 * 7 + 1 }
        spawn { r2 = 2 * 7 + 1 }
        spawn { r3 = 3 * 7 + 1 }
        spawn { r4 = 4 * 7 + 1 }
        spawn { r5 = 5 * 7 + 1 }
        spawn { r6 = 6 * 7 + 1 }
        spawn { r7 = 7 * 7 + 1 }
        spawn { r8 = 8 * 7 + 1 }
        spawn { r9 = 9 * 7 + 1 }
    }

    assert(r0 == 1)
    assert(r1 == 8)
    assert(r2 == 15)
    assert(r3 == 22)
    assert(r4 == 29)
    assert(r5 == 36)
    assert(r6 == 43)
    assert(r7 == 50)
    assert(r8 == 57)
    assert(r9 == 64)
}

// ================================================================
// SECTION 10: cooperative scheduling — REAL coroutine interleave
// via supervised + Time.sleep(0).
//
// Plan 83.10.4 Ф.6 (2026-05-27): MOVED to cooperative_interleave.nv
// with NOVA_AUTOARM=0. These tests rely on FIFO single-thread scheduling
// for exact `log == NNNN` assertions, which does not hold under armed
// M:N (fibers run in parallel on workers, race on shared mut).
// ================================================================
