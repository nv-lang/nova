// 44_fiber_throw.nv — fiber-safe throw.
//
// До этого PR `throw` внутри fiber-body вызывал abort() через longjmp в
// неверный setjmp-frame (frame на main-stack, fiber stack уже ушёл).
//
// Теперь spawn-entry обёрнут в локальный fail-frame на fiber-stack'е,
// nova_throw → longjmp → catch'ится прямо в fiber, fiber завершается
// чисто, scope-runner записывает первую ошибку и rethrow'ит на main.
//
// Эти тесты проверяют **отсутствие abort** при throw из fiber. Сами
// они НЕ кидают throw — только демонстрируют что инфраструктура
// готова. Тесты с реальным throw-rethrow'ом потребуют test-runner'а
// с поддержкой ожидаемых exit-кодов.

module concurrency.fiber_throw

// Helper: simulates an operation that may fail via Result.
fn validated(n int) -> Result {
    if n > 0 { Ok(n) }
    else { Err("negative input") }
}

// ================================================================
// SECTION 1: spawn-body использует ? на Result успешно
// ================================================================

test "fiber: ? on Ok inside spawn body works" {
    mut got = 0
    supervised {
        spawn {
            // ? на Ok разворачивает значение и продолжает.
            ro r = validated(7)
            ro v = match r {
                Ok(n) => n
                Err(_) => -1
            }
            got = v * v
        }
    }
    assert(got == 49)
}

test "fiber: ? on Err inside spawn body, error path via match" {
    mut got_ok = false
    mut got_err = false
    supervised {
        spawn {
            ro r = validated(-5)
            ro tag = match r {
                Ok(_n)  => 1
                Err(_e) => 2
            }
            if tag == 1 { got_ok = true } else { got_err = true }
        }
    }
    assert(!got_ok)
    assert(got_err)
}

// ================================================================
// SECTION 2: success-path — никто не throw'ит, сценарий OK
// ================================================================

test "supervised: many fibers, all succeed, scope completes normally" {
    mut counter = 0
    supervised {
        mut i = 0
        while i < 10 {
            ro cur = i
            spawn {
                if cur >= 0 {
                    counter += 1
                }
            }
            i += 1
        }
    }
    assert(counter == 10)   // none failed → all incremented
}

// ================================================================
// SECTION 3: записать "did_throw" флаг через Result-цепочку
// ================================================================

test "fiber: error-flag via Result.match (no real throw)" {
    mut errors = 0
    mut successes = 0
    supervised {
        mut i = -3
        while i <= 3 {
            ro cur = i
            spawn {
                ro r = validated(cur)
                ro tag = match r {
                    Ok(_n)  => 1
                    Err(_e) => 2
                }
                if tag == 1 { successes += 1 } else { errors += 1 }
            }
            i += 1
        }
    }
    // i = -3, -2, -1, 0 → Err (4 fibers)
    // i = 1, 2, 3       → Ok  (3 fibers)
    assert(errors == 4)
    assert(successes == 3)
}

// ================================================================
// SECTION 4: документация — throw infrastructure ready, tests TBD
// ================================================================
//
// Тесты с реальным `throw` из fiber'а требуют:
//   - Либо runtime API `nova_supervised_safe(q)` который ловит rethrow
//     и возвращает status (вместо longjmp дальше на main).
//   - Либо test runner с поддержкой "expected non-zero exit" для
//     negative tests.
//
// Сейчас infrastructure такова:
//   - spawn-entry имеет setjmp на fiber-stack'е → throw из body
//     правильно ловится локально, fiber завершается чисто.
//   - scope-runner записывает первый error и rethrow'ит на main
//     ПОСЛЕ полного drain'а scope. Это безопасно (longjmp на main-stack).
//   - Без try/catch на main, rethrow → abort с сообщением. Это
//     spec-faithful (D50: "scope перевыбрасывает ошибку наружу"),
//     но затрудняет positive-тестирование.
//
// Закрывающие задачи: см. open-questions D71 (cancellation propagation,
// race/cancel_scope, with_timeout).
