// ENV NOVA_AUTOARM=0
// cooperative_interleave.nv — Plan 22/D62 cooperative-mode interleaving tests.
//
// Spec: D14, D50, D62 — Time.sleep is a yield-point. Without timer-wheel,
// sleep(0) just yields control to scheduler. Inside `supervised { }`,
// multiple spawns coexist in a queue; the scheduler runs round-robin until
// all complete. With deterministic FIFO order, observable interleaving is
// exact.
//
// Encoding: each fiber writes single decimal digits into a shared `mut log`
// via `log = log * 10 + N`. The final value reveals the exact order of writes.
//
// Plan 83.10.4 Ф.6 (2026-05-27): split out from deep_spawn.nv. These tests
// fundamentally rely on cooperative single-thread FIFO scheduling — under
// armed M:N fibers can run on different workers in parallel, breaking the
// strict-alternation log assertions. NOVA_AUTOARM=0 selects single-thread
// cooperative scheduler where these semantics hold.
//
// Cross-runtime: tokio `current_thread` runtime — closest equivalent
// (single-thread cooperative); Node always cooperative single-thread.

module concurrency.cooperative_interleave

test "supervised: two fibers interleave at every yield" {
    // A writes 1, yield, 2, yield, 3.
    // B writes 4, yield, 5, yield, 6.
    // FIFO scheduler with sleep(0) yields after each write:
    //   A1 → B4 → A2 → B5 → A3 → B6
    // Encoded: 1,4,2,5,3,6 → 142536
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2"); log = log * 10 + 2
            Time.sleep(0)
            println("A: 3"); log = log * 10 + 3
        }
        spawn {
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 5"); log = log * 10 + 5
            Time.sleep(0)
            println("B: 6"); log = log * 10 + 6
        }
    }
    println("two-fibers final log = ", log)
    assert(log == 142536)
}

test "supervised: three fibers interleave round-robin" {
    // Three fibers, each writes 2 digits with one yield between:
    //   A: 1, yield, 2
    //   B: 3, yield, 4
    //   C: 5, yield, 6
    // Round-robin: A1, B3, C5, A2, B4, C6 → 135246
    let mut log = 0
    supervised {
        spawn {
            println("A first"); log = log * 10 + 1
            Time.sleep(0)
            println("A second"); log = log * 10 + 2
        }
        spawn {
            println("B first"); log = log * 10 + 3
            Time.sleep(0)
            println("B second"); log = log * 10 + 4
        }
        spawn {
            println("C first"); log = log * 10 + 5
            Time.sleep(0)
            println("C second"); log = log * 10 + 6
        }
    }
    println("three-fibers final log = ", log)
    assert(log == 135246)
}

test "supervised: fiber without yield runs to completion before others" {
    // Without Time.sleep, a fiber runs straight through — no preemption
    // (cooperative-only). A writes 1,2,3 first; only after A dies does
    // B get scheduled and write 4,5,6.
    //   Encoded: 1,2,3,4,5,6 → 123456
    let mut log = 0
    supervised {
        spawn {
            println("A runs all 3 (no yield)")
            log = log * 10 + 1
            log = log * 10 + 2
            log = log * 10 + 3
        }
        spawn {
            println("B runs all 3 (after A done)")
            log = log * 10 + 4
            log = log * 10 + 5
            log = log * 10 + 6
        }
    }
    println("no-yield final log = ", log)
    assert(log == 123456)
}

test "supervised: yield count equals interleave depth" {
    // A yields twice: writes 1, 3, 5
    // B yields twice: writes 2, 4, 6
    // After every write, yield → strictly alternating: 1,2,3,4,5,6 → 123456
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("A: 5"); log = log * 10 + 5
        }
        spawn {
            println("B: 2"); log = log * 10 + 2
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 6"); log = log * 10 + 6
        }
    }
    println("strict-alternation log = ", log)
    assert(log == 123456)
}

test "supervised: yields uneven, fiber A finishes first" {
    // A: 1, yield, 2 (one yield)
    // B: 3, yield, 4, yield, 5 (two yields)
    // Order: A1, B3, A2 (A done), B4, B5 → 13245
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2 (done)"); log = log * 10 + 2
        }
        spawn {
            println("B: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
            Time.sleep(0)
            println("B: 5 (done)"); log = log * 10 + 5
        }
    }
    println("uneven log = ", log)
    assert(log == 13245)
}

test "supervised: producer-consumer pattern via shared mut + yields" {
    // Producer fiber writes values 1..5 to `slot`, yields after each.
    // Consumer fiber reads `slot` after each yield, accumulates `received`.
    // Because producer writes BEFORE its yield, then consumer is scheduled,
    // consumer sees each fresh value exactly once.
    let mut slot = 0
    let mut received = 0
    let mut producer_done = false
    supervised {
        spawn {
            let mut i = 1
            while i <= 5 {
                slot = i
                println("  producer: slot = ", i)
                Time.sleep(0)   // hand off to consumer
                i += 1
            }
            producer_done = true
        }
        spawn {
            let mut count = 0
            while count < 5 {
                println("  consumer: read ", slot)
                received += slot   // pick up current value
                Time.sleep(0)      // wait for next produce
                count += 1
            }
        }
    }
    println("producer-consumer received = ", received)
    // Consumer sees slot at: 1, 2, 3, 4, 5 → sum = 15
    assert(received == 15)
    assert(producer_done)
}

test "supervised: 4 fibers, 1 yield each, round-robin order" {
    // FIFO scheduler: A,B,C,D each write a digit, yield, write next.
    //   A1, B3, C5, D7, A2, B4, C6, D8 → 13572468
    let mut log = 0
    supervised {
        spawn {
            println("A: 1"); log = log * 10 + 1
            Time.sleep(0)
            println("A: 2"); log = log * 10 + 2
        }
        spawn {
            println("B: 3"); log = log * 10 + 3
            Time.sleep(0)
            println("B: 4"); log = log * 10 + 4
        }
        spawn {
            println("C: 5"); log = log * 10 + 5
            Time.sleep(0)
            println("C: 6"); log = log * 10 + 6
        }
        spawn {
            println("D: 7"); log = log * 10 + 7
            Time.sleep(0)
            println("D: 8"); log = log * 10 + 8
        }
    }
    println("4-fibers log = ", log)
    assert(log == 13572468)
}

test "supervised: yield inside loop, fiber lifetime spans many iterations" {
    // A counts 0..3 with yield between each step; B counts 10,20,30 likewise.
    // Each fiber visits 3 write-yield cycles. Total writes: 6, fully alternating.
    //   A0, B10, A1, B20, A2, B30 → log records sum at each step on B side.
    let mut a_steps = 0
    let mut b_steps = 0
    let mut order = 0
    supervised {
        spawn {
            let mut i = 0
            while i < 3 {
                a_steps += 1
                println("  A iteration ", i)
                order = order * 10 + 1   // A marker
                Time.sleep(0)
                i += 1
            }
        }
        spawn {
            let mut j = 0
            while j < 3 {
                b_steps += 1
                println("  B iteration ", j)
                order = order * 10 + 2   // B marker
                Time.sleep(0)
                j += 1
            }
        }
    }
    println("loop-spans order = ", order)
    assert(a_steps == 3)
    assert(b_steps == 3)
    assert(order == 121212)   // strict alternation A,B,A,B,A,B
}

test "supervised: nested supervised — inner scope completes before outer continues" {
    // Outer supervised has fiber X. X itself contains an inner supervised
    // with fibers Y1, Y2 that interleave; Y must finish before X continues.
    let mut order = 0
    supervised {
        spawn {
            println("X starts"); order = order * 10 + 1
            supervised {
                spawn {
                    println("  Y1 first"); order = order * 10 + 2
                    Time.sleep(0)
                    println("  Y1 second"); order = order * 10 + 4
                }
                spawn {
                    println("  Y2 first"); order = order * 10 + 3
                    Time.sleep(0)
                    println("  Y2 second"); order = order * 10 + 5
                }
            }
            // Inner finished: 2,3,4,5 appended (interleaved)
            println("X resumes"); order = order * 10 + 6     // X resumes
        }
    }
    println("nested order = ", order)
    // 1 (X), 2,3,4,5 (Y1+Y2 interleaved), 6 (X) → 123456
    assert(order == 123456)
}
