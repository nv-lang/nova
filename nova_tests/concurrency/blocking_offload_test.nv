// blocking_offload_test.nv — Plan 83.3 Ф.4.2: real threadpool offload.
// Plan 113 migration: blocking { } → #blocking fn.
//
// #blocking fn in fiber context offloads to libuv threadpool:
// fiber parks (D93 park/wake), worker is free to run sibling fibers.
// On main thread (no fiber), #blocking fn call runs inline.
//
// V1-contract (D50): body is a leaf (CPU/FFI without GC-allocation).
// Here the body is a CPU busy-loop (pure arithmetic), V1-compatible.

module concurrency.blocking_offload_test

// leaf work: CPU busy-loop. Returns result → tests result-passing via ctx-struct after wake.
#blocking fn _busy_sum_work(upto int) -> int {
    mut acc = 0
    mut i = 0
    while i < upto {
        acc = acc + (i % 7)
        i = i + 1
    }
    acc
}

fn busy_sum(upto int) -> int {
    _busy_sum_work(upto)
}

// ================================================================
// SECTION 1: offload in fiber context — correctness of result-passing
// ================================================================

test "blocking: offload in fiber returns correct result" {
    mut got = 0
    supervised {
        spawn {
            got = busy_sum(70)
        }
    }
    // sum of (i%7) for i in 0..70 — exactly 10 cycles 0+1+..+6 = 10*21 = 210.
    assert(got == 210)
}

// ================================================================
// SECTION 2: worker freed — sibling fiber progresses during offload
// ================================================================

test "blocking: worker freed — sibling fiber progresses during offload" {
    mut marker = 0
    mut a_saw = -1
    supervised {
        spawn {
            // Fiber A — offloads to threadpool, parks.
            ro _ = busy_sum(1000000)
            // What A sees immediately after returning from blocking offload.
            a_saw = marker
        }
        spawn {
            // Fiber B — light: should progress while A is parked on offload.
            marker = 1
        }
    }
    // B set marker while A was parked → A saw 1.
    assert(a_saw == 1)
    assert(marker == 1)
}

// ================================================================
// SECTION 3: main thread — inline branch (no fiber, no offload)
// ================================================================

test "blocking: on main thread runs inline" {
    // Outside fiber context (mco_running == false) — runs inline.
    ro r = busy_sum(700)
    assert(r == 2100)   // 100 cycles * 21
}

// ================================================================
// SECTION 4: multiple fibers with blocking offload in parallel
// ================================================================

test "blocking: multiple fibers offload concurrently" {
    mut s1 = 0
    mut s2 = 0
    mut s3 = 0
    supervised {
        spawn { s1 = busy_sum(70) }
        spawn { s2 = busy_sum(140) }
        spawn { s3 = busy_sum(210) }
    }
    assert(s1 == 210)   // 10 cycles
    assert(s2 == 420)   // 20 cycles
    assert(s3 == 630)   // 30 cycles
}
