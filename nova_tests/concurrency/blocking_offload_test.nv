// blocking_offload_test.nv — Plan 83.3 Ф.4.2: реальный threadpool-offload.
//
// `blocking { }` в fiber-контексте уводит leaf-блокирующую работу в libuv
// threadpool: fiber паркуется (D93 park/wake), worker свободен и крутит
// соседние fiber'ы. На main-потоке нет worker'а пинить — тело выполняется
// inline.
//
// V1-контракт (D50): тело `blocking { }` — leaf (CPU/FFI без GC-аллокации
// и без вызовов обратно в Nova-рантайм). Здесь тело — CPU busy-loop
// (чистая арифметика), что V1-совместимо.

module concurrency.blocking_offload_test

// leaf-работа: CPU busy-loop. Возвращает значение → проверяет
// result-passing через ctx-struct после wake.
fn busy_sum(upto int) Blocking -> int {
    let r = blocking {
        let mut acc = 0
        let mut i = 0
        while i < upto {
            acc = acc + (i % 7)
            i = i + 1
        }
        acc
    }
    r
}

// ================================================================
// SECTION 1: offload в fiber-контексте — корректность result-passing
// ================================================================

test "blocking: offload in fiber returns correct result" {
    let mut got = 0
    supervised {
        spawn {
            got = busy_sum(70)
        }
    }
    // sum of (i%7) for i in 0..70 — ровно 10 циклов 0+1+..+6 = 10*21 = 210.
    assert(got == 210)
}

// ================================================================
// SECTION 2: worker НЕ запинен — соседний fiber прогрессирует
// ================================================================

test "blocking: worker freed — sibling fiber progresses during offload" {
    let mut marker = 0
    let mut a_saw = -1
    supervised {
        spawn {
            // Fiber A — уводит блокирующую работу в threadpool, паркуется.
            let _ = busy_sum(1000000)
            // То, что A видит СРАЗУ после возврата из blocking-offload.
            a_saw = marker
        }
        spawn {
            // Fiber B — лёгкий: должен прогрессировать пока A запаркован
            // на offload'е (worker свободен).
            marker = 1
        }
    }
    // B выставил marker пока A был запаркован → A увидел 1.
    // Если бы blocking пинил worker — B не получил бы управление до
    // полного завершения A, и A увидел бы 0.
    assert(a_saw == 1)
    assert(marker == 1)
}

// ================================================================
// SECTION 3: main-поток — inline-ветка (нет fiber'а, нет offload'а)
// ================================================================

test "blocking: on main thread runs inline" {
    // Вне fiber-контекста (mco_running == false) blocking { } выполняется
    // inline тем же _nova_blk — нет worker'а, который надо освобождать.
    let r = busy_sum(700)
    assert(r == 2100)   // 100 циклов * 21
}

// ================================================================
// SECTION 4: несколько fiber'ов с blocking-offload параллельно
// ================================================================

test "blocking: multiple fibers offload concurrently" {
    let mut s1 = 0
    let mut s2 = 0
    let mut s3 = 0
    supervised {
        spawn { s1 = busy_sum(70) }
        spawn { s2 = busy_sum(140) }
        spawn { s3 = busy_sum(210) }
    }
    assert(s1 == 210)   // 10 циклов
    assert(s2 == 420)   // 20 циклов
    assert(s3 == 630)   // 30 циклов
}
