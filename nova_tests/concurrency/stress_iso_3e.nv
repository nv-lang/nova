// stress_iso_3e.nv — Plan 83.10.5 Ф.A.1 diagnostic isolate
// Exact clone of cancel_latency_bench test 2 — should pass if bench test 2 passes.
// Used to verify [M-83.10.4-iso-cancel-startup-race] under diagnostic counters.
module concurrency.stress_iso_3e

test "99+1 fibers sleep(10000), cancel(30ms) — bench clone" {
    let tok = CancelToken.new()
    let t0 = Time.now()
    supervised(cancel: tok) {
        for _ in 0..99 {
            spawn { Time.sleep(10_000) }
        }
        spawn {
            Time.sleep(30)
            tok.cancel()
        }
    }
    let elapsed = Time.now() - t0
    let after_cancel = elapsed - 30
    assert(after_cancel < 300)
}
