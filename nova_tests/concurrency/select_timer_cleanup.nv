// Plan 44.1 Ф.2 B7: Time.after cleanup в select.
//
// Когда select выигрывает arm НЕ-таймер, on_select_lost callback
// должен отменить uv_timer.  До B7 timer срабатывал даже не нужен,
// засоряя event-loop heap.  После B7 — stop + uv_close с idempotent
// `cancelled` guard.
//
// Тест: 50 итераций select { recv-arm wins, timer-arm timeout 10s }.
// Если timer не cleanup'ится, активные timer'ы держат event-loop
// открытым 10s после теста — наблюдаемо как timeout на test runner.
// Без leak'а тест завершается за <1s.
//
// Plan 44.1 audit R7 (2026-05-12): on_select_lost теперь срабатывает и
// из try_immediate ветки (раньше только park-path).
// Plan 44.1 audit R8 (2026-05-13): NovaAfterState переведена на malloc/free
// вместо nova_alloc — снимает Boehm conservative scan dependency,
// решает Windows boundary ~35 SEGV. Восстановлен оригинальный 50-iter.

module concurrency.select_timer_cleanup

import std.time.duration

test "Time.after cleanup: 50 quick wins не оставляют висящих таймеров" {
    let mut wins = 0
    let mut i = 0
    while i < 50 {
        let ch = Channel.new(1)
        supervised {
            spawn {
                ch.tx.send(i)
            }
            spawn {
                select {
                    Some(_) = ch.rx => { wins = wins + 1 }
                    Some(_) = ChanReader.close_after(Duration.from_millis(10_000)) => {
                        // 10s timeout — никогда не должен сработать,
                        // если recv wins; но если sub-test runs <10s
                        // и B7 работает — timer cancelled.
                    }
                }
            }
        }
        i = i + 1
    }
    assert(wins == 50)
}

test "Time.after wins: подтверждает что таймер всё ещё работает когда нужен" {
    let ch = Channel.new(1)
    let mut timeout_fired = false
    supervised {
        // НЕ посылаем в ch — timer должен выиграть
        spawn {
            select {
                Some(_) = ch.rx => { }
                Some(_) = ChanReader.close_after(Duration.from_millis(50)) => { timeout_fired = true }
            }
        }
    }
    assert(timeout_fired)
}
