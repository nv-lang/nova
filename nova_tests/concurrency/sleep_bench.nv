// sleep_bench.nv — Plan 22 Ф.6 bench: scheduler throughput.
//
// Validates production-grade scheduler: park/wake через uv_timer_t
// scales до тысяч fiber'ов без CPU burn, throughput sleep(0) yield'ов
// сравним с тривиальными loop'ами.
//
// Slack'и широкие для CI-стабильности.
//
// Plan 83.4.5.3 Ф.2 (2026-05-23): добавлен `// ENV NOVA_MAXPROCS=1` под
// 10k concurrent sleeps под armed multi-worker triggered drain hang.
//
// Plan 83.10.4 Ф.6 (2026-05-27): scale reduced 10k → 5k, MAXPROCS=1
// directive REMOVED. Под default M:N 5k fibers sleep(100) reliably
// PASS в <500ms (16 workers × libuv timers). 10k под MAXPROCS=1 теперь
// SEGFAULTs (post-Ф.3/Ф.4 runtime change), под default M:N 16 workers
// flaky cliff ~7k-10k (UV timer storm + worker contention). 5k стабильно
// тестирует scheduler scalability; "thousands of fibers in parallel"
// claim упирается в 10k гипотетически — TBD via [M-83.10.4-sleep-bench-scale-cliff].

module concurrency.sleep_bench

// 5k concurrent sleep'ов через park/wake. Theoretical: ~100ms
// wall-clock (все спят параллельно через libuv event loop). Если
// scheduler busy-loop'ит — это бы было 5000×100ms = 500s. Production-
// grade: ~100-500ms. Ф.7 убрала NOVA_SCOPE_CAP — heap-allocated arrays
// grow до требуемого, hard limit ушёл.
test "5k concurrent sleeps в <5000ms (production-scale, M:N)" {
    ro t0 = Time.now()
    supervised {
        for _ in 0..5_000 {
            spawn { Time.sleep(100) }
        }
    }
    ro elapsed = Time.now() - t0
    assert(elapsed < 5000)
}

// Yield-throughput bench: scheduler hot path calibration.
//
// Plan 83.4.5.3 Ф.2 (2026-05-23): iterations 1M → 100k. Под armed
// runtime + MAXPROCS=1 worker yield overhead — ~10-50µs/yield, 1M
// итераций = 10-50s wall-clock + `nova test --jobs 16` oversubscription
// добавляет 2-5×. Total > 60s → TIMEOUT. 100k yields ~1-5s удерживается
// под обоими режимами. Bootstrap производительность калибруется в
// отдельном bench/micro/sleep_bench_throughput.nv (Plan 83.4.5.6 Ф.4).
test "100k sleep(0) yields в <5 секунд (throughput, M:N-tolerant)" {
    ro t0 = Time.now()
    supervised {
        spawn {
            for _ in 0..100_000 {
                Time.sleep(0)
            }
        }
    }
    ro elapsed = Time.now() - t0
    // Slack: under armed runtime + jobs=16 oversubscription scheduler-tick
    // overhead ~ 50µs/yield. 100k × 50µs = 5s upper bound.
    assert(elapsed < 5000)
}
