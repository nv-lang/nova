// blocking_pool_saturation_test.nv — Plan 83.3 Ф.5: pool saturation.
// Plan 113 migration: blocking { } → #blocking fn.
// ENV NOVA_BLOCKING_THREADS=2
//
// More concurrent blocking offloads than pool threads →
// libuv queues excess uv_work_t. Checks: saturation degrades gracefully
// (queue, not deadlock) — all fibers complete with correct results.

module concurrency.blocking_pool_saturation_test

// leaf CPU work: increments acc upto times, returns upto.
#blocking fn _busy_work(upto int) -> int {
    let mut acc = 0
    let mut i = 0
    while i < upto {
        acc = acc + 1
        i = i + 1
    }
    acc
}

fn busy(upto int) -> int {
    _busy_work(upto)
}

test "blocking: pool saturation — offloads > pool size, graceful queue" {
    let mut total = 0
    supervised {
        // 6 fibers, pool of 2 threads → 4 queued.
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
    }
    assert(total == 240000)
}

test "blocking: saturation with mixed work sizes" {
    let mut total = 0
    supervised {
        spawn { let r = busy(10000); total = total + r }
        spawn { let r = busy(20000); total = total + r }
        spawn { let r = busy(30000); total = total + r }
        spawn { let r = busy(40000); total = total + r }
        spawn { let r = busy(50000); total = total + r }
    }
    assert(total == 150000)
}
