// 40_detach.nv — D50 `detach { body }` fire-and-forget primitive.
//
// Spec D50 (revised 2026-05-23, Plan 83.4.5.2 Ф.4): detach запускает body
// как orphan fiber переживающий caller'а, привязан к глобальному
// LogAndDrop fail-handler. Default handler — AsyncDetach (fire-and-forget
// на worker pool / cooperative orphan scope, не inline в caller'е).
//
// Cross-runtime: паритет Go `go fn()`, tokio `tokio::spawn` без JoinHandle,
// Kotlin `GlobalScope.launch { … }`.
//
// Plan 83.4.5.2 Ф.3 (2026-05-23): тесты переписаны на explicit-sync
// через `runtime.drain_orphans()` — analog Go `sync.WaitGroup.Wait()`
// для anonymous-spawn'ов. До flip-activation: bootstrap orphan scope
// (cooperative drain). После flip + Plan 83.4.5.7 race fix: worker pool
// fire-and-forget.

module concurrency.detach_test

type Counter {
    mut val int
}

fn make_counter(v int) -> Counter => { val: v }

// ================================================================
// SECTION 1: базовое исполнение (с explicit-sync через drain_orphans)
// ================================================================

test "detach: body executes (visible after drain_orphans)" {
    let mut x = 0
    detach {
        x = 42
    }
    runtime.drain_orphans()
    assert(x == 42)
}

test "detach: empty body is no-op" {
    let mut touched = false
    detach { touched = true }
    runtime.drain_orphans()
    assert(touched)
}

test "detach: trailing expr value is discarded (fire-and-forget)" {
    let mut log = 0
    detach {
        log = 7
        99   // discarded
    }
    runtime.drain_orphans()
    assert(log == 7)
}

// ================================================================
// SECTION 2: capture
// ================================================================

test "detach: captures immutable int" {
    let n = 21
    let mut result = 0
    detach { result = n * 2 }
    runtime.drain_orphans()
    assert(result == 42)
}

test "detach: captures multiple vars" {
    let a = 3
    let b = 5
    let mut c = 0
    detach { c = a * a + b * b }
    runtime.drain_orphans()
    assert(c == 34)
}

test "detach: mutates captured record field" {
    let counter = make_counter(10)
    detach {
        counter.val = counter.val + 5
    }
    runtime.drain_orphans()
    assert(counter.val == 15)
}

// ================================================================
// SECTION 3: detach + control flow
// ================================================================

test "detach with if inside" {
    let n = 5
    let mut tag = 0
    detach {
        if n > 0 {
            tag = 1
        } else {
            tag = -1
        }
    }
    runtime.drain_orphans()
    assert(tag == 1)
}

test "detach with while inside" {
    let mut acc = 0
    detach {
        let mut i = 1
        while i <= 5 {
            acc += i
            i += 1
        }
    }
    runtime.drain_orphans()
    assert(acc == 15)
}

// ================================================================
// SECTION 4: detach внутри supervised — orphan (НЕ участвует в scope queue)
// ================================================================

test "detach inside supervised: orphan body completes after drain" {
    // detach живёт мимо scope. AsyncDetach (D50 revised): orphan body
    // НЕ участвует в supervised drain — completes asynchronously.
    // Каждый spawn внутри supervised drained scope'ом; orphan — global.
    let mut detach_flag = 0
    let mut spawn_sum = 0
    supervised {
        detach {
            detach_flag = 1
        }
        spawn {
            spawn_sum += 10
        }
        spawn {
            spawn_sum += 20
        }
    }
    // После scope-exit: spawn'ы drained (spawn_sum == 30 гарантировано).
    // Orphan detach МОЖЕТ ещё не отработать — drain explicit.
    assert(spawn_sum == 30)
    runtime.drain_orphans()
    assert(detach_flag == 1)
}

// ================================================================
// SECTION 5: nested detach (both orphans)
// ================================================================

test "detach inside detach: оба orphan, completeness assertion" {
    // AsyncDetach: outer detach spawns orphan, inner detach (внутри outer's
    // body) тоже spawns orphan. Оба завершаются после drain.
    let mut outer_done = 0
    let mut inner_done = 0
    detach {
        outer_done = 1
        detach {
            inner_done = 1
        }
    }
    runtime.drain_orphans()
    assert(outer_done == 1)
    assert(inner_done == 1)
}

test "detach: multiple detaches all complete (set-equality)" {
    // AsyncDetach: 3 orphan fibers. Order не специфицирован (Go semantics
    // — spawn ordering undef). Проверяем completeness через sum.
    let mut sum = 0
    detach { sum += 1 }
    detach { sum += 2 }
    detach { sum += 4 }
    runtime.drain_orphans()
    // 1 + 2 + 4 = 7. Bitmask-style проверка — каждый orphan уникально
    // contributed к sum, доказывает все 3 executed.
    assert(sum == 7)
}

// ================================================================
// SECTION 6: detach + records, arrays
// ================================================================

test "detach mutates array via captured ref" {
    let mut sum = 0
    let xs = [10, 20, 30]
    detach {
        let mut i = 0
        while i < 3 {
            sum += xs[i]
            i += 1
        }
    }
    runtime.drain_orphans()
    assert(sum == 60)
}

test "detach: usable outside supervised (orphan semantic)" {
    // detach по спеке D50 не требует scope (vs spawn — spawn вне
    // supervised — compile error). Detach привязан к global orphan pool,
    // поэтому валиден везде где вызывается функция с эффектом Detach
    // в сигнатуре.
    let mut x = 100
    detach { x = x + 1 }
    detach { x = x * 2 }
    runtime.drain_orphans()
    // Order между orphans НЕ детерминирован (D50 + Plan 83 §6). Два возможных
    // outcome'а: (x+1)*2 = 202, OR (x*2)+1 = 201. Проверяем что один из них.
    assert(x == 202 || x == 201)
}

// ================================================================
// SECTION 7: NEGATIVE — drain_orphans idempotent
// ================================================================

test "drain_orphans negative: empty pool — no-op" {
    // Никаких detach'ей. drain_orphans должен быть no-op (быстрый return).
    let mut sentinel = 0
    runtime.drain_orphans()
    sentinel = 1
    assert(sentinel == 1)
}

test "drain_orphans negative: повторный вызов — idempotent" {
    // После первого drain orphan pool empty. Второй drain — no-op.
    let mut x = 0
    detach { x = 5 }
    runtime.drain_orphans()
    assert(x == 5)
    // Второй drain — empty pool, no-op.
    runtime.drain_orphans()
    assert(x == 5)
}
