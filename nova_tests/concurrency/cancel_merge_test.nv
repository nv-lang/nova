// cancel_merge_test.nv — Plan 49 P3 (beyond state-of-the-art):
// `tok = tok1.merge(tok2)` — composed cancel-token.
//
// Превосходит Go (нет merge нескольких contexts напрямую),
// TS AbortSignal.any() (есть, но reason: any), Rust (нет stdlib merge).

module concurrency.cancel_merge_test


test "merge: cancel первого источника отменяет merged" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    assert(!merged.is_cancelled())
    t1.cancel("via t1")
    assert(merged.is_cancelled())
}


test "merge: cancel второго источника отменяет merged" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    t2.cancel("via t2")
    assert(merged.is_cancelled())
}


test "merge: оба cancel - first-wins (idempotent)" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    t1.cancel("first")
    t2.cancel("second-ignored")
    // merged.reason() — first reason, second идемпотентно игнорируется
    assert(merged.is_cancelled())
    ro r = merged.reason()
    ro got = match r {
        Some(s) => s
        None    => ""
    }
    assert(got == "first")
}


test "merge: оба uncancelled - merged тоже uncancelled" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    assert(!merged.is_cancelled())
    assert(!t1.is_cancelled())
    assert(!t2.is_cancelled())
}


// ──────────────────────────────────────────────────────────────────────────
// Edge cases — chained merge, idempotency
// ──────────────────────────────────────────────────────────────────────────


test "merge chained 3 источника: cancel первого пробрасывается" {
    // merged3 = (t1.merge(t2)).merge(t3) — любой из 3 cancel → merged3.
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro t3 = CancelToken.new()
    ro m12 = t1.merge(t2)
    ro m123 = m12.merge(t3)
    assert(!m123.is_cancelled())
    t1.cancel("through chain")
    assert(m123.is_cancelled())
}


test "merge chained: cancel ПОСЛЕДНЕГО (через chain)" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro t3 = CancelToken.new()
    ro m12 = t1.merge(t2)
    ro m123 = m12.merge(t3)
    t3.cancel("last source")
    assert(m123.is_cancelled())
}


test "merge: cancel SAMOГО merged не пропагируется в источники" {
    // Directional: merged cancelled когда любой источник cancelled,
    // но cancel merged НЕ отменяет источники (parent → child каскад,
    // не обратно).
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    merged.cancel("only merged")
    assert(merged.is_cancelled())
    assert(!t1.is_cancelled())
    assert(!t2.is_cancelled())
}


test "merge с уже cancelled источником: merged сразу cancelled" {
    // Если t1 cancelled ДО merge — merged должен сразу подобрать cancel.
    ro t1 = CancelToken.new()
    t1.cancel("pre-merge")
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    // bind_cascade при cancel-already-fired бросает cancel в child немедленно
    assert(merged.is_cancelled())
}


// ──────────────────────────────────────────────────────────────────────────
// Negative behavior
// ──────────────────────────────────────────────────────────────────────────


test "negative: merge не cancel'ит источники при создании" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro _ = t1.merge(t2)
    assert(!t1.is_cancelled())
    assert(!t2.is_cancelled())
}


test "negative: merged.is_cancelled() = false до любого cancel" {
    ro t1 = CancelToken.new()
    ro t2 = CancelToken.new()
    ro merged = t1.merge(t2)
    assert(!merged.is_cancelled())
}
