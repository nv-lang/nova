// Plan 103.9 (D174) — Pilot migration: RwLock with ReadGuard/WriteGuard consume API.
//
// V2 pattern: rw.read() → ReadGuard consume; rw.write() → WriteGuard consume.
// Guards are distinct types; unlock() is the consume method.
//
// EXPECT_TIMEOUT_MS 60000

module nova_tests.concurrency.sync_rwlock_guards

test "ReadGuard: explicit unlock after read" {
    let mut rw = RwLock.new()
    let mut v = AtomicInt.new(100)

    supervised {
        spawn {
            consume rg = rw.read()
            let x = v.load()
            rg.unlock()
            assert(x == 100)
        }
    }
}

test "WriteGuard: exclusive write with explicit unlock" {
    let mut rw = RwLock.new()
    let mut v = AtomicInt.new(0)

    supervised {
        spawn {
            consume wg = rw.write()
            v.fetch_add(1)
            wg.unlock()
        }
        spawn {
            consume wg = rw.write()
            v.fetch_add(1)
            wg.unlock()
        }
    }
    assert(v.load() == 2)
}

test "ReadGuard: multiple readers coexist, writer waits" {
    let mut rw = RwLock.new()
    let mut readers = AtomicInt.new(0)
    let mut writer_ran = AtomicInt.new(0)

    supervised {
        spawn {
            consume rg1 = rw.read()
            readers.fetch_add(1)
            runtime.yield()
            readers.fetch_add(-1)
            rg1.unlock()
        }
        spawn {
            consume rg2 = rw.read()
            readers.fetch_add(1)
            runtime.yield()
            readers.fetch_add(-1)
            rg2.unlock()
        }
        spawn {
            // Writer must wait for both readers
            runtime.yield()
            runtime.yield()
            consume wg = rw.write()
            writer_ran.fetch_add(1)
            wg.unlock()
        }
    }
    assert(writer_ran.load() == 1)
}

