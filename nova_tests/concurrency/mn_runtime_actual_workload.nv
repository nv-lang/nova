// Plan 44.5 Layer 5 + Plan 92 — M:N parallelism: spawned fibers
// выполняются на worker-пуле, и work-stealing распределяет их по
// нескольким worker'ам.
//
// **Compute-only:** spawn body не использует Time.sleep/Channel.recv
// (park/wake migration к worker scope — отдельный milestone).
//
// Тест проверяет ДВЕ величины разной природы (Plan 92 Ф.0):
//
//   (1) ВЫПОЛНЕНИЕ — контракт рантайма, **детерминирован**: все 16
//       fibers отрабатывают на worker-потоках (`worker_id >= 0`, не
//       main-thread `-1`). Проверяется `assert` КАЖДУЮ попытку.
//
//   (2) РАСПРЕДЕЛЕНИЕ — эвристика планировщика, **НЕ контракт**:
//       work-stealing раскидывает fibers по >1 worker'у. Под
//       CPU-starvation worker-потоков ОС один worker законно может
//       выполнить все 16 tiny-fibers (Plan 92 Ф.0: под устойчивой
//       нагрузкой одиночный `on_w0 < 16` падал 66/100 — это валидное
//       поведение work-stealing, не баг). Поэтому распределение
//       проверяется **статистически** — до 20 независимых batch'ей с
//       early-break (как только распределение замечено — стоп): рабочий
//       планировщик распределяет batch с подавляющей вероятностью
//       (в реальном прогоне `nova test` `p >= 0.99` → обычно хватает
//       1-2 batch'ей; false-fail = `(1-p)^20` ничтожен); полностью
//       сломанный round-robin не распределит НИ ОДИН batch → все 20
//       попыток впустую → детерминированный fail. Это корректный
//       способ проверки вероятностного свойства (ср. Go
//       `TestGoroutineParallelism`), не упрощение. Early-break держит
//       стоимость теста на уровне исходного (обычно 1 batch).

module nova_tests.concurrency.mn_runtime_actual_workload

test "M:N: 16 fibers выполняются на worker-пуле + распределяются" {
    runtime.init(4)

    // 16 mut slots — each spawn writes own slot's worker_id.
    mut w00 = -1; mut w01 = -1; mut w02 = -1; mut w03 = -1
    mut w04 = -1; mut w05 = -1; mut w06 = -1; mut w07 = -1
    mut w08 = -1; mut w09 = -1; mut w10 = -1; mut w11 = -1
    mut w12 = -1; mut w13 = -1; mut w14 = -1; mut w15 = -1

    mut attempt = 0
    mut distributed = false

    while attempt < 20 {
        // Сброс слотов перед каждым независимым batch'ем.
        w00 = -1; w01 = -1; w02 = -1; w03 = -1
        w04 = -1; w05 = -1; w06 = -1; w07 = -1
        w08 = -1; w09 = -1; w10 = -1; w11 = -1
        w12 = -1; w13 = -1; w14 = -1; w15 = -1

        supervised {
            spawn { w00 = runtime.current_worker_id() }
            spawn { w01 = runtime.current_worker_id() }
            spawn { w02 = runtime.current_worker_id() }
            spawn { w03 = runtime.current_worker_id() }
            spawn { w04 = runtime.current_worker_id() }
            spawn { w05 = runtime.current_worker_id() }
            spawn { w06 = runtime.current_worker_id() }
            spawn { w07 = runtime.current_worker_id() }
            spawn { w08 = runtime.current_worker_id() }
            spawn { w09 = runtime.current_worker_id() }
            spawn { w10 = runtime.current_worker_id() }
            spawn { w11 = runtime.current_worker_id() }
            spawn { w12 = runtime.current_worker_id() }
            spawn { w13 = runtime.current_worker_id() }
            spawn { w14 = runtime.current_worker_id() }
            spawn { w15 = runtime.current_worker_id() }
        }

        // (1) КОНТРАКТ (детерминирован): все 16 fibers отработали на
        // worker'ах — каждый slot >= 0 (а не -1 = main-thread).
        // Проверяется каждую попытку: реальная потеря работы или
        // выполнение на main вместо worker'а — мгновенный fail.
        ro total_ran =
            (if w00 >= 0 { 1 } else { 0 }) +
            (if w01 >= 0 { 1 } else { 0 }) +
            (if w02 >= 0 { 1 } else { 0 }) +
            (if w03 >= 0 { 1 } else { 0 }) +
            (if w04 >= 0 { 1 } else { 0 }) +
            (if w05 >= 0 { 1 } else { 0 }) +
            (if w06 >= 0 { 1 } else { 0 }) +
            (if w07 >= 0 { 1 } else { 0 }) +
            (if w08 >= 0 { 1 } else { 0 }) +
            (if w09 >= 0 { 1 } else { 0 }) +
            (if w10 >= 0 { 1 } else { 0 }) +
            (if w11 >= 0 { 1 } else { 0 }) +
            (if w12 >= 0 { 1 } else { 0 }) +
            (if w13 >= 0 { 1 } else { 0 }) +
            (if w14 >= 0 { 1 } else { 0 }) +
            (if w15 >= 0 { 1 } else { 0 })
        assert(total_ran == 16)

        // (2) РАСПРЕДЕЛЕНИЕ (статистически): не все 16 на worker 0.
        ro on_w0 =
            (if w00 == 0 { 1 } else { 0 }) +
            (if w01 == 0 { 1 } else { 0 }) +
            (if w02 == 0 { 1 } else { 0 }) +
            (if w03 == 0 { 1 } else { 0 }) +
            (if w04 == 0 { 1 } else { 0 }) +
            (if w05 == 0 { 1 } else { 0 }) +
            (if w06 == 0 { 1 } else { 0 }) +
            (if w07 == 0 { 1 } else { 0 }) +
            (if w08 == 0 { 1 } else { 0 }) +
            (if w09 == 0 { 1 } else { 0 }) +
            (if w10 == 0 { 1 } else { 0 }) +
            (if w11 == 0 { 1 } else { 0 }) +
            (if w12 == 0 { 1 } else { 0 }) +
            (if w13 == 0 { 1 } else { 0 }) +
            (if w14 == 0 { 1 } else { 0 }) +
            (if w15 == 0 { 1 } else { 0 })
        if on_w0 < 16 {
            // Распределение замечено — статистическое свойство доказано,
            // дальше повторять незачем (early-break держит стоимость
            // теста на уровне одного batch'а в обычном прогоне).
            distributed = true
            break
        }

        attempt = attempt + 1
    }

    // За <= 20 независимых batch'ей work-stealing распределил работу
    // хотя бы раз. Сломанный round-robin (всегда worker 0) не пройдёт
    // ни одного → distributed остаётся false → детерминированный fail.
    assert(distributed)

    runtime.shutdown()
}
