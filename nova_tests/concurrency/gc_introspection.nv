// gc_introspection.nv — Plan 32: тесты runtime GC API (std.runtime.gc).
//
// API:
//   gc.heap_size()    -> int    bytes; 0 если backend без introspection
//   gc.live_count()   -> int    приблизительное число live-объектов
//   gc.alloc_count()  -> int    монотонный счётчик с старта
//   gc.collect()                принудительный сбор (no-op под malloc)
//   gc.reset_stats()            сброс счётчиков
//
// Эти тесты — без ALLOC_REQUIRES — работают с любым backend'ом.
// Логика: differential через `if heap_size() == 0` (malloc-marker).

module concurrency.gc_introspection

type Obj { a int, b int, c int }

fn make_obj(a int, b int, c int) -> Obj =>
    { a, b, c }

// ── 1. alloc_count монотонно растёт ───────────────────────────────────────

test "gc: alloc_count монотонно растёт после аллокаций" {
    ro before = gc.alloc_count()
    mut sum = 0
    for i in 0..1_000 {
        ro o = make_obj(i, i, i)
        sum = sum + o.a
    }
    ro after = gc.alloc_count()
    assert(after >= before + 1_000)
    assert(sum == 499_500)
}

// ── 2. collect() не падает на пустом heap ─────────────────────────────────

test "gc: collect() безопасен при отсутствии мусора" {
    gc.collect()
    gc.collect()  // повторный вызов — тоже ок
    assert(true)  // sanity: дошли сюда без crash
}

// ── 3. heap_size sentinel: malloc==0, boehm>0 после аллокаций ──────────────

test "gc: heap_size — backend-marker (malloc 0, boehm >0)" {
    // Аллоцируем чтобы наполнить heap.
    mut keep = make_obj(1, 2, 3)
    for i in 0..1_000 {
        ro o = make_obj(i, i, i)
        keep = o  // удерживает последний live
    }
    ro h = gc.heap_size()
    // Под malloc h == 0 (honest "not supported").
    // Под boehm  h > 0 (heap не пустой).
    // Оба варианта acceptable — проверяем что значение non-negative.
    assert(h >= 0)
    assert(keep.a > 0 || keep.a == 0)  // sanity: keep жив
}

// ── 4. Differential: bounded heap под boehm vs unbounded под malloc ───────

test "gc: после collect() heap не растёт линейно (только под boehm)" {
    // Под boehm — этот тест демонстрирует bounded heap.
    // Под malloc — early-exit через heap_size() == 0.
    ro h0 = gc.heap_size()
    if h0 == 0 {
        // malloc backend: skip — нет introspection, тест trivially passes
        assert(true)
    } else {
        // boehm: создаём 10k короткоживущих, явный collect
        mut discard = 0
        for i in 0..10_000 {
            ro o = make_obj(i, i + 1, i + 2)
            discard = discard + o.a
        }
        gc.collect()
        ro h1 = gc.heap_size()
        // 10k × 24 bytes = 240k bytes если бы leak. Boehm должен держать
        // heap в разумных пределах (не больше чем h0 + 10x).
        // Если linear leak — h1 был бы ~h0 + 240k или больше.
        // Mild: h1 < h0 * 10 + 1MB (consery).
        ro bound = h0 * 10 + 1_048_576
        assert(h1 < bound)
        assert(discard > 0)
    }
}

// ── 5. reset_stats обнуляет alloc_count ───────────────────────────────────

test "gc: reset_stats обнуляет alloc_count" {
    // Сначала аллоцируем чтобы счётчик был > 0
    mut s = 0
    for i in 0..100 {
        ro o = make_obj(i, i, i)
        s = s + o.a
    }
    ro before = gc.alloc_count()
    assert(before > 0)
    gc.reset_stats()
    ro after = gc.alloc_count()
    // После reset_stats счётчик должен упасть (либо до 0, либо
    // близко — pending аллокации с момента reset не считаем).
    assert(after < before)
    assert(s == 4950)
}

// ── 6. live_count >= 0 и не "ломается" ────────────────────────────────────

test "gc: live_count — sanity, non-negative" {
    ro lc = gc.live_count()
    assert(lc >= 0)
    // Аллоцируем
    mut keep = make_obj(7, 8, 9)
    for i in 0..50 {
        ro o = make_obj(i, i, i)
        keep = o
    }
    ro lc2 = gc.live_count()
    // Под malloc live_count = alloc_count (free всегда 0) — растёт.
    // Под boehm  live_count = alloc_count (upper bound) — тоже растёт.
    // Оба варианта: lc2 >= lc.
    assert(lc2 >= lc)
    assert(keep.a >= 0)
}
