// Plan 18 std.sync: Mutex tests.
//
// Verifies fiber-aware mutual exclusion: lock/unlock/try_lock.
// Mutual-exclusion test tracks `inside` — incremented under lock, decremented
// before unlock. If ever > 1, two fibers entered the critical section
// simultaneously → violation. This is an observable interleave property,
// not just a final-value check.

module nova_tests.concurrency.sync_mutex

// ─── Basic API ─────────────────────────────────────────────────

test "Mutex: try_lock on fresh mutex succeeds" {
    let mut m = Mutex.new()
    let ok = m.try_lock()
    assert(ok == true)
    m.unlock()
}

test "Mutex: try_lock while locked returns false" {
    let mut m = Mutex.new()
    let ok1 = m.try_lock()
    assert(ok1 == true)
    let ok2 = m.try_lock()
    assert(ok2 == false)
    m.unlock()
}

test "Mutex: lock and unlock in single fiber" {
    let mut m = Mutex.new()
    let mut counter = 0
    supervised {
        spawn {
            m.lock()
            counter = counter + 1
            m.unlock()
            m.lock()
            counter = counter + 1
            m.unlock()
        }
    }
    assert(counter == 2)
}

// ─── Mutual exclusion ──────────────────────────────────────────

// Two fibers each take the mutex 50 times. `inside` is incremented under
// lock and decremented before unlock. If mutual exclusion holds, `inside`
// never exceeds 1 → violations == 0.
test "Mutex: mutual exclusion — inside never > 1" {
    let mut m = Mutex.new()
    let mut inside = 0
    let mut violations = 0

    supervised {
        spawn {
            let mut i = 0
            while i < 50 {
                m.lock()
                inside = inside + 1
                if inside > 1 { violations = violations + 1 }
                runtime.yield()
                inside = inside - 1
                m.unlock()
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < 50 {
                m.lock()
                inside = inside + 1
                if inside > 1 { violations = violations + 1 }
                runtime.yield()
                inside = inside - 1
                m.unlock()
                i = i + 1
            }
        }
    }
    assert(violations == 0)
    assert(inside == 0)
}

// Protected counter: two fibers increment without atomic ops — mutex must
// prevent lost updates. Final value must equal sum of both.
test "Mutex: protected counter — no lost updates" {
    let mut m = Mutex.new()
    let mut counter = 0
    supervised {
        spawn {
            let mut i = 0
            while i < 100 {
                m.lock()
                counter = counter + 1
                m.unlock()
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < 100 {
                m.lock()
                counter = counter + 1
                m.unlock()
                i = i + 1
            }
        }
    }
    assert(counter == 200)
}

// ─── M:N mode ──────────────────────────────────────────────────

// Same mutual-exclusion property under M:N scheduler with 2 workers.
// The park/wake cross-worker path gets exercised.
test "Mutex: mutual exclusion in M:N mode" {
    runtime.init(2)
    let mut m = Mutex.new()
    let mut inside = 0
    let mut violations = 0
    supervised {
        spawn {
            let mut i = 0
            while i < 30 {
                m.lock()
                inside = inside + 1
                if inside > 1 { violations = violations + 1 }
                inside = inside - 1
                m.unlock()
                i = i + 1
            }
        }
        spawn {
            let mut i = 0
            while i < 30 {
                m.lock()
                inside = inside + 1
                if inside > 1 { violations = violations + 1 }
                inside = inside - 1
                m.unlock()
                i = i + 1
            }
        }
    }
    assert(violations == 0)
    runtime.shutdown()
}
