// Plan 83.1 Ф.3: runtime.maxprocs() — целевое число worker-потоков.
//
// maxprocs() резолвит целевое число даже ДО runtime.init (в отличие от
// worker_count(), который = 0 пока пул не материализован). Plan 83.1
// Ф.4: пул ленивый — после init() worker_count() == 0 до первого spawn.
//
// Plan 83.4.5.11 (2026-05-26): добавлен // ENV NOVA_AUTOARM=0.
// Тест "maxprocs resolves a positive target before init" проверяет
// !runtime.is_initialized(). По умолчанию auto-arm инициализирует
// runtime в main() до тестов → assert падает. AUTOARM=0 отключает
// auto-arm: тесты управляют lifecycle через runtime.init() / shutdown().
//
// ENV NOVA_AUTOARM=0

module concurrency.mn_maxprocs_getter

test "maxprocs resolves a positive target before init" {
    assert(!runtime.is_initialized())
    assert(runtime.maxprocs() > 0)
    // worker_count = 0 пока пул не поднят, maxprocs() — цель.
    assert(runtime.worker_count() == 0)
}

test "maxprocs reflects explicit init(n), pool still lazy" {
    runtime.init(4)
    assert(runtime.maxprocs() == 4)
    // Ф.4: init не материализует пул — worker_count() == 0 до spawn.
    assert(runtime.worker_count() == 0)
    runtime.shutdown()
}

test "maxprocs stays resolvable after shutdown" {
    runtime.init(2)
    runtime.shutdown()
    assert(!runtime.is_initialized())
    // после shutdown — снова цель по умолчанию (auto-detect), > 0.
    assert(runtime.maxprocs() > 0)
}
