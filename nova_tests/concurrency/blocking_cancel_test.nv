// blocking_cancel_test.nv — Plan 83.3 Ф.3: cancellation of blocking offload.
// Plan 113 migration: blocking { } → #blocking fn.
//
// `nova_blocking_offload` registers stop_cb in pending table of the scope (D93).
// On scope cancel, stop_cb calls `uv_cancel`:
//   - not-yet-started uv_work_t → cancelled, fiber woken with cancel;
//   - in-flight C call → NOT interrupted (opaque), runs to completion,
//     result discarded — industry-standard (Go/tokio).
// In both cases after_work_cb always fires → fiber woken, no deadlock.

module concurrency.blocking_cancel_test

#blocking fn _busy_work(upto int) -> int {
    mut acc = 0
    mut i = 0
    while i < upto {
        acc = acc + 1
        i = i + 1
    }
    acc
}

fn busy(upto int) -> int {
    _busy_work(upto)
}

// ================================================================
// SECTION 1: supervised(cancel:) without cancel() — blocking works normally
// ================================================================

test "blocking: offload in supervised(cancel:) — no cancel, runs normally" {
    ro tok = CancelToken.new()
    mut got = 0
    supervised(cancel: tok) {
        spawn { got = busy(50000) }
    }
    // stop_cb registration in pending table does not break normal path.
    assert(got == 50000)
}

// ================================================================
// SECTION 2: cancel() + blocking offload — no deadlock or crash
// ================================================================

test "blocking: offload + scope cancel — after_work_cb always wakes, no deadlock" {
    ro tok = CancelToken.new()
    mut reached_end = false
    with Fail = effect Fail {
        fail(_msg) {
            interrupt ()
        }
    } {
        supervised(cancel: tok) {
            spawn { tok.cancel() }
            spawn {
                ro _ = busy(50000)
            }
        }
    }
    reached_end = true
    assert(reached_end)
}

// ================================================================
// SECTION 3: cancel AFTER blocking offload — token survives scope
// ================================================================

test "blocking: cancel() on finished scope after offload — harmless no-op" {
    ro tok = CancelToken.new()
    mut got = 0
    supervised(cancel: tok) {
        spawn { got = busy(30000) }
    }
    tok.cancel()
    assert(got == 30000)
    assert(tok.is_cancelled())
}
