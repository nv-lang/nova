// blocking_test.nv — Plan 83.3 Ф.4.1 / Plan 113 migration.
// Plan 113: #blocking fn attribute replaces blocking { } block-form.
//
// #blocking fn wraps the entire fn in libuv threadpool offload at call sites.
// Arguments are passed as parameters; result is returned normally.
// On main thread (no fiber): runs inline (no worker to free).

module concurrency.blocking_test

// ================================================================
// SECTION 1: basic execution + return value
// ================================================================

#blocking fn _double_work(n int) -> int {
    n * 2
}

fn blocking_double(n int) -> int {
    _double_work(n)
}

test "blocking: body executes, value computed" {
    assert(blocking_double(21) == 42)
}

#blocking fn _empty_work() -> bool {
    true
}

fn blocking_empty() -> bool {
    _empty_work()
}

test "blocking: body executes trivially" {
    assert(blocking_empty())
}

#blocking fn _side_effect_work(n int) -> int {
    let mut log = n
    log = 7
    log
}

fn blocking_trailing_value() -> int {
    _side_effect_work(0)
}

test "blocking: fn returns computed value" {
    assert(blocking_trailing_value() == 7)
}

// ================================================================
// SECTION 2: parameter passing (replaces capture semantics)
// ================================================================

#blocking fn _sum_squares_work(a int, b int) -> int {
    a * a + b * b
}

fn blocking_capture_multi(a int, b int) -> int {
    _sum_squares_work(a, b)
}

test "blocking: passes multiple params" {
    assert(blocking_capture_multi(3, 5) == 34)
}

#blocking fn _add_to_val_work(val int, delta int) -> int {
    val + delta
}

fn blocking_compute_record(start int) -> int {
    _add_to_val_work(start, 5)
}

test "blocking: computes value from params" {
    assert(blocking_compute_record(10) == 15)
}

// ================================================================
// SECTION 3: blocking + control flow inside body
// ================================================================

#blocking fn _sign_work(n int) -> int {
    if n > 0 {
        1
    } else {
        -1
    }
}

fn blocking_with_if(n int) -> int {
    _sign_work(n)
}

test "blocking: if inside body" {
    assert(blocking_with_if(5) == 1)
    assert(blocking_with_if(-2) == -1)
}

#blocking fn _triangle_sum_work(upto int) -> int {
    let mut acc = 0
    let mut i = 1
    while i <= upto {
        acc += i
        i += 1
    }
    acc
}

fn blocking_with_while(upto int) -> int {
    _triangle_sum_work(upto)
}

test "blocking: while inside body" {
    assert(blocking_with_while(5) == 15)
}

// ================================================================
// SECTION 4: multiple sequential blocking calls
// ================================================================

fn blocking_sequential() -> int {
    let mut log = 0
    log = _add_to_val_work(log * 10, 1)
    log = _add_to_val_work(log * 10, 2)
    log = _add_to_val_work(log * 10, 3)
    log
}

test "blocking: multiple calls preserve sequential order" {
    assert(blocking_sequential() == 123)
}

// ================================================================
// SECTION 5: blocking with array computation
// ================================================================

#blocking fn _sum_three_work(x0 int, x1 int, x2 int) -> int {
    x0 + x1 + x2
}

fn blocking_sum_array() -> int {
    let xs = [10, 20, 30]
    _sum_three_work(xs[0], xs[1], xs[2])
}

test "blocking: sums array elements via params" {
    assert(blocking_sum_array() == 60)
}
