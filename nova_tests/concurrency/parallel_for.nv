// 41_parallel_for.nv — D14 `parallel for x in iter { body }` fan-out.
//
// Desugars to `supervised { for x in iter { spawn { body } } }`.
// Loop-variable `x` captured BY VALUE (immutable scalar) — each queued
// fiber sees its own snapshot, not the last iteration's value.
//
// Plan 83.4.5.3 Ф.1 (2026-05-23): рефакторинг с encoded-log ordering на
// **set-equality (multiset count + sum)**. Под bootstrap'е cooperative
// drain давал детерминированный round-robin → tests опирались на
// `log == 121212`. Под armed runtime (Plan 83.2 flip) даже с 1 worker'ом
// work-stealing deque (Chase-Lev: owner LIFO pop) → fiber order
// меняется. Production-tests **не должны** опираться на specific spawn
// ordering (Plan 83 spec §6 — "Spawn ordering: NOT specified"; паритет
// с Go `go func()` / tokio `tokio::spawn` / Kotlin `launch`).
//
// Cross-runtime аналог: Go testing convention сортирует results
// (`sort.Ints(got)` + `reflect.DeepEqual(got, expected)`); tokio
// проверяет channel sums; Kotlin `runBlocking` checks coroutine-counts.
//
// Файл валиден на обоих режимах:
//   - bootstrap cooperative drain;
//   - armed M:N (multi-worker work-stealing).
// Real parallelism proof перенесён в bench/micro/parallel_*
// (Plan 83.4.5.6 Ф.4 speedup-bench).
//
// ENV NOVA_MAXPROCS=1
//
// Directive выше — `// ENV NOVA_MAXPROCS=1` — оставлен из Plan 83.4.3 B3
// как fallback для armed runtime, где multi-worker work-stealing race
// `supervised double-resume` (Plan 83.4.2 Ф.1) под multi-fiber load
// триггерит fiber arena access violation. Под 1 worker drain happens
// одним потоком — race исключён. Set-equality assertions ниже не
// зависят от specific scheduler ordering, но в принципе работают и
// под N-worker (когда supervised-drain race будет полностью закрыт
// в Plan 83.4.5.1).
//
// Println'ы внутри fiber bodies — для визуальной диагностики при ручном
// запуске бинаря (test runner их не показывает).

module concurrency.parallel_for

// ================================================================
// SECTION 1: базовое суммирование (correctness — order-independent)
// ================================================================

test "parallel for: sum of [1..5]" {
    mut sum = 0
    parallel for x in [1, 2, 3, 4, 5] {
        sum += x
    }
    assert(sum == 15)
}

test "parallel for: empty array, no iterations" {
    mut touched = 0
    ro xs = []
    parallel for _ in xs {
        touched += 1
    }
    assert(touched == 0)
}

test "parallel for: single element" {
    mut got = 0
    parallel for x in [42] {
        got = x
    }
    assert(got == 42)
}

// ================================================================
// SECTION 2: COMPLETENESS — каждый fiber выполняет body полностью.
// Set-equality: total iterations + sum, без ordering-asserts.
// ================================================================

test "parallel for: 2 fibers each write 3 times (completeness)" {
    // Каждая итерация пишет цифру x три раза с yield. Под cooperative
    // или work-stealing M:N — каждый fiber завершает все 3 шага.
    // Проверка multiset-equality: total writes = 6, sum = 3*(1+2) = 9.
    mut total_writes = 0
    mut sum = 0
    parallel for x in [1, 2] {
        println("  fiber x=", x, " step 1")
        total_writes += 1
        sum += x
        Time.sleep(0)
        println("  fiber x=", x, " step 2")
        total_writes += 1
        sum += x
        Time.sleep(0)
        println("  fiber x=", x, " step 3")
        total_writes += 1
        sum += x
    }
    println("final total_writes = ", total_writes, " sum = ", sum)
    assert(total_writes == 6)   // 2 fibers × 3 шага каждый
    assert(sum == 9)            // (1+2) × 3 = 9
}

test "parallel for: 3 fibers each write 2 times (completeness)" {
    // 3 fibers по 2 шага с yield. multiset-equality:
    // total writes = 6, sum = 2*(1+2+3) = 12.
    mut total_writes = 0
    mut sum = 0
    parallel for x in [1, 2, 3] {
        println("  fiber ", x, " a")
        total_writes += 1
        sum += x
        Time.sleep(0)
        println("  fiber ", x, " b")
        total_writes += 1
        sum += x
    }
    println("final total_writes = ", total_writes, " sum = ", sum)
    assert(total_writes == 6)   // 3 fibers × 2 шага
    assert(sum == 12)           // (1+2+3) × 2 = 12
}

test "parallel for: NO yield → each fiber runs to completion" {
    // Без Time.sleep — у каждого fiber'а body выполняется атомарно.
    // Проверяем completeness: каждый x встретился x раз → total = 1+2+3 = 6.
    // Order между fibers НЕ проверяется (M:N work-stealing → undef).
    mut total = 0
    mut count_1 = 0
    mut count_2 = 0
    mut count_3 = 0
    parallel for x in [1, 2, 3] {
        println("  fiber ", x, " writes")
        mut i = 0
        while i < x {
            total += 1
            if x == 1 {
                count_1 += 1
            } else {
                if x == 2 {
                    count_2 += 1
                } else {
                    count_3 += 1
                }
            }
            i += 1
        }
    }
    println("final total = ", total)
    assert(total == 6)
    assert(count_1 == 1)
    assert(count_2 == 2)
    assert(count_3 == 3)
}

test "parallel for vs sequential for: same sum, both complete" {
    // Sequential for + parallel for — оба обходят весь массив.
    // Order не проверяется — только что каждый fiber/iteration выполнен.
    mut seq_sum = 0
    for x in [1, 2] {
        seq_sum += x
        Time.sleep(0)
        seq_sum += x
        Time.sleep(0)
        seq_sum += x
    }
    // Sequential: каждый x записан 3 раза → 3*1 + 3*2 = 9
    assert(seq_sum == 9)

    mut par_sum = 0
    parallel for x in [1, 2] {
        par_sum += x
        Time.sleep(0)
        par_sum += x
        Time.sleep(0)
        par_sum += x
    }
    // Parallel: тот же набор iterations, тот же sum.
    assert(par_sum == 9)
    assert(seq_sum == par_sum)
}

// ================================================================
// SECTION 3: range-iterator (completeness для range, не array)
// ================================================================

test "parallel for over range 0..3: each i runs twice (completeness)" {
    mut total_writes = 0
    mut sum = 0
    parallel for i in 0..3 {
        println("  fiber i=", i, " a")
        total_writes += 1
        sum += i + 1   // pad to non-zero (1, 2, 3)
        Time.sleep(0)
        println("  fiber i=", i, " b")
        total_writes += 1
        sum += i + 1
    }
    println("final total_writes = ", total_writes, " sum = ", sum)
    assert(total_writes == 6)   // 3 fibers × 2 шага
    assert(sum == 12)           // (1+2+3) × 2 = 12
}

test "parallel for over inclusive range 1..=3: completeness" {
    mut total_writes = 0
    mut sum = 0
    parallel for i in 1..=3 {
        total_writes += 1
        sum += i
        Time.sleep(0)
        total_writes += 1
        sum += i
    }
    assert(total_writes == 6)   // 3 fibers × 2 шага
    assert(sum == 12)           // (1+2+3) × 2 = 12
}

// ================================================================
// SECTION 4: snapshot-семантика (capture-by-value)
// ================================================================

test "parallel for: each fiber sees its OWN x (snapshot)" {
    // Если бы x захватывалось by-pointer, все queued fibers видели бы
    // последний элемент массива (=5). Сумма была бы 5+5+5+5+5 = 25.
    // С by-value snapshot: 1+2+3+4+5 = 15.
    mut sum = 0
    parallel for x in [1, 2, 3, 4, 5] {
        sum += x
    }
    assert(sum == 15)   // by-pointer дало бы 25 — это ловушка для регрессии
}

test "parallel for: snapshot survives across yield" {
    // x каждого fiber'а сохраняется через yield-точку.
    // Если бы x перезаписывался между итерациями, после yield все увидели бы 3.
    mut sum = 0
    parallel for x in [1, 2, 3] {
        Time.sleep(0)   // yield ДО чтения x
        sum += x
    }
    assert(sum == 6)   // 1+2+3 = 6, не 3+3+3 = 9
}

// ================================================================
// SECTION 5: вложенные структуры
// ================================================================

test "parallel for inside ordinary for (3 outer × 3 parallel)" {
    mut total = 0
    mut row = 0
    while row < 3 {
        parallel for x in [1, 2, 3] {
            total += x
        }
        row += 1
    }
    assert(total == 18)   // 3 проходов × (1+2+3)
}

test "ordinary for inside parallel for" {
    mut count = 0
    parallel for outer in [10, 20, 30] {
        mut inner = 0
        while inner < 4 {
            count += 1
            inner += 1
        }
        ro _ = outer   // touch capture
    }
    assert(count == 12)   // 3 × 4
}

// ================================================================
// SECTION 6: capture mutable outer + immutable inner
// ================================================================

test "parallel for: mut outer by-ptr, inner x by-value" {
    mut accum = 0
    ro bonus = 100
    parallel for x in [1, 2, 3] {
        accum += x + bonus
    }
    // (1+100)+(2+100)+(3+100) = 306
    assert(accum == 306)
}

// ================================================================
// SECTION 7: NEGATIVE — каждый fiber видит SVOY snapshot, не последний
// ================================================================

test "parallel for negative: 5 spawns over [10, 20, 30] = 60 not 90" {
    // Если бы capture был by-pointer и `x` зафиксировался бы на
    // последнем значении (=30), сумма стала бы 30*3 = 90.
    // by-value: 10+20+30 = 60.
    mut sum = 0
    parallel for x in [10, 20, 30] {
        Time.sleep(0)   // даём scheduler'у переключиться
        sum += x
    }
    assert(sum == 60)   // НЕ 90
}

test "parallel for negative: empty body still scope-cleans" {
    // Empty body не должен оставить мусор. Scope-exit должен пройти clean.
    mut sentinel = 0
    parallel for _ in [1, 2, 3] {
        // empty body
    }
    sentinel = 1
    assert(sentinel == 1)
}
