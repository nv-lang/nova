// Plan 83.11 §8.1 P9 — nested_supervised_3_levels_cancel
//
// Regression guard for nested supervised(cancel:) cascade. THREE supervised
// scopes nested sequentially (outer → middle → inner), each with parked
// sleeping fibers; cancel the OUTER token from a side fiber. The cascade must
// reach every level: all parked sleepers wake, every scope unwinds, the entire
// stack completes well before the 10-second sleep budget would expire.
//
// Cascade is established via `child.cancelled_by(parent)` (D75) — the
// explicit form keeps the propagation observable and exercises the
// `nova_cancel_token_bind_cascade` path (fibers.h ~972-1046).
//
// **2026-06-05 Plan 83.11 [M-83.11-nested-supervised-cascade-drain-hang]
// fix.** Restored depth=2 → 3 + middle_tok chain. Pre-fix bind's deferred
// cancel-propagation (when cancel fired before bind via cascade race) was
// incomplete — only nova_sched_cancel_all_pending was called, missing
// nova_scope_cancel_wake_all + nova_runtime_cancel_worker_fibers +
// _nova_cancel_via_driver. Result: outer scope worker-parked fibers stayed
// parked → supervised_run hung до watchdog. Closed by full cancel-hook
// propagation в nova_cancel_token_bind (fibers.h ~755-775).
//
// Nesting structure: outer{ middle{ inner{} } } all on the main fiber —
// does NOT wrap inner supervised in spawn{} (the spawn-of-supervised pattern
// is covered separately by Plan 83.10.3 `panic_in_nested_supervised`). This
// fixture isolates cancel-cascade propagation through 3 levels.

module nova_tests.concurrency

test "nested supervised cascade — outer cancel cascades 3 levels" {
    ro outer_tok = CancelToken.new()
    ro middle_tok = CancelToken.new()
    ro inner_tok = CancelToken.new()

    // Linked cascade: outer.cancel() → middle → inner.
    middle_tok.cancelled_by(outer_tok)
    inner_tok.cancelled_by(middle_tok)

    ro t0 = Time.now()

    supervised(cancel: outer_tok) {
        spawn { Time.sleep(10_000) }

        // Side fiber triggers the cascade from the outermost level.
        spawn {
            Time.sleep(30)
            outer_tok.cancel()
        }

        supervised(cancel: middle_tok) {
            spawn { Time.sleep(10_000) }

            supervised(cancel: inner_tok) {
                spawn { Time.sleep(10_000) }
            }
        }
    }

    ro elapsed = Time.now() - t0

    // All three tokens must report cancelled (cascade propagated through all levels).
    assert(outer_tok.is_cancelled())
    assert(middle_tok.is_cancelled())
    assert(inner_tok.is_cancelled())

    // The 10-second sleeps must have been interrupted: cancel fired at ~30ms.
    // Budget 3000ms = cascade hop + 3-level scope unwind on Windows M:N.
    ro after_cancel = elapsed - 30
    assert(after_cancel < 3_000)
}
