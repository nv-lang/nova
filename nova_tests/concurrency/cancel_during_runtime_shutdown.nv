// Plan 83.11 §8.2 N12 — cancel_during_runtime_shutdown
//
// Regression guard for the interaction between cancel-driven wake dispatch
// and `runtime.shutdown()` worker teardown. The scenario:
//
//   1. `runtime.init(N)` arms a multi-worker pool.
//   2. A `supervised(cancel: tok)` block spawns fibers that park (Time.sleep)
//      then has one fiber issue `tok.cancel()`. This forces the centralized
//      I/O driver / sched-wake path to fire while workers may still be in
//      `uv_run`.
//   3. `runtime.shutdown()` is called immediately after the supervised scope
//      returns. Any in-flight wake/dispatch from the cancel must have fully
//      drained before workers join — otherwise we risk:
//        - use-after-free on park slots,
//        - lost wake (worker stuck in uv_run during shutdown),
//        - SIGSEGV from wake-after-close on driver async handle,
//        - "token already bound to a live scope" if GC misses the token.
//
// **2026-06-05 bump-back (Plan 110.x supervised(cancel:) shield fix landed):**
// Restored fiber count 4 → 16. Pre-fix codegen NovaSpawnCtx layout missing
// _nova_cancel_mask_count / _nova_cancel_deadline_ns base fields → garbage
// shield activation under load. Closed by codegen layout fix on
// [emit_c.rs](../../compiler-codegen/src/codegen/emit_c.rs#L6258).
//
// Per Plan 83.1 Ф.4 the worker pool is one-shot per process — once
// materialized, subsequent runtime.init() calls are no-ops (verbose stderr
// warning, intentional). A "5-cycles" loop pattern would test re-init
// semantics, not the cancel/shutdown race; for race coverage the external
// `tools/stress_bisect.sh` harness re-runs the binary many times.
//
// ENV NOVA_AUTOARM=0

module concurrency.cancel_during_runtime_shutdown

test "cancel + immediate shutdown — parked fibers cancelled, runtime drains cleanly" {
    runtime.init(2)
    assert(runtime.is_initialized())

    ro tok = CancelToken.new()
    supervised(cancel: tok) {
        for _ in 0..16 {
            spawn { Time.sleep(5_000) }
        }
        spawn {
            // Short delay so peer fibers reach their park before cancel.
            Time.sleep(5)
            tok.cancel()
        }
    }
    // Cancel reason must have stuck (first-cancel-wins) and intent visible.
    assert(tok.is_cancelled())

    // Tight sequence: shutdown right after the scope drains. This is the
    // closest legal Nova-level approximation of "cancel during shutdown" —
    // the driver/sched still has wake-dispatch residue when workers join.
    runtime.shutdown()
    assert(!runtime.is_initialized())
    assert(runtime.worker_count() == 0)
}

test "cancel + shutdown — no parked fibers (cancel-on-empty)" {
    // No runtime.init() — uses lazy pool materialization from auto-arm
    // (or remains single-thread if AUTOARM=0). Either way, no park-points.
    ro tok = CancelToken.new()
    supervised(cancel: tok) {
        spawn { tok.cancel() }
        spawn { for _i in 0..100 { } }
    }
    assert(tok.is_cancelled())
}
