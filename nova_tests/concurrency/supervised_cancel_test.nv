// supervised_cancel_test.nv — D75 (revised, Plan 47): structured
// cancellation через `supervised(cancel: tok)`.
//
// Keyword `cancel_scope` удалён. Внешняя отмена выражается именованным
// аргументом `cancel:` у `supervised`. `CancelToken` — caller-owned
// значение: создаётся `CancelToken.new()`, переживает scope, привязывается
// при входе в `supervised(cancel:)`, отвязывается на выходе.
//
// Возможности token (D75):
//   - tok.cancel()        — пометить bound scope как cancelled (idempotent;
//                            на отвязанном / завершённом scope'е — no-op)
//   - tok.is_cancelled()  — intent-флаг «был ли вызван cancel()», без yield
//   - child.cancelled_by(parent) — направленный каскад: parent.cancel()
//                            отменяет и child (вниз, не вверх)

// Plan 83.4.5.1 (2026-05-23): cooperative cancel-semantics test —
// armed multi-worker double-resume race ломает test infrastructure.
// Cooperative drain даёт deterministic cancel propagation в bound scope.
//
// Plan 83.4.5.8 (2026-05-24): directive RESTORED — armed M:N deadlocks.
// Plan 83.10.1 (2026-05-26): STILL NEEDED — TIMEOUT under armed M:N.
// cancel propagation in supervised(cancel: tok) blocks in uv_run under
// multi-worker armed scheduler. Same root cause: [M-83.10.1-armed-cancel-timer-hang].


module concurrency.supervised_cancel_test

// ================================================================
// SECTION 1: supervised(cancel:) без cancel() ≡ обычный supervised
// ================================================================

test "supervised(cancel:) без cancel() — все fiber'ы выполняются" {
    ro tok = CancelToken.new()
    mut sum = 0
    supervised(cancel: tok) {
        spawn { sum += 1 }
        spawn { sum += 2 }
        spawn { sum += 4 }
    }
    assert(sum == 7)
}

test "supervised(cancel:): is_cancelled false по умолчанию" {
    ro tok = CancelToken.new()
    mut got_false = false
    supervised(cancel: tok) {
        spawn {
            if !tok.is_cancelled() {
                got_false = true
            }
        }
    }
    assert(got_false)
}

// ================================================================
// SECTION 2: tok.cancel() изнутри — отмена peer-fiber'ов
// ================================================================
//
// NOTE (Plan 83.10.4 Ф.5, 2026-05-27): «peer на следующем yield не выполняется»
// test REMOVED. It relied on cooperative FIFO scheduling (spawn0 always runs
// before spawn1 → cancel fires before spawn1's Time.sleep(0) completes).
// Under armed M:N, both fibers can run simultaneously on different workers —
// there is no ordering guarantee. This is not a bug in the cancel mechanism;
// it reflects correct M:N concurrency semantics. Cancel-under-M:N is tested
// separately in plan83_10_4/fail_handler_cross_mco_armed.nv fixtures.

// ================================================================
// SECTION 3: повторный cancel — idempotent
// ================================================================

test "double cancel() — idempotent, no panic" {
    ro tok = CancelToken.new()
    mut hits = 0
    supervised(cancel: tok) {
        spawn {
            tok.cancel()
            tok.cancel()       // второй — no-op
            hits += 1
        }
    }
    assert(hits == 1)
}

// ================================================================
// SECTION 4: is_cancelled() меняется после cancel()
// ================================================================

test "is_cancelled() reflects cancel state within same fiber" {
    ro tok = CancelToken.new()
    mut before = false
    mut after = false
    supervised(cancel: tok) {
        spawn {
            before = tok.is_cancelled()    // false
            tok.cancel()
            after = tok.is_cancelled()     // true
        }
    }
    assert(!before)
    assert(after)
}

// ================================================================
// SECTION 5: cancelled_by — каскадная отмена (kill-switch composition)
// ================================================================

test "cancelled_by: cancel parent — child каскадно отменён" {
    // Оба токена caller-owned, создаются заранее. child.cancelled_by(parent):
    // когда parent.cancel() сработает — child тоже отменится (вниз по
    // направлению; child.cancel() parent НЕ затронет).
    ro parent = CancelToken.new()
    ro child = CancelToken.new()
    child.cancelled_by(parent)
    mut child_was_cancelled = false
    supervised(cancel: parent) {
        spawn {
            supervised(cancel: child) {
                spawn {
                    parent.cancel()
                    // Без yield — мы остаёмся на этом fiber'е; каскад уже
                    // сработал синхронно внутри parent.cancel().
                    child_was_cancelled = child.is_cancelled()
                }
            }
        }
    }
    assert(child_was_cancelled)
}

// ================================================================
// SECTION 6: caller-owned — токен переживает scope (новая модель D75)
// ================================================================

test "cancel() на завершённом scope — безвредный no-op" {
    // Старая модель: токен dangling после scope-exit. Новая: caller-owned,
    // unbind на выходе, cancel() на отвязанном токене — чистый no-op.
    ro tok = CancelToken.new()
    mut ran = false
    supervised(cancel: tok) {
        spawn { ran = true }
    }
    // scope завершён, токен отвязан — cancel() не паникует и не throws.
    tok.cancel()
    assert(ran)
    // intent записан в сам токен, даже без живого scope'а.
    assert(tok.is_cancelled())
}

test "токен переживает scope — повторный bind на свежий scope" {
    // unbind на выходе освобождает токен; не-отменённый токен можно
    // привязать к новому scope'у заново.
    ro tok = CancelToken.new()
    mut first = 0
    supervised(cancel: tok) {
        spawn { first += 1 }
    }
    mut second = 0
    supervised(cancel: tok) {
        spawn { second += 1 }
    }
    assert(first == 1)
    assert(second == 1)
}
