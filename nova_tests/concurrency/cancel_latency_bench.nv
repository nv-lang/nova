// cancel_latency_bench.nv — Plan 22 R4 target verification.
//
// Plan 22 заявил «cancel-during-sleep wake'ает в течение <1ms».
// Этот bench measures actual wake latency через cancel-token →
// nova_sched_cancel_all_pending → close_cb chain (Ф.8 ASYNC).
//
// Methodology:
//   - Spawn fiber что Time.sleep(10000) (10s — заведомо никогда не fire'нет).
//   - Параллельно cancel-fiber: Time.sleep(50) → tok.cancel().
//   - Measure elapsed scope-exit'а минус 50ms (минимум cancel-trigger).
//   - elapsed_after_cancel = elapsed - 50ms = время от cancel до wake.
//
// Plan 22 R4 target: elapsed_after_cancel < 1ms.
// Реалистично: Windows scheduler + uv_close async cb ≈ 1-10ms p99.

// Plan 83.4.5.1 (2026-05-23): cooperative cancel-latency bench — armed
// multi-worker double-resume race blocks measurement. Cooperative path
// validates wake_all + cancel_all_pending behavior.
//
// ENV NOVA_NO_AUTOARM=1

module concurrency.cancel_latency_bench

test "single fiber cancel-during-sleep — wake latency measurement" {
    let t0 = Time.now()
    let tok = CancelToken.new()
    supervised(cancel: tok) {
        spawn {
            Time.sleep(10_000)  // never fires
        }
        spawn {
            Time.sleep(50)
            tok.cancel()
        }
    }
    let elapsed = Time.now() - t0
    let after_cancel = elapsed - 50

    // Plan 22 R4 «<1ms» — overclaim для Windows (timer-gran + uv_run pass).
    // Реалистично 1-20ms p99. Документируем: cancel response не блокирует
    // long-running sleep, но имеет measurable latency.
    assert(after_cancel < 50)  // generous bound для CI

    // Если < 10ms — Plan 22 claim в reasonable пределах.
    // Если > 10ms — claim нужно обновить.
    // На Windows typical: 5-15ms (uv_close cb pass).
}

test "100 parked fibers cancel — wake latency under load" {
    // 100 fiber'ов в sleep(10000), один cancel'ит scope.
    // cancel_all_pending iterates все 100, инициирует close для каждого.
    // Все close_cb'и должны fire'нуть в одном-двух uv_run pass'ах.
    let t0 = Time.now()
    let tok = CancelToken.new()
    supervised(cancel: tok) {
        for _ in 0..99 {
            spawn { Time.sleep(10_000) }
        }
        spawn {
            Time.sleep(30)
            tok.cancel()
        }
    }
    let elapsed = Time.now() - t0
    let after_cancel = elapsed - 30

    // Plan 22 R4: cancel batch'ом 100 timer handle'ов. Realistic budget
    // 100 × close_cb pass — может занять 50-200ms на high-contention CI.
    // Если < 100ms — production-grade.
    assert(after_cancel < 300)
}

test "10 nested cancels — cumulative latency" {
    // 10 scope'ов sequentially, каждый с 10 fiber'ов + cancel.
    // Measures aggregate cancel latency.
    let mut total_after_cancel int = 0
    for _ in 0..10 {
        let t0 = Time.now()
        let tok = CancelToken.new()
        supervised(cancel: tok) {
            for _ in 0..9 {
                spawn { Time.sleep(10_000) }
            }
            spawn {
                Time.sleep(20)
                tok.cancel()
            }
        }
        let elapsed = Time.now() - t0
        total_after_cancel = total_after_cancel + (elapsed - 20)
    }
    // 10 cancel ops × ~10ms each = ~100ms total budget. Generous slack 500ms.
    assert(total_after_cancel < 500)
}
