// Plan 44.1 (Plan 44 Этап 0): smoke test для M:N runtime infrastructure.
//
// Минимальный verification что multi-thread runtime может:
//   1. ARM'иться через runtime.init (зафиксировать целевое число).
//   2. Report maxprocs() / worker_count() / is_initialized() корректно.
//   3. Graceful shutdown без deadlock/crash.
//
// Plan 83.1 Ф.4: пул ленивый — runtime.init только ARM'ит рантайм;
// worker-потоки поднимаются на первом spawn. Материализация и
// diagnosed-no-op повторного init — см. mn_lazy_spawn.nv /
// mn_init_after_materialize.nv.

module concurrency.mn_runtime_smoke

test "runtime not initialized by default" {
    assert(!runtime.is_initialized())
    assert(runtime.worker_count() == 0)
    assert(runtime.current_worker_id() == -1)
}

test "init + shutdown lifecycle (2 workers)" {
    runtime.init(2)
    assert(runtime.is_initialized())
    assert(runtime.maxprocs() == 2)
    // Пул ленивый: без spawn worker-потоки не подняты.
    assert(runtime.worker_count() == 0)
    // main thread не worker.
    assert(runtime.current_worker_id() == -1)

    runtime.shutdown()
    assert(!runtime.is_initialized())
    assert(runtime.worker_count() == 0)
}

test "repeated init before first spawn re-tunes the target" {
    // Plan 83.1 Ф.4: runtime.init — тюнер; до материализации пула
    // (до первого spawn) повторный вызов валиден и переопределяет цель.
    runtime.init(1)
    runtime.init(99)
    assert(runtime.maxprocs() == 99)
    runtime.shutdown()
}

test "init auto-detect (n=0)" {
    runtime.init(0)
    assert(runtime.is_initialized())
    // auto-detect (uv_available_parallelism) → maxprocs() > 0.
    assert(runtime.maxprocs() > 0)
    runtime.shutdown()
}
