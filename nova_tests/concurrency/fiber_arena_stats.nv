// Plan 44.2 Этап 3: smoke test для std.runtime.fibers introspection.
// Plan 82 Ф.1: arena теперь активна и на Windows (fiber_arena_win.c) —
// Windows идёт по тому же пути, что Linux/macOS.
//
// Verify что `fibers.*` API доступен и возвращает sane values:
//   - Linux/macOS/Windows: arena активна → slot_count > 0, slots_active
//     растёт после spawn'a fibers.
//   - Платформы без arena (NOVA_FIBER_ARENA_ENABLED=0): всё возвращает 0.
//
// Тест PASS на всех платформах — branching через slot_count == 0.

module concurrency.fiber_arena_stats


test "fibers introspection API доступен" {
    ro slots = fibers.slot_count()
    if slots == 0 {
        // Платформа без arena. Все API симметрично возвращают 0.
        assert(fibers.virtual_reserved() == 0)
        assert(fibers.slots_active() == 0)
        assert(fibers.high_water() == 0)
    } else {
        // arena активна (Linux/macOS/Windows). virtual_reserved = slot_count *
        // slot_size + guard; slot_count >= 4096 (production sizing).
        assert(fibers.virtual_reserved() > 0)
        assert(slots >= 4096)
        // high_water не превышает slot_count.
        assert(fibers.high_water() <= slots)
    }
}

test "spawn увеличивает slots_active под arena" {
    ro before_active = fibers.slots_active()
    ro before_high = fibers.high_water()

    supervised {
        spawn {
            // Inside fiber — slot allocated в arena (все платформы с arena).
            ro now_active = fibers.slots_active()
            if fibers.slot_count() > 0 {
                // Arena активна — slot для этого fiber'a должен быть учтён.
                assert(now_active > before_active)
            } else {
                // Платформа без arena — всегда 0.
                assert(now_active == 0)
            }
        }
    }

    // После завершения fiber slot переиспользуется. slots_active может
    // вернуться к before_active (или меньше при concurrent cleanup).
    ro after_active = fibers.slots_active()
    if fibers.slot_count() > 0 {
        assert(after_active <= before_high + 1)
    }
}
