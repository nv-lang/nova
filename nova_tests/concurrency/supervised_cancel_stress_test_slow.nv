// supervised_cancel_stress_test.nv — Plan 22 Ф.6 / Plan 47 production
// stress test для `supervised(cancel: tok)`.
//
// Validates: cancel-during-park (R4 в Plan 22) корректно работает при
// concurrent stress — N fiber'ов в Time.sleep, один из них triggers
// cancel в middle. Все fiber'ы должны wake immediate, throw "scope
// cancelled", scope завершается быстро (НЕ park-forever).
//
// ─── RE-ENABLED — Plan 83-go-cmn Ф.5 (2026-06-11) ────────────────────
// История: [M-83.10.4-iso-cancel-startup-race] — supervised(cancel:) FIRST
// test в бинаре TIMEOUT'ил (100 fibers sleep(10_000) + cancel → park-forever
// в uv_run; cold worker-startup vs cancel-dispatch race). 83.10.5 tactical
// fix был ~55% (неадекватен). СТРУКТУРНО ЗАКРЫТ Ф.2 (gopark/goready):
// timer-backed park вето́ит на cancel перед arming + READY-latch + driver
// async-close wake. Подтверждено 380 armed-прогонами (MP=1 и MP=4) = 0 hang.
//
// Бюджеты: исходные `< 50+SLACK_MS` (250ms) были latency-SLA, флакавший ~0.8%
// под GC/scheduler jitter (все fiber'ы ПРОСЫПАЛИСЬ — wall-clock иногда >250ms).
// Реальный инвариант теста = «cancel будит всех, scope НЕ виснет на 10s», а не
// 250ms-латентность. Бюджеты ослаблены до wake-not-hang границ (10×+ ниже sleep).

module nova_tests.concurrency

test "cancel during 100 parked sleeps wakes all immediately" {
    ro tok = CancelToken.new()
    ro t0 = Time.now()
    supervised(cancel: tok) {
        for _ in 0..99 {
            spawn {
                Time.sleep(10_000)
            }
        }
        spawn {
            Time.sleep(50)
            tok.cancel()
        }
    }
    ro elapsed = Time.now() - t0
    // wake-not-hang: все 99 проснулись (иначе 10_000ms). 1000 >> jitter, << sleep.
    assert(elapsed < 1000)
}

test "cancel mid-flight with mixed sleep durations" {
    ro tok = CancelToken.new()
    ro t0 = Time.now()
    supervised(cancel: tok) {
        for i in 0..50 {
            spawn {
                Time.sleep(100 + i * 100)
            }
        }
        spawn {
            Time.sleep(30)
            tok.cancel()
        }
    }
    ro elapsed = Time.now() - t0
    assert(elapsed < 1000)
}

test "no leak on cancel — scope completes cleanly" {
    ro t0 = Time.now()
    for _ in 0..3 {
        ro tok = CancelToken.new()
        supervised(cancel: tok) {
            for _ in 0..100 {
                spawn { Time.sleep(5_000) }
            }
            spawn {
                Time.sleep(20)
                tok.cancel()
            }
        }
    }
    ro elapsed = Time.now() - t0
    // 3 sequential 100-fiber scopes; wake-not-hang (иначе 3×5_000ms).
    assert(elapsed < 2000)
}
