// Fast variant — reduced parameters. Full test: gc_bench_slow.nv
//
// gc_bench.nv — Bench-тест скорости GC аллокаций.
// Fast variant: test 1 reduced 100k->1k record allocs;
//               test 5 reduced 1M->10k sentinel allocs.

module concurrency.gc_bench

type Obj { a int, b int, c int }

fn make_obj(a int, b int, c int) -> Obj =>
    { a, b, c }

// ── Bench 1: 1k простых аллокаций (fast) ────────────────────────────────────

test "bench: 1k record-аллокаций, сумма корректна" {
    mut sum = 0
    for i in 0..1_000 {
        ro o = make_obj(i, i + 1, i + 2)
        sum = sum + o.a
    }
    // sum(i, 0..999) = 999 * 1000 / 2 = 499_500
    assert(sum == 499_500)
}

// ── Bench 2: 5k строковых аллокаций ─────────────────────────────────────────

test "bench: 5k str-аллокаций через interpolation" {
    mut count = 0
    for i in 0..5_000 {
        ro s = "item_${i}"
        count = count + s.byte_len()
    }
    // Все строки "item_N" имеют длину ≥ 6 — count > 30k
    assert(count > 30_000)
}

// ── Bench 3: 100 fiber'ов с аллокациями ─────────────────────────────────────

test "bench: 100 fiber'ов × 10 аллокаций каждый" {
    mut total = 0
    supervised {
        for i in 0..100 {
            spawn {
                mut local = 0
                for j in 0..10 {
                    ro o = make_obj(i, j, i + j)
                    local = local + o.a + o.c
                }
                total = total + local
            }
        }
    }
    // o.a=i, o.c=i+j; local = sum over j=0..9: (i + i+j) = sum(2i+j) = 20i + 45
    // total = sum over i=0..99: 20i + 45 = 20*4950 + 45*100 = 99_000 + 4_500 = 103_500
    assert(total == 103_500)
}

// ── Bench 4: смешанные аллокации (записи + массивы + строки) ─────────────────

test "bench: 1k смешанных аллокаций" {
    mut sum = 0
    for i in 0..1_000 {
        ro o = make_obj(i, i * 2, i * 3)
        mut arr = [o.a, o.b, o.c]
        ro mv = arr.get(1)
        ro v = match mv {
            Some(n) => n
            None    => 0
        }
        sum = sum + v
    }
    // sum(i*2, 0..999) = 2 * sum(i, 0..999) = 2 * 499_500 = 999_000
    assert(sum == 999_000)
}

// ── Bench 5: давление на heap — объект выживает после 10k аллокаций ──────────

test "bench: объект-sentinel жив после 10k аллокаций" {
    ro sentinel = make_obj(777_777, 888_888, 999_999)
    mut discarded = 0
    for i in 0..10_000 {
        ro o = make_obj(i, i, i)
        discarded = discarded + o.a
    }
    assert(sentinel.a == 777_777)
    assert(sentinel.b == 888_888)
    assert(sentinel.c == 999_999)
    assert(discarded > 0)
}
