// memory_footprint_test.nv — Plan 22 Ф.6 production memory test.
//
// Validates: NovaSchedState lazy-alloc (Вариант B) — для supervised
// блоков **без** Time.sleep/Channel.recv sched_state остаётся NULL.
// Это значит idle scope'ы тратят только 8 bytes на pointer, не ~50 KB
// на NovaSchedState array.
//
// Test strategy: supervised блоки с N fiber'ами без park'а — должны
// завершаться быстро, нет abort'а.
//
// D97 fix: SpawnCtx хранится в fiber_ctx[] (GC-managed array) —
// Boehm видит все live SpawnCtx через NovaFiberQueue.fiber_ctx[],
// не допускает преждевременную сборку.

module concurrency.memory_footprint_test

test "100 idle supervised scopes — no sched_state allocations" {
    // 100 fiber'ов которые spawn'ятся и сразу завершаются.
    // sched_state должен остаться NULL для каждого — никто не park'ится.
    mut completed = 0
    supervised {
        for _ in 0..100 {
            spawn {
                // No sleep, no recv — no park.
                completed = completed + 1
            }
        }
    }
    assert(completed == 100)
}

test "1000 idle spawns не allocate sched_state" {
    // Stress 1000 fiber'ов без park'а. SpawnCtx хранится в GC-managed
    // fiber_ctx[] массиве (D97 fix) — Boehm видит все live contexts,
    // GC не собирает их пока fiber не завершится.
    mut sum = 0
    supervised {
        for i in 0..1000 {
            spawn {
                sum = sum + i
            }
        }
    }
    // Sum 0..1000 = 499_500.
    assert(sum == 499_500)
}
