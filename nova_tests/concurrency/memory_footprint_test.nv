// memory_footprint_test.nv — Plan 22 Ф.6 production memory test.
//
// Validates: NovaSchedState lazy-alloc (Вариант B) — для supervised
// блоков **без** Time.sleep/Channel.recv sched_state остаётся NULL.
// Это значит idle scope'ы тратят только 8 bytes на pointer, не ~50 KB
// на NovaSchedState array.
//
// Test strategy: supervised блоки с N fiber'ами без park'а — должны
// завершаться быстро, нет abort'а.
//
// N=500 выбран как стабильный предел для Boehm GC на Windows:
// 1000 fiber'ов × 56 KB стека = 56 MB live во время scan двух тестов
// (Boehm scan'ит все живые mco_coro стеки при каждой коллекции).
// 500 = 28 MB — в пределах нормы для Boehm conservative scan.

module nova_tests.concurrency.memory_footprint_test

test "100 idle supervised scopes — no sched_state allocations" {
    // 100 fiber'ов которые spawn'ятся и сразу завершаются.
    // sched_state должен остаться NULL для каждого — никто не park'ится.
    let mut completed = 0
    supervised {
        for _ in 0..100 {
            spawn {
                // No sleep, no recv — no park.
                completed = completed + 1
            }
        }
    }
    assert(completed == 100)
}

test "500 idle spawns не allocate sched_state" {
    // Stress 500 fiber'ов без park'а. Если sched_state allocates
    // для каждого — это +25 MB heap (зависит от реализации).
    // N=500 безопасен для Boehm GC conservative scan на Windows.
    let mut sum = 0
    supervised {
        for i in 0..500 {
            spawn {
                sum = sum + i
            }
        }
    }
    // Sum 0..500 = 124_750.
    assert(sum == 124_750)
}
