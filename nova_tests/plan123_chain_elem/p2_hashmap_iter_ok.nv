// Регрессия Plan 123 chain-cache element-type (fix f1cd07b15a9).
//
// Прямой триггер корневого пути: `for (k, v) in map` вызывает
// `HashMapIter[K,V].@next()`, тело которого читает `@map._buckets[@pos]`
// многократно → field-cache материализует `_at_map__buckets_chain`.
// Без фикса элемент массива `[]Slot[K,V]` инферился как `nova_int`
// → `slot->tag` на nova_int → CC-FAIL.
//
// КРИТЕРИИ ПРИЁМКИ (positive):
//  - `for (k, v) in HashMap[K,V]` компилируется (element-type Slot[K,V]
//    резолвится через template+subst в кэш-temp binding);
//  - агрегаты по итерации дают верный результат под release nova.

module nova_tests.plan123_chain_elem

import std.collections.hashmap.{HashMap}

test "for (k, v) in HashMap[str, int] — chain-cache iter" {
    ro m HashMap[str, int] = ["a": 1, "b": 2, "c": 3]
    mut sum = 0
    for (_k, v) in m {
        sum = sum + v
    }
    assert(sum == 6)
}

test "for (k, v) in HashMap[int, int] — keys+values" {
    ro m HashMap[int, int] = [1: 10, 2: 20, 3: 30]
    mut ksum = 0
    mut vsum = 0
    for (k, v) in m {
        ksum = ksum + k
        vsum = vsum + v
    }
    assert(ksum == 6)
    assert(vsum == 60)
}
