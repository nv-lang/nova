// Plan 138 Ф.4 — t_vec_write_index: v[i] = val on Vec[T]
// A1b: v[i] = val → write, panic on OOB

module nova_tests.plan138

import std.collections.vec.{Vec}

test "v[i] = val writes through" {
    mut v = Vec[int].of(1, 2, 3)
    v[0] = 10
    v[1] = 20
    v[2] = 30
    assert(v.get(0) == Some(10))
    assert(v.get(1) == Some(20))
    assert(v.get(2) == Some(30))
}

test "v[i] = val on Vec[str]" {
    mut v = Vec[str].of("hello", "world")
    v[0] = "goodbye"
    assert(v.get(0) == Some("goodbye"))
    assert(v.get(1) == Some("world"))
}
