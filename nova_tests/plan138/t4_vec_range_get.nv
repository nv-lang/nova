// Plan 138 Ф.4 — t4: v[i..j] range slices + view semantics
// Extended range slice tests

module nova_tests.plan138

import std.collections.vec.{Vec}

test "inclusive range v[1..=3]" {
    ro v = Vec[int].of(10, 20, 30, 40, 50)
    ro slice = v[1..=3]
    assert(slice.len() == 3)
    assert(slice.get(0) == Some(20))
    assert(slice.get(2) == Some(40))
}

test "open-start v[..3]" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro slice = v[..3]
    assert(slice.len() == 3)
    assert(slice.get(0) == Some(1))
    assert(slice.get(2) == Some(3))
}

test "open-end v[2..]" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro slice = v[2..]
    assert(slice.len() == 3)
    assert(slice.get(0) == Some(3))
    assert(slice.get(2) == Some(5))
}
