// Plan 138 Ф.4 — t5: was `s[i] -> char` (D238 `str | int | char`).
// Plan 152.1 (D249 + D238 AMEND): integer-indexing a str is RETRACTED — codepoint
// indexing UTF-8 is O(n) hiding behind `[i]`. The i-th codepoint now goes through
// the `as_chars()` lens: `s.as_chars().nth(i) -> Option[char]` (O(n), explicit).
// The compile-error for `s[i]` lives in plan152_1/n_str_int_index.

module nova_tests.plan138

test "as_chars().nth(i): i-th codepoint" {
    ro s = "abc"
    assert(s.as_chars().nth(0) == Some('a'))
    assert(s.as_chars().nth(1) == Some('b'))
    assert(s.as_chars().nth(2) == Some('c'))
}

test "as_chars().nth on str literal" {
    assert("hello".as_chars().nth(0) == Some('h'))
    assert("hello".as_chars().nth(4) == Some('o'))
}
