// Plan 138 Ф.4 — t3: v[from..to] → zero-copy view
// A3: v[2..5] → Vec[T] zero-copy view; push on view → detach, original unchanged

module plan138.t3_vec_range_index

import std.collections.vec_owned.{Vec}

test "v[1..3] yields a 2-element view" {
    ro v = Vec[int].from([10, 20, 30, 40, 50])
    ro slice = v[1..3]
    assert(slice.len() == 2)
    assert(slice.get(0) == Some(20))
    assert(slice.get(1) == Some(30))
}

test "v[0..5] full-range view" {
    ro v = Vec[int].from([1, 2, 3, 4, 5])
    ro slice = v[0..5]
    assert(slice.len() == 5)
    assert(slice.get(0) == Some(1))
    assert(slice.get(4) == Some(5))
}

test "v[2..2] empty range view" {
    ro v = Vec[int].from([1, 2, 3])
    ro slice = v[2..2]
    assert(slice.len() == 0)
    assert(slice.get(0) == None)
}
