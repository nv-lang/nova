// Plan 164 Ф.2 — blanket mono-name must be independent of generic param order.
//
// Bug: `fn[T Compare, I Next[T]] I mut @zmin()` (T first, I second) produced a
// wrong type_subst in emit_call because the code used `fn_decl.generics.first()`
// to find the receiver typevar, binding T→concrete_iterator instead of
// I→concrete_iterator. The fix: look up the generic whose name matches the
// registered receiver typevar (type_name / blanket_tvname), not blindly use [0].
//
// This file tests the existing `fn[I Next[T], T Compare]` methods (@zmin / @zmax)
// from vec_iter_zc to confirm the codegen path works correctly end-to-end.
// Those methods have I as generics[0], so they exercised the *working* path; the
// fix now also handles the swapped order (T first) robustly via name-lookup.
module plan164.blanket_param_order

import std.collections.vec_iter_zc

test "zmin returns smallest int element" {
    ro v = Vec[int].of(3, 1, 4, 1, 5, 9, 2, 6)
    ro m = v.ziter().zmin()
    assert(m.unwrap_or(-1) == 1)
}

test "zmax returns largest int element" {
    ro v = Vec[int].of(3, 1, 4, 1, 5, 9, 2, 6)
    ro m = v.ziter().zmax()
    assert(m.unwrap_or(-1) == 9)
}

test "zmin on empty iterator returns None" {
    ro v = Vec[int].of()
    ro m = v.ziter().zmin()
    assert(m == None)
}

test "zmax on empty iterator returns None" {
    ro v = Vec[int].of()
    ro m = v.ziter().zmax()
    assert(m == None)
}

test "zmin / zmax after zfilter adapter (multi-bound blanket)" {
    ro v = Vec[int].of(10, 3, 7, 1, 8, 2)
    // zfilter changes the receiver type to FilterIter — codegen must still
    // resolve the two-bound blanket fn[I Next[T], T Compare] correctly.
    ro lo = v.ziter().zfilter(|x| x > 3).zmin()
    ro hi = v.ziter().zfilter(|x| x < 8).zmax()
    assert(lo.unwrap_or(-1) == 7)
    assert(hi.unwrap_or(-1) == 7)
}

test "zmin / zmax after zmap adapter (chained, two-bound blanket)" {
    ro v = Vec[int].of(5, 2, 8, 1, 9, 3)
    ro lo = v.ziter().zmap(|x| x * 2).zmin()
    ro hi = v.ziter().zmap(|x| x * 2).zmax()
    assert(lo.unwrap_or(-1) == 2)
    assert(hi.unwrap_or(-1) == 18)
}
