// Plan 164 Ф.3 — nth on FilterIter returns correct Option[int].
//
// Regression guard: blanket `fn[I Next[T]] I mut @nth(n int)` must dispatch
// to the FilterIter receiver correctly, consuming the first n matching elements
// and returning the (n+1)-th.
module nova_tests.plan164

import std.collections.vec_iter

test "nth on VecIter" {
    ro v = Vec[int].of(10, 20, 30, 40, 50)
    assert(v.iter().nth(0) == Some(10))
    assert(v.iter().nth(2) == Some(30))
    assert(v.iter().nth(4) == Some(50))
}

test "nth on FilterIter returns correct indexed element" {
    ro v = Vec[int].of(1, 2, 3, 4, 5, 6, 7, 8)
    // FilterIter yields: 2, 4, 6, 8 — nth(1) = 4, nth(3) = 8
    ro r0 = v.iter().filter(|x| x % 2 == 0).nth(0)
    ro r1 = v.iter().filter(|x| x % 2 == 0).nth(1)
    ro r3 = v.iter().filter(|x| x % 2 == 0).nth(3)
    assert(r0 == Some(2))
    assert(r1 == Some(4))
    assert(r3 == Some(8))
}

test "nth out of range on FilterIter returns None" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro r = v.iter().filter(|x| x % 2 == 0).nth(10)
    assert(r == None)
}

test "nth on empty FilterIter returns None" {
    ro v = Vec[int].of(1, 3, 5)
    ro r = v.iter().filter(|x| x % 2 == 0).nth(0)
    assert(r == None)
}

test "nth after map on FilterIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5, 6)
    // map(*10) → MapIter; filter(>25) keeps 30,40,50,60; nth(2) = 50
    ro r = v.iter().map(|x| x * 10).filter(|x| x > 25).nth(2)
    assert(r == Some(50))
}
