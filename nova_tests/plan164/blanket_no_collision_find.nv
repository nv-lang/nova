// Plan 164 Ф.3 — find on FilterIter returns correct Option[int].
//
// Regression guard: blanket `fn[I Next[T]] I mut @find(pred fn(T)->bool)` must
// dispatch to the FilterIter receiver, not to any concrete type registered last
// in method_receivers.
module plan164.blanket_no_collision_find

import std.collections.vec_iter as vec_iter

test "find on VecIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    assert(v.iter().find(|x| x > 3) == Some(4))
}

test "find on FilterIter finds first match" {
    ro v = Vec[int].of(1, 2, 3, 4, 5, 6, 7, 8)
    // FilterIter passes only even elements; find finds first > 4 among those.
    ro r = v.iter().filter(|x| x % 2 == 0).find(|x| x > 4)
    assert(r == Some(6))
}

test "find on FilterIter no match returns None" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    ro r = v.iter().filter(|x| x % 2 == 0).find(|x| x > 100)
    assert(r == None)
}

test "find on empty FilterIter returns None" {
    ro v = Vec[int].of(1, 3, 5)
    ro r = v.iter().filter(|x| x % 2 == 0).find(|x| x > 0)
    assert(r == None)
}

test "find after map on FilterIter" {
    ro v = Vec[int].of(1, 2, 3, 4, 5)
    // MapIter → FilterIter → find (three adapter types chained)
    ro r = v.iter().map(|x| x * 3).filter(|x| x > 6).find(|x| x < 15)
    assert(r == Some(9))
}
