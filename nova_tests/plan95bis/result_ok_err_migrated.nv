// Plan 95.bis Ф.3.1: Result.ok() / Result.err() — projection to Option.
//
// Прежние Nova_Result_method_ok (трамплин + #define) и inline emit для
// `Result.err()` (emit_c.rs:11903+) ЗАМЕНЕНЫ на Nova-body:
//   ok()  => match @ { Ok(v)  => Some(v), Err(_) => None }
//   err() => match @ { Ok(_) => None,    Err(e) => Some(e) }

module plan95bis.result_ok_err_migrated

test "Result.ok() — Ok → Some, Err → None" {
    ro ok_r Result[int, str] = Ok(123)
    ro err_r Result[int, str] = Err("boom")

    ro some_v = ok_r.ok()
    assert(some_v.is_some())
    assert(some_v.unwrap_or(0) == 123)

    ro none_v = err_r.ok()
    assert(none_v.is_none())
}

test "Result.err() — Ok → None, Err → Some" {
    ro ok_r Result[int, str] = Ok(123)
    ro err_r Result[int, str] = Err("boom")

    ro none_e = ok_r.err()
    assert(none_e.is_none())

    ro some_e = err_r.err()
    assert(some_e.is_some())
    assert(some_e.unwrap_or("") == "boom")
}
