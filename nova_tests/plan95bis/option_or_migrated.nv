// Plan 95.bis Ф.3.1: Option.or — Nova-body fallback chain.
//
// Прежний Nova_Option_method_or_<T> (NOVA_ARRAY_IMPL + explicit
// _nova_str specialization в array.h) ЗАМЕНЁН на Nova-body
// `=> match @ { Some(v) => Some(v), None => other }`.

module plan95bis.option_or_migrated

test "Option[int].or — chain None.or(Some).or(None) → Some" {
    ro a Option[int] = None
    ro b Option[int] = Some(10)
    ro c Option[int] = None
    ro result_i = a.or(b).or(c)
    assert(result_i.is_some())
    assert(result_i.unwrap_or(0) == 10)
}

test "Option[str].or — both None → None" {
    ro s1 Option[str] = None
    ro s2 Option[str] = None
    ro result_s = s1.or(s2)
    assert(result_s.is_none())
}

test "Option[str].or — first wins when present" {
    ro p Option[str] = Some("primary")
    ro q Option[str] = Some("secondary")
    ro result_p = p.or(q)
    assert(result_p.unwrap_or("none") == "primary")
}

test "Option[char].or — None.or(Some) → second" {
    ro n Option[char] = None
    ro v Option[char] = Some('X')
    assert(n.or(v).unwrap_or('?') == 'X')
}
