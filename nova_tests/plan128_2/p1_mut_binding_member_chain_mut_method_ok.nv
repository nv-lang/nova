// Plan 128.2 Ф.2 P1 — mut binding + member chain + mut method = OK.
//
// `mut b` binding, `Wrapper2 { mut inner Vec32 }`, b.inner.set_x(42).
// Verifies positive path: chain-walking enforcement allows mutation
// когда root binding `mut` и intermediate field `mut`.

module nova_tests.plan128_2

type Vec32(x int, y int, z int)

fn Vec32 mut @set_x(v int) -> () {
    @x = v
}

type Wrapper2 {
    mut inner Vec32
}

fn Wrapper2.new() -> Self => {
    inner: Vec32(x: 1, y: 2, z: 3),
}

test "mut binding + member chain + mut method — OK" {
    mut b = Wrapper2.new()
    b.inner.set_x(42)
    assert(b.inner.x == 42)
    assert(b.inner.y == 2)
    assert(b.inner.z == 3)
}
