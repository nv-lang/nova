// Plan 128.2 Р¤.2 P4 вЂ” deep member chain mut binding + mut method = OK.
//
// `mut Av: Av; Av.Bv.Cv.Dv.mut_m()` вЂ” chain depth 4, root binding `mut`, РІСЃРµ
// intermediate fields `mut`. Chain-walking helper recursively walks
// РґРѕ root Ident.

module plan128_2.p4_deep_chain_mut_ok

type Dv {
    mut value int
}

fn Dv.new() -> Self => { value: 0 }

fn Dv mut @set(v int) -> () {
    @value = v
}

type Cv {
    mut Dv Dv
}

fn Cv.new() -> Self => { Dv: Dv.new() }

type Bv {
    mut Cv Cv
}

fn Bv.new() -> Self => { Cv: Cv.new() }

type Av {
    mut Bv Bv
}

fn Av.new() -> Self => { Bv: Bv.new() }

test "deep chain mut binding + mut method вЂ” OK" {
    mut Av = Av.new()
    Av.Bv.Cv.Dv.set(99)
    assert(Av.Bv.Cv.Dv.value == 99)
}
