module nova_tests.plan91_18

import std.unicode

test "collate compare" {
    ro c = Collator.root()
    ro r = c.order("apple", "banana")
    assert(r < 0)
}

test "collate same" {
    ro c = Collator.root()
    assert(c.same("café", "café"))
}

test "collate compare case secondary" {
    assert(collate_compare("apple", "Apple") < 0)
}

test "collate sort key is Vec[u32]" {
    ro key = collate_sort_key("hello")
    assert(key.len() > 0)
}
