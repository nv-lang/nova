module nova_tests.plan91_18

test "as_sentences is O(1)" {
    ro it = "Hello. World.".as_sentences()
    assert(!it.is_empty())
}

test "sentences basic" {
    mut cnt = 0
    mut it = "Hello. World. Foo.".as_sentences()
    while it.next() != None { cnt += 1 }
    assert(cnt >= 2)
}

test "sentences is_empty after drain" {
    mut it = "Hi.".as_sentences()
    while it.next() != None {}
    assert(it.is_empty())
}

test "sentences empty string" {
    assert("".as_sentences().is_empty())
}
