// EXPECT_COMPILE_ERROR D147
//
// Plan 100.4.1 (D147): defer body имеет Fail[E] effect, но enclosing
// fn-sig не объявил Fail[E] → compile error.
//
// Force'ит explicit visibility cleanup-fail в API.

module nova_tests.plan100_4_1.defer_fail_err_no_fail_in_sig

type CommitErr { msg str }

type Transaction consume {
    id int,
}

fn Transaction consume @commit() Fail[CommitErr] -> () {
    throw CommitErr { msg: "x" }
}

fn begin() -> Transaction => Transaction { id: 1 }

// ❌ fn-sig без Fail[E].
fn process() -> () {                            // ← no Fail в sig
    consume tx = begin()
    // ОШИБКА D147-defer-fail-not-in-sig: defer body имеет Fail[CommitErr],
    // но enclosing fn не declares Fail. Suggest: add `Fail[CommitErr]` к sig.
    defer { tx.commit() }
}

test "defer fail без Fail в sig — error" {
    process()
}
