// Plan 100.4.1 (D147): errdefer fail во время propagation — composes
// с primary.

module nova_tests.plan100_4_1.errdefer_fail_ok_propagation

type WorkErr { msg str }
type RollbackErr { msg str }

type Transaction consume { id int }

fn Transaction consume @rollback() Fail[RollbackErr] -> () {
    throw RollbackErr { msg: "rollback failed too" }
}

fn begin() -> Transaction => Transaction { id: 1 }

fn process() Fail -> () {
    consume tx = begin()
    errdefer { tx.rollback() }                  // may fail
    throw WorkErr { msg: "primary work failed" }
    // Unwinding:
    //   1. body throws WorkErr (primary)
    //   2. errdefer fires; rollback fails RollbackErr (suppressed)
    //   3. composite: { primary: WorkErr, suppressed: [RollbackErr] }
}

test "errdefer fail composes с primary" {
    process()
}
