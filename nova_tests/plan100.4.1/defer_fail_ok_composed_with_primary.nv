// Plan 100.4.1 (D147): defer-fail во время error-propagation —
// composite-error через Plan 49 MultiError.

module nova_tests.plan100_4_1.defer_fail_ok_composed_with_primary

type WorkErr { msg str }
type CommitErr { msg str }

type Transaction consume {
    id int,
}

fn Transaction consume @commit() Fail[CommitErr] -> () {
    throw CommitErr { msg: "network timeout" }
}

fn begin() -> Transaction => Transaction { id: 1 }

fn do_work_that_fails() Fail[WorkErr] -> () {
    throw WorkErr { msg: "operation failed" }
}

// fn-sig объявляет оба Fail (union или composite).
fn process() Fail -> () {
    consume tx = begin()
    defer { tx.commit() }                       // failable cleanup (D147)
    do_work_that_fails()?                        // throws WorkErr
    // Unwinding:
    //   defer fires; tx.commit() throws CommitErr
    //   composite: { primary: WorkErr, suppressed: [CommitErr] }
    //   caller получает composite через Fail
}

test "do_work fails + defer commit fails — composite error" {
    let r = process()
    // r — Result; composite error.
}
