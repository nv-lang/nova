// Plan 100.4.1 (D147): caller inspects composite via MultiError API.

module nova_tests.plan100_4_1.multi_error_inspect_ok

type WorkErr { msg str }
type CleanupErr { msg str }

type Transaction consume {
    id int,
}

fn Transaction consume @commit() Fail[CleanupErr] -> () {
    throw CleanupErr { msg: "cleanup-fail" }
}

fn begin() -> Transaction => Transaction { id: 1 }

fn inner() Fail -> () {
    consume tx = begin()
    defer { tx.commit() }                       // will fail during unwind
    throw WorkErr { msg: "work-fail" }
}

test "caller inspects MultiError chain" {
    match inner() {
        Ok(_) => println("unreachable"),
        Err(e) => {
            // e — MultiError; .primary() / .suppressed() API (D147).
            println("primary: ${e.primary()}")
            for s in e.suppressed() {
                println("  suppressed: ${s}")
            }
        }
    }
}
