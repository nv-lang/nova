// Plan 100.4.1 (D158): backward-compat — defer без Fail effect работает
// как раньше (Plan 20 D90).

module nova_tests.plan100_4_1.defer_ok_no_fail_backward_compat

// Infallible cleanup-method — нет Fail-effect.
type Counter {
    value int,
}

fn Counter mut @log() -> () { println("logged") }

fn process() -> () {
    let c = Counter { value: 0 }
    defer { c.log() }                           // infallible body — work как раньше
    // do_work — success
}

test "defer без Fail — backward-compat" {
    process()
}
