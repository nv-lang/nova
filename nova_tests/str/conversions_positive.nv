// conversions_positive.nv — Plan 75 Ф.3
// str.from(char/int/bool) Ok-ветки. Round-trip bytes.

module str.conversions_positive

test "str.from ASCII char" {
    assert(str.from('A') == "A")
}

test "str.from Cyrillic char (2-byte UTF-8)" {
    ro s = str.from('Ю')
    assert(s == "Ю")
    assert(s.len() == 2)         // Plan 108 D26 rev: len = bytes
    assert(s.char_len() == 1)    // char_len = codepoints
}

test "str.from emoji char (4-byte UTF-8)" {
    ro s = str.from('😀')
    assert(s == "😀")
    assert(s.len() == 4)         // Plan 108 D26 rev: len = bytes
    assert(s.char_len() == 1)    // char_len = codepoints
}

test "str.from(int) zero" {
    assert(str.from(0) == "0")
}

test "str.from(int) positive" {
    assert(str.from(42) == "42")
}

test "str.from(int) negative" {
    assert(str.from(-7) == "-7")
}

test "str.from(true)" {
    assert(str.from(true) == "true")
}

test "str.from(false)" {
    assert(str.from(false) == "false")
}

test "int.try_from valid positive" {
    ro r = int.try_from("123")
    assert(r.is_ok())
    assert(r.unwrap_or(0) == 123)
}

test "int.try_from valid negative" {
    ro r = int.try_from("-100")
    assert(r.is_ok())
    assert(r.unwrap_or(0) == -100)
}

test "bool.try_from true" {
    assert(bool.try_from("true").is_ok())
}

test "bool.try_from false" {
    assert(bool.try_from("false").is_ok())
}

test "round-trip ASCII str through bytes" {
    ro s = "hello"
    ro r = str.try_from(s.to_bytes())
    assert(r.is_ok())
}

test "round-trip Cyrillic str through bytes" {
    ro s = "Привет"
    ro r = str.try_from(s.to_bytes())
    assert(r.is_ok())
}