// slice_oob.nv — Plan 75 Ф.6
// @slice OOB: clamp behaviour.

module str.slice_oob

test "slice normal range" {
    assert("hello".slice(0, 3) == "hel")
}

test "slice full string" {
    assert("abc".slice(0, 3) == "abc")
}

test "slice empty range" {
    assert("abc".slice(1, 1) == "")
}

test "slice clamp: to > len returns up to end" {
    assert("abc".slice(0, 100) == "abc")
}

test "slice clamp: from > len returns empty" {
    assert("abc".slice(10, 20) == "")
}