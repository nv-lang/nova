// split_edge.nv — Plan 75 Ф.2
// split edge cases: соседние разделители, sep не найден, крайние позиции.

module str.split_edge

test "split: basic multi-part" {
    ro parts = "a,b,c".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "b")
    assert(parts[2] == "c")
}

test "split: adjacent separators produce empty element" {
    ro parts = "a,,b".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "")
    assert(parts[2] == "b")
}

test "split: separator not found returns single element" {
    ro parts = "abc".split("X")
    assert(parts.len() == 1)
    assert(parts[0] == "abc")
}

test "split: separator at start produces leading empty" {
    ro parts = ",abc".split(",")
    assert(parts.len() == 2)
    assert(parts[0] == "")
    assert(parts[1] == "abc")
}

test "split: separator at end produces trailing empty" {
    ro parts = "abc,".split(",")
    assert(parts.len() == 2)
    assert(parts[0] == "abc")
    assert(parts[1] == "")
}

test "split: single separator only produces two empty strings" {
    ro parts = ",".split(",")
    assert(parts.len() == 2)
    assert(parts[0] == "")
    assert(parts[1] == "")
}

test "split: multi-char separator" {
    ro parts = "aXXbXXc".split("XX")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "b")
    assert(parts[2] == "c")
}