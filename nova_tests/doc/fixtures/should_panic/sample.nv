//! Plan 45 Ф.22.8 / D104 — smoke fixture для `should_panic` doc-test.
//!
//! Демонстрирует `nova,should_panic` модификатор — тест ожидает,
//! что код завершится с panic во время выполнения.

module nova_tests.doc.fixtures.should_panic.sample

/// Возвращает элемент массива по индексу.
///
/// # Examples
///
/// Нормальный доступ:
///
/// ```nova
/// let mut arr = [10, 20, 30]
/// assert(arr[1] == 20)
/// ```
///
/// Доступ за границы → panic (ожидаемое поведение):
///
/// ```nova,should_panic
/// let mut arr = [1, 2, 3]
/// let _ = arr[99]
/// ```
export fn get(arr []int, i int) -> int => arr[i]
