//! Plan 45 Ф.7: fixture для doc-tests с модификаторами + hidden lines.

module doctests.sample

/// Удваивает `x`.
///
/// # Examples
///
/// Тривиальный пример:
///
/// ```nova
/// let x = 21
/// let y = x * 2
/// ```
///
/// Crate-scope (Ф.21.1): вызов документируемой функции:
///
/// ```nova
/// assert(double(3) == 6)
/// ```
///
/// Не запускаем (compile-only):
///
/// ```nova,no_run
/// let big = 1_000_000 * 2
/// ```
///
/// Игнорируем (показано, но не запускается):
///
/// ```nova,ignore
/// undefined_symbol()
/// ```
///
/// Compile-fail тест (ожидаемая ошибка типа):
///
/// ```nova,compile_fail
/// let x: int = "not an int"
/// ```
///
/// SMT-verified (Ф.21.4): без contracts → trivially verifies.
///
/// ```nova,must_verify
/// let _ = 1
/// ```
export fn double(x int) -> int =>
    x * 2
