// Plan 45 Ф.23.8/9: Effects structured в doc — EffectEntry с is_row_var.
// Позитивный тест: функции с effects корректно работают.
// Правильный синтаксис Nova effects: без `fn` keyword в effect body.

module nova_tests.doc

type Logger_f23effectspositive effect {
    log(msg str) -> ()
}

type Counter_f23effectspositive effect {
    tick() -> ()
    get() -> int
}

/// Log a message — requires Logger_f23effectspositive effect.
export fn log_message(msg str) Logger_f23effectspositive -> () {
    Logger_f23effectspositive.log(msg)
}

/// Count up to n using Counter_f23effectspositive effect.
export fn count_to_f23effectspositive(n int) Counter_f23effectspositive -> int {
    mut i = 0
    while i < n {
        Counter_f23effectspositive.tick()
        i = i + 1
    }
    Counter_f23effectspositive.get()
}

test "log with handler — void result" {
    mut calls = 0
    with Logger_f23effectspositive = effect Logger_f23effectspositive {
        log(msg str) {
            calls = calls + 1
            return ()
        }
    } {
        log_message("hello")
        log_message("world")
    }
    assert(calls == 2)
}

test "count_to_f23effectspositive basic" {
    mut n = 0
    ro result = with Counter_f23effectspositive = effect Counter_f23effectspositive {
        tick() { n = n + 1; return () }
        get() { return n }
    } {
        count_to_f23effectspositive(5)
    }
    assert(result == 5)
}

test "count_to_f23effectspositive zero" {
    mut n = 0
    ro result = with Counter_f23effectspositive = effect Counter_f23effectspositive {
        tick() { n = n + 1; return () }
        get() { return n }
    } {
        count_to_f23effectspositive(0)
    }
    assert(result == 0)
}

test "effects compose sequentially" {
    mut log_count = 0
    mut cnt = 0
    with Logger_f23effectspositive = effect Logger_f23effectspositive {
        log(_msg str) { log_count = log_count + 1; return () }
    } {
        log_message("start")
        ro inner = with Counter_f23effectspositive = effect Counter_f23effectspositive {
            tick() { cnt = cnt + 1; return () }
            get() { return cnt }
        } {
            count_to_f23effectspositive(3)
        }
        log_message("end")
        assert(inner == 3)
    }
    assert(log_count == 2)
    assert(cnt == 3)
}
