// Plan 45 Ф.26.3 / D63: allow_transit capability placeholder.
// Позитивный тест: функции с #realtime, #pure capabilities (которые
// существуют в parser) компилируются и runtime ok. allow_transit поле
// в DocItem уже есть, но parser его не fills — это покрывает cargo
// integration tests. Здесь — runtime behavior существующих capabilities.

module doc.f26_capabilities_positive

/// Pure function — без side effects.
export fn square(x int) -> int => x * x

/// Pure function returns boolean.
export fn is_positive(x int) -> bool => x > 0

/// Realtime-safe function — no allocation, no blocking.
#realtime
fn add_realtime(a int, b int) -> int => a + b

/// Realtime nogc — strictest tier.
#realtime nogc
fn max_realtime_nogc(a int, b int) -> int => if a > b { a } else { b }

/// Pure + recursive — должно быть pure_fn: true.
export fn pow_pure(base int, exp int) -> int {
    if exp <= 0 { 1 } else { base * pow_pure(base, exp - 1) }
}

/// Mixed — pure helper for non-pure code.
export fn use_pure_helpers(x int) -> int {
    let sq = square(x)
    let ok = is_positive(x)
    if ok { sq } else { 0 }
}

test "square pure correctness" {
    assert(square(0) == 0)
    assert(square(5) == 25)
    assert(square(-3) == 9)
    assert(square(10) == 100)
}

test "is_positive" {
    assert(is_positive(1))
    assert(is_positive(100))
    assert(!is_positive(0))
    assert(!is_positive(-5))
}

test "add_realtime" {
    assert(add_realtime(0, 0) == 0)
    assert(add_realtime(2, 3) == 5)
    assert(add_realtime(-1, 1) == 0)
}

test "max_realtime_nogc" {
    assert(max_realtime_nogc(5, 3) == 5)
    assert(max_realtime_nogc(3, 5) == 5)
    assert(max_realtime_nogc(7, 7) == 7)
    assert(max_realtime_nogc(-1, -2) == -1)
}

test "pow_pure" {
    assert(pow_pure(2, 0) == 1)
    assert(pow_pure(2, 1) == 2)
    assert(pow_pure(2, 10) == 1024)
    assert(pow_pure(3, 3) == 27)
}

test "use_pure_helpers composes" {
    assert(use_pure_helpers(5) == 25)
    assert(use_pure_helpers(-5) == 0)
    assert(use_pure_helpers(0) == 0)
}

test "capabilities don't affect runtime" {
    // #pure / #realtime — only doc/verify metadata, no runtime difference.
    let r1 = square(7)
    let r2 = add_realtime(7, 7)
    let r3 = max_realtime_nogc(r1, r2)
    assert(r1 == 49)
    assert(r2 == 14)
    assert(r3 == 49)
}
