// Plan 45 Ф.26.2 / Ф.23.4: Handler matrix (Effect → callers).
// Позитивный тест: функции с `effect Effect { ... }` literals компилируются
// и runtime работает корректно. Doc-pipeline scan'ит handler literals и
// populate'ит Effect.handlers — это проверяется cargo integration tests.
// Здесь — runtime correctness handlers.

module nova_tests.doc

/// Counter_f26handlermatrixpositive effect — simple state.
export type Counter_f26handlermatrixpositive effect {
    incr()
    #pure get() -> int
    axiom non_negative(_x int) => true
}

/// Logger_f26handlermatrixpositive effect — collect strings.
export type Logger_f26handlermatrixpositive effect {
    log(msg str)
    #pure last() -> str
}

/// Function — single handler usage.
export fn count_to_f26handlermatrixpositive(n int) -> int {
    mut c = 0
    with #trusted Counter_f26handlermatrixpositive = effect Counter_f26handlermatrixpositive {
        incr() { c = c + 1 }
        get() => c
    } {
        mut i = 0
        while i < n {
            Counter_f26handlermatrixpositive.incr()
            i = i + 1
        }
        Counter_f26handlermatrixpositive.get()
    }
}

/// Function — multiple distinct handlers (two-handler scenario).
export fn count_and_log(n int) -> int {
    mut c = 0
    mut last_msg = ""
    with #trusted Counter_f26handlermatrixpositive = effect Counter_f26handlermatrixpositive {
        incr() { c = c + 1 }
        get() => c
    } {
        with #trusted Logger_f26handlermatrixpositive = effect Logger_f26handlermatrixpositive {
            log(msg) { last_msg = msg }
            last() => last_msg
        } {
            mut i = 0
            while i < n {
                Counter_f26handlermatrixpositive.incr()
                Logger_f26handlermatrixpositive.log("tick")
                i = i + 1
            }
            Counter_f26handlermatrixpositive.get()
        }
    }
}

/// Helper — reuses Counter_f26handlermatrixpositive handler in second caller.
export fn count_twice(n int) -> int {
    mut c = 0
    with #trusted Counter_f26handlermatrixpositive = effect Counter_f26handlermatrixpositive {
        incr() { c = c + 1 }
        get() => c
    } {
        Counter_f26handlermatrixpositive.incr()
        Counter_f26handlermatrixpositive.incr()
    }
    count_to_f26handlermatrixpositive(n)
}

test "count_to_f26handlermatrixpositive basic" {
    assert(count_to_f26handlermatrixpositive(0) == 0)
    assert(count_to_f26handlermatrixpositive(1) == 1)
    assert(count_to_f26handlermatrixpositive(5) == 5)
    assert(count_to_f26handlermatrixpositive(10) == 10)
}

test "count_and_log basic" {
    assert(count_and_log(0) == 0)
    assert(count_and_log(1) == 1)
    assert(count_and_log(3) == 3)
}

test "count_twice — second call independent" {
    // First handler isolates c=0; count_to_f26handlermatrixpositive does its own.
    assert(count_twice(5) == 5)
    assert(count_twice(0) == 0)
}

test "handler isolation per with-block" {
    // Two separate with-blocks → each has own state.
    ro r1 = count_to_f26handlermatrixpositive(3)
    ro r2 = count_to_f26handlermatrixpositive(7)
    assert(r1 == 3)
    assert(r2 == 7)
}
