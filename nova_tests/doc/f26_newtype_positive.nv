// Plan 45 Ф.26.1: Newtype variant correctness (dead match arm fix).
// Позитивный тест: newtype declarations компилируются и runtime работает.
// Через doc-pipeline (НЕ через nova test): JSON output должен показывать
// kind: "newtype", не "alias". Здесь проверяем что Nova compile + runtime ok.

module doc.f26_newtype_positive

/// Email — newtype над str для type safety.
export type Email str

/// AccountId — newtype над int.
export type AccountId int

/// UserName — обычный alias (НЕ newtype).
export type UserName alias str

/// Validate email — принимает Email newtype.
export fn validate_email(e Email) -> bool => true

/// Get account_id as raw int (newtype unwrap).
export fn account_to_int(id AccountId) -> int {
    let raw int = id
    raw
}

test "newtype используется как distinct type" {
    let id AccountId = 42
    assert(account_to_int(id) == 42)
}

test "newtype with multiple instances" {
    let a AccountId = 1
    let b AccountId = 2
    assert(account_to_int(a) + account_to_int(b) == 3)
}

test "alias works for plain types" {
    let name UserName = "Alice"
    assert(name == "Alice")
}

test "newtype and alias coexist" {
    let id AccountId = 100
    let name UserName = "Bob"
    assert(account_to_int(id) == 100)
    assert(name == "Bob")
}

test "validate_email accepts Email newtype" {
    let e Email = "test@example.com"
    assert(validate_email(e))
}
