// Plan 45 Ф.24.18: infer_contracts doc-test modifier.
// Позитивный тест — функции, для которых assert() в infer_contracts doc-tests
// определяют контракты, реально удовлетворяют этим контрактам в runtime.

module nova_tests.doc

/// Возвращает абсолютное значение.
///
/// # Examples
///
/// ```nova,infer_contracts
/// assert(abs_val_f24infercontractspositive(-5) == 5)
/// assert(abs_val_f24infercontractspositive(0) == 0)
/// assert(abs_val_f24infercontractspositive(3) == 3)
/// ```
export fn abs_val_f24infercontractspositive(x int) -> int => if x < 0 { 0 - x } else { x }

/// Зажимает значение в диапазон [lo, hi].
///
/// # Examples
///
/// ```nova,infer_contracts
/// assert(clamp_f24infercontractspositive(5, 0, 10) == 5)
/// assert(clamp_f24infercontractspositive(-5, 0, 10) == 0)
/// assert(clamp_f24infercontractspositive(15, 0, 10) == 10)
/// ```
export fn clamp_f24infercontractspositive(x int, lo int, hi int) -> int
    requires lo <= hi
    => if x < lo { lo } else if x > hi { hi } else { x }

/// Минимум двух чисел.
///
/// # Examples
///
/// ```nova,infer_contracts
/// assert(min_of(3, 7) == 3, "min returns smaller")
/// assert(min_of(7, 3) == 3, "symmetric")
/// assert(min_of(5, 5) == 5, "equal values")
/// ```
export fn min_of(a int, b int) -> int => if a < b { a } else { b }

/// Факториал (n >= 0).
///
/// # Examples
///
/// ```nova,infer_contracts
/// assert(factorial_f24infercontractspositive(0) == 1)
/// assert(factorial_f24infercontractspositive(1) == 1)
/// assert(factorial_f24infercontractspositive(5) == 120)
/// ```
export fn factorial_f24infercontractspositive(n int) -> int {
    if n <= 0 { 1 } else { n * factorial_f24infercontractspositive(n - 1) }
}

test "abs_val_f24infercontractspositive satisfies inferred contracts" {
    assert(abs_val_f24infercontractspositive(-5) == 5)
    assert(abs_val_f24infercontractspositive(0) == 0)
    assert(abs_val_f24infercontractspositive(3) == 3)
    assert(abs_val_f24infercontractspositive(-100) == 100)
    assert(abs_val_f24infercontractspositive(1) == 1)
}

test "abs_val_f24infercontractspositive always non-negative" {
    assert(abs_val_f24infercontractspositive(-999) >= 0)
    assert(abs_val_f24infercontractspositive(0) >= 0)
    assert(abs_val_f24infercontractspositive(999) >= 0)
}

test "clamp_f24infercontractspositive satisfies inferred contracts" {
    assert(clamp_f24infercontractspositive(5, 0, 10) == 5)
    assert(clamp_f24infercontractspositive(-5, 0, 10) == 0)
    assert(clamp_f24infercontractspositive(15, 0, 10) == 10)
}

test "clamp_f24infercontractspositive edge cases" {
    assert(clamp_f24infercontractspositive(0, 0, 0) == 0)
    assert(clamp_f24infercontractspositive(-1, 0, 5) == 0)
    assert(clamp_f24infercontractspositive(6, 0, 5) == 5)
    assert(clamp_f24infercontractspositive(3, 3, 3) == 3)
}

test "min_of satisfies inferred contracts" {
    assert(min_of(3, 7) == 3)
    assert(min_of(7, 3) == 3)
    assert(min_of(5, 5) == 5)
}

test "min_of additional" {
    assert(min_of(0, -1) == -1)
    assert(min_of(-10, -20) == -20)
    assert(min_of(100, 0) == 0)
}

test "factorial_f24infercontractspositive satisfies inferred contracts" {
    assert(factorial_f24infercontractspositive(0) == 1)
    assert(factorial_f24infercontractspositive(1) == 1)
    assert(factorial_f24infercontractspositive(5) == 120)
    assert(factorial_f24infercontractspositive(4) == 24)
    assert(factorial_f24infercontractspositive(3) == 6)
    assert(factorial_f24infercontractspositive(2) == 2)
}
