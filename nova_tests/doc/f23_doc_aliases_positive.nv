// Plan 45 Ф.22.6 + Ф.23: doc_alias attrs парсятся и не ломают runtime.
// Позитивный тест: функции с #doc_alias работают нормально.

module nova_tests.doc

/// Compute absolute_f23docaliasespositive value.
#doc_alias("abs", "magnitude")
export fn absolute_f23docaliasespositive(x int) -> int => if x < 0 { 0 - x } else { x }

/// Convert to string representation.
#doc_alias("stringify", "to_str")
export fn to_string_repr(n int) -> str {
    if n == 0 { return "0" }
    if n == 1 { return "1" }
    if n == 2 { return "2" }
    "other"
}

test "absolute_f23docaliasespositive value positive input" {
    assert(absolute_f23docaliasespositive(5) == 5)
    assert(absolute_f23docaliasespositive(0) == 0)
}

test "absolute_f23docaliasespositive value negative input" {
    assert(absolute_f23docaliasespositive(-5) == 5)
    assert(absolute_f23docaliasespositive(-1) == 1)
}

test "to_string_repr basic" {
    assert(to_string_repr(0) == "0")
    assert(to_string_repr(1) == "1")
    assert(to_string_repr(2) == "2")
    assert(to_string_repr(99) == "other")
}

test "aliases dont affect runtime" {
    assert(absolute_f23docaliasespositive(-42) == 42)
    assert(absolute_f23docaliasespositive(42) == 42)
}
