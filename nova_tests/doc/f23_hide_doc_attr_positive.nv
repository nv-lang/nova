// Plan 45 Ф.23.21: #hide_doc attr парсится и не ломает runtime.
// Позитивный тест: items с #hide_doc работают нормально,
// только из doc-output они исключаются (проверяется cargo-тестами).

module doc.f23_hide_doc_attr_positive

/// Public exported function — visible in docs.
export fn public_api(x int) -> int => x * 2

/// Internal helper — hidden from docs.
#hide_doc
export fn internal_helper(x int) -> int => x + 1

/// Another hidden function.
#hide_doc
fn private_impl(x int) -> int => x - 1

export fn combined(x int) -> int => public_api(internal_helper(x))

test "public api works" {
    assert(public_api(5) == 10)
    assert(public_api(0) == 0)
    assert(public_api(-2) == -4)
}

test "internal helper works even if hidden from docs" {
    assert(internal_helper(5) == 6)
    assert(internal_helper(0) == 1)
}

test "combined uses both" {
    // combined(x) = public_api(internal_helper(x)) = (x+1)*2
    assert(combined(4) == 10)
    assert(combined(0) == 2)
    assert(combined(-1) == 0)
}
