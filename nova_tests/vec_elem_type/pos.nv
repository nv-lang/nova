// Generic-argument type-match: the cases that MUST stay legal.
//  - `[]T ≡ Vec[T]` (D239): a Vec[int] flows into a []int param and back.
//  - same element type is fine.
//  - scalar int → narrow-int element coercion (push) stays allowed.
module vec_elem_type.pos

fn sum_slice(a []int) -> int {
    mut s = 0
    for x in a { s += x }
    s
}

fn sum_vec(v Vec[int]) -> int {
    mut s = 0
    for x in v { s += x }
    s
}

test "Vec[int] inferred flows into []int param (D239 []T ≡ Vec[T])" {
    mut a = Vec[int].with_capacity(2)
    a.push(1)
    a.push(2)
    assert(sum_slice(a) == 3)
}

test "[]int literal flows into Vec[int] param" {
    assert(sum_vec([4, 5]) == 9)
}

test "scalar int pushed into Vec[u32] element is allowed (value coercion)" {
    mut u = Vec[u32].with_capacity(2)
    u.push(7)        // int literal → u32 element: safe truncation, NOT flagged
    assert(u.len() == 1)
}
