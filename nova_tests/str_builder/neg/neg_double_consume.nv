// EXPECT_COMPILE_ERROR D131
//
// Plan 85.1 Ф.3 — негатив: двойной consume @as_str().
//
// Второй вызов consume-метода `@as_str()` на уже потреблённом
// StringBuilder — use-after-consume (D131).

module neg.neg_double_consume

test "двойной as_str — use-after-consume" {
    consume sb = StringBuilder.from("data")
    ro _ = sb.into_str()                 // первый consume
    ro _ = sb.into_str()                 // ← ОШИБКА D131
}
