// Plan 85.1 Ф.3 — StringBuilder Unicode-покрытие.
//
// Кириллица, CJK и emoji во всех методах: len (bytes) > char_len
// для многобайтных, starts_with/ends_with на codepoint-границах.

module nova_tests.str_builder


test "Cyrillic — len вдвое больше char_len" {
    consume sb = StringBuilder.new()
    sb.append("Программирование")
    assert(sb.char_len() == 16)   // 16 codepoints
    assert(sb.len() == 32)        // 2 байта на codepoint
    ro _ = sb.into_str()
}

test "CJK — len втрое больше char_len" {
    consume sb = StringBuilder.new()
    sb.append("中文字符")
    assert(sb.char_len() == 4)
    assert(sb.len() == 12)
    ro _ = sb.into_str()
}

test "emoji — len вчетверо больше char_len" {
    consume sb = StringBuilder.new()
    sb.append("😀😁😂")
    assert(sb.char_len() == 3)
    assert(sb.len() == 12)
    ro _ = sb.into_str()
}

test "смешанный скрипт — точный подсчёт" {
    consume sb = StringBuilder.new()
    sb.append("ASCII")            // 5 cp, 5 b
    sb.append("Кир")              // 3 cp, 6 b
    sb.append("中")               // 1 cp, 3 b
    sb.append('😀')               // 1 cp, 4 b
    assert(sb.char_len() == 10)
    assert(sb.len() == 18)
    ro _ = sb.into_str()
}

test "Unicode — starts_with на codepoint-границе" {
    consume sb = StringBuilder.new()
    sb.append("日本語テキスト")
    assert(sb.starts_with("日本"))
    assert(sb.starts_with("日本語"))
    assert(!sb.starts_with("本"))
    ro _ = sb.into_str()
}

test "Unicode — ends_with на codepoint-границе" {
    consume sb = StringBuilder.new()
    sb.append("текст конца 🎉")
    assert(sb.ends_with("🎉"))
    assert(sb.ends_with("конца 🎉"))
    ro _ = sb.into_str()
}

test "Unicode — append(char) по одному codepoint'у" {
    consume sb = StringBuilder.new()
    sb.append('П')
    sb.append('р')
    sb.append('и')
    sb.append('в')
    sb.append('е')
    sb.append('т')
    assert(sb.char_len() == 6)
    assert(sb.len() == 12)
    assert(sb.into_str() == "Привет")
}

test "Unicode — clone сохраняет многобайтные codepoint'ы" {
    consume a = StringBuilder.new()
    a.append("Ёлка 🎄 中")
    consume b = a.clone()
    assert(b.len() == a.len())
    assert(b.char_len() == a.char_len())
    assert(b.into_str() == "Ёлка 🎄 中")
    ro _ = a.into_str()
}

test "Unicode — as_str паритет char count со str" {
    consume sb = StringBuilder.new()
    sb.append("Привет, 世界 😀")
    ro n = sb.char_len()    // codepoints
    ro s = sb.into_str()
    // Plan 108 D26 rev: s.as_chars().count() = codepoints == sb.char_len() before consume.
    assert(s.as_chars().count() == n)
}
