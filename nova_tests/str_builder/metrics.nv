// Plan 85.1 Ф.2 — StringBuilder метрики: len / byte_len / capacity.
//
// @len()      — длина в codepoint'ах (D26 школа B), O(n).
// @byte_len() — размер в UTF-8 байтах, O(1).
// @capacity() — allocated capacity в байтах, >= byte_len.

module str_builder.metrics


// ── @len codepoints vs @byte_len bytes ────────────────────────────

test "ASCII: len == byte_len" {
    let mut sb = StringBuilder.new()
    sb.append("hello world")
    assert(sb.len() == 11)
    assert(sb.byte_len() == 11)
}

test "Cyrillic: byte_len = 2 * len" {
    let mut sb = StringBuilder.new()
    sb.append("Привет")
    assert(sb.len() == 6)
    assert(sb.byte_len() == 12)
}

test "emoji: byte_len = 4 * len" {
    let mut sb = StringBuilder.new()
    sb.append('😀')
    sb.append('🎉')
    assert(sb.len() == 2)
    assert(sb.byte_len() == 8)
}

test "смешанный текст: len < byte_len" {
    let mut sb = StringBuilder.new()
    sb.append("Hi Я 中")     // H,i,space,Я,space,中 = 6 codepoints
    assert(sb.len() == 6)
    // H(1)+i(1)+sp(1)+Я(2)+sp(1)+中(3) = 9 байт
    assert(sb.byte_len() == 9)
}

test "пустой: len == 0, byte_len == 0" {
    let mut sb = StringBuilder.new()
    assert(sb.len() == 0)
    assert(sb.byte_len() == 0)
}


// ── @capacity ──────────────────────────────────────────────────────

test "capacity >= byte_len всегда" {
    let mut sb = StringBuilder.new()
    sb.append("some content here")
    assert(sb.capacity() >= sb.byte_len())
}

test "capacity растёт при переполнении" {
    let mut sb = StringBuilder.with_capacity(4)
    let cap_before = sb.capacity()
    sb.append("aaaaaaaaaaaaaaaa")     // 16 байт >> cap 4
    assert(sb.byte_len() == 16)
    assert(sb.capacity() >= 16)
    assert(sb.capacity() >= cap_before)
}

test "capacity не уменьшается при чтении" {
    let mut sb = StringBuilder.new()
    sb.append("data")
    let c1 = sb.capacity()
    let _ = sb.len()
    let _ = sb.byte_len()
    let _ = sb.is_empty()
    assert(sb.capacity() == c1)
}


// ── len после grow корректна ───────────────────────────────────────

test "hot-loop accumulation — len точна после многих grow" {
    let mut sb = StringBuilder.with_capacity(2)
    for i in 0..200 {
        sb.append("x")
    }
    assert(sb.len() == 200)
    assert(sb.byte_len() == 200)
    assert(sb.capacity() >= 200)
}

test "hot-loop Unicode — len codepoints, byte_len bytes" {
    let mut sb = StringBuilder.new()
    for i in 0..50 {
        sb.append('Я')
    }
    assert(sb.len() == 50)
    assert(sb.byte_len() == 100)
}
