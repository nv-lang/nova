// Plan 100.8 (D166): error D133-not-consumed имеет structured format
// per spec (error-code + ranges + suggestions + notes).
//
// EXPECT_COMPILE_ERROR D133-not-consumed
//
// Expected diagnostic format (structured per D166):
//   error[D133-not-consumed]: consume value not consumed before scope exit
//      ╭─[diag_d133_not_consumed_format.nv:LINE:COL]
//    L │     consume tx = begin()
//      │     ━━━━━━━━━━━━━━━━━━━━ consume binding declared here
//    L │ }
//      │ ━ scope exit; tx still Live
//      ╰─
//      note: type `Transaction` declared `consume` at LINE
//      help: consume via one of:
//            .commit() -> ()
//            .rollback() -> ()
//      suggestion (machine-applicable):
//            + errdefer { tx.rollback() }
//            + tx.commit()?

module nova_tests.plan100_8.diag_d133_not_consumed_format

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => Transaction { id: 1 }

test "diagnostic format consistency D166" {
    consume tx = begin()
    // ОШИБКА D133-not-consumed: tx Live на exit.
    // Format должен соответствовать D166 spec.
}
