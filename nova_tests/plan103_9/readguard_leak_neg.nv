// EXPECT_COMPILE_ERROR D133
//
// Plan 103.9 (D174) — Negative: ReadGuard not consumed at scope exit.
// `consume rg = rw.read()` creates obligation; missing rg.unlock() → D133.

module plan103_9.readguard_leak_neg

test "forget ReadGuard unlock → compile error" {
    mut rw = RwLock.new()
    consume rg = rw.read()
    // MISSING: rg.unlock()
    // D133: rg is Live at scope exit
}
