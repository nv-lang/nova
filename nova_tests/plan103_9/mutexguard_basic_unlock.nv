// Plan 103.9 (D174) — Positive: MutexGuard basic explicit unlock.
//
// `consume g = mu.lock()` creates a consume obligation.
// `g.unlock()` satisfies it → no E_CONSUME_NOT_CONSUMED.

module nova_tests.plan103_9.mutexguard_basic_unlock

test "MutexGuard explicit unlock satisfies consume obligation" {
    mut mu = Mutex.new()
    consume g = mu.lock()
    // Critical section placeholder
    g.unlock()
    // mu is now free — try_lock should succeed
    ro acquired = mu.try_lock()
    assert(acquired == true)
    mu.unlock()
}

test "MutexGuard defer unlock panic-safe" {
    mut mu = Mutex.new()
    consume g = mu.lock()
    defer g.unlock()
    // Deferred unlock runs even if body throws
    // (tested by existing plan103_3 panic-safety tests)
}

test "MutexGuard lock/unlock round-trip multiple times" {
    mut mu = Mutex.new()
    mut counter = AtomicInt.new(0)
    for _i in 0..10 {
        consume g = mu.lock()
        counter.fetch_add(1)
        g.unlock()
    }
    assert(counter.load() == 10)
}
