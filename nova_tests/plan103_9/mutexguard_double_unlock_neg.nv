// EXPECT_COMPILE_ERROR D131
//
// Plan 103.9 (D174) — Negative: double unlock of MutexGuard.
// g.unlock() consumes g; second g.unlock() → E_CONSUMED_AFTER_USE (D131).

module nova_tests.plan103_9.mutexguard_double_unlock_neg

test "double unlock via guard → compile error" {
    let mu = Mutex.new()
    consume g = mu.lock()
    g.unlock()
    g.unlock()   // ERROR: g already consumed
}
