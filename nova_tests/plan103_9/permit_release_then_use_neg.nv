// EXPECT_COMPILE_ERROR D131
//
// Plan 103.9 (D174) — Negative: use of Permit after release.
// p.release() consumes p; any subsequent use of p → E_CONSUMED_AFTER_USE (D131).

module plan103_9.permit_release_then_use_neg

test "use permit after release → compile error" {
    mut sem = Semaphore.new(2)
    consume p = sem.acquire()
    p.release()     // p consumed here
    p.release()     // ERROR: p already consumed
}
