// EXPECT_COMPILE_ERROR D133
//
// Plan 103.9 (D174) — Negative: MutexGuard not consumed at scope exit.
// `consume g = mu.lock()` creates obligation; scope exit without unlock →
// E_CONSUME_NOT_CONSUMED (D133).

module nova_tests.plan103_9.mutexguard_leak_neg

test "forget to unlock guard → compile error" {
    let mut mu = Mutex.new()
    consume g = mu.lock()
    // MISSING: g.unlock()
    // D133: g is Live at scope exit — E_CONSUME_NOT_CONSUMED
}
