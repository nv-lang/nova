// EXPECT_COMPILE_ERROR D133
//
// Plan 103.9 (D174) — Negative: OnceGuard not consumed (no commit, no abort).
// consume g = once.make_guard(); no commit/abort → E_NOT_CONSUMED (D133).

module nova_tests.plan103_9.onceguard_no_commit_no_abort_neg

test "onceguard not consumed → D133 compile error" {
    let once = Once.new()
    consume g = once.make_guard()
    // Missing: g.commit() or g.abort()
    // ERROR: g is Live at scope exit → D133
}
