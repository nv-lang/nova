// EXPECT_COMPILE_ERROR D133
//
// Plan 103.9 (D174) — Negative: Permit not released at scope exit.
// `consume p = sem.acquire()` without p.release() → D133.

module nova_tests.plan103_9.permit_leak_neg

test "forget Permit release → compile error" {
    let sem = Semaphore.new(2)
    consume p = sem.acquire()
    // MISSING: p.release()
    // D133: p is Live at scope exit
}
