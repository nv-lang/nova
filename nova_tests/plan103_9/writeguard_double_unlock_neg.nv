// EXPECT_COMPILE_ERROR D131
//
// Plan 103.9 (D174) — Negative: WriteGuard double unlock.
// wg.unlock() consumes wg; second unlock → E_CONSUMED_AFTER_USE (D131).

module nova_tests.plan103_9.writeguard_double_unlock_neg

test "WriteGuard double unlock → compile error" {
    mut rw = RwLock.new()
    consume wg = rw.write()
    wg.unlock()
    wg.unlock()   // ERROR: wg already consumed
}
