// Plan 103.9 (D174) — Positive: Guard lifetime spans multiple statements.
//
// A MutexGuard can be held across multiple statements in the same fiber
// before being consumed. Tests that the consume obligation tracks correctly.

module nova_tests.plan103_9.guard_cross_scope_transfer

fn do_work_under_lock(consume g MutexGuard, mut counter AtomicInt) -> () {
    counter.fetch_add(1)
    g.unlock()  // consumed here
}

test "Guard passed to helper function and consumed there" {
    mut mu = Mutex.new()
    mut counter = AtomicInt.new(0)
    consume g = mu.lock()
    do_work_under_lock(g, counter)
    assert(counter.load() == 1)
}

test "Guard held while doing multiple operations" {
    mut mu = Mutex.new()
    mut a = AtomicInt.new(0)
    mut b = AtomicInt.new(0)

    consume g = mu.lock()
    // Multiple operations under same guard
    a.fetch_add(10)
    b.fetch_add(20)
    g.unlock()

    assert(a.load() == 10)
    assert(b.load() == 20)
}

test "ReadGuard held across multiple reads" {
    mut rw = RwLock.new()
    mut v = AtomicInt.new(42)

    consume rg = rw.read()
    ro x = v.load()
    ro y = v.load()
    rg.unlock()

    assert(x == 42)
    assert(y == 42)
}

test "Permit held while processing" {
    mut sem = Semaphore.new(1)
    mut result = AtomicInt.new(0)

    consume p = sem.acquire()
    result.fetch_add(1)
    result.fetch_add(1)
    p.release()

    assert(result.load() == 2)
}
