// Plan 125 Ф.1: trailing-throw в then, []int в else.

module nova_tests.plan125

fn pick10(c bool) Fail -> []int {
    if c {
        throw "no"
    } else {
        [1, 2, 3]
    }
}

test "list[int] in else" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro xs = pick10(false)
        assert(xs.len() == 3)
        assert(xs[0] == 1)
        assert(xs[2] == 3)
    }
}
