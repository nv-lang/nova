// Plan 125 Ф.2: match arm panic, others int.

module nova_tests.plan125

type Tag1 | Lo | Hi | Bad

fn rank2(t Tag1) -> int {
    match t {
        Lo  => 1
        Hi  => 100
        Bad => panic("invalid tag")
    }
}

test "rank2 Lo" {
    assert(rank2(Tag1.Lo) == 1)
}

test "rank2 Hi" {
    assert(rank2(Tag1.Hi) == 100)
}
