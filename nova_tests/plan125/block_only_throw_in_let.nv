// Plan 125 Ф.4: block-expression — { throw "..." } непосредственно как trailing if-then.
// Demonstrates block-recursion в expr_diverges_125.

module nova_tests.plan125

fn pick1(c bool) Fail -> int {
    if c {
        {
            throw "wrapped"
        }
    } else {
        9
    }
}

test "block-wrapped throw in then" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro n = pick1(false)
        assert(n == 9)
    }
}
