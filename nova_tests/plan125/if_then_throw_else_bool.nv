// Plan 125 Ф.1: bool тип в else, throw в then.

module nova_tests.plan125

fn pick9(c bool) Fail -> bool {
    if c {
        throw "x"
    } else {
        true
    }
}

test "bool else, throw then" {
    with Fail = effect Fail {
        fail(_) { interrupt () }
    } {
        ro b = pick9(false)
        assert(b)
    }
}
