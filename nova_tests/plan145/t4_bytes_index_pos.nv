// Plan 145 — t4: `as_bytes()[i]` — NovaArray-путь индексации (emit_bchk_array_access).
// Проверяет миграцию 1D-хелпера на portable nova_idx_chk для байтового слоя строки.

module nova_tests.plan145

test "as_bytes()[i] reads bytes" {
    ro s = "ABC"
    ro b = s.as_bytes()
    assert(b[0] == 65)
    assert(b[1] == 66)
    assert(b[2] == 67)
}
