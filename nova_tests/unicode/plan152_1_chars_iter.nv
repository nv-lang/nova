// Plan 152.1 Ф.3 (D250): CharsIter — codepoint decoding lens. as_chars() yields a
// stream (Next[char]+Iter), NOT a collection: count()/nth() O(n), no Index[int].
// for c in s decodes codepoints (D58 amend, str @iter() => @as_chars()).
module nova_tests.unicode

test "as_chars().count(): ASCII + multibyte (codepoints, not bytes)" {
    assert("hello".as_chars().count() == 5)
    assert("héllo".as_chars().count() == 5)   // 5 codepoints, 6 bytes
    assert("héllo".byte_len() == 6)
    assert("".as_chars().count() == 0)
}

test "as_chars().is_empty()" {
    assert("héllo".as_chars().is_empty() == false)
    assert("".as_chars().is_empty() == true)
}

test "as_chars().nth(i): i-th codepoint" {
    ro s = "héllo"
    assert(s.as_chars().nth(0) == Some('h'))
    assert(s.as_chars().nth(1) == Some('é'))
    assert(s.as_chars().nth(2) == Some('l'))
    assert(s.as_chars().nth(4) == Some('o'))
    assert(s.as_chars().nth(5) == None)       // out of range
    assert(s.as_chars().nth(-1) == None)      // negative
}

test "for c in s decodes codepoints (str @iter => as_chars)" {
    ro s = "héllo"
    mut count = 0
    mut last = ' '
    for c in s {
        count = count + 1
        last = c
    }
    assert(count == 5)        // codepoints, not 6 bytes
    assert(last == 'o')
}

test "for c in s.as_chars() (explicit lens, Iter self)" {
    mut n = 0
    for c in "abc".as_chars() {
        n = n + 1
    }
    assert(n == 3)
}

test "as_chars() walks first/last codepoint of multibyte" {
    ro s = "héllo"
    mut first = ' '
    mut seen = false
    for c in s {
        if !seen { first = c; seen = true }
    }
    assert(first == 'h')
}

test "4-byte codepoint (emoji)" {
    ro s = "a😀b"            // a(1) + 😀(4) + b(1) = 6 bytes, 3 codepoints
    assert(s.byte_len() == 6)
    assert(s.as_chars().count() == 3)
    assert(s.as_chars().nth(1) == Some('😀'))
}
