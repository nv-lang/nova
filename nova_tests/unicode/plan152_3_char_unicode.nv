// Plan 152.3b (D252, Phase B): char Unicode-aware API. Rust `char` parity for the
// UCD classification + full case mapping. These char methods are OPT-IN — they
// delegate to the `std.unicode` code-point tables (category.nv) and are available
// only under `import std.unicode` (the table cost is paid by importers, not the
// prelude). The ASCII-core methods (char_ascii.nv) need no import.
module nova_tests.unicode

import std.unicode
import std.unicode.{Lu, Nd}

test "is_* Unicode predicates (positive)" {
    assert('Ω'.is_alphabetic())              // GREEK CAPITAL OMEGA U+03A9 (Lu)
    assert('世'.is_alphabetic())             // CJK U+4E16 (Lo)
    assert('٣'.is_numeric())                 // ARABIC-INDIC DIGIT THREE U+0663 (Nd)
    assert('Ⅻ'.is_numeric())                 // ROMAN NUMERAL TWELVE U+216B (Nl)
    assert('½'.is_numeric())                 // VULGAR FRACTION ONE HALF U+00BD (No)
    assert('A'.is_alphanumeric())
    assert('٣'.is_alphanumeric())
    assert('Ω'.is_alphanumeric())
    assert(' '.is_whitespace())              // ASCII space
    assert('\u{A0}'.is_whitespace())         // NO-BREAK SPACE U+00A0 (Zs)
    assert('\u{2028}'.is_whitespace())       // LINE SEPARATOR U+2028 (Zl)
    assert('A'.is_uppercase())
    assert('Ω'.is_uppercase())               // U+03A9 Lu
    assert('a'.is_lowercase())
    assert('ω'.is_lowercase())               // U+03C9 Ll
}

test "to_uppercase / to_lowercase (full, multi-code-point)" {
    assert('ß'.to_uppercase() == "SS")       // SHARP S → "SS" (multi-cp expansion)
    assert('ﬁ'.to_uppercase() == "FI")       // LATIN SMALL LIGATURE FI U+FB01 → "FI"
    assert('a'.to_uppercase() == "A")        // simple 1:1
    assert('Ω'.to_lowercase() == "ω")        // Σ-free Greek: Ω → ω
    // İ (LATIN CAPITAL I WITH DOT ABOVE, U+0130): context-free full lowercase is
    // the multi-cp "i" + COMBINING DOT ABOVE (U+0069 U+0307), NOT Turkish 'i'.
    assert('İ'.to_lowercase() == "\u{69}\u{307}")
    assert('İ'.to_lowercase().byte_len() == 3)
    assert('İ'.to_lowercase().as_chars().count() == 2)
    // Lone Σ (U+03A3): Final_Sigma is a string-level rule, so context-free it is
    // the non-final σ (U+03C3), the correct isolated answer.
    assert('\u{3A3}'.to_lowercase() == "\u{3C3}")
    assert('5'.to_uppercase() == "5")        // non-letter unchanged
}

test "general_category" {
    assert('A'.general_category() == Lu)
    assert('5'.general_category() == Nd)
}

test "is_* Unicode predicates (negative)" {
    assert('@'.is_alphabetic() == false)     // commercial at (Po) — not alphabetic
    assert('7'.is_alphabetic() == false)     // digit is numeric, not alphabetic
    assert('a'.is_uppercase() == false)
    assert('A'.is_lowercase() == false)
    assert('Ω'.is_lowercase() == false)
    assert('\n'.is_control() == true)        // LF U+000A (Cc)
    assert('\u{0}'.is_control() == true)      // NUL (Cc)
    assert('A'.is_control() == false)
    assert(' '.is_control() == false)
    assert('A'.is_numeric() == false)
    assert('@'.is_alphanumeric() == false)
}
