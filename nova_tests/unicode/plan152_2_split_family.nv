// Plan 152.2 Ф.1 (D251): split-family — byte-scans, zero-copy views.
module nova_tests.unicode

test "splitn: at most n parts, last is remainder" {
    ro p = "a,b,c,d".splitn(2, ",")
    assert(p.len() == 2)
    assert(p[0] == "a")
    assert(p[1] == "b,c,d")
    assert("a,b,c".splitn(1, ",").len() == 1)        // whole
    assert("a,b,c".splitn(0, ",").len() == 0)        // none
    assert("a,b,c".splitn(9, ",").len() == 3)        // n > parts
}

test "rsplit: from right, reversed order" {
    ro p = "a,b,c".rsplit(",")
    assert(p.len() == 3)
    assert(p[0] == "c")
    assert(p[1] == "b")
    assert(p[2] == "a")
}

test "rsplitn: at most n from right" {
    ro p = "a,b,c,d".rsplitn(2, ",")
    assert(p.len() == 2)
    assert(p[0] == "d")
    assert(p[1] == "a,b,c")
}

test "split_once / rsplit_once" {
    match "key=a=b".split_once("=") {
        Some(kv) => { assert(kv.0 == "key"); assert(kv.1 == "a=b") },
        None => assert(false),
    }
    match "key=a=b".rsplit_once("=") {
        Some(kv) => { assert(kv.0 == "key=a"); assert(kv.1 == "b") },
        None => assert(false),
    }
    match "nosep".split_once("=") {
        Some(_) => assert(false),
        None => assert(true),
    }
}

test "split_terminator: no trailing empty" {
    ro p = "a,b,".split_terminator(",")
    assert(p.len() == 2)
    assert(p[0] == "a")
    assert(p[1] == "b")
    assert("a,b".split_terminator(",").len() == 2)
}

test "split_whitespace: runs, skip empty, trim ends" {
    ro p = "  hello   world  ".split_ascii_whitespace()
    assert(p.len() == 2)
    assert(p[0] == "hello")
    assert(p[1] == "world")
    assert("\tone\ntwo\r three ".split_ascii_whitespace().len() == 3)
    assert("".split_ascii_whitespace().len() == 0)
}

test "lines: strip \\n and \\r\\n, final unterminated line kept" {
    ro p = "a\nb\r\nc".lines()
    assert(p.len() == 3)
    assert(p[0] == "a")
    assert(p[1] == "b")
    assert(p[2] == "c")
    assert("a\n".lines().len() == 1)
    assert("".lines().len() == 0)
}

test "split-family on multibyte (byte-correct)" {
    ro p = "α,β,γ".split(",")   // each Greek letter = 2 bytes
    assert(p.len() == 3)
    assert(p[0] == "α")
    assert(p[1] == "β")
    assert(p[2] == "γ")
}
