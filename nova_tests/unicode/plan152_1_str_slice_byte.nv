// Plan 152.1 Ф.1b (D249): `str[a..b]` is a BYTE-range zero-copy slice (the ONLY
// valid `str[..]` form after the int-index ban) — was codepoint-indexed, which
// broke non-ASCII `split` (it slices on byte offsets). Range index — allowed.
module nova_tests.unicode

test "str byte-range slice (literal Range index)" {
    ro s = "hello"
    assert(s[0..2] == "he")
    assert(s[2..5] == "llo")
    assert(s[1..4] == "ell")
}

test "open-ended slices" {
    ro s = "hello"
    assert(s[2..] == "llo")
    assert(s[..2] == "he")
    assert(s[..] == "hello")
}

test "byte-range slice on multibyte (héllo: é = bytes 1..3)" {
    ro s = "héllo"            // h(0) é(1,2) l(3) l(4) o(5), byte_len=6
    assert(s.byte_len() == 6)
    assert(s[0..1] == "h")
    assert(s[1..3] == "é")    // byte offsets 1..3 = the 2 bytes of é
    assert(s[1..3].byte_len() == 2)
    assert(s[3..] == "llo")
}

test "find composes with byte-slice (non-ASCII)" {
    ro s = "key=héllo"
    match s.find("=") {
        Some(k) => assert(s[k+1..] == "héllo"),   // k is a BYTE offset; slice is byte-range
        None => assert(false),
    }
}

test "non-ASCII split (regression: byte-slice fixes codepoint-index bug)" {
    ro parts = "a,é,b".split(",")
    assert(parts.len() == 3)
    assert(parts[0] == "a")
    assert(parts[1] == "é")
    assert(parts[2] == "b")
}
