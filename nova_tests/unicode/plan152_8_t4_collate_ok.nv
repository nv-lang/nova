// Plan 152.8 Layer 1 (Vec[u32] migration) — T4: collation after migration.
module nova_tests.unicode

import std.unicode.{collate_compare, collate_eq, Collator}

test "collate_compare: basic ordering" {
    assert(collate_compare("apple", "banana") < 0)
    assert(collate_compare("zebra", "apple") > 0)
    assert(collate_compare("hello", "hello") == 0)
}

test "collate_compare: empty string" {
    assert(collate_compare("", "a") < 0)
    assert(collate_compare("a", "") > 0)
    assert(collate_compare("", "") == 0)
}

test "collate_eq: canonical equivalents compare equal" {
    assert(collate_eq("caf\u{e9}", "cafe\u{301}"))   // precomposed vs decomposed é
    assert(collate_compare("caf\u{e9}", "cafe\u{301}") == 0)
}

test "collate_compare: accents are secondary" {
    assert(collate_compare("cafe", "café") < 0)      // unaccented before accented
    assert(collate_compare("résumé", "resume") > 0)  // accented after plain
}

test "Collator namespace delegates to free functions" {
    assert(Collator.order("apple", "banana") < 0)
    assert(Collator.order("zebra", "apple") > 0)
    assert(Collator.same("caf\u{e9}", "cafe\u{301}"))
}
