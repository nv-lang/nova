// Plan 152.5a D-R4 bench: str operator hot-path (compare/eq/concat) after the
// Nova-body reroute. Confirms RawMem-body parity with the retired C lowering —
// same primitives (memcmp via RawMem.compare, memcpy via Vec.append). Not a unit
// assertion of correctness (that's comparison.nv); a workload to time end-to-end.
module nova_tests.unicode

test "operator workload (compare + eq + concat) runs to completion" {
    ro a = "the quick brown fox jumps over the lazy dog"
    ro b = "the quick brown fox jumps over the lazy doe"
    mut lt_count = 0
    mut eq_count = 0
    mut i = 0
    // ~200k comparisons (memcmp hot-path) + eq checks.
    while i < 200000 {
        if a < b { lt_count = lt_count + 1 }
        if a == a { eq_count = eq_count + 1 }
        i = i + 1
    }
    assert(lt_count == 0)        // a > b (…dog > …doe), so a < b never
    assert(eq_count == 200000)

    // ~50k concatenations (alloc + 2 memcpy + steal hot-path).
    mut cat_len = 0
    mut j = 0
    while j < 50000 {
        ro s = a + b
        cat_len = s.byte_len()
        j = j + 1
    }
    assert(cat_len == a.byte_len() + b.byte_len())
}
