// Plan 152.4.5 (D253): word segmentation (UAX #29) + to_titlecase — hand-authored
// semantic cases (full WordBreakTest breadth lives in word_conformance.nv).

module nova_tests.unicode

import std.unicode.{WordsIter, to_titlecase}

test "as_words — UAX #29 segments" {
    assert("café".as_words().count() == 1)               // ALetter run (WB5)
    assert("3.14".as_words().count() == 1)               // Numeric . Numeric (WB11/12)
    assert("can\u{27}t".as_words().count() == 1)         // can't — apostrophe (WB6/7)
    assert("\u{1f1fa}\u{1f1f8}".as_words().count() == 1) // 🇺🇸 flag — RI pair (WB15/16)
    // "Hello, world" → Hello | "," | " " | world
    {
        mut w = "Hello, world".as_words()
        match w.next() { Some(s) => assert(s == "Hello"), None => assert(false) }
        match w.next() { Some(s) => assert(s == ","), None => assert(false) }
        match w.next() { Some(s) => assert(s == " "), None => assert(false) }
        match w.next() { Some(s) => assert(s == "world"), None => assert(false) }
        assert(w.next() == None)
    }
}

test "to_titlecase — first cased char per word, rest lowercased" {
    assert(to_titlecase("hello world") == "Hello World")
    assert(to_titlecase("\u{fb01}le") == "File")         // ﬁ → "Fi" (title) + "le"
    // digraph: ǆ (U+01C6) titlecases to ǅ (U+01C5), NOT uppercase Ǆ (U+01C4) —
    // pins that to_titlecase uses the TITLE mapping, not upper.
    assert(to_titlecase("\u{1c6}") == "\u{1c5}")
    assert(to_titlecase("\u{1c6}") != "\u{1c4}")
    // Greek: first cased Ο titlecased, remainder lowercased with Final_Sigma.
    assert(to_titlecase("\u{39f}\u{394}\u{39f}\u{3a3}") == "\u{39f}\u{3b4}\u{3bf}\u{3c2}")  // ΟΔΟΣ → Οδος
}
