// Plan 152.4.5 (criterion A6): word segmentation / title-casing are part of the
// OPT-IN std.unicode module — NOT in the prelude. Without `import std.unicode`,
// `to_titlecase` is not in scope: the program must not silently compile.
//
// EXPECT_COMPILE_ERROR undefined identifier
module neg.plan152_4_n_words_opt_in

test "to_titlecase is undefined without import std.unicode" {
    ro x = to_titlecase("abc")
    assert(x == "Abc")
}
