// Plan 103.3 — ReentrantMutex.unlock() when not locked → RUNTIME_PANIC.
//
// EXPECT_RUNTIME_PANIC ReentrantMutex.unlock() called by non-owner fiber or mutex not locked

module neg.plan103_3_reentrant_unlock_not_locked_neg

test "unlock when never locked panics" {
    mut rm = ReentrantMutex.new()
    rm.unlock()
}
