// Plan 59.1 A2 — multi-instantiation: same generic fn → разные typedef'ы.
module nova_tests.plan59_1

fn[T] dup_multiinst(v T) -> (T, T) => (v, v)

test "dup_multiinst[int]" {
    ro (a, b) = dup_multiinst[int](42)
    assert(a == 42)
    assert(b == 42)
}

test "dup_multiinst[str]" {
    ro (s, t) = dup_multiinst[str]("hi")
    assert(s == "hi")
    assert(t == "hi")
}
