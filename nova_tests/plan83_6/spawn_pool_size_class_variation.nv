// Plan 83.6 (2026-05-25): test pool routing для разных ctx sizes.
//
// Mixes parallel-for variants с varied capture counts: small (single
// capture → 64-class), medium (3 captures → 128/256-class), large (5
// captures → 256/512-class). Verifies pool correctly routes по size
// class.
//
// Plan 83.7 (2026-05-25): rewrite under parallel-for (no shared mut
// race). Previous version had shared `sum_small += cur` data race
// которая был masked deque LIFO ordering pre-runnext; runnext slot
// exposed it.
//
// ALLOC_REQUIRES boehm

module plan83_6.spawn_pool_size_class_variation

test "varied ctx sizes — small ctx routing correct" {
    // Small: 1 capture → 64B class.
    ro xs = parallel for i in 0..100 { i * 2 }
    assert(xs[99] == 198)
    assert(xs[0] == 0)
    assert(xs[50] == 100)
}

test "varied ctx sizes — medium ctx routing correct" {
    // Medium: closure-by-value captures sum into result. Pool routes 128B class.
    ro multiplier = 3
    ro offset = 7
    ro xs = parallel for i in 0..100 { i * multiplier + offset }
    assert(xs[99] == 99 * 3 + 7)
    assert(xs[0] == 7)
}
