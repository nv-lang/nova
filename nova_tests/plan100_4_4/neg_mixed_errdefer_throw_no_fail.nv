// EXPECT_COMPILE_ERROR D158
//
// Plan 100.4.4 (D161): errdefer + okdefer family — Fail body требует
// Fail[E] в fn-sig. D158 universal для defer/errdefer/okdefer/defer-with-result.

module nova_tests.plan100_4_4.neg_mixed_errdefer_throw_no_fail

type Err { msg str }

fn rollback() Fail[Err] -> () { throw Err { msg: "boom" } }

// ❌ no Fail in sig
fn process() -> () {
    errdefer { rollback() }   // D158 error
}

test "errdefer Fail body без Fail в sig — D158 error" {
    process()
}
