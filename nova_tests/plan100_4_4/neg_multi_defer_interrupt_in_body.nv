// EXPECT_COMPILE_ERROR D90
//
// Plan 100.4.4 (D161): interrupt в defer body — ВСЕГДА запрещён (D90 §6),
// independently of D161 wrap. Hijack scope-exit ≠ failable cleanup.

module nova_tests.plan100_4_4.neg_multi_defer_interrupt_in_body

fn process() -> int {
    ro x = with Time = effect Time {
        sleep(_ms) { () }
        now() { 0 }
        now_ms() { 0 }
        now_ns() { 0 }
    } {
        defer { interrupt 42 }   // ❌ D90 §6
        100
    }
    x
}

test "interrupt в defer body — D90 §6 error" {
    process()
}
