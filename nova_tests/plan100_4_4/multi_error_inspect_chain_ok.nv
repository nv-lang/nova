// Plan 100.4.4 (D161): caller inspects composite через MultiError
// .primary() / .suppressed() / .fmt_chain() — public API verify.

module nova_tests.plan100_4_4.multi_error_inspect_chain_ok

fn make_chain() -> MultiError =>
    { primary: "primary error", suppressed: ["suppr1", "suppr2", "suppr3"] }

test "MultiError chain inspection — primary + suppressed + fmt_chain" {
    let e = make_chain()
    assert(e.primary() == "primary error")
    assert(e.suppressed().len() == 3)
    let s = e.fmt_chain()
    assert(s == "primary error")
}
