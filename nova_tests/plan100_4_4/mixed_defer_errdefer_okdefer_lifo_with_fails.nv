// Plan 100.4.4 (D161): mixed defer family (defer / errdefer / okdefer)
// + LIFO + Fail bodies — все 3 typed defer-kind работают вместе.

module nova_tests.plan100_4_4.mixed_defer_errdefer_okdefer_lifo_with_fails

type Err { msg str }

fn cleanup() Fail[Err] -> () { () }
fn rollback() Fail[Err] -> () { () }
fn commit() Fail[Err] -> () { () }

fn process_success() Fail[Err] -> () {
    defer    { cleanup() }   // ALL paths
    errdefer { rollback() }  // ERROR paths only — skipped here
    okdefer  { commit() }    // SUCCESS paths only
}

fn process_error() Fail -> () {
    defer    { cleanup() }
    errdefer { rollback() }
    okdefer  { commit() }    // skipped
    throw Err { msg: "boom" }
}

test "mixed defer family + LIFO + Fail bodies" {
    process_success()
    with Fail = effect Fail { fail(_msg) { interrupt () } } {
        process_error()
    }
}
