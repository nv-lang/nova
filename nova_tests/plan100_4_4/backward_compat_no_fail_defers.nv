// Plan 100.4.4 (D161): backward-compat — infallible defers работают
// как раньше; D161 wrap не ломает Plan 20 D90 semantics.

module nova_tests.plan100_4_4.backward_compat_no_fail_defers

fn log(_n int) -> () { () }

fn process() -> () {
    defer { log(1) }   // runs LAST LIFO
    defer { log(2) }
    defer { log(3) }   // runs FIRST LIFO
}

test "infallible LIFO — Plan 20 backward-compat" {
    process()
}
