// for_iter_typed.nv — Plan 14 Ф.1: Iterable[T] generalization для T ≠ int.
//
// Plan 06 Ф.1 закрыл общий for-in через Iterable[T] protocol-fallback,
// но element-type был захардкожен на nova_int. Plan 14 Ф.1 заменил
// `NovaOpt_nova_int` на real `NovaOpt_<T>` typedef с lazy struct-decl
// (для T без NOVA_ARRAY_DECL в runtime). Some(v) и None теперь
// эмитятся через compound literal с реальным T.
//
// Покрывает: Iterable[u8], Iterable[bool], Iterable[i32], Iterable[str], Iterable[(int,str)].

module syntax.for_iter_typed


// Iterable[u8] — счётчик байтов 0..n.
type ByteCounter {
    end      u8
    mut cur  u8
}


export fn ByteCounter mut @next() -> Option[u8] {
    if @cur >= @end {
        None
    } else {
        ro v = @cur
        @cur = (@cur as int + 1) as u8
        Some(v)
    }
}


export fn ByteCounter.new(end u8) -> ByteCounter {
    ByteCounter { end, cur: 0 as u8 }
}


test "for-in over Iterable[u8]" {
    ro it = ByteCounter.new(5 as u8)
    mut sum int = 0
    for b in it {
        sum = sum + b as int
    }
    // 0+1+2+3+4 = 10
    assert(sum == 10)
}


// Iterable[bool] — alternating true/false для n шагов.
type BoolToggler {
    end      int
    mut cur  int
    mut on   bool
}


export fn BoolToggler mut @next() -> Option[bool] {
    if @cur >= @end {
        None
    } else {
        ro v = @on
        @on = !@on
        @cur += 1
        Some(v)
    }
}


export fn BoolToggler.new(end int) -> BoolToggler {
    BoolToggler { end, cur: 0, on: true }
}


test "for-in over Iterable[bool]" {
    ro it = BoolToggler.new(4)
    mut trues int = 0
    mut falses int = 0
    for b in it {
        if b { trues = trues + 1 } else { falses = falses + 1 }
    }
    assert(trues == 2)
    assert(falses == 2)
}


// Iterable[i32] — narrow-int sequence (negative values работают).
type I32Seq {
    end       int
    mut cur   int
}


export fn I32Seq mut @next() -> Option[i32] {
    if @cur >= @end {
        None
    } else {
        ro v = (-100 + @cur * 50) as i32
        @cur += 1
        Some(v)
    }
}


export fn I32Seq.new(end int) -> I32Seq {
    I32Seq { end, cur: 0 }
}


test "for-in over Iterable[i32]" {
    ro it = I32Seq.new(4)
    mut sum int = 0
    for n in it {
        sum = sum + n as int
    }
    // -100 + -50 + 0 + 50 = -100
    assert(sum == -100)
}


// Iterable[str] — iter over fixed strings.
type StrSeq {
    mut idx  int
}


export fn StrSeq mut @next() -> Option[str] {
    if @idx == 0 {
        @idx = 1
        Some("alpha")
    } else if @idx == 1 {
        @idx = 2
        Some("beta")
    } else if @idx == 2 {
        @idx = 3
        Some("gamma")
    } else {
        None
    }
}


export fn StrSeq.new() -> StrSeq {
    StrSeq { idx: 0 }
}


test "for-in over Iterable[str]" {
    ro it = StrSeq.new()
    mut found_alpha bool = false
    mut found_beta bool = false
    mut found_gamma bool = false
    mut count int = 0
    for s in it {
        if s == "alpha" { found_alpha = true }
        if s == "beta" { found_beta = true }
        if s == "gamma" { found_gamma = true }
        count = count + 1
    }
    assert(found_alpha)
    assert(found_beta)
    assert(found_gamma)
    assert(count == 3)
}


// Iterable[(int, int)] — tuple-pattern destructure (key-value pair).
// (int, str) и другие mixed-type tuples требуют typed-tuple typedef'ов
// (legacy _NovaTupleN — все поля nova_int) — отдельная задача.
type PairSeq {
    mut idx  int
}


export fn PairSeq mut @next() -> Option[(int, int)] {
    if @idx == 0 {
        @idx = 1
        Some((10, 100))
    } else if @idx == 1 {
        @idx = 2
        Some((20, 200))
    } else {
        None
    }
}


export fn PairSeq.new() -> PairSeq {
    PairSeq { idx: 0 }
}


test "for-in over Iterable[(int, int)] — tuple destructure" {
    ro it = PairSeq.new()
    mut sum_keys int = 0
    mut sum_vals int = 0
    for (k, v) in it {
        sum_keys = sum_keys + k
        sum_vals = sum_vals + v
    }
    // 10 + 20 = 30; 100 + 200 = 300
    assert(sum_keys == 30)
    assert(sum_vals == 300)
}
