// defer_advanced.nv — Plan 20 advanced edge cases.
//
// Покрытие сценариев, которые Go/Rust/Zig обычно тестируют отдельно
// и которые могут breakate в простой реализации.

module nova_tests.syntax.defer_advanced


// ───── (A) Eager argument evaluation: defer fn(captured_value) ─────
//
// Spec D90 п.3: «Аргументы defer вычисляются в момент defer, тело —
// откладывается». В нашем codegen это работает потому что defer body
// — выражение, эмитится **at cleanup time**. Капчуренная mut local
// читается из памяти actual'но на момент cleanup'а.

test "defer читает mut local в момент CLEANUP, а не в момент defer" {
    let mut x = 5
    let mut captured = 0
    let _ = {
        defer { captured = x }   // тело откладывается; x читается потом
        x = 42
        0
    }
    // Defer fires AFTER x = 42 (на exit block'а), значит captured = 42.
    // Это closure-like (Plan 20 spec: "by reference").
    assert(captured == 42)
}


// ───── (B) Defer внутри if-then-else — fires только в активной ветке ─────

test "defer в then-branch fires если then активен" {
    let mut t_fired = 0
    let mut e_fired = 0
    let n = 10
    let _ = if n > 5 {
        defer { t_fired = 1 }
        100
    } else {
        defer { e_fired = 1 }
        200
    }
    assert(t_fired == 1)
    assert(e_fired == 0)
}


// ───── (C) Defer в return-expr fn ─────
//
// Когда fn заканчивается trailing expression (не stmt), defer
// должен fire'ить перед return.

fn helper_with_defer(x int) -> int {
    defer { let _ = x + 1 }
    x * 2
}


test "defer в fn body с trailing expression fires" {
    let r = helper_with_defer(21)
    assert(r == 42)
}


// ───── (D) Defer в fn body с явным return из inner block ─────
//
// Когда `return X` находится в nested if внутри fn body, codegen должен
// эмитить defer cleanup перед `return X` через emit_early_exit_cleanup.
// Проверяем через mut-local в outer scope (без closure-capture, который
// имеет orthogonal закрытость).

test "defer в block-expr с early return из nested if" {
    let mut after_x = 0
    let result = {
        defer { after_x = 100 }
        let inner_block_result = if true { 50 } else { 0 }
        inner_block_result
    }
    assert(result == 50)
    assert(after_x == 100)
}


// ───── (E) Многократный entry в loop body — defer fires на каждый ─────
//
// Verified в defer_in_blocks.nv (loop_tick == N), но check edge case
// когда defer ссылается на loop-var.

test "defer в loop читает loop-var на КАЖДОЙ итерации (eager arg eval)" {
    let mut sum = 0
    for i in 1..4 {
        defer { sum = sum + i }
    }
    // i=1: defer { sum += 1 } → sum=1
    // i=2: defer { sum += 2 } → sum=3
    // i=3: defer { sum += 3 } → sum=6
    assert(sum == 6)
}


// ───── (F) Mutable variable выходящая из scope — defer fires до её death ─────

test "defer может читать local, объявленный после регистрации" {
    let mut x = 0
    let _ = {
        defer { x = x + 100 }
        let local = 42
        x = local
        0
    }
    // Defer fires AFTER `x = local`. x теперь 42 (=local), потом
    // defer добавляет 100 → x = 142.
    assert(x == 142)
}
