// errdefer_throw.nv — Plan 20 D90 throw-path positive-тесты.
//
// errdefer срабатывает на ВСЕХ error-exit путях (D90 п.7):
//   - throw err с handler что НЕ interrupt'ит — после handler
//     `Nova_Fail_fail` всё равно вызывает nova_throw (Fail-strict D65)
//     → fail-frame → errdefer.
//
// errdefer НЕ срабатывает на:
//   - `interrupt v` внутри handler (это handled normal exit; handler
//     longjmp'ит на InterruptFrame, минуя fail-frame — corret).
//
// При срабатывании errdefer fail-frame pop'ается + nova_throw re-thrown
// — outer frame ловит throw дальше.

module nova_tests.syntax.errdefer_throw


// ───── errdefer на throw + handler (non-interrupt) ─────
//
// handler НЕ делает interrupt: возвращается normally. По D65 Fail-strict
// после handler всё равно вызывается nova_throw для unwind. Наш local
// fail-frame должен поймать → errdefer → re-throw → outer handler/scope.

test "errdefer срабатывает на throw + non-interrupt handler" {
    let mut cleaned_up = 0
    let mut caught_inner_handler = false
    // Handler НЕ делает interrupt — после handler return Nova_Fail_fail
    // продолжит nova_throw → local fail-frame errdefer'а → cleanup →
    // re-throw → inner with-block fail-frame ловит → нормальный exit.
    with Fail = handler Fail {
        fail(_msg) {
            caught_inner_handler = true
            // НЕ interrupt'им — Fail-strict (D65): после handler
            // обязательно происходит unwind через nova_throw.
        }
    } {
        let _ = {
            errdefer { cleaned_up = cleaned_up + 1 }
            throw "boom"
            0
        }
    }
    assert(caught_inner_handler)
    // errdefer СРАБОТАЛ на throw-path (Fail-strict unwind ловит наш fail-frame).
    assert(cleaned_up == 1)
}


// ───── errdefer НЕ срабатывает когда handler делает interrupt ─────

test "errdefer не срабатывает когда handler делает interrupt" {
    let mut cleaned_up = 0
    let mut caught = false
    // Handler делает interrupt — это handled normally exit для inner scope.
    // По семантике D65/D90 errdefer этого inner scope НЕ должен срабатывать,
    // потому что control покидает inner scope через interrupt (longjmp на
    // InterruptFrame), а не через nova_throw (fail-frame).
    with Fail = handler Fail {
        fail(_msg) {
            caught = true
            interrupt ()
        }
    } {
        let _ = {
            errdefer { cleaned_up = cleaned_up + 1 }
            throw "boom"
            0
        }
    }
    assert(caught)
    // Handler перехватил throw через interrupt — это НЕ error path для
    // inner scope. errdefer не вызывался.
    assert(cleaned_up == 0)
}


// ───── LIFO порядок errdefer'ов на throw-path ─────

test "несколько errdefer-ов выполняются в LIFO на throw-path" {
    let mut step = 0
    let mut order_a = 0
    let mut order_b = 0
    let mut order_c = 0
    let mut caught = false
    with Fail = handler Fail {
        fail(_msg) {
            caught = true
            // НЕ interrupt — даём errdefer'ам сработать.
        }
    } {
        let _ = {
            errdefer {
                step = step + 1
                order_a = step    // registered first — last to fire
            }
            errdefer {
                step = step + 1
                order_b = step
            }
            errdefer {
                step = step + 1
                order_c = step    // registered last — first to fire
            }
            throw "fail"
            0
        }
    }
    assert(caught)
    // LIFO: C first, B second, A last.
    assert(order_c == 1)
    assert(order_b == 2)
    assert(order_a == 3)
}


// ───── defer + errdefer вместе на throw-path ─────

test "defer + errdefer на throw — оба срабатывают, LIFO регистрации" {
    let mut step = 0
    let mut defer_order = 0
    let mut errdefer_order = 0
    let mut caught = false
    with Fail = handler Fail {
        fail(_msg) {
            caught = true
        }
    } {
        let _ = {
            defer {
                step = step + 1
                defer_order = step
            }
            errdefer {
                step = step + 1
                errdefer_order = step
            }
            throw "boom"
            0
        }
    }
    assert(caught)
    // LIFO: errdefer registered second → fires first; defer registered
    // first → fires second.
    assert(errdefer_order == 1)
    assert(defer_order == 2)
}
