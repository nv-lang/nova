// errdefer_throw.nv — Plan 20 D90 throw-path positive-тесты.
//
// errdefer срабатывает на error-exit пути (через nova_throw / fail-frame).
//
// Тесты с handler'ом не покрывают все throw-path сценарии из-за
// семантики D65 правило 3 (re-throw skips current handler) которое
// требует runtime поддержки (Q-handler-rethrow). Для production-grade
// верификации errdefer-on-throw используем сценарий с handler'ом
// который делает `interrupt` — корректное skip errdefer (это handled
// normal exit). См. также `errdefer_unhandled.nv` для unhandled-throw
// сценария (отдельный файл, использует EXPECT_RUNTIME_PANIC).

module syntax.errdefer_throw


// ───── errdefer НЕ срабатывает когда handler делает interrupt ─────

test "errdefer не срабатывает когда handler делает interrupt" {
    mut cleaned_up = 0
    mut caught = false
    // Handler делает interrupt — это handled normal exit для inner scope.
    // Spec-compliant по D61 (handler-method exit'ит control через interrupt).
    // По D90 errdefer этого inner scope НЕ должен срабатывать, потому что
    // control покидает inner scope через InterruptFrame, а не через
    // nova_throw (fail-frame).
    with Fail = effect Fail {
        fail(_msg) {
            caught = true
            interrupt ()
        }
    } {
        ro _ = {
            errdefer { cleaned_up = cleaned_up + 1 }
            throw "boom"
            0
        }
    }
    assert(caught)
    // Handler перехватил throw через interrupt — это НЕ error path для
    // inner scope. errdefer корректно не вызывался.
    assert(cleaned_up == 0)
}


// ───── Несколько errdefer + interrupt handler ─────
//
// Аналог теста LIFO но для interrupt-handler пути: ни один errdefer
// не должен сработать, потому что handler делает interrupt.

test "несколько errdefer + interrupt — ни один не срабатывает" {
    mut a = 0
    mut b = 0
    mut c = 0
    mut caught = false
    with Fail = effect Fail {
        fail(_msg) {
            caught = true
            interrupt ()
        }
    } {
        ro _ = {
            errdefer { a = 1 }
            errdefer { b = 1 }
            errdefer { c = 1 }
            throw "fail"
            0
        }
    }
    assert(caught)
    assert(a == 0)
    assert(b == 0)
    assert(c == 0)
}


// Тест "defer + errdefer + interrupt — только defer" реализован и проходит
// в nova_tests/syntax/defer_on_interrupt.nv (Plan 20 Ф.8 (2) закрыто).
