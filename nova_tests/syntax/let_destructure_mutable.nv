// Plan 53 Ф.6.3: `let mut { x, y } = p` — bound fields mutable.
//
// Production-fix: до Ф.6.3 `emit_record_destructure` НЕ propagates
// `decl.mutable` в bound names → spawn-capture decision (var_mutable
// lookup) использует wrong default → silent correctness risk.
//
// Этот тест проверяет что mutable destructure действительно делает
// каждое поле mutable-bound (можно переприсвоить) и source record
// не затрагивается (field-copy semantics).
module syntax.let_destructure_mutable

type Pair { x int, y int }

test "let mut { x, y } binds mutable copies" {
    let p = Pair { x: 10, y: 20 }
    let mut { x, y } = p
    assert(x == 10)
    assert(y == 20)
    // Переприсваиваем — должно компилироваться (mutable bindings)
    x = 100
    y = 200
    assert(x == 100)
    assert(y == 200)
    // Source — неизменён (field-copy, не reference)
    assert(p.x == 10)
    assert(p.y == 20)
}

test "let mut single-field destructure" {
    let p = Pair { x: 5, y: 7 }
    let mut { x, .. } = p
    assert(x == 5)
    x = 999
    assert(x == 999)
    assert(p.x == 5)
}

test "immutable destructure stays immutable (regression baseline)" {
    let p = Pair { x: 1, y: 2 }
    let { x, y } = p
    assert(x == 1)
    assert(y == 2)
    // Не пытаемся переприсваивать — это compile error для non-mut.
    // Этот тест защищает от случайной деградации (mutable propagation
    // не должна делать всё mutable).
}
