// self_in_expr.nv — Plan 11 Ф.4.5: D66 Self в expression position.
//
// Self в type-position (return type, parameter type) уже работает.
// План 11 Ф.4.5 добавляет Self в expression-position:
//   - `Self.method(args)` — call current type's static (Path-form).
//   - `Self.method(args)` — то же через Member-form (obj=Ident("Self")).
//   - `Self { fields }` — record literal current type'а.
//
// Bootstrap-ограничение: method_receivers single-key, поэтому имена
// методов уникальные между типами (Plan 11 Ф.1-Ф.3 это решит для
// methods с receiver'ом). Здесь Self — именно эти methods, поэтому
// уникальные имена нужны.

module syntax.self_in_expr


// ─── 1. Default → parameterized constructor ───

type Account {
    balance int
}

export fn Account.acc_with_initial(amount int) -> Self =>
    { balance: amount }

export fn Account.acc_new() -> Self =>
    Self.acc_with_initial(0)


test "Self.method(...) в static — default → parameterized" {
    let a = Account.acc_new()
    assert(a.balance == 0)
    let b = Account.acc_with_initial(100)
    assert(b.balance == 100)
}


// ─── 2. Self { ... } literal в multi-field record ───

type Box {
    value int
    tag   int
}

export fn Box.box_empty() -> Self =>
    { value: 0, tag: 0 }

export fn Box.box_tagged(v int, t int) -> Self =>
    { value: v, tag: t }


test "Self { ... } literal" {
    let b1 = Box.box_empty()
    assert(b1.value == 0 && b1.tag == 0)
    let b2 = Box.box_tagged(42, 7)
    assert(b2.value == 42 && b2.tag == 7)
}


// ─── 3. Builder pattern: chain Self.method ───

type Builder {
    count int
}

export fn Builder.bld_empty() -> Self =>
    Self.bld_with_count(0)

export fn Builder.bld_with_count(n int) -> Self =>
    { count: n }

export fn Builder.bld_from_default() -> Self =>
    Self.bld_empty()


test "Self.method chain в нескольких constructors" {
    let b = Builder.bld_from_default()
    assert(b.count == 0)
    let c = Builder.bld_with_count(5)
    assert(c.count == 5)
}


// ─── 4. Self.method с несколькими args ───

type Counter {
    value int
}

export fn Counter.ctr_with_initial(v int) -> Self =>
    { value: v }

export fn Counter.ctr_from_pair(a int, b int) -> Self =>
    Self.ctr_with_initial(a + b)


test "Self.method с несколькими args" {
    let c = Counter.ctr_from_pair(3, 4)
    assert(c.value == 7)
}


// ─── 5. Self.method в instance-методе ───
// Instance method вызывает static через Self.

type SelfInstance {
    n int
}

export fn SelfInstance.si_make(v int) -> Self =>
    { n: v }

// Instance метод, который через Self вызывает свой static.
export fn SelfInstance @si_double() -> Self =>
    Self.si_make(@n * 2)


test "Self.method из instance-метода" {
    let a = SelfInstance.si_make(5)
    let b = a.si_double()
    assert(b.n == 10)
}


// ─── 6. Self в return-position и expression-position одновременно ───

type Chain {
    step int
}

export fn Chain.chain_zero() -> Self =>
    { step: 0 }

export fn Chain @chain_next() -> Self =>
    { step: @step + 1 }


test "Self в return + Self literal в body" {
    let c0 = Chain.chain_zero()
    let c1 = c0.chain_next()
    let c2 = c1.chain_next()
    assert(c2.step == 2)
}


// ─── 7. Nested Self (Self.X где X сам делает Self.Y) ───

type Nest {
    depth int
}

export fn Nest.nst_zero() -> Self =>
    { depth: 0 }

export fn Nest.nst_one() -> Self =>
    { depth: 1 }

export fn Nest.nst_two() -> Self =>
    { depth: Self.nst_one().depth + 1 }


test "nested Self.method calls" {
    let n = Nest.nst_two()
    assert(n.depth == 2)
}
