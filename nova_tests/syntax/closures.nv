// 21_closures.nv — лямбды, closures, функции как значения.
//
// В 05_functions.nv покрыты только базовые лямбды. Здесь — захват
// окружения, возврат функции, передача функции как параметра.

module syntax.closures

fn make_adder(n int) -> fn(int) -> int {
    |x| x + n
}

fn apply_twice(f fn(int) -> int, x int) -> int {
    f(f(x))
}

fn compose(f fn(int) -> int, g fn(int) -> int) -> fn(int) -> int {
    |x| f(g(x))
}

test "closure захватывает параметр функции" {
    ro add5 = make_adder(5)
    ro add10 = make_adder(10)
    assert(add5(3) == 8)
    assert(add10(3) == 13)
}

test "независимые closure'ы не влияют друг на друга" {
    ro a = make_adder(1)
    ro b = make_adder(100)
    assert(a(0) == 1)
    assert(b(0) == 100)
    assert(a(0) == 1)
}

test "функция как параметр" {
    ro r = apply_twice(|x| x * 2, 3)
    assert(r == 12)
}

test "lambda inline на ro" {
    ro sq = |x| x * x
    assert(sq(7) == 49)
    assert(sq(0) == 0)
}

test "композиция функций" {
    ro inc = |x| x + 1
    ro dbl = |x| x * 2
    ro f = compose(inc, dbl)
    assert(f(3) == 7)
}

test "closure захватывает локальную ro" {
    ro factor = 3
    ro mul = |x| x * factor
    assert(mul(4) == 12)
}

test "closure возвращается из block" {
    // Note: после `let n = 42` в block'е `|x| x + n` неоднозначно
    // для парсера (без явного `;` или newline-disambig он трактует
    // как продолжение `n = 42 | x | x + n` bitwise OR). Делаем явный
    // wrap чтобы parser видел closure начало expression-start.
    ro f = {
        ro n = 42
        ro inner = |x| x + n
        inner
    }
    assert(f(8) == 50)
}
