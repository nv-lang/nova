// as_cast_restrictions.nv — Plan 08 Ф.5: as-cast restrictions для
// char/u8/bool. Раздел allowed-cases.
//
// Запрещённые `as`-cast'ы (compile-error):
//   - int as char     → char.try_from(n)?
//   - char as u8    → u8.try_from(c)?  (за исключением CharLit)
//   - int as bool     → n != 0
//   - str as T        → T.try_from(s)?
//   - T as str        → str.from(v)
//
// Negative tests (что цепляются compile-error'ом) — ручная проверка
// через `nova-codegen check`, не в test-runner.
//
// Этот файл — positive smoke: разрешённые cast'ы продолжают работать.

module syntax.as_cast_restrictions


test "char-literal as int/u8 — разрешено (program ставит codepoint буквально)" {
    ro a = 'A' as u8
    ro b = 'A' as int
    ro c = 'A' as u8
    assert(a as int == 65)
    assert(b == 65)
    assert(c as int == 65)
}


test "u8 → int (widening) — разрешено" {
    ro b u8 = 65
    ro n = b as int
    assert(n == 65)
}


test "int → u8 (narrowing wraparound) — разрешено (план 05)" {
    ro big int = 1111
    ro b = big as u8
    assert(b as int == 87)  // 1111 mod 256
}


test "f64 → int (saturation) — разрешено (план 07)" {
    ro f f64 = 100.5
    ro n = f as int
    assert(n == 100)
}


test "bool → int — разрешено (D54: bool это {0,1})" {
    ro t = true
    ro f = false
    assert(t as int == 1)
    assert(f as int == 0)
}


type RestrictionsMyInt alias int


test "newtype-alias as underlying — identity (план 05)" {
    ro x RestrictionsMyInt = 42 as RestrictionsMyInt
    ro n int = x as int
    assert(n == 42)
}
