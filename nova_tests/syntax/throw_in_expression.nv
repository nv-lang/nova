// 54_throw_in_expression.nv — D25/D65: `throw` как expression, type never.
//
// До этого `throw` парсился ТОЛЬКО как Stmt::Throw (statement-level).
// Spec D65 «Fail strict»: throw — операция эффекта Fail с типом never.
// Это значит throw должен быть валидной expression в любой позиции,
// требующей значения — match-arm body, тернарник, аргумент функции и т.д.
//
// В codegen: ExprKind::Throw эмитируется как `Nova_Fail_fail(msg);` +
// dummy `((nova_int)0LL)` (никогда не используется — control не вернётся).

module syntax.throw_in_expression

// ================================================================
// SECTION 1: throw в match-arm body
// ================================================================

fn check_positive(n int) -> int {
    match n {
        0 => 0
        _ if n > 0 => n * 2
        _ => throw "negative not allowed"
    }
}

test "throw in match-arm — handler catches" {
    let mut caught = ""
    let mut got = -1
    with Fail = handler Fail {
        fail(msg) {
            caught = msg
            interrupt ()
        }
    } {
        got = check_positive(-5)
    }
    assert(caught == "negative not allowed")
}

test "throw in match-arm — happy path returns value" {
    let mut got = -1
    with Fail = handler Fail {
        fail(_msg) { interrupt () }
    } {
        got = check_positive(5)
    }
    assert(got == 10)
}

// ================================================================
// SECTION 2: throw в if-else expression position
// ================================================================

// Note: if-else с throw в одной из веток требует, чтобы тип ветки
// throw был совместим с другой веткой. Bootstrap-codegen для if-без-
// trailing считает unit, что конфликтует с int. Workaround — throw
// делается как statement, после if-else возвращается реальное значение:

fn assert_not_zero(n int) -> int {
    if n == 0 { throw "zero forbidden" }
    n + 1
}

test "throw before fall-through statement" {
    let mut caught = ""
    with Fail = handler Fail {
        fail(msg) {
            caught = msg
            interrupt ()
        }
    } {
        let _ = assert_not_zero(0)
    }
    assert(caught == "zero forbidden")
}

test "throw before fall-through — happy path" {
    let mut got = -1
    with Fail = handler Fail {
        fail(_msg) { interrupt () }
    } {
        got = assert_not_zero(7)
    }
    assert(got == 8)
}

// ================================================================
// SECTION 3: throw как RHS в ?? coalesce (short-circuit семантика)
//
// Закрывает Q-throw-comma: до этого ExprKind::Throw эмитировался через
// statement+dummy паттерн (self.line(...) + Ok("0LL")). Это работало в
// branching contexts (if/match), но **ломало short-circuit** в тернарных:
// `?? throw` desugar'ится в C-тернарник `cond ? value : RHS`, и при
// statement+dummy throw выполнялся бы **eagerly**, до проверки cond.
//
// Миграция на comma-expression `(Nova_Fail_fail(v), 0)` — inline expression,
// выполняется только когда родитель реально evaluates RHS. Эти тесты
// верифицируют что Some-ветка НЕ вызывает throw.
// ================================================================

test "?? throw — Some-ветка НЕ выполняет throw (short-circuit)" {
    let mut caught_msg = ""
    with Fail = handler Fail {
        fail(msg) {
            caught_msg = msg
            interrupt ()
        }
    } {
        let opt = Some(42)
        let v = opt ?? throw "should not throw"
        assert(v == 42)
    }
    // Throw НЕ вызвался — handler не сработал, caught_msg пуст.
    assert(caught_msg == "")
}


test "?? throw — None-ветка реально бросает" {
    let mut caught_msg = ""
    with Fail = handler Fail {
        fail(msg) {
            caught_msg = msg
            interrupt ()
        }
    } {
        let opt Option[int] = None
        let _v = opt ?? throw "expected Some"
    }
    assert(caught_msg == "expected Some")
}


test "?? throw в цепочке lookup'ов" {
    let mut last_thrown = ""
    with Fail = handler Fail {
        fail(msg) {
            last_thrown = msg
            interrupt ()
        }
    } {
        // Все Some — throw'ов не должно быть.
        let a = Some(1) ?? throw "a is None"
        let b = Some(2) ?? throw "b is None"
        let c = Some(3) ?? throw "c is None"
        assert(a + b + c == 6)
    }
    assert(last_thrown == "")
}
