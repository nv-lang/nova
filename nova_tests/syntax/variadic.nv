// variadic.nv — Plan 14 Ф.6: D69 variadic parameters + spread.
//
// `...items []T` в декларации — variadic-параметр (только последний).
// На call-site: regular args собираются в []T, `...arr` — spread,
// поддерживается mixed (`f(a, ...arr, b)`).
//
// Проверяем:
//   - declaration + body использует items как []int;
//   - call всеми regular args;
//   - call со spread;
//   - mixed (regular + spread + regular);
//   - empty (variadic position пустая) → []T length 0;
//   - method с variadic-параметром.

module syntax.variadic


// Declaration: ...items []int (variadic last).
fn sum_all(...items []int) -> int {
    let mut total int = 0
    for x in items {
        total += x
    }
    total
}


fn count_items(...items []int) -> int {
    let mut n int = 0
    for _ in items {
        n += 1
    }
    n
}


test "variadic — все regular args" {
    let r = sum_all(1, 2, 3)
    assert(r == 6)
}


test "variadic — empty (variadic-position пустая)" {
    let r = sum_all()
    assert(r == 0)
    assert(count_items() == 0)
}


test "variadic — spread `...arr`" {
    let arr = [10, 20, 30]
    let r = sum_all(...arr)
    assert(r == 60)
}


test "variadic — mixed regular + spread + regular" {
    let middle = [2, 3, 4]
    let r = sum_all(1, ...middle, 5)
    assert(r == 15)
}


test "variadic — count vs sum independent" {
    let a = [10, 20, 30, 40]
    assert(count_items(...a) == 4)
    assert(sum_all(...a) == 100)
}


// Combination of regular + variadic params.
fn weighted_sum(weight int, ...items []int) -> int {
    let mut total int = 0
    for x in items {
        total += x * weight
    }
    total
}


test "variadic — комбинация regular + variadic" {
    // weight=3, items=[1,2,3] → 3*1 + 3*2 + 3*3 = 18.
    let r = weighted_sum(3, 1, 2, 3)
    assert(r == 18)
    let arr = [4, 5]
    // weight=2, items=[4,5] → 2*4 + 2*5 = 18.
    let r2 = weighted_sum(2, ...arr)
    assert(r2 == 18)
}


// Method with variadic.
type Aggregator {
    label  str
}


export fn Aggregator @sum(...nums []int) -> int {
    let mut t int = 0
    for n in nums {
        t += n
    }
    t
}


export fn Aggregator.new(label str) -> Aggregator {
    Aggregator { label: label }
}


test "variadic — method (Aggregator.@sum)" {
    let agg = Aggregator.new("test")
    let r = agg.sum(7, 8, 9)
    assert(r == 24)
    let xs = [100, 200]
    assert(agg.sum(...xs) == 300)
    assert(agg.sum() == 0)
}
