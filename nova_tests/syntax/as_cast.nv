// as_cast.nv — D54 `as`-cast в codegen.
//
// План 05: `as` теперь эмитит явный C-cast, а не no-op. Тесты
// проверяют:
//   - narrowing (int → u8 / int → i32) — wraparound
//   - identity (u8 → int / int → f64)
//   - truncate (f64 → int)
//   - newtype ↔ underlying — no-op в C, корректный тип в Nova

module syntax.as_cast


// Newtype для последнего теста.
type CastUserId alias int


test "as u8: narrowing с wraparound" {
    ro a int = 1111
    ro b = a as u8
    // 1111 mod 256 = 87
    assert(b as int == 87)
}


test "as u8: chain с bitwise (mask + cast)" {
    ro n int = 0xFFFF
    ro lo = (n & 0xFF) as u8
    assert(lo as int == 0xFF)
}


test "as i32 from int: wraparound старших бит" {
    ro big int = 0x100000001
    ro small = big as i32
    // младшие 32 бита = 1
    assert(small as int == 1)
}


test "as f64 from int: identity" {
    ro n int = 42
    ro f = n as f64
    assert(f == 42.0)
}


test "as int from f64: truncate (не round)" {
    ro f f64 = 3.7
    ro n = f as int
    assert(n == 3)
}


test "newtype-alias as underlying: identity" {
    ro id CastUserId = 42 as CastUserId
    ro n int = id as int
    assert(n == 42)
}


test "as u8: zero-byte preserved" {
    ro z int = 256
    ro b = z as u8
    // 256 mod 256 = 0
    assert(b as int == 0)
}


test "as u8: negative wraps to 0..255" {
    ro neg int = -1
    ro b = neg as u8
    // -1 wraps to 255 (0xFF) under unsigned semantics.
    assert(b as int == 255)
}
