// 16_if_let.nv — `if let` и `while let` (D34)

module syntax.if_let

fn lookup(n int) -> Option {
    if n > 0 { return Some(n * 100) }
    None
}

test "if let Some matches" {
    let opt = lookup(5)
    let v = if let Some(n) = opt {
        n
    } else {
        -1
    }
    assert(v == 500)
}

test "if let None falls through" {
    let opt = lookup(-1)
    let v = if let Some(n) = opt {
        n
    } else {
        999
    }
    assert(v == 999)
}

test "if let with tuple destructure" {
    let pair = (10, 20)
    let r = if let (a, b) = pair {
        a + b
    } else {
        0
    }
    assert(r == 30)
}

test "while let drains Option" {
    let mut state = 5
    let mut iterations = 0
    while let Some(n) = (if state > 0 { Some(state) } else { None }) {
        iterations += 1
        state = state - 1
        if iterations > 100 { break }
    }
    assert(iterations == 5)
}

test "if let bound name visible inside then" {
    let opt = Some(7)
    let r = if let Some(x) = opt {
        x + x
    } else {
        0
    }
    assert(r == 14)
}
