// 16_if_let.nv — `if let` и `while let` (D34)

module syntax.if_let

fn lookup(n int) -> Option {
    if n > 0 { return Some(n * 100) }
    None
}

test "if Some matches" {
    ro opt = lookup(5)
    ro v = if Some(n) = opt {
        n
    } else {
        -1
    }
    assert(v == 500)
}

test "if None falls through" {
    ro opt = lookup(-1)
    ro v = if Some(n) = opt {
        n
    } else {
        999
    }
    assert(v == 999)
}

test "if ro with tuple destructure" {
    ro pair = (10, 20)
    ro r = if (a, b) = pair {
        a + b
    } else {
        0
    }
    assert(r == 30)
}

test "while ro drains Option" {
    mut state = 5
    mut iterations = 0
    while Some(n) = (if state > 0 { Some(state) } else { None }) {
        iterations += 1
        state = state - 1
        if iterations > 100 { break }
    }
    assert(iterations == 5)
}

test "if ro bound name visible inside then" {
    ro opt = Some(7)
    ro r = if Some(x) = opt {
        x + x
    } else {
        0
    }
    assert(r == 14)
}
