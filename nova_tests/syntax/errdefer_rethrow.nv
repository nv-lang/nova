// errdefer_rethrow.nv — Plan 20 Ф.8 (4): D65 правило 3 (re-throw) +
// errdefer интеграция.
//
// D65 правило 3: когда `throw err` происходит ВНУТРИ handler-body,
// runtime должен dispatch'нуться на OUTER handler (skip current — иначе
// infinite recursion).
//
// Реализовано в Ф.8 (4): NovaVtable_Fail.prev = outer-handler;
// Nova_Fail_fail swap'ает _nova_handler_Fail = current->prev на время
// invocation handler-body, восстанавливает после return.
//
// Этот тест верифицирует:
//   1. Inner handler делает re-throw → throw dispatch'ится на outer.
//   2. errdefer между inner-rethrow и outer-catch срабатывает (throw
//      проходит через local fail-frame).

module syntax.errdefer_rethrow


// ───── re-throw из handler работает (D65 правило 3) ─────

test "re-throw из inner handler dispatch'ится на outer handler" {
    mut inner_called = false
    mut outer_called = false
    // Outer handler — финальный catch через interrupt.
    with Fail = effect Fail {
        fail(_msg) {
            outer_called = true
            interrupt ()
        }
    } {
        // Inner handler — помечает + re-throw'ит. D65 правило 3:
        // throw в handler-body → outer handler (skip current).
        with Fail = effect Fail {
            fail(msg) {
                inner_called = true
                throw msg               // re-throw — должен идти к outer
            }
        } {
            throw "boom"
        }
    }
    assert(inner_called)
    assert(outer_called)
}


// ───── errdefer + re-throw: throw проходит через local fail-frame ─────
//
// Когда outer handler делает interrupt, control skip'ает все fail-frame'ы
// (через InterruptFrame longjmp). Errdefer внутри inner scope НЕ
// срабатывает — это handled exit через interrupt (см. D90 + interrupt
// semantics).
//
// Чтобы errdefer fired — нужно чтобы throw действительно прошёл через
// fail-frame'ы. Это случается если outer handler ТОЖЕ re-throw'ит,
// throw пробрасывается до unhandled (test-runner panic). Однако
// test-сценарии для unhandled throw требуют EXPECT_RUNTIME_PANIC
// маркера — это другой тест-файл (errdefer_unhandled.nv).

test "errdefer + re-throw + outer interrupt — errdefer skip" {
    mut cleaned_up = 0
    mut outer_called = false
    with Fail = effect Fail {
        fail(_msg) {
            outer_called = true
            interrupt ()
        }
    } {
        with Fail = effect Fail {
            fail(msg) {
                throw msg               // re-throw → outer handler
            }
        } {
            ro _ = {
                errdefer { cleaned_up = cleaned_up + 1 }
                throw "boom"
                0
            }
        }
    }
    assert(outer_called)
    // Outer handler сделал interrupt → control longjmp'нул через все
    // fail-frame'ы (включая local _defer_BID_ff). errdefer не fired.
    // Это правильно по D90: errdefer attached к fail-frame, который
    // skipped longjmp'ом.
    assert(cleaned_up == 0)
}


// ───── Многоуровневый re-throw ─────

test "трёхуровневый re-throw: каждый handler пропускает дальше" {
    mut level1 = false
    mut level2 = false
    mut level3 = false
    with Fail = effect Fail {
        fail(_msg) {
            level3 = true
            interrupt ()
        }
    } {
        with Fail = effect Fail {
            fail(msg) {
                level2 = true
                throw msg
            }
        } {
            with Fail = effect Fail {
                fail(msg) {
                    level1 = true
                    throw msg
                }
            } {
                throw "deep"
            }
        }
    }
    assert(level1)
    assert(level2)
    assert(level3)
}
