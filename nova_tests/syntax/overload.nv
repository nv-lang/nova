// overload.nv — Plan 11 Ф.1-Ф.3: ad-hoc overload по типу аргумента.
//
// `method_overloads: HashMap<(type, name), Vec<MethodSig>>` хранит
// все signatures. Resolution на call-site по статическим типам args.
//
// Strict matching, no implicit conversions.
// Free-functions overload не разрешён (только для methods).

module syntax.overload


// ─── 1. Static overload по типу аргумента ───

type Money {
    cents int
}

export fn Money.from_int(c int) -> Money =>
    { cents: c }

export fn Money.from(n int) -> Money =>
    { cents: n }

export fn Money.from(s str) -> Money =>
    { cents: 999 }    // marker — distinguish from int-version


test "static overload Money.from(int) vs from(str)" {
    ro m_int = Money.from(42)
    assert(m_int.cents == 42)
    ro m_str = Money.from("hello")
    assert(m_str.cents == 999)
}


// ─── 2. Instance overload по типу аргумента ───

type Acc {
    sum int
}

export fn Acc.new() -> Acc =>
    { sum: 0 }

export fn Acc @add(n int) -> Acc =>
    { sum: @sum + n }

export fn Acc @add(s str) -> Acc =>
    { sum: @sum + 1 }    // marker: str increments by 1


test "instance overload Acc.@add(int) vs @add(str)" {
    ro a0 = Acc.new()
    ro a1 = a0.add(10)
    assert(a1.sum == 10)
    ro a2 = a1.add("foo")
    assert(a2.sum == 11)         // 10 + 1 (marker)
    ro a3 = a2.add(5)
    assert(a3.sum == 16)
}


// ─── 3. Одноимённые static на разных типах ───
// Раньше падало (single-key last-wins).

type Box1 {
    value int
}

type Box2 {
    label int
}

export fn Box1.make() -> Box1 =>
    { value: 100 }

export fn Box2.make() -> Box2 =>
    { label: 200 }


test "одноимённые static на разных типах не конфликтуют" {
    ro b1 = Box1.make()
    assert(b1.value == 100)
    ro b2 = Box2.make()
    assert(b2.label == 200)
}


// ─── 4. Arity overload — разное число параметров ───

type Logger {
    level int
}

export fn Logger.new() -> Logger =>
    { level: 0 }

// 1 параметр:
export fn Logger @log(msg str) -> Logger =>
    { level: @level + 1 }

// 2 параметра:
export fn Logger @log(lvl int, msg str) -> Logger =>
    { level: @level + lvl }


test "arity overload: @log(msg) vs @log(level, msg)" {
    ro l0 = Logger.new()
    ro l1 = l0.log("info")              // 1 arg → @log(msg) → +1
    assert(l1.level == 1)
    ro l2 = l1.log(5, "warn")           // 2 args → @log(int, str) → +5
    assert(l2.level == 6)                // 1 + 5
    ro l3 = l2.log("debug")             // 1 arg again
    assert(l3.level == 7)
}


// ─── 5. 3+ overloads на одном методе ───

type Combiner {
    state int
}

export fn Combiner.new() -> Combiner =>
    { state: 0 }

export fn Combiner @put(n int) -> Combiner =>
    { state: @state + n }       // int: add

export fn Combiner @put(s str) -> Combiner =>
    { state: @state * 2 }       // str: double

export fn Combiner @put(b bool) -> Combiner =>
    { state: @state - 1 }       // bool: decrement


test "3 overloads различаются по типу первого аргумента" {
    ro c0 = Combiner.new()
    ro c1 = c0.put(10)                  // +10 → 10
    assert(c1.state == 10)
    ro c2 = c1.put("foo")               // *2 → 20
    assert(c2.state == 20)
    ro c3 = c2.put(true)                // -1 → 19
    assert(c3.state == 19)
}


// ─── 6. Mixed: static + instance overload одного имени ───
// `from` как static и instance method'ом — оба должны работать.

type Mixed {
    value int
}

export fn Mixed.from(n int) -> Mixed =>
    { value: n }

export fn Mixed @from(other Mixed) -> Mixed =>
    { value: @value + other.value }


test "mixed static+instance overload одного имени" {
    ro m1 = Mixed.from(7)               // static
    ro m2 = Mixed.from(3)
    ro m3 = m1.from(m2)                 // instance — Self.@from(Self)
    assert(m3.value == 10)
}


// ─── 7. Overload с разными возвращаемыми типами ───
// Strict-match по param-types: return-type не участвует, выбирает
// сам compiler по контексту.

type Convert {
    raw int
}

export fn Convert.new(v int) -> Convert =>
    { raw: v }

export fn Convert @get(fallback int) -> int =>
    if @raw == 0 { fallback } else { @raw }

export fn Convert @get(fallback str) -> str =>
    if @raw == 0 { fallback } else { "non-zero" }


test "overload с разными return типами по типу arg" {
    ro c1 = Convert.new(42)
    ro v_int = c1.get(0)
    assert(v_int == 42)

    ro c2 = Convert.new(0)
    ro v_str = c2.get("fallback")
    assert(v_str == "fallback")
}


// ─── 8. Multi-arg overload ───

type Pair {
    a int
    b int
}

export fn Pair.new() -> Pair =>
    { a: 0, b: 0 }

export fn Pair @set(x int, y int) -> Pair =>
    { a: x, b: y }

export fn Pair @set(x str, y int) -> Pair =>
    { a: 0, b: y }                  // ignores str x


test "overload по first arg type" {
    mut p0 = Pair.new()
    ro p1 = p0.set(3, 4)                // (int, int) → both
    assert(p1.a == 3)
    assert(p1.b == 4)
    ro p2 = p0.set("foo", 7)            // (str, int) → b only
    assert(p2.a == 0)
    assert(p2.b == 7)
}


// ─── 9. No-arg overload (одно из них без args, другое с args) ───
// Это arity-overload с 0 vs N args.

type Counter2 {
    n int
}

export fn Counter2.zero() -> Counter2 =>
    { n: 0 }

export fn Counter2 @bump() -> Counter2 =>
    { n: @n + 1 }

export fn Counter2 @bump(by int) -> Counter2 =>
    { n: @n + by }


test "no-arg vs N-arg arity overload" {
    ro c0 = Counter2.zero()
    ro c1 = c0.bump()                   // 0 args → +1
    assert(c1.n == 1)
    ro c2 = c1.bump(10)                 // 1 arg → +10
    assert(c2.n == 11)
}
