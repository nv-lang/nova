// as_cast_float.nv — План 07: float→int saturation helpers.
//
// `f as iN` / `f as uN` для f64/f32 → integer теперь имеет defined
// behavior на любом входе (NaN → 0, ±∞ → границы, out-of-range →
// saturation). Согласовано с Rust 1.45+ (RFC #2484 sealed casts).
//
// NaN / Infinity создаются через арифметику (0.0/0.0, 1.0/0.0) —
// f64.NAN / f64.INFINITY константы в bootstrap не реализованы.

module syntax.as_cast_float


// ───── Helper'ы для NaN / Inf — bootstrap не имеет констант ─────

fn make_nan() -> f64 {
    ro z f64 = 0.0
    z / z
}

fn make_pos_inf() -> f64 {
    ro z f64 = 0.0
    1.0 / z
}

fn make_neg_inf() -> f64 {
    ro z f64 = 0.0
    -1.0 / z
}


// ───── Tests ─────

test "f64 as i16 — in range, truncate towards zero" {
    ro f f64 = 100.7
    assert(f as i16 as int == 100)
}


test "f64 as i16 — out of range positive saturates to INT16_MAX" {
    ro f f64 = 70000.0
    assert(f as i16 as int == 32767)
}


test "f64 as i16 — out of range negative saturates to INT16_MIN" {
    ro f f64 = -70000.0
    assert(f as i16 as int == -32768)
}


test "f64 as i16 — NaN gives 0" {
    ro f = make_nan()
    assert(f as i16 as int == 0)
}


test "f64 as i16 — +Infinity saturates to INT16_MAX" {
    ro f = make_pos_inf()
    assert(f as i16 as int == 32767)
}


test "f64 as i16 — -Infinity saturates to INT16_MIN" {
    ro f = make_neg_inf()
    assert(f as i16 as int == -32768)
}


test "f64 as u16 — negative becomes 0 (not wraparound)" {
    ro f f64 = -100.0
    assert(f as u16 as int == 0)
}


test "f64 as u8 — out of range saturates to UINT8_MAX" {
    ro f f64 = 1000.0
    assert(f as u8 as int == 255)
}


test "f64 as u8 — NaN gives 0" {
    ro f = make_nan()
    assert(f as u8 as int == 0)
}


test "f64 as int — preserves precision in range" {
    ro f f64 = 12345.0
    assert(f as int == 12345)
}


test "f64 as int — large positive saturates to INT64_MAX" {
    ro f f64 = 1.0e20
    // INT64_MAX = 9223372036854775807; 1e20 ≫ INT64_MAX → saturate
    ro n = f as int
    // Проверяем что результат — INT64_MAX, через сравнение с
    // n+1 переполнением: если n == INT64_MAX, то n + 1 wraps.
    // Простое сравнение: n должен быть очень большим положительным.
    assert(n > 9000000000000000000)
}


test "f64 as int — large negative saturates to INT64_MIN" {
    ro f f64 = -1.0e20
    ro n = f as int
    assert(n < -9000000000000000000)
}


test "int wraparound (план 05) не сломан" {
    ro big int = 0x100000000
    ro small = big as i32
    // 2^32 mod 2^32 = 0
    assert(small as int == 0)
    ro big2 int = 0x1FF
    assert(big2 as u8 as int == 255)
}
