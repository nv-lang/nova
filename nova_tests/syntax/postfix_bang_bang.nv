// postfix_bang_bang.nv — Plan 19 C7 (D85): postfix `!!` для Result/Option.
//
// `expr!!` на Some(v)/Ok(v) разворачивает; на None/Err(e) бросает
// через Fail[E]. Внешняя fn должна иметь Fail[E] в effects (или
// активный with-handler).

module syntax.postfix_bang_bang

// ─── !! на Result ──────────────────────────────────────────────────

fn parse_int(s str) -> Result[int, str] {
    if s == "ok" { Ok(42) } else { Err("bad") }
}

fn pipeline_throw(s str) Fail -> int {
    ro n = parse_int(s)!!
    n + 1
}

test "!!: Ok(v) разворачивается в v" {
    with Fail = effect Fail {
        fail(_) => interrupt -1
    } {
        ro r = pipeline_throw("ok")
        assert(r == 43)
    }
}

test "!!: Err(e) бросает через Fail" {
    with Fail = effect Fail {
        fail(_) => interrupt -1
    } {
        ro r = pipeline_throw("bad")
        assert(r == -1)
    }
}

// ─── prefix !! (двойное boolean not) не сломан ────────────────────

test "!!cond — двойное отрицание (D85 не ломает существующее)" {
    assert(!!true)
    // !!false ≡ !(!false) ≡ !true ≡ false; assert(false) — fail.
    // Поэтому проверяем что true получается из !!true.
    ro r = !!true
    assert(r == true)
}
