// Plan 11 Ф.5 → Plan 132 migration: overloaded method values.
//
// Bound method value `obj.@method as fn(...)` removed in Plan 132.
// Replaced by lambdas that capture the receiver.
// Unbound `Type.@method as fn(Type, ...)` still works.

module syntax.overload_method_values

type Buf { items []int }

fn Buf.new() -> Self => { items: [] }

// Два overload'а — по типу аргумента.
fn Buf mut @push(n int) -> int => @items.len()
fn Buf mut @push(b bool) -> int => if b { 1 } else { 0 }

test "Ф.5: bound method value via closure-full (int overload)" {
    mut buf = Buf.new()
    ro f = fn(n int) -> int => buf.push(n)
    ro r = f(42)
    assert(r == 0)   // empty before push (наша заглушка возвращает len без push)
}

test "Ф.5: bound method value via closure-full (bool overload)" {
    mut buf = Buf.new()
    ro g = fn(b bool) -> int => buf.push(b)
    ro r = g(true)
    assert(r == 1)
}

test "Ф.5: unbound disambiguation" {
    mut buf = Buf.new()
    ro h = Buf.@push as fn(Buf, int) -> int
    ro r = h(buf, 10)
    assert(r == 0)
}
