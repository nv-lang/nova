// Plan 11 Ф.5: as fn(...) disambiguation для overloaded method values.
//
// Когда у метода несколько overload'ов, без annotation нельзя выбрать —
// используем `as fn(P...) -> R` для disambiguation.

module syntax.overload_method_values

type Buf { items []int }

fn Buf.new() -> Self => { items: [] }

// Два overload'а — по типу аргумента.
fn Buf mut @push(n int) -> int => @items.len()
fn Buf mut @push(b bool) -> int => if b { 1 } else { 0 }

test "Ф.5: bound method value disambiguation through as-fn" {
    mut buf = Buf.new()
    ro f = buf.@push as fn(int) -> int
    ro r = f(42)
    assert(r == 0)   // empty before push (наша заглушка возвращает len без push)
}

test "Ф.5: bound method value, bool overload" {
    mut buf = Buf.new()
    ro g = buf.@push as fn(bool) -> int
    ro r = g(true)
    assert(r == 1)
}

test "Ф.5: unbound disambiguation" {
    mut buf = Buf.new()
    ro h = Buf.@push as fn(Buf, int) -> int
    ro r = h(buf, 10)
    assert(r == 0)
}
