// Plan 51: record-литерал — тип пишется ровно один раз.
// Каноничные формы компилируются; sum-coercion (тип литерала ≠
// return-тип) НЕ сломан.

module nova_tests.syntax

type Pt2 { x int, y int }
type Shape2 | Circle { r int } | Square { s int }

// `=>`-тело: тип в return-аннотации, литерал без префикса.
fn mk(a int, b int) -> Pt2 => { x: a, y: b }
// `-> Self => { }`: Self резолвится к receiver-типу.
fn Pt2.origin() -> Self => { x: 0, y: 0 }
// sum-coercion: тип литерала (`Circle`) ≠ return-тип (`Shape2`) →
// префикс нужен, правило «type once» не срабатывает.
fn mk_circle(r int) -> Shape2 => Circle { r }

test "=>-body typeless record literal" {
    ro p = mk(3, 4)
    assert(p.x == 3)
    assert(p.y == 4)
}

test "-> Self => { } resolves Self" {
    assert(Pt2.origin().x == 0)
}

test "let with annotation, typeless literal" {
    ro p Pt2 = { x: 7, y: 8 }
    assert(p.x == 7)
    assert(p.y == 8)
}

test "let without annotation, typed literal" {
    ro q = Pt2 { x: 1, y: 2 }
    assert(q.x == 1)
}

test "sum-coercion not broken (literal type != return type)" {
    ro s = mk_circle(5)
    // match в let-позиции (arms возвращают int) — `mk_circle` строит
    // `Circle { r: 5 }` через sum-coercion из `-> Shape2 => Circle { ... }`.
    ro res = match s {
        Circle { r } => r
        Square { s } => -1
    }
    assert(res == 5)
}
