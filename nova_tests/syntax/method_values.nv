// Method values тесты (Plan 11 Ф.4).
// `obj.@method` — bound method value (struct {fn_ptr, self}).
// `Type.@method` — unbound method value (fn pointer берёт self явно).
// `Type.method`  — static method value (fn pointer без self).

module syntax.method_values

type Counter { value int }

fn Counter.new() -> Self => { value: 0 }
fn Counter @get() -> int => @value
fn Counter @add(n int) -> int => @value + n
fn Counter @add_two(a int, b int) -> int => @value + a + b

test "bound method value: no args" {
    ro c = Counter.new()
    ro f = c.@get
    ro v = f()
    assert(v == 0)
}

test "bound method value: one arg" {
    ro c = Counter.new()
    ro f = c.@add
    ro r = f(7)
    assert(r == 7)
}

test "bound method value: two args" {
    ro c = Counter.new()
    ro f = c.@add_two
    ro r = f(3, 4)
    assert(r == 7)
}

test "unbound method value: explicit self pass" {
    ro c = Counter.new()
    ro f = Counter.@add
    ro r = f(c, 5)
    assert(r == 5)
}

test "bound method value: разные обращения" {
    ro a = Counter.new()
    ro b = Counter.new()
    // Каждый bound несёт свой self.
    ro fa = a.@get
    ro fb = b.@get
    assert(fa() == 0)
    assert(fb() == 0)
}

// Method values на primitive types (str, int) — пока bootstrap-
// ограничение: external runtime методы (str API в std/runtime/string.nv)
// не доступны как method values, нужна отдельная routing-логика
// через ExternalRegistry. Future work. Пока method values работают
// только на user-defined типах.

// Plan 11 Ф.5: as fn(...) disambiguation.
// Сейчас @add единственный overload, поэтому disambiguation тривиальная,
// но annotation должна compile + работать.
test "Ф.5: as fn type annotation" {
    ro c = Counter.new()
    ro f = c.@add as fn(int) -> int
    ro r = f(11)
    assert(r == 11)
}
