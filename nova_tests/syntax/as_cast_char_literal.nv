// as_cast_char_literal.nv — Plan 14 Ф.7: int-литерал → char.
//
// D54 запрещает `n as char` для int-переменных (suggested
// `char.try_from(n)?`), но для **compile-time-known литералов** в
// валидном Unicode-диапазоне range-check тривиален и checker
// выполняет его статически — runtime Fail не нужен.
//
// Валидно: 0..=0x10FFFF исключая 0xD800..=0xDFFF (surrogates).
//
// Off-range литералы → compile error (negative tests — ручная
// проверка через `nova-codegen check`, не в test-runner).

module syntax.as_cast_char_literal


test "decimal literal as char — basic ASCII" {
    ro a = 65 as char
    assert(a == 'A')
}


test "hex literal as char — ASCII boundary" {
    ro zero = 0x30 as char
    ro nine = 0x39 as char
    assert(zero == '0')
    assert(nine == '9')
}


test "hex literal as char — NUL и DEL" {
    ro nul = 0 as char
    ro del = 0x7F as char
    assert(nul as int == 0)
    assert(del as int == 0x7F)
}


test "hex literal as char — кириллица (U+0410 = 'А')" {
    ro cyr_a = 0x0410 as char
    assert(cyr_a as int == 0x0410)
}


test "hex literal as char — верхняя граница U+10FFFF" {
    ro max = 0x10FFFF as char
    assert(max as int == 0x10FFFF)
}


test "hex literal as char — у surrogate range (D7FF и E000)" {
    // Граничные значения — валидные, не surrogate.
    ro before = 0xD7FF as char
    ro after = 0xE000 as char
    assert(before as int == 0xD7FF)
    assert(after as int == 0xE000)
}


test "binary literal as char" {
    ro a = 0b0100_0001 as char
    assert(a == 'A')
}


test "underscore-separated literal as char" {
    ro v = 1_114_111 as char  // U+10FFFF
    assert(v as int == 0x10FFFF)
}
