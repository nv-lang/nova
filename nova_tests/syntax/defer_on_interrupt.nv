// defer_on_interrupt.nv — Plan 20 Ф.8 (2): defer на interrupt-path.
//
// По D90 п.8 `defer` запускается на ВСЕХ exit'ах из scope, включая
// `interrupt v` из handler-body. Соответственно `errdefer` — НЕ
// срабатывает на interrupt-path (это handled normal exit).
//
// Codegen integration (Ф.8 (2)): enter_defer_scope эмитит local
// NovaInterruptFrame setjmp wrapper, который перехватывает
// interrupt longjmp, запускает defer-cleanup (skip errdefer),
// pop'ает interrupt-frame, и re-interrupt'ит с тем же value
// чтобы outer interrupt-frame получил значение.

module nova_tests.syntax.defer_on_interrupt


// ───── defer срабатывает когда handler делает interrupt ─────

test "defer срабатывает на interrupt-path" {
    let mut defer_fired = false
    let mut handled = false
    with Fail = handler Fail {
        fail(_msg) {
            handled = true
            interrupt ()
        }
    } {
        let _ = {
            defer { defer_fired = true }
            throw "boom"
            0
        }
    }
    assert(handled)
    // По D90: defer срабатывает на любом exit'е из scope, включая
    // interrupt-path. Ф.8 (2) интегрировал defer cleanup в
    // NovaInterruptFrame setjmp wrapper.
    assert(defer_fired)
}


// ───── errdefer НЕ срабатывает на interrupt-path ─────

test "errdefer не срабатывает на interrupt-path (handled exit)" {
    let mut errdefer_fired = false
    let mut handled = false
    with Fail = handler Fail {
        fail(_msg) {
            handled = true
            interrupt ()
        }
    } {
        let _ = {
            errdefer { errdefer_fired = true }
            throw "boom"
            0
        }
    }
    assert(handled)
    // errdefer — только на error-exit (throw без user handler /
    // re-throw до unhandled). На interrupt — handled, errdefer skip.
    assert(!errdefer_fired)
}


// ───── defer + errdefer combo на interrupt-path ─────

test "defer + errdefer + interrupt — только defer" {
    let mut defer_fired = false
    let mut errdefer_fired = false
    with Fail = handler Fail {
        fail(_msg) {
            interrupt ()
        }
    } {
        let _ = {
            defer { defer_fired = true }
            errdefer { errdefer_fired = true }
            throw "boom"
            0
        }
    }
    assert(defer_fired)
    assert(!errdefer_fired)
}


// ───── LIFO порядок defer'ов на interrupt-path ─────

test "несколько defer'ов на interrupt — LIFO" {
    let mut step = 0
    let mut order_a = 0
    let mut order_b = 0
    let mut order_c = 0
    with Fail = handler Fail {
        fail(_msg) {
            interrupt ()
        }
    } {
        let _ = {
            defer {
                step = step + 1
                order_a = step    // registered first — last to fire
            }
            defer {
                step = step + 1
                order_b = step
            }
            defer {
                step = step + 1
                order_c = step    // registered last — first to fire
            }
            throw "fail"
            0
        }
    }
    // LIFO: C first, B second, A last.
    assert(order_c == 1)
    assert(order_b == 2)
    assert(order_a == 3)
}
