// Plan 53: record-destructuring в let-биндингах.
// `let { tx, rx } = ch` вместо `let tx = ch.tx; let rx = ch.rx`.

module syntax.let_destructure_record

type Pair {
    tx int
    rx int
}

type Outer {
    inner Pair
    label int
}

fn make_pair(a int, b int) -> Pair => { tx: a, rx: b }

test "shorthand basic" {
    ro { tx, rx } = make_pair(1, 2)
    assert(tx == 1)
    assert(rx == 2)
}

test "type-prefix" {
    ro p = Pair { tx: 5, rx: 6 }
    ro Pair { tx, rx } = p
    assert(tx == 5)
    assert(rx == 6)
}

test "rest .. без bind" {
    ro p = Pair { tx: 7, rx: 8 }
    ro { tx, .. } = p
    assert(tx == 7)
}

test "renaming через под-pattern" {
    ro p = Pair { tx: 9, rx: 10 }
    ro { tx: sender, rx: receiver } = p
    assert(sender == 9)
    assert(receiver == 10)
}

test "nested destructure" {
    ro o = Outer { inner: Pair { tx: 11, rx: 12 }, label: 42 }
    ro { inner: { tx, rx }, label } = o
    assert(tx == 11)
    assert(rx == 12)
    assert(label == 42)
}

test "одиночный eval RHS — порядок side-effects" {
    mut count = []int.new()
    ro p = {
        count.push(1)
        Pair { tx: 100, rx: 200 }
    }
    ro { tx, rx } = p
    assert(tx == 100)
    assert(rx == 200)
    // p eval'нулся один раз; count.push выполнен ровно один раз.
    assert(count.len() == 1)
}

test "Channel.new use case" {
    ro { tx, rx } = Channel.new(1)
    tx.close()
    ro _ = rx
    assert(true)
}

// Plan 53 Ф.6.5: round-trip через destructured handles.
// Acceptance §192: «Channel.new use-case работает (получает
// Nova_ChanWriter* + Nova_ChanReader*)». Прежний тест выше только
// проверял что `tx.close()` not crash — не verified что обе половины
// действительно функциональны после destructure.
test "Channel.new round-trip — destructured tx send → rx recv" {
    ro { tx, rx } = Channel.new(4)
    ro _ = tx.send(42)
    ro _ = tx.send(99)
    tx.close()
    // Receive через destructured rx — оба handle должны работать.
    // Используем == сравнение вместо if-let (pre-existing codegen
    // if-let-as-expr quirk).
    assert(rx.recv() == Some(42))
    assert(rx.recv() == Some(99))
    // После close + drain — recv даёт None.
    assert(rx.recv() == None)
}
