// Негативный тест: errdefer НЕ срабатывает на нормальном выходе из блока.
// Если errdefer сработает — println изменит stdout, test-runner
// не ожидает этот вывод → тест провалится.

module syntax.errdefer_no_fire_on_normal


test "errdefer не срабатывает на нормальном выходе" {
    mut fired = 0
    ro _ = {
        errdefer { fired = fired + 1 }
        42
    }
    assert(fired == 0)
}

test "errdefer не срабатывает: несколько bloков — все нормальные" {
    mut count = 0
    ro _ = {
        errdefer { count = count + 1 }
        ro _ = {
            errdefer { count = count + 1 }
            10
        }
        20
    }
    assert(count == 0)
}

test "errdefer не срабатывает, defer срабатывает — на нормальном выходе" {
    mut defer_count = 0
    mut errdefer_count = 0
    ro _ = {
        defer { defer_count = defer_count + 1 }
        errdefer { errdefer_count = errdefer_count + 1 }
        99
    }
    assert(defer_count == 1)
    assert(errdefer_count == 0)
}
