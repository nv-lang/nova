module plan126.p19_comparable_field_lacks_neg

type Bare2 {
    n int
}

#impl(Compare)
type Cmp {
    inner Bare2
}

test "Compare field lacks protocol fails" {
    ro c = Cmp { inner: Bare2 { n: 0 } }
    assert(c.inner.n == 0)
}
