// Plan 126 (D230) вЂ” POS F03:
// `#impl(Clone)` РЅР° record СЃ primitive fields в†’ auto-derive @clone().
// AC-126.4.
module nova_tests.plan126

#impl(Clone)
type Point2 {
    x int
    y int
}

test "Point2 type-checks with auto-derived @clone" {
    ro p = Point2 { x: 1, y: 2 }
    assert(p.x == 1)
}
