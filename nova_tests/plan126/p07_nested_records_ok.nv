// Plan 126 вЂ” POS F07:
// Р РµРєСѓСЂСЃРёРІРЅС‹Р№ auto-derive вЂ” Outer СЃРѕРґРµСЂР¶РёС‚ Inner, РѕР±Р° `#impl(Equal)`.
// Verify field-eligibility: Inner satisfies в†’ Outer synthesis succeeds.
// AC-126.7 (nested levels).
module nova_tests.plan126

#impl(Equal)
type Inner1 {
    n int
}

#impl(Equal)
type Outer1 {
    inner Inner1
    extra int
}

test "Nested Equal records type-check" {
    ro o = Outer1 { inner: Inner1 { n: 5 }, extra: 10 }
    assert(o.extra == 10)
}
