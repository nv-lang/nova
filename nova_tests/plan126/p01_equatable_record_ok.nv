// Plan 126 (D109 amend, D230) — POS F01:
// `#impl(Equatable)` на record с primitive fields → auto-derive @equals.
// AC-126.2.
module plan126.p01_equatable_record_ok

#impl(Equatable)
type Vec3 {
    x f64
    y f64
    z f64
}

test "Vec3 type-checks with auto-derived @equals" {
    ro a = Vec3 { x: 1.0, y: 2.0, z: 3.0 }
    assert(a.x == 1.0)
}
