// Plan 126 (D109 amend, D230) вЂ” POS F01:
// `#impl(Equal)` РЅР° record СЃ primitive fields в†’ auto-derive @equal.
// AC-126.2.
module nova_tests.plan126

#impl(Equal)
type Vec3 {
    x f64
    y f64
    z f64
}

test "Vec3 type-checks with auto-derived @equal" {
    ro a = Vec3 { x: 1.0, y: 2.0, z: 3.0 }
    assert(a.x == 1.0)
}
