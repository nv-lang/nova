// Plan 126 вЂ” POS F08:
// 3-level СЂРµРєСѓСЂСЃРёРІРЅС‹Р№ auto-derive вЂ” Level1 в†’ Level2 в†’ Level3.
// AC-126.7 (3+ levels).
module plan126.p08_nested_3level_ok

#impl(Clone)
type L3 {
    leaf int
}

#impl(Clone)
type L2 {
    inner L3
}

#impl(Clone)
type L1 {
    inner L2
}

test "3-level nesting type-checks" {
    ro x = L1 { inner: L2 { inner: L3 { leaf: 42 } } }
    assert(x.inner.inner.leaf == 42)
}
