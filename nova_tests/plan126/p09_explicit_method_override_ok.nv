// Plan 126 — POS F09:
// User explicit `fn T @method(...)` wins над auto-derive.
// AC-126.10 (manual override).
module plan126.p09_explicit_method_override_ok

#impl(Equatable)
type Custom {
    a int
    b int
}

// User-provided explicit equals — overrides auto-derive.
fn Custom @equals(other Custom) -> bool =>
    @a == other.a

test "explicit equals method satisfies #impl" {
    ro c = Custom { a: 1, b: 999 }
    assert(c.a == 1)
}
