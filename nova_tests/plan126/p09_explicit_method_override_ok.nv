// Plan 126 вЂ” POS F09:
// User explicit `fn T @method(...)` wins РЅР°Рґ auto-derive.
// AC-126.10 (manual override).
module nova_tests.plan126

#impl(Equal)
type Custom {
    a int
    b int
}

// User-provided explicit equals вЂ” overrides auto-derive.
fn Custom @equal(other Custom) -> bool =>
    @a == other.a

test "explicit equals method satisfies #impl" {
    ro c = Custom { a: 1, b: 999 }
    assert(c.a == 1)
}
