// Plan 126 вЂ” POS F15:
// `priv` field СЃРѕРІРјРµСЃС‚РёРј СЃ auto-derive вЂ” synthesizer = type-method scope.
// AC-126.13 (composability СЃ priv).
module nova_tests.plan126

#impl(Equal)
type Secret {
    priv code int
    label str
}

fn Secret.new(c int, l str) -> Secret =>
    { code: c, label: l }

test "priv field auto-derive works" {
    ro s = Secret.new(42, "x")
    assert(s.label == "x")
}
