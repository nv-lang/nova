// Plan 126 вЂ” POS F05:
// `#impl(Display)` РЅР° record в†’ auto-derive @display(sb) (memberwise format).
// AC-126.6.
module plan126.p05_printable_record_ok

#impl(Display)
type Tag {
    name str
    code int
}

test "Tag type-checks with auto-derived @display" {
    ro t = Tag { name: "info", code: 1 }
    assert(t.code == 1)
}
