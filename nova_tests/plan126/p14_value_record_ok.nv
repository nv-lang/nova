// Plan 126 вЂ” POS F14:
// Multi-protocol + mut field combinator вЂ” auto-derive composes СЃ D33 mut.
// AC-126.13 (composability СЃ mut field modifier).
module nova_tests.plan126

#impl(Hash + Equal)
type Vector {
    mut x f64
    mut y f64
}

test "multi-protocol auto-derive composes СЃ mut fields" {
    ro v = Vector { x: 1.0, y: 2.0 }
    assert(v.x == 1.0)
}
