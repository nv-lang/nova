// Plan 126 РІРӮвҖқ POS F06:
// Combined auto-derive РІРӮвҖқ Р РҶРЎРғР Вө 5 built-in Р С—РЎРӮР С•РЎвҖҡР С•Р С”Р С•Р В»Р С•Р РҶ Р С•Р Т‘Р Р…Р С•Р РҶРЎРӮР ВөР СҳР ВөР Р…Р Р…Р С•.
// AC-126.2 + 126.3 + 126.4 + 126.5 + 126.6.
module plan126.p06_combined_all_protocols_ok

#impl(Equal + Hash + Clone + Compare + Display)
type Quad {
    a int
    b int
    c int
    d int
}

test "Quad type-checks with all 5 protocols auto-derived" {
    ro q = Quad { a: 1, b: 2, c: 3, d: 4 }
    assert(q.a == 1)
}
