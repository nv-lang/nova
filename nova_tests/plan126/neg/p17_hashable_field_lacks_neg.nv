// EXPECT_COMPILE_ERROR E_AUTO_DERIVE_FIELD_LACKS_PROTOCOL
//
// Plan 126 вЂ” NEG F17:
// Hash auto-derive вЂ” field type РЅРµ Hash в†’ error.
// AC-126.9.
module neg.p17_hashable_field_lacks_neg

type RawX {
    raw int
}

#impl(Hash)
type NeedsHash {
    payload RawX
}

test "Hash field lacks protocol fails" {
    ro h = NeedsHash { payload: RawX { raw: 1 } }
    assert(h.payload.raw == 1)
}
