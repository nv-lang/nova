// Plan 126 вЂ” POS F11:
// bool / char fields eligible (РІСЃРµ primitives auto-derivable).
// AC-126.2.
module nova_tests.plan126

#impl(Hash)
type Flag {
    enabled bool
    marker char
    count int
}

test "Flag with bool/char/int eligible" {
    ro f = Flag { enabled: true, marker: 'x', count: 7 }
    assert(f.count == 7)
}
