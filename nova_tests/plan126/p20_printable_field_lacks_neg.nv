// EXPECT_COMPILE_ERROR E_AUTO_DERIVE_FIELD_LACKS_PROTOCOL
//
// Plan 126 — NEG F20:
// Printable auto-derive — field type не Printable → error.
// AC-126.9.
module plan126.p20_printable_field_lacks_neg

type RawY {
    raw int
}

#impl(Printable)
type NeedsFmt {
    body RawY
}

test "Printable field lacks protocol fails" {
    ro f = NeedsFmt { body: RawY { raw: 0 } }
    assert(f.body.raw == 0)
}
