module plan126.p20_printable_field_lacks_neg

type RawY {
    raw int
}

#impl(Display)
type NeedsFmt {
    body RawY
}

test "Display field lacks protocol fails" {
    ro f = NeedsFmt { body: RawY { raw: 0 } }
    assert(f.body.raw == 0)
}
