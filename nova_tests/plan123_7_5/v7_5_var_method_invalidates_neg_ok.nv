// Plan 123.7.5 (V7.5, 2026-06-04): NEGATIVE вЂ” V7.5 doesn't relax for
// non-@F-receiver method calls. `var.method()` (local-variable
// receiver) still conservatively invalidates. Semantic preservation
// РїСЂРѕРІРµСЂСЏРµС‚СЃСЏ.

module nova_tests.plan123_7_5

type Cv {
    mut n int
}

fn Cv.new() -> Cv => { n: 3 }

fn Cv mut @do(mut v []int) -> int {
    ro a = @n
    // var.push() вЂ” non-self receiver, V7.5 РЅРµ applicable.
    // V1.1 splits @n cache here; pre-call @n cache valid; post-call
    // re-read.
    v.push(99)
    ro b = @n
    a + b
}

test "V7.5: var.method() still invalidates, semantic preserved" {
    mut Cv = Cv.new()
    mut v = []int.new()
    ro r = Cv.do(v)
    assert(r == 6)
    assert(v.len() == 1)
}
