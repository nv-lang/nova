// Plan 123.1 T1.1: ro field accessed 2+ times → cache emitted.
// Expected: `let _at_x = @x` + `let _at_y = @y` prefix lets injected.

module nova_tests.plan123

type Point3 {
    ro x int
    ro y int
}

fn Point3 @sum_squared() -> int {
    @x * @x + @y * @y
}

fn Point3.new(x int, y int) -> Point3 {
    Point3 { x, y }
}

test "ro field caching preserves semantics" {
    ro p = Point3.new(3, 4)
    ro r = p.sum_squared()
    // 3*3 + 4*4 = 9 + 16 = 25
    assert(r == 25)
}
