// Plan 123.1 T2.11 positive: ro caching combined с method arguments.
// @field reads cached, args не affected.

module nova_tests.plan123

type Bounded4 {
    ro lo int
    ro hi int
}

fn Bounded4 @clamp(x int) -> int {
    // 4 reads ro fields (2 each) — cache emitted.
    if x < @lo { @lo } else { if x > @hi { @hi } else { x } }
}

fn Bounded4 @sum_clamped(a int, b int) -> int {
    // @lo + @hi accessed twice each here too.
    ro mid = (@lo + @hi) / 2
    @clamp(a) + @clamp(b) + mid + (@lo - @hi)
}

fn Bounded4.new(lo int, hi int) -> Bounded4 {
    Bounded4 { lo, hi }
}

test "method with args + ro caching" {
    ro r = Bounded4.new(0, 10)
    assert(r.clamp(5) == 5)
    assert(r.clamp(-3) == 0)
    assert(r.clamp(99) == 10)
}

test "ro caching across self-method-calls" {
    ro r = Bounded4.new(0, 10)
    // Each clamp call independently triggers ro caching.
    ro s = r.sum_clamped(5, 7)
    // 5+7 + 5 (mid=(0+10)/2) + (0-10) = 12+5-10 = 7
    assert(s == 7)
}
