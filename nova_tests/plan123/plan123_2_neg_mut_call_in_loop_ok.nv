// Plan 123.2 T-NEG.2: Call inside loop body — for mut fields, V2
// conservative skip hoisting (call could mutate @F via alias).

module nova_tests.plan123

type Acc4_plan1232negmutcallinloopok {
    mut total int
}

fn Acc4_plan1232negmutcallinloopok.adjust(x int) -> int { x + 1 }

fn Acc4_plan1232negmutcallinloopok mut @sum_n(n int) -> int {
    mut i = 0
    mut s = 0
    while i < n {
        // call inside loop body → no LICM hoist для mut @total.
        s = s + @total + @total + Acc4_plan1232negmutcallinloopok.adjust(i)
        i = i + 1
    }
    s
}

fn Acc4_plan1232negmutcallinloopok.new(t int) -> Acc4_plan1232negmutcallinloopok {
    Acc4_plan1232negmutcallinloopok { total: t }
}

test "call in loop blocks mut hoist — correctness" {
    mut a = Acc4_plan1232negmutcallinloopok.new(10)
    ro r = a.sum_n(3)
    // 3 iterations × (10+10) + (1+2+3) = 60 + 6 = 66.
    assert(r == 66)
}
