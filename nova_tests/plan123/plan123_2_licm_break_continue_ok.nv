// Plan 123.2 T1.6: break/continue preserve correctness with hoisted
// cache. Hoisted load is side-effect-free.

module nova_tests.plan123

type UpperBound3 {
    ro hi int
}

fn UpperBound3 @sum_partial(skip int) -> int {
    mut total = 0
    mut i = 0
    while i < @hi {
        if i == skip {
            i = i + 1
            continue
        }
        total = total + @hi + i
        i = i + 1
    }
    total
}

fn UpperBound3.new(h int) -> UpperBound3 {
    UpperBound3 { hi: h }
}

test "break/continue safe with LICM" {
    ro r = UpperBound3.new(5).sum_partial(2)
    // i=0..5; skip i=2. Pairs: (0,5+0=5), (1,6), skip(2), (3,8), (4,9).
    // total = 5+6+8+9 = 28.
    assert(r == 28)
}
