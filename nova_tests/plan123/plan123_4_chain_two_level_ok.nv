// Plan 123.4 T1.1: @parent.inner accessed 2+ times → chain cached.

module nova_tests.plan123

type Inner2_plan1234chaintwolevelok {
    ro value int
}

type Outer3_plan1234chaintwolevelok {
    ro inner Inner2_plan1234chaintwolevelok
    ro mark int
}

fn Outer3_plan1234chaintwolevelok @sum_with_chain() -> int {
    // 3 reads of @inner.value (= chain length 2 = "inner.value").
    @inner.value + @inner.value + @inner.value + @mark
}

fn Outer3_plan1234chaintwolevelok.new(v int, m int) -> Outer3_plan1234chaintwolevelok {
    Outer3_plan1234chaintwolevelok { inner: Inner2_plan1234chaintwolevelok { value: v }, mark: m }
}

test "chain @inner.value cached" {
    ro o = Outer3_plan1234chaintwolevelok.new(7, 5)
    ro r = o.sum_with_chain()
    // 3*7 + 5 = 26.
    assert(r == 26)
}
