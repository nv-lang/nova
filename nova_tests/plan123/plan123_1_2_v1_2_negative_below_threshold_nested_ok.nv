// Plan 123.1.2 (V1.2, 2026-06-04): NEGATIVE РІРӮвҖқ nested region РЎРғ reads <
// threshold Р Р…Р Вө cached. Semantic preservation Р С—РЎРӮР С•Р РҶР ВөРЎРӮР ВөР Р…Р В° Р Т‘Р В»РЎРҸ cold path.

module nova_tests.plan123

type Cv_plan12312v12negativebelowthresholdnestedok { mut x int }

fn Cv_plan12312v12negativebelowthresholdnestedok.new() -> Cv_plan12312v12negativebelowthresholdnestedok => { x: 1 }

fn Cv_plan12312v12negativebelowthresholdnestedok mut @almost(cond bool) -> int {
    if cond {
        @x = 99
        // Р СһР С•Р В»РЎРҠР С”Р С• 1 read РІРӮвҖқ V1.2 Р Р…Р Вө Р Т‘Р С•Р В»Р В¶Р ВөР Р… cached.
        ro a = @x
        a
    } else {
        0
    }
}

test "V1.2: nested below-threshold not cached, semantic ok" {
    mut cv = Cv_plan12312v12negativebelowthresholdnestedok.new()
    ro r = cv.almost(true)
    assert(r == 99)
    mut c2 = Cv_plan12312v12negativebelowthresholdnestedok.new()
    ro r2 = c2.almost(false)
    assert(r2 == 0)
}
