// Plan 123 V*.followups 2026-06-05 marker 3 — chain-norm V2 user-fluent.
// Closes [M-123.4.4-user-fluent-detection].
// Positive: user `-> @` fluent builder chain triggers chain-norm
// hoisting via FnDecl.returns_receiver discovery (V1 hardcoded list
// would skip).

module nova_tests.plan123

type Counter4_plan123followups20260605m3chainnormv2userfluentok {
    mut n int
}

fn Counter4_plan123followups20260605m3chainnormv2userfluentok.new() -> Counter4_plan123followups20260605m3chainnormv2userfluentok => { n: 0 }

// User fluent builder: `-> @` return marker → registered в
// FluentMethodRegistry.
fn Counter4_plan123followups20260605m3chainnormv2userfluentok mut @step(by int) -> @ {
    @n = @n + by
    @
}

fn Counter4_plan123followups20260605m3chainnormv2userfluentok @get() -> int => @n

type Holder8 {
    mut c Counter4_plan123followups20260605m3chainnormv2userfluentok
}

fn Holder8.new() -> Holder8 => { c: Counter4_plan123followups20260605m3chainnormv2userfluentok.new() }

fn Holder8 mut @use_chain() -> int {
    // V2: `@c.step(1).step(2).step(3)` — root `@c` (heap-record ref),
    // chain depth 3 of user-defined `step` `-> @`. V2 hoists root.
    @c.step(1).step(2).step(3)
    @c.get()
}

test "chain-norm V2 user fluent: depth-3 user step chain" {
    mut h = Holder8.new()
    ro r = h.use_chain()
    // 0 → 1 → 3 → 6
    assert(r == 6)
    assert(h.c.get() == 6)
}
