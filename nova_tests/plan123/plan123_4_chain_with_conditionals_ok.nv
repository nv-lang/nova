// Plan 123.4 T1.6: chain reads spanning if-else branches.

module nova_tests.plan123

type Wrap3_plan1234chainwithconditionalsok {
    ro inner Wrap_Inner
}

type Wrap_Inner {
    ro flag int
    ro data int
}

fn Wrap3_plan1234chainwithconditionalsok @select_value() -> int {
    if @inner.flag > 0 {
        @inner.data + @inner.data
    } else {
        @inner.flag * 0 + 100
    }
}

fn Wrap3_plan1234chainwithconditionalsok.new(f int, d int) -> Wrap3_plan1234chainwithconditionalsok {
    Wrap3_plan1234chainwithconditionalsok { inner: Wrap_Inner { flag: f, data: d } }
}

test "chain caching across branches" {
    assert(Wrap3_plan1234chainwithconditionalsok.new(1, 5).select_value() == 10)
    assert(Wrap3_plan1234chainwithconditionalsok.new(0, 99).select_value() == 100)
}
