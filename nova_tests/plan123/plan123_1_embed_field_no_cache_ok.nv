// Plan 123.1 T2.9 (negative-style): embed field skipped (use-style
// embed = D39 auto-proxy, не direct field caching applicable).

module nova_tests.plan123

type Inner_plan1231embedfieldnocacheok {
    ro v int
}

type Outer3_plan1231embedfieldnocacheok {
    use inner Inner_plan1231embedfieldnocacheok
    ro mark int
}

fn Outer3_plan1231embedfieldnocacheok @combine() -> int {
    // @mark — 3 reads — should be cached (ro).
    // @inner.v access — embed proxy; not direct @field caching.
    // V1 conservative: @inner — embed, skipped from registry.
    @mark + @mark + @mark + @inner.v
}

fn Outer3_plan1231embedfieldnocacheok.new(v int, m int) -> Outer3_plan1231embedfieldnocacheok {
    Outer3_plan1231embedfieldnocacheok { inner: Inner_plan1231embedfieldnocacheok { v }, mark: m }
}

test "embed field skipped, ro mark cached" {
    ro r = Outer3_plan1231embedfieldnocacheok.new(7, 5).combine()
    // 5+5+5+7 = 22.
    assert(r == 22)
}
