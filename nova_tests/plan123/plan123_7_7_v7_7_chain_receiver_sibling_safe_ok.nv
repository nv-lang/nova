// Plan 123.7.7 (V7.7, 2026-06-04): chain receiver IPA refinement.
// Closes [M-123.7.5-chain-receiver].
//
// Extends V7.5 sibling-safe rule k chains: `@F0.F1.....Fn.method()`
// preserves caches of fields outside the chain root.

module nova_tests.plan123

type Inner2_plan12377v77chainreceiversiblingsafeok {
    mut sub []int
}

type Cv3_plan12377v77chainreceiversiblingsafeok {
    mut counter int
    mut inner Inner2_plan12377v77chainreceiversiblingsafeok
}

fn Inner2_plan12377v77chainreceiversiblingsafeok.new() -> Inner2_plan12377v77chainreceiversiblingsafeok => { sub: []int.new() }

fn Cv3_plan12377v77chainreceiversiblingsafeok.new() -> Cv3_plan12377v77chainreceiversiblingsafeok => { counter: 0, inner: Inner2_plan12377v77chainreceiversiblingsafeok.new() }

fn Cv3_plan12377v77chainreceiversiblingsafeok mut @sample_and_grow(v int) -> int {
    // V7.7: chain `@inner.sub.push(v)` doesn't invalidate sibling
    // `@counter` cache. Read counter twice before Рё twice after.
    ro c1 = @counter
    ro c2 = @counter
    @inner.sub.push(v)
    ro c3 = @counter
    ro c4 = @counter
    c1 + c2 + c3 + c4
}

test "V7.7: chain receiver doesn't invalidate sibling cache" {
    mut cv3 = Cv3_plan12377v77chainreceiversiblingsafeok.new()
    cv3.counter = 13
    ro r = cv3.sample_and_grow(42)
    // counter = 13 throughout вЂ” 13*4 = 52
    assert(r == 52)
    // Verify chain mutation:
    assert(cv3.inner.sub.len() == 1)
    assert(cv3.inner.sub[0] == 42)
}
