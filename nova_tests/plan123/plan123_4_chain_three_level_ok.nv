// Plan 123.4 T1.2: depth-3 chain `@parent.inner.cfg`.

module nova_tests.plan123

type Cfg {
    ro limit int
}

type Inner1 {
    ro cfg Cfg
}

type Parent3 {
    ro inner Inner1
}

fn Parent3 @check_limits() -> int {
    // 3 reads of chain @inner.cfg.limit (depth 3).
    @inner.cfg.limit + @inner.cfg.limit * 2 + @inner.cfg.limit
}

fn Parent3.new(lim int) -> Parent3 {
    Parent3 { inner: Inner1 { cfg: Cfg { limit: lim } } }
}

test "3-level chain cached" {
    ro p = Parent3.new(7)
    ro r = p.check_limits()
    // 7 + 14 + 7 = 28.
    assert(r == 28)
}
