// Plan 141 — A1: NaN tuple equality by IEEE semantics.
// `(nan, 1) == (nan, 1)` must be FALSE: IEEE `NaN != NaN`.
// The prior memcmp gave TRUE (bit-identical NaN compares equal).
module nova_tests.plan141

fn make_nan1(z f64) -> f64 => z / z

test "(nan, 1) == (nan, 1) → false (IEEE NaN != NaN)" {
    ro zero = 0.0
    ro nan = make_nan1(zero)
    ro a = (nan, 1)
    ro b = (nan, 1)
    assert(a != b)
    assert(!(a == b))
}

test "(1.0, 2) == (1.0, 2) → true (sanity, non-NaN float tuple)" {
    ro a = (1.0, 2)
    ro b = (1.0, 2)
    assert(a == b)
}
