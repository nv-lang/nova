// Plan 152.2 Ф.2 (D251): trim / trim_matches / strip — zero-copy views.
module plan152_2.trim_strip

test "trim / trim_start / trim_end (ASCII whitespace)" {
    assert("  hi  ".trim() == "hi")
    assert("\t\n hi \r\n".trim() == "hi")
    assert("  hi  ".trim_start() == "hi  ")
    assert("  hi  ".trim_end() == "  hi")
    assert("nows".trim() == "nows")
    assert("   ".trim() == "")
}

test "trim_matches / trim_start_matches / trim_end_matches (char)" {
    assert("xxhixx".trim_matches('x') == "hi")
    assert("xxhixx".trim_start_matches('x') == "hixx")
    assert("xxhixx".trim_end_matches('x') == "xxhi")
    assert("---".trim_matches('-') == "")
    assert("hi".trim_matches('x') == "hi")
}

test "trim_matches on a multibyte char" {
    // 'я' = 2 bytes (U+044F). Trimming it must work byte-correctly.
    assert("яяtextяя".trim_matches('я') == "text")
    assert("яяtext".trim_start_matches('я') == "text")
}

test "strip_prefix / strip_suffix -> Option" {
    assert("foobar".strip_prefix("foo") == Some("bar"))
    assert("foobar".strip_prefix("xyz") == None)
    assert("foobar".strip_suffix("bar") == Some("foo"))
    assert("foobar".strip_suffix("xyz") == None)
    assert("foobar".strip_prefix("") == Some("foobar"))   // empty prefix
}

test "strip composes (non-ASCII)" {
    // "αβγ": each Greek letter 2 bytes
    match "αβγ".strip_prefix("α") {
        Some(rest) => assert(rest == "βγ"),
        None => assert(false),
    }
}
