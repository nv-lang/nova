// Plan 152.2 Ф.3 (D251): match_indices/matches/is_char_boundary + replacen + pad.
module nova_tests.plan152_2

test "match_indices: byte-offsets of non-overlapping matches" {
    ro idx = "abXabXab".match_indices("X")
    assert(idx.len() == 2)
    assert(idx[0] == 2)
    assert(idx[1] == 5)
    assert("aaaa".match_indices("aa").len() == 2)   // non-overlapping: 0, 2
    assert("none".match_indices("z").len() == 0)
}

test "matches: matched substrings (views)" {
    ro m = "XaXbX".matches("X")
    assert(m.len() == 3)
    assert(m[0] == "X")
}

test "is_char_boundary (héllo: é = bytes 1..3)" {
    ro s = "héllo"            // byte_len 6
    assert(s.is_char_boundary(0))
    assert(s.is_char_boundary(1))    // start of é
    assert(!s.is_char_boundary(2))   // continuation byte of é
    assert(s.is_char_boundary(3))
    assert(s.is_char_boundary(6))    // == byte_len
    assert(!s.is_char_boundary(7))   // > byte_len
    assert(!s.is_char_boundary(-1))
}

test "replacen: first n occurrences" {
    assert("a.a.a.a".replacen(".", "-", 2) == "a-a-a.a")
    assert("aaa".replacen("a", "b", 0) == "aaa")     // n=0 → unchanged
    assert("aaa".replacen("a", "b", 9) == "bbb")     // n > occurrences
    assert("xyz".replacen("q", "Q", 3) == "xyz")     // not found
}

test "pad_*: width in CODEPOINTS (not bytes)" {
    assert("é".pad_start(3, '·') == "··é")      // é=2 bytes, 1 codepoint → 2 pad
    assert("hi".pad_end(4, '.') == "hi..")
    assert("x".pad_center(5, '-') == "--x--")
    assert("toolong".pad_start(3, ' ') == "toolong")   // width <= len → unchanged
}
