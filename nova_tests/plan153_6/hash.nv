module nova_tests.plan153_6
test "equal vecs hash equal" {
    ro a = Vec[int].of(1, 2, 3)
    ro b = Vec[int].of(1, 2, 3)
    assert(a.hash() == b.hash())
}
test "empty + single round-trip" {
    assert(Vec[int].new().hash() == Vec[int].new().hash())
    assert(Vec[int].of(42).hash() == Vec[int].of(42).hash())
}
test "content + length distinguish (FNV, no collision for these)" {
    assert(Vec[int].of(1, 2, 3).hash() != Vec[int].of(1, 2, 4).hash())
    assert(Vec[int].of(1, 2).hash() != Vec[int].of(1, 2, 0).hash())
}
