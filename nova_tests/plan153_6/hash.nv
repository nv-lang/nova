module plan153_6.hash
test "equal vecs hash equal" {
    ro a = Vec[int].from([1, 2, 3])
    ro b = Vec[int].from([1, 2, 3])
    assert(a.hash() == b.hash())
}
test "empty + single round-trip" {
    assert(Vec[int].new().hash() == Vec[int].new().hash())
    assert(Vec[int].from([42]).hash() == Vec[int].from([42]).hash())
}
test "content + length distinguish (FNV, no collision for these)" {
    assert(Vec[int].from([1, 2, 3]).hash() != Vec[int].from([1, 2, 4]).hash())
    assert(Vec[int].from([1, 2]).hash() != Vec[int].from([1, 2, 0]).hash())
}
