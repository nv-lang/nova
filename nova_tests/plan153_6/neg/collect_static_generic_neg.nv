// EXPECT_COMPILE_ERROR for-in: type 'S'
//
// Plan 153.6 (D264) — negative: a *static* generic FromIterator constructor
// `Vec[T].from_iter[S Iter[T]](src S)` whose body iterates `S` does NOT compile.
// The `S Iter[T]` bound is not resolved for the for-in dispatch inside a static
// generic method (the typevar stays `Nova_S`), so codegen rejects the for-in.
//
// The working FromIterator surface is the *instance* method
// `Vec[T].new().extend(src)` (`@extend[S Iter[T]]`, mutate.nv), which monomorphises
// correctly. This fixture locks the gating boundary: closing
// `[M-153.6-collect-static-generic]` should flip this to a positive test.
module neg.collect_static_generic_neg

fn Vec[T].from_iter_generic[S Iter[T]](src S) -> Vec[T] {
    mut out = Vec[T].new()
    for x in src {
        out.push(x)
    }
    out
}

fn main() -> () {
    ro v = Vec[int].from_iter_generic(0..4)
    assert(v.len() == 4)
}
