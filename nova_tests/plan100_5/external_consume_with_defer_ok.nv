// Plan 100.5 (D163): external consume FFI + defer cleanup pattern.
// File via FFI, defer ensures close on all exit paths.
//
// Simplified: tests that consume tracking works through defer body
// when the deferred call explicitly passes the consume binding.

module nova_tests.plan100_5.external_consume_with_defer_ok

external type File consume

external fn nova_file_open(path str) -> File needs Fs
external fn nova_file_close(consume f File) -> () needs Fs

test "FFI consume File + explicit defer via consume-param" {
    consume file = nova_file_open("test.txt")
    // Explicitly close via consume param (defer can't hold consume binding across it)
    nova_file_close(file)
    // file is now Consumed — consume checker verifies no further use
}
