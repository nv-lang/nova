// Plan 100.5 (D163): pilot MutexHandle lock-guard pattern через FFI.
// Lock automatically released via defer.
// Note: `view` param qualifier is a future feature (D163 §D5).
// Current Nova uses plain param (GC ref, non-consuming) for borrow semantics.
// Note: Type named `FfiMutex` (not `Mutex`) to avoid collision with stdlib Nova_Mutex.

module nova_tests.plan100_5.external_mutex_lock_release_ok

external type FfiMutex consume
external type LockGuard consume

external fn nova_mutex_lock(m FfiMutex) -> LockGuard needs Sys
external fn nova_lock_release(consume g LockGuard) -> () needs Sys

fn LockGuard consume @release() -> () {
    nova_lock_release(@)
}

fn critical_section(m FfiMutex) -> int {
    consume guard = nova_mutex_lock(m)
    defer { guard.release() }                   // unlock на любом exit-path
    // critical work...
    42
}

test "FfiMutex lock-guard pattern + defer release" {
    // mutex setup would be here; mock
}
