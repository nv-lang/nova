// Plan 87 Ф.4.3 — `for mut x TYPE in iter`: мутабельная loop-переменная
// с явной аннотацией типа.
//
// `mut` помечает loop-переменную мутабельной (D32/D33); комбинируется
// с аннотацией типа по правилу «name type».

module plan87.explicit_mut


test "for mut x int — мутация loop-переменной" {
    mut sum = 0
    for mut x int in [1, 2, 3] {
        x = x * 10
        sum = sum + x
    }
    assert(sum == 60)
}

test "for mut x int — несколько переприсваиваний" {
    mut last = 0
    for mut x int in [5, 7, 9] {
        x = x + 1
        x = x + 1
        last = x
    }
    assert(last == 11)
}

test "for mut x int без аннотации-мутации — просто чтение" {
    mut count = 0
    for mut x int in [4, 4, 4] {
        count = count + x
    }
    assert(count == 12)
}
