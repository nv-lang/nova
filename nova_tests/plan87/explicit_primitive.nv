// Plan 87 Ф.4.1 — for-in с явным типом элемента: примитивы.
//
// `for x TYPE in iter` (D72 «name type»): аннотация типа loop-переменной.
// Spec/syntax.md документирует её (`for id u64 in ids`); Plan 87 закрывает
// spec/impl drift. Аннотация опциональна и проверяется (Ф.3).

module nova_tests.plan87.explicit_primitive


test "for x int in array literal" {
    mut sum = 0
    for x int in [1, 2, 3] {
        sum = sum + x
    }
    assert(sum == 6)
}

test "for b u8 in []u8" {
    ro bytes []u8 = [10, 20, 30]
    mut total = 0
    for b u8 in bytes {
        total = total + (b as int)
    }
    assert(total == 60)
}

test "for c char in char array" {
    mut count = 0
    for c char in ['a', 'b', 'c'] {
        ro _ = c
        count = count + 1
    }
    assert(count == 3)
}

test "for i int in range" {
    mut acc = 0
    for i int in 0..5 {
        acc = acc + i
    }
    assert(acc == 10)
}
