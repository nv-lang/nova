// EXPECT_COMPILE_ERROR D159
//
// Plan 100.4.2 (D159): spawn в defer body — error.
// Создание новых fiber'ов в cleanup = leak supervised hierarchy.

module nova_tests.plan100_4_2.defer_err_spawn_in_body

fn process() -> () {
    defer {
        // ❌ ОШИБКА D159-spawn-in-defer: новый fiber в cleanup утечёт scope.
        spawn { println("leaked fiber") }
    }
    println("body")
}

test "spawn в defer body — error" {
    process()
}
