// Plan 100.4.2 (D159): graceful DB connection drain через defer.

module nova_tests.plan100_4_2.defer_db_drain_ok

type Connection consume { fd int }

fn Connection consume @drain(timeout_ms int) Time -> () {
    Time.sleep(timeout_ms)
}

fn open_conn() -> Connection => Connection { fd: 7 }

fn process() Time -> () {
    consume conn = open_conn()
    defer { conn.drain(500) }                   // graceful drain — Time.sleep allowed (D159)
    println("db work")
}

test "defer DB drain (async cleanup)" {
    process()
}
