// Negative / boundary tests for flat_map.
// Verifies that flat_map correctly handles exhaustion, empty inner
// iterators, and that next() after None stays None.

module plan153_2.flat_map_neg

import std.collections.vec_lazy

test "flat_map empty outer — first next is None" {
    mut it = Vec[int].of().lazy().flat_map(|x| Vec[int].of(x).lazy())
    assert(it.next() == None)
    // stays None
    assert(it.next() == None)
}

test "flat_map all-empty inners — next is None" {
    mut it = Vec[int].of(1, 2, 3).lazy().flat_map(|_| Vec[int].of().lazy())
    assert(it.next() == None)
}

test "flat_map exhaust — next after last element is None" {
    mut it = Vec[int].of(1).lazy().flat_map(|x| Vec[int].of(x).lazy())
    assert(it.next() == Some(1))
    assert(it.next() == None)
    assert(it.next() == None)
}

test "flat_map skips empty then yields from non-empty" {
    // [empty, non-empty, empty] pattern
    ro v = Vec[int].of(1, 2, 3)
    ro got = v.lazy().flat_map(|x| {
        if x == 1 {
            Vec[int].of().lazy()
        } else {
            Vec[int].of(x * 100).lazy()
        }
    }).collect()
    assert(got == [200, 300])
}
