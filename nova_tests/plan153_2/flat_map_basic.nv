module nova_tests.plan153_2

import std.collections.vec_lazy

test "flat_map basic next" {
    ro v = Vec[int].of(1, 2, 3)
    mut it = v.lazy().flat_map(|x| Vec[int].of(x, x * 10).lazy())
    assert(it.next() == Some(1))
}

test "flat_map collect all" {
    ro v = Vec[int].of(1, 2, 3)
    ro got = v.lazy().flat_map(|x| Vec[int].of(x, x * 10).lazy()).collect()
    assert(got == [1, 10, 2, 20, 3, 30])
}

test "flat_map empty outer" {
    ro v = Vec[int].of()
    ro got = v.lazy().flat_map(|x| Vec[int].of(x, x * 10).lazy()).collect()
    assert(got == [])
}

test "flat_map empty inner" {
    ro v = Vec[int].of(1, 2, 3)
    ro got = v.lazy().flat_map(|_| Vec[int].of().lazy()).collect()
    assert(got == [])
}

test "flat_map mixed empty and non-empty inner" {
    ro v = Vec[int].of(1, 2, 3)
    ro got = v.lazy().flat_map(|x| {
        if x == 2 {
            Vec[int].of().lazy()
        } else {
            Vec[int].of(x).lazy()
        }
    }).collect()
    assert(got == [1, 3])
}

test "flat_map count" {
    ro v = Vec[int].of(1, 2, 3)
    ro n = v.lazy().flat_map(|x| Vec[int].of(x, x * 10).lazy()).count()
    assert(n == 6)
}

test "flat_map single element outer" {
    ro v = Vec[int].of(5)
    ro got = v.lazy().flat_map(|x| Vec[int].of(x, x + 1, x + 2).lazy()).collect()
    assert(got == [5, 6, 7])
}
