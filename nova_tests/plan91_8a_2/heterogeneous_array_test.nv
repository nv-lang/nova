module nova_tests.plan91_8a_2

// Plan 91.8a.2 followup: heterogeneous []Display array.
// Storage: NovaArray_void_p where each slot holds heap-alloc'd
// NovaBox_Printable*. Iteration deref'ит к value, virtual dispatch
// per element правильно резолвит концерт type через vtable.

type Money5 { cents int }
fn str.from(m Money5) -> str => "Money5(" + str.from(m.cents) + ")"

type Coin6 { value int }
fn Coin6 @into() -> str => "Coin6(" + str.from(@value) + ")"

type Tag1 { name str }
fn str.from(t Tag1) -> str => "Tag1(" + t.name + ")"

test "[]Display holds Money5 + Coin6 + Tag1, iterate + fmt all" {
    ro m = Money5 { cents: 10 }
    ro c = Coin6 { value: 5 }
    ro t = Tag1 { name: "x" }
    ro xs []Display = [m, c, t]
    consume sb = StringBuilder.new()
    for x in xs {
        x.display(sb)
        sb.append("|")
    }
    assert(sb.into_str() == "Money5(10)|Coin6(5)|Tag1(x)|")
}

test "[]Display single element works" {
    ro m = Money5 { cents: 42 }
    ro xs []Display = [m]
    consume sb = StringBuilder.new()
    for x in xs {
        x.display(sb)
    }
    assert(sb.into_str() == "Money5(42)")
}

test "[]Display пустой массив — for-loop не выполняется" {
    ro xs []Display = []
    consume sb = StringBuilder.new()
    sb.append("before")
    for x in xs {
        x.display(sb)
    }
    sb.append("after")
    assert(sb.into_str() == "beforeafter")
}
