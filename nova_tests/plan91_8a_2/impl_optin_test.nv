module nova_tests.plan91_8a_2

// Plan 91.9 (D186): `#impl(P + Q + ...)` opt-in annotation.
// Verifies:
//   - bare call `u.method()` works когда type opted-in via #impl
//   - bound `[T P]` + coercion `let x P = u` остаются structural (no #impl
//     required) since user explicitly opts in at use-site
//   - multi-protocol #impl(A + B) works

type Greetable2 protocol {
    @greet() -> str {
        "Hello, " + @name()
    }
}

#impl(Greetable2)
type User4 { display_name str }
fn User4 @name() -> str => @display_name

#impl(Equal + Compare + Display)
type Coin8 { value int }
fn Coin8 @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }
fn str.from(c Coin8) -> str => "Coin8(${c.value})"

test "#impl(Greetable2): bare call works" {
    ro u = User4 { display_name: "World" }
    assert(u.greet() == "Hello, World")
}

test "#impl(A + B + C): multi-protocol opt-in" {
    ro a = Coin8 { value: 5 }
    ro b = Coin8 { value: 5 }
    ro c = Coin8 { value: 9 }
    // Equal.equals via @compare default — opted in
    assert(a.equal(b))
    assert(!a.equal(c))
    // Compare.compare — explicit method (always works)
    assert(a.compare(c) < 0)
    // Display.fmt via str.from(Coin8) default — opted in
    consume sb = StringBuilder.new()
    a.display(sb)
    assert(sb.into_str() == "Coin8(5)")
}

test "#impl(Greetable2): generic bound mono'd through opted-in type" {
    ro u = User4 { display_name: "Bound" }
    assert(make_greeting2(u) == "Hello, Bound")
}

fn make_greeting2[T Greetable2](x T) -> str => x.greet()
