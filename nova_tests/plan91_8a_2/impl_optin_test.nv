module plan91_8a_2.impl_optin_test

// Plan 91.9 (D186): `#impl(P + Q + ...)` opt-in annotation.
// Verifies:
//   - bare call `u.method()` works когда type opted-in via #impl
//   - bound `[T P]` + coercion `let x P = u` остаются structural (no #impl
//     required) since user explicitly opts in at use-site
//   - multi-protocol #impl(A + B) works

type Greetable protocol {
    @greet() -> str {
        "Hello, " + @name()
    }
}

#impl(Greetable)
type User { display_name str }
fn User @name() -> str => @display_name

#impl(Equal + Compare + Display)
type Coin { value int }
fn Coin @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }
fn str.from(c Coin) -> str => "Coin(${c.value})"

test "#impl(Greetable): bare call works" {
    ro u = User { display_name: "World" }
    assert(u.greet() == "Hello, World")
}

test "#impl(A + B + C): multi-protocol opt-in" {
    ro a = Coin { value: 5 }
    ro b = Coin { value: 5 }
    ro c = Coin { value: 9 }
    // Equal.equals via @compare default — opted in
    assert(a.equal(b))
    assert(!a.equal(c))
    // Compare.compare — explicit method (always works)
    assert(a.compare(c) < 0)
    // Display.fmt via str.from(Coin) default — opted in
    consume sb = StringBuilder.new()
    a.display(sb)
    assert(sb.as_str() == "Coin(5)")
}

test "#impl(Greetable): generic bound mono'd through opted-in type" {
    ro u = User { display_name: "Bound" }
    assert(make_greeting(u) == "Hello, Bound")
}

fn make_greeting[T Greetable](x T) -> str => x.greet()
