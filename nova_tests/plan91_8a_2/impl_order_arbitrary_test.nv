module nova_tests.plan91_8a_2

// Plan 91.9 acceptance: #impl(A + B) vs #impl(B + A) — order arbitrary,
// equivalent verification + behavior.

#impl(Compare + Equal)
type ItemA2 { value int }
fn ItemA2 @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

#impl(Equal + Compare)
type ItemB2 { value int }
fn ItemB2 @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

test "order in #impl list — irrelevant" {
    ro a1 = ItemA2 { value: 7 }
    ro a2 = ItemA2 { value: 7 }
    ro b1 = ItemB2 { value: 7 }
    ro b2 = ItemB2 { value: 7 }
    assert(a1.equal(a2))
    assert(b1.equal(b2))
    assert(a1.compare(a2) == 0)
    assert(b1.compare(b2) == 0)
}
