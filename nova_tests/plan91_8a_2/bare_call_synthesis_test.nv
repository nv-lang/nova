module nova_tests.plan91_8a_2.bare_call_synthesis_test

// Plan 91.8a.2 followup: bare-call synthesis (без [T Protocol] bound).
// Type T satisfies Equatable/Printable через default body — прямой вызов
// `m.equals(other)` / `m.fmt(sb)` работает без обёртки в generic fn.

// Equatable.equals via @compare default body — bare call.
#impl(Equatable)
type Score { value int }
fn Score @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

test "bare call: m.equals(other) для Score (только @compare)" {
    let a = Score { value: 10 }
    let b = Score { value: 10 }
    let c = Score { value: 99 }
    assert(a.equals(b))
    assert(!a.equals(c))
}

// Printable.fmt via str.from(T) overload — bare call.
#impl(Printable)
type Money { cents int }
fn str.from(m Money) -> str => "Money(" + str.from(m.cents) + ")"

test "bare call: m.fmt(sb) для Money (через fn str.from)" {
    let m = Money { cents: 500 }
    let mut sb = StringBuilder.new()
    m.fmt(sb)
    assert(sb.to_str() == "Money(500)")
}

// Printable.fmt via @into → str chain — bare call.
#impl(Printable)
type Coin { value int }
fn Coin @into() -> str => "Coin(" + str.from(@value) + ")"

test "bare call: c.fmt(sb) для Coin (через @into)" {
    let c = Coin { value: 7 }
    let mut sb = StringBuilder.new()
    c.fmt(sb)
    assert(sb.to_str() == "Coin(7)")
}
