module nova_tests.plan91_8a_2

// Plan 91.8a.2 part 3: type только Equal (no @compare) satisfies
// Equal bound через explicit @equal. Default body fallback не
// требуется — explicit method takes precedence.

type Vector32 { x int, y int, z int }

fn Vector32 @equal(other Self) -> bool =>
    @x == other.x && @y == other.y && @z == other.z

fn check_eq2[T Equal](a T, b T) -> bool => a.equal(b)

test "Vector32 без @compare satisfies Equal bound (explicit @equal)" {
    ro v1 = Vector32 { x: 1, y: 2, z: 3 }
    ro v2 = Vector32 { x: 1, y: 2, z: 3 }
    ro v3 = Vector32 { x: 4, y: 5, z: 6 }
    assert(check_eq2(v1, v2))
    assert(!check_eq2(v1, v3))
}
