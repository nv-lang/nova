module nova_tests.plan91_8a_2

// Plan 91.8a.2 [M-91.8a.2-default-body-general]: synthesis is generalized.
// Defines a NEW protocol (not Equal/Display) with a default body that
// references a method available на T. Synthesis должна работать без hardcoded
// special-case для этого protocol name.

type Greetable1 protocol {
    @greet() -> str {
        "Hello, " + @name()
    }
}

#impl(Greetable1)
type User2 { display_name str }

fn User2 @name() -> str => @display_name

test "general synthesis: Greetable1.greet via T.@name (no hardcoded case)" {
    ro u = User2 { display_name: "World" }
    ro s = u.greet()
    assert(s == "Hello, World")
}

test "generic bound [T Greetable1] dispatches to synthesized method" {
    ro u = User2 { display_name: "Alice" }
    ro r = make_greeting1(u)
    assert(r == "Hello, Alice")
}

fn make_greeting1[T Greetable1](x T) -> str => x.greet()
