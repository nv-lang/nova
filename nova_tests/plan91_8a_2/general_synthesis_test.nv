module nova_tests.plan91_8a_2.general_synthesis_test

// Plan 91.8a.2 [M-91.8a.2-default-body-general]: synthesis is generalized.
// Defines a NEW protocol (not Equatable/Printable) with a default body that
// references a method available на T. Synthesis должна работать без hardcoded
// special-case для этого protocol name.

type Greetable protocol {
    greet() -> str {
        "Hello, " + @name()
    }
}

type User { display_name str }

fn User @name() -> str => @display_name

test "general synthesis: Greetable.greet via T.@name (no hardcoded case)" {
    let u = User { display_name: "World" }
    let s = u.greet()
    assert(s == "Hello, World")
}

test "generic bound [T Greetable] dispatches to synthesized method" {
    let u = User { display_name: "Alice" }
    let r = make_greeting(u)
    assert(r == "Hello, Alice")
}

fn make_greeting[T Greetable](x T) -> str => x.greet()
