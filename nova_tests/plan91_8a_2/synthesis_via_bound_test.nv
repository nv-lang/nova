module plan91_8a_2.synthesis_via_bound_test

// Plan 91.8a.2 part 3 MVP: full lifecycle test.
// Type with only @compare → @equal synthesized → используется через
// generic bound → produces correct result.

#impl(Equal)
type Score { value int }

fn Score @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

// Generic bound — body вызывает .equal() который synthesized из default body.
fn any_equal[T Equal](xs []T, target T) -> bool {
    for x in xs {
        if x.equal(target) { return true }
    }
    false
}

test "synthesized equals работает в generic bound с loop" {
    ro scores []Score = [Score { value: 10 }, Score { value: 20 }, Score { value: 30 }]
    ro target = Score { value: 20 }
    assert(any_equal(scores, target))
    ro missing = Score { value: 99 }
    assert(!any_equal(scores, missing))
}

test "synthesized equals для empty array" {
    ro empty []Score = []
    ro target = Score { value: 5 }
    assert(!any_equal(empty, target))
}
