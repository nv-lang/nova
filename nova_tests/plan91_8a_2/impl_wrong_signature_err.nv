// EXPECT_COMPILE_ERROR E_IMPL_WRONG_SIGNATURE

module plan91_8a_2.impl_wrong_signature_err

// Plan 91.9: type claims #impl(Comparable) но @compare имеет wrong signature.
// Comparable.compare(other Self) -> int. У Item compare возвращает bool — mismatch.

#impl(Comparable)
type Item { value int }

fn Item @compare(other Self) -> bool => @value == other.value
// ↑ wrong return type (bool вместо int) → E_IMPL_WRONG_SIGNATURE

test "marker" {
    assert(true)
}
