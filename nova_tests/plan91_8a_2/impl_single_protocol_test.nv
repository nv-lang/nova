module nova_tests.plan91_8a_2

// Plan 91.9 acceptance: #impl(SingleProtocol) с explicit @compare —
// type verified, no error, bare-call works.

#impl(Compare)
type Date2 { day int, month int, year int }

fn Date2 @compare(other Self) -> int {
    if @year != other.year { return @year - other.year }
    if @month != other.month { return @month - other.month }
    @day - other.day
}

test "single protocol #impl + explicit method works" {
    ro a = Date2 { day: 1, month: 1, year: 2020 }
    ro b = Date2 { day: 1, month: 1, year: 2020 }
    ro c = Date2 { day: 2, month: 1, year: 2020 }
    assert(a.compare(b) == 0)
    assert(a.compare(c) < 0)
    assert(c.compare(a) > 0)
}
