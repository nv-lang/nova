module nova_tests.plan91_8a_2.interpolation_printable_test

// Plan 91.8a.2 followup: "${m}" interpolation routes через Printable.fmt
// path. Three paths covered:
//   Path 1: explicit `fn T @fmt(mut sb StringBuilder)` — direct fmt call.
//   Path 2: `fn str.from(T) -> str` overload — append result.
//   Path 3: `fn T @into() -> str` — append result.

#impl(Printable)
type Money { cents int }
fn str.from(m Money) -> str => "Money(" + str.from(m.cents) + ")"

#impl(Printable)
type Coin { value int }
fn Coin @into() -> str => "Coin(" + str.from(@value) + ")"

// Point has explicit @fmt — `#impl(Printable)` not required (type-checker
// finds method directly без synthesis). Annotation добавлен для verification.
#impl(Printable)
type Point { x int, y int }
fn Point @fmt(mut sb StringBuilder) -> () {
    sb.append("Point(")
    sb.append(str.from(@x))
    sb.append(", ")
    sb.append(str.from(@y))
    sb.append(")")
}

test "\"${m}\" with fn str.from(Money) overload" {
    ro m = Money { cents: 250 }
    ro s = "amount = ${m}"
    assert(s == "amount = Money(250)")
}

test "\"${c}\" with fn Coin @into() -> str" {
    ro c = Coin { value: 7 }
    ro s = "got ${c} pcs"
    assert(s == "got Coin(7) pcs")
}

test "\"${p}\" with explicit fn Point @fmt" {
    ro p = Point { x: 3, y: 4 }
    ro s = "loc=${p}"
    assert(s == "loc=Point(3, 4)")
}

test "multiple interpolations same string" {
    ro m = Money { cents: 1 }
    ro c = Coin { value: 2 }
    ro p = Point { x: 5, y: 6 }
    ro s = "m=${m} c=${c} p=${p}"
    assert(s == "m=Money(1) c=Coin(2) p=Point(5, 6)")
}
