module plan91_8a_2.interpolation_printable_test

// Plan 91.8a.2 followup: "${m}" interpolation routes через Display.fmt
// path. Three paths covered:
//   Path 1: explicit `fn T @display(mut w Write)` — direct fmt call (D258 AMEND).
//   Path 2: `fn str.from(T) -> str` overload — append result.
//   Path 3: `fn T @into() -> str` — append result.

#impl(Display)
type Money { cents int }
fn str.from(m Money) -> str => "Money(" + str.from(m.cents) + ")"

#impl(Display)
type Coin { value int }
fn Coin @into() -> str => "Coin(" + str.from(@value) + ")"

// Point has explicit @display — `#impl(Display)` not required (type-checker
// finds method directly без synthesis). Annotation добавлен для verification.
// Plan 152.7.1 (D258 AMEND): migrated to Write sink — @display(mut w Write).
#impl(Display)
type Point { x int, y int }
fn Point @display(mut w Write) -> () {
    w.write("Point(")
    w.write(str.from(@x))
    w.write(", ")
    w.write(str.from(@y))
    w.write(")")
}

test "\"${m}\" with fn str.from(Money) overload" {
    ro m = Money { cents: 250 }
    ro s = "amount = ${m}"
    assert(s == "amount = Money(250)")
}

test "\"${c}\" with fn Coin @into() -> str" {
    ro c = Coin { value: 7 }
    ro s = "got ${c} pcs"
    assert(s == "got Coin(7) pcs")
}

test "\"${p}\" with explicit fn Point @display" {
    ro p = Point { x: 3, y: 4 }
    ro s = "loc=${p}"
    assert(s == "loc=Point(3, 4)")
}

test "multiple interpolations same string" {
    ro m = Money { cents: 1 }
    ro c = Coin { value: 2 }
    ro p = Point { x: 5, y: 6 }
    ro s = "m=${m} c=${c} p=${p}"
    assert(s == "m=Money(1) c=Coin(2) p=Point(5, 6)")
}
