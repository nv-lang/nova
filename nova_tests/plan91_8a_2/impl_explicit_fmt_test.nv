module plan91_8a_2.impl_explicit_fmt_test

// Plan 91.9 acceptance: #impl(Printable) с explicit @fmt method (not via
// default body). Verification finds @fmt directly, no default-body
// satisfiability check needed.

#impl(Printable)
type Tag { name str }

fn Tag @fmt(mut sb StringBuilder) -> () {
    sb.append("Tag(")
    sb.append(@name)
    sb.append(")")
}

test "verified #impl(Printable) with explicit @fmt" {
    ro t = Tag { name: "hello" }
    // Bare call works (explicit method, не synth)
    consume sb = StringBuilder.new()
    t.fmt(sb)
    assert(sb.as_str() == "Tag(hello)")
}

test "explicit @fmt routes through interpolation directly" {
    ro t = Tag { name: "world" }
    ro s = "got ${t}"
    assert(s == "got Tag(world)")
}
