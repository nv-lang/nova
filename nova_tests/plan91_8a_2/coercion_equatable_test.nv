module nova_tests.plan91_8a_2

// Plan 91.8a.2 followup: Equal coercion с Self-typed param.
// `let x Equal = m` works; `x.equal(y)` virtual dispatch where y is
// also Equal-typed; codegen lowers Self → void* в vtable struct,
// thunk casts to concrete, call site unwraps NovaBox arg к .data.

type Score4 { value int }
fn Score4 @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

test "Score4 coerced to Equal, virtual equals() call" {
    ro a = Score4 { value: 7 }
    ro b = Score4 { value: 7 }
    ro c = Score4 { value: 8 }
    ro ea Equal = a
    ro eb Equal = b
    ro ec Equal = c
    assert(ea.equal(eb))
    assert(!ea.equal(ec))
}

test "Equal coerced — equals with concrete RHS (auto-passthrough)" {
    ro a = Score4 { value: 42 }
    ro b = Score4 { value: 42 }
    ro ea Equal = a
    // Note: ea.equal(b) where b is concrete Score4 — codegen passes b
    // directly (not via .data unwrap). Type-checker accepts because
    // Equal.equal(other Self) — Self here resolved через ea's
    // erased type, but b is also Score4 (concrete impl).
    assert(ea.equal(b))
}
