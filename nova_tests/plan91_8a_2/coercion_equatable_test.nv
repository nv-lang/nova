module plan91_8a_2.coercion_equatable_test

// Plan 91.8a.2 followup: Equatable coercion с Self-typed param.
// `let x Equatable = m` works; `x.equals(y)` virtual dispatch where y is
// also Equatable-typed; codegen lowers Self → void* в vtable struct,
// thunk casts to concrete, call site unwraps NovaBox arg к .data.

type Score { value int }
fn Score @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }

test "Score coerced to Equatable, virtual equals() call" {
    ro a = Score { value: 7 }
    ro b = Score { value: 7 }
    ro c = Score { value: 8 }
    ro ea Equatable = a
    ro eb Equatable = b
    ro ec Equatable = c
    assert(ea.equals(eb))
    assert(!ea.equals(ec))
}

test "Equatable coerced — equals with concrete RHS (auto-passthrough)" {
    ro a = Score { value: 42 }
    ro b = Score { value: 42 }
    ro ea Equatable = a
    // Note: ea.equals(b) where b is concrete Score — codegen passes b
    // directly (not via .data unwrap). Type-checker accepts because
    // Equatable.equals(other Self) — Self here resolved через ea's
    // erased type, but b is also Score (concrete impl).
    assert(ea.equals(b))
}
