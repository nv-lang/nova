module plan91_8a_2.impl_verification_test

// Plan 91.9 (D186) — verification pass for `#impl(P + Q + ...)`.
// При декларации type X #impl(P) compiler проверяет что X provides все
// методы P (explicit OR synthesizable from P's default body).
// Missing → E_IMPL_MISSING_METHODS at type-decl site (не при использовании).

type Greetable protocol {
    greet() -> str {
        "Hello, " + @name()
    }
}

// Positive: User имеет @name → Greetable.greet synthesizable → #impl ok.
#impl(Greetable)
type User { display_name str }
fn User @name() -> str => @display_name

test "verified #impl(Greetable) — bare call works" {
    ro u = User { display_name: "World" }
    assert(u.greet() == "Hello, World")
}

test "verified #impl multi: Equatable + Comparable + Printable" {
    ro a = Coin { value: 5 }
    ro b = Coin { value: 5 }
    assert(a.equals(b))
    assert(a.compare(b) == 0)
    consume sb = StringBuilder.new()
    a.fmt(sb)
    assert(sb.as_str() == "Coin(5)")
}

#impl(Equatable + Comparable + Printable)
type Coin { value int }
fn Coin @compare(other Self) -> int =>
    if @value < other.value { -1 }
    else if @value > other.value { 1 }
    else { 0 }
fn str.from(c Coin) -> str => "Coin(${c.value})"
