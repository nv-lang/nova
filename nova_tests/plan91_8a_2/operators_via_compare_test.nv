module nova_tests.plan91_8a_2.operators_via_compare_test

// Plan 91.8a.2 part 3 (D183 amendment): operators `==`/`!=`/`<`/`<=`/`>`/`>=`
// dispatch через @compare если type satisfies Comparable. Raньше fallback
// на (a < b) — pointer comparison, semantically broken.

type Money { cents int }

fn Money @compare(other Self) -> int =>
    if @cents < other.cents { -1 }
    else if @cents > other.cents { 1 }
    else { 0 }

test "< через @compare synthesis" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 200 }
    assert(a < b)
    assert(!(b < a))
}

test "> через @compare synthesis" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 200 }
    assert(b > a)
    assert(!(a > b))
}

test "<= и >= через @compare synthesis" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 100 }
    ro c = Money { cents: 200 }
    assert(a <= b)
    assert(a <= c)
    assert(!(c <= a))
    assert(b >= a)
    assert(c >= a)
}

test "== / != через @compare synthesis (no explicit @equals)" {
    ro a = Money { cents: 100 }
    ro b = Money { cents: 100 }
    ro c = Money { cents: 200 }
    assert(a == b)
    assert(!(a == c))
    assert(a != c)
    assert(!(a != b))
}
