// Plan 118.5 V3 T9 → MIGRATED by Plan 138.5 (2026-06-11).
//
// The retired §V3.2 "safety-outer" forms split two ways under the final
// model:
//   - value-T (`unsafe ro int` / `unsafe mut int`): order is free — both
//     these and the flipped `ro unsafe` / `mut unsafe` compile.
//   - pointer pointee-safety: the prefix `unsafe * ro Acc` form is retired
//     (E_POINTER_PREFIX_MODIFIER); the canonical postfix forms are
//     `*unsafe ro Acc` / `*unsafe mut Acc` (ptr to a possibly-uninit Acc
//     whose pointee is ro / mut). FFI nullable-uninit is `Option[*unsafe Acc]`.

module plan118_5_v3.t9_safety_outer_ok

type Acc {
    id i64
}

// value-level uninit + readonly / mutable contract (order free)
extern "nova" fn p1(x unsafe ro int) -> ()
extern "nova" fn p2(x unsafe mut int) -> ()

// postfix pointee-unsafe pointer forms (canonical, replacing `unsafe * …`)
extern "nova" fn p3(x *unsafe ro Acc) -> ()
extern "nova" fn p4(x *unsafe mut Acc) -> ()

test "value-T safety order + postfix pointee-unsafe pointer accepted" {
    assert(1 == 1)
}
