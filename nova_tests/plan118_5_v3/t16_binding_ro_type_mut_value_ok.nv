// Plan 118.5 V3 Ф.6 POS T16 — `ro x mut T` binding form всегда разрешено.
//
// Per V3 §V3.1 amend (relaxation): storage-class check applies только к
// TYPE-position `ro mut T`. В binding-position `ro x mut T` модификаторы
// orthogonal: `ro` — на binding (запрет переприсваивания x), `mut` — на
// type (можно менять поля / вызывать mut методы). Не §V3.1 conflict.

module plan118_5_v3.t16_binding_ro_type_mut_value_ok

type Acc {
    id i64
}

// ro binding + mut value-type (int) — должен работать.
external fn t16_p1(ro x mut int) -> ()

// ro binding + mut value-type (str) — должен работать.
external fn t16_p2(ro x mut str) -> ()

// ro binding + mut reference-type (Acc) — должен работать.
external fn t16_p3(ro x mut Acc) -> ()

test "ro x mut T binding form allowed regardless of T storage class" {
    assert(1 == 1)
}
