// Plan 100.8 (D166) neg #3: D133-not-consumed suggestion lists SPECIFIC consume method.
//
// EXPECT_COMPILE_ERROR D133-not-consumed
//
// When a consume type has consume-methods, the suggestion should name the
// specific method (e.g. `.close()`) rather than a generic placeholder.
//
// Expected suggestion:
//   suggestion (maybe-incorrect): file.close()
//
// This validates that the suggestion renderer picks the first consume method.

module nova_tests.plan100_8.diag_D152_capability_suggest_specific

type File consume { fd int; path str }

fn File consume @close() -> () { () }
fn File consume @close_err() -> () { () }

fn open(path str) -> File => { fd: 1; path }

test "D152 specific method suggestion: .close() named in hint" {
    consume file = open("/tmp/test.txt")
    // ❌ D133-not-consumed: file not consumed.
    // Suggestion should name `.close()` not generic placeholder.
}
