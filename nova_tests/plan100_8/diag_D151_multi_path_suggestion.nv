// Plan 100.8 (D166) neg #2: D133-not-consumed MaybeConsumed — multi-path suggestion.
//
// EXPECT_COMPILE_ERROR D133-not-consumed
//
// When a consume binding is in MaybeConsumed state (different branches may or
// may not consume it), the suggestion should list BOTH errdefer + okdefer:
//
//   suggestion (maybe-incorrect):
//     errdefer { tx.rollback() }
//     okdefer { tx.commit() }
//
// This validates the D151-style multi-path suggestion per D166.

module nova_tests.plan100_8.diag_D151_multi_path_suggestion

type Transaction consume { id int }

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin_tx() -> Transaction => { id: 1 }

fn check_ok() -> bool => true

test "D151 multi-path suggestion: MaybeConsumed on branch" {
    consume tx = begin_tx()
    if check_ok() {
        tx.commit()
    }
    // ❌ D133-not-consumed: tx MaybeConsumed (only consumed in if-branch).
    // Suggestion: errdefer { tx.rollback() } + okdefer { tx.commit() }
}
