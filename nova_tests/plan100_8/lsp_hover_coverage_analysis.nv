// Plan 100.8 (D166) pos #4: LSP hover shows coverage analysis for consume binding.
//
// Expected hover behaviour (D166 format):
//   consume conn: Connection
//     Status: Covered
//     Error path: errdefer { conn.abort() }  ← line N
//     Success path: explicit commit at line M
//
// This fixture verifies: failable fn with both errdefer + explicit commit compiles clean.

module nova_tests.plan100_8.lsp_hover_coverage_analysis

type Connection consume { id int; host str }

fn Connection consume @commit() -> () { () }
fn Connection consume @abort() -> () { () }

fn connect(host str) -> Connection => { id: 1; host }

fn do_work() Fail[str] -> () { () }

fn process_request(host str) Fail[str] -> () {
    consume conn = connect(host)
    errdefer { conn.abort() }         // error path covered
    do_work()?
    conn.commit()                     // success path covered
}

test "hover coverage analysis — both paths covered" {
    process_request("localhost")
}
