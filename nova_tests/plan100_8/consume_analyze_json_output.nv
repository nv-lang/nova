// Plan 100.8 (D166) pos #9: nova consume-analyze --format json output.
//
// Expected `nova consume-analyze --format json`:
//   {
//     "schema": "nova-consume-analyze/v1",
//     "total_bindings": 1,
//     "covered": 1,
//     "uncovered": 0,
//     "files": [...]
//   }
//
// This fixture verifies: consume type that is properly covered produces
// JSON output with uncovered=0 from the CLI.

module nova_tests.plan100_8.consume_analyze_json_output

type Handle consume { fd int }

fn Handle consume @close() -> () { () }
fn Handle consume @cancel() -> () { () }

fn open_handle(fd int) -> Handle => { fd }

fn process_handle(fd int) Fail[str] -> () {
    consume h = open_handle(fd)
    errdefer { h.cancel() }
    h.close()
}

test "consume-analyze JSON output — uncovered=0" {
    process_handle(1)
}
