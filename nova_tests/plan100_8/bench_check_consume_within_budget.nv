// Plan 100.8 (D166) pos #7: bench check_consume overhead < 5% of baseline.
//
// This fixture demonstrates the typical consume-type pattern that the bench
// suite (bench/plan100/) measures. check_consume overhead target: < 5% vs
// nova check without consume analysis.
//
// Baseline from 100.8-artifacts/baseline-bench.md:
//   plan100_1/ 23 files: ~225ms → check_consume pass: < 5% overhead (< 11ms).
//   Single small file: ~497ms total → check_consume overhead: < 25ms.

module nova_tests.plan100_8.bench_check_consume_within_budget

type Resource consume { id int }

fn Resource consume @release() -> () { () }
fn Resource consume @abort() -> () { () }

fn acquire(id int) -> Resource => { id }

fn use_resource() Fail[str] -> () {
    consume r = acquire(1)
    errdefer { r.abort() }
    r.release()
}

test "bench check_consume: overhead within budget (< 5%)" {
    use_resource()
}
