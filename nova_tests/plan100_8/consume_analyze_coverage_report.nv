// Plan 100.8 (D166) pos #8: nova consume-analyze CLI coverage report format.
//
// Expected `nova consume-analyze` human output:
//   Coverage report (consume-analyze):
//
//     ✅ ...consume_analyze_coverage_report.nv: 2 bindings; 2 covered, 0 NOT COVERED
//
//   Summary: 2 total bindings, 2 covered, 0 uncovered
//
// This fixture verifies: properly-covered consume types produce clean analysis report.

module nova_tests.plan100_8.consume_analyze_coverage_report

type Token consume { id int }

fn Token consume @use_token() -> () { () }
fn Token consume @discard_token() -> () { () }

fn make_token(id int) -> Token => { id }

fn process_tokens() Fail[str] -> () {
    consume t1 = make_token(1)
    errdefer { t1.discard_token() }
    t1.use_token()
}

test "consume-analyze: coverage report — all bindings covered" {
    process_tokens()
}
