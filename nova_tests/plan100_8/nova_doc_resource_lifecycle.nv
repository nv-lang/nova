// Plan 100.8 (D166) pos #6: nova doc renders Resource lifecycle section.
//
// Expected `nova doc` output for `DbConn` type:
//   #### Resource lifecycle
//   This type is **consume-typed** (D133). Every binding of type `DbConn`
//   **must** be consumed before its scope exits:
//   - Call a **consume-method** ...
//   - Pass as a **consume-parameter** ...
//   - Cover error/success paths via `errdefer` / `okdefer` (D160)
//   Failure to consume results in a compile error (`D133-not-consumed`).
//
// This fixture verifies: consume type with multiple methods compiles clean.

module nova_tests.plan100_8.nova_doc_resource_lifecycle

/// Database connection — consume-typed to ensure proper cleanup.
///
/// ## Resource lifecycle
///
/// Always pair `begin_tx()` with either `commit()` (success) or
/// `rollback()` (failure). Use `errdefer { conn.rollback() }` to
/// ensure cleanup on all paths.
type DbConn consume { id int; url str }

/// Commit and release the connection.
fn DbConn consume @commit() -> () { () }

/// Rollback and release the connection.
fn DbConn consume @rollback() -> () { () }

fn connect(url str) -> DbConn => { id: 1; url }

fn perform_query(url str) Fail[str] -> () {
    consume conn = connect(url)
    errdefer { conn.rollback() }
    conn.commit()
}

test "Resource lifecycle section — consume type with errdefer/commit" {
    perform_query("postgres://localhost/db")
}
