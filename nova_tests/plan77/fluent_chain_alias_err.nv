// EXPECT_COMPILE_ERROR D131
//
// Plan 77 (D132) + Plan 73 (D131): builder-chain alias.
// `append` объявлен `-> @` → `let sb2 = sb.append(...)` делает `sb2`
// алиасом `sb`. consume через `sb2` инвалидирует и `sb`.

module nova_tests.plan77.fluent_chain_alias_err

test "use after consume через builder-chain alias" {
    let sb = StringBuilder.new()
    let sb2 = sb.append("a")   // sb2 — алиас sb (append: -> @)
    let s = sb2.as_str()       // consume через alias
    sb.append("b")             // ОШИБКА D131: sb — алиас потреблённого
    assert(s == "a")
}
