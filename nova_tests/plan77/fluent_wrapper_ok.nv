// Plan 77 (D132) amendment: wrapper-метод `-> @` правильно делегирует
// в другой `-> @` метод. StringBuilder.@append chain — эталонный пример.
// Plan 91 followup: @plus убран, заменён на explicit .append() chain.

module plan77.fluent_wrapper_ok

type Buf { mut n int }

fn Buf.new() -> Buf => { n: 0 }

fn Buf mut @write() -> @ {
    @n = @n + 1
    @
}

// Правильно: wrapper объявлен `-> @`, делегирует во fluent `-> @`.
fn Buf mut @push() -> @ => @write()

test "fluent wrapper -> @ делегирует в -> @" {
    mut b = Buf.new()
    ro r = b.push().push().push()
    assert(r.n == 3)
}

test "StringBuilder @append -> @ chain" {
    consume sb = StringBuilder.new()
    ro s = sb.append("hello").append(" ").append("world").as_str()
    assert(s == "hello world")
}
