// перестаёт распознаваться как folder-module (`is_folder_module_dir`
// требует идентичных decl) → каждый peer проверяется как single-file
// и проваливает manifest check (rev-3 ожидает `folder_inconsistent_decl.alpha`).

module folder_inconsistent_decl.alpha

export fn alpha_fn() -> int =>
    1

test "unreachable — manifest mismatch" {
    assert(alpha_fn() == 1)
}
