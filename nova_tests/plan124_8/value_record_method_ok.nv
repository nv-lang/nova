// Plan 124.8 — positive: methods on value-record.
module nova_tests.plan124_8

type Vec311 value {
    x f64
    y f64
    z f64
}

fn Vec311.new(a f64, b f64, c f64) -> Vec311 =>
    { x: a, y: b, z: c }

fn Vec311 @magnitude_sq() -> f64 =>
    @x * @x + @y * @y + @z * @z

test "method on value-record works" {
    ro v = Vec311.new(1.0, 2.0, 2.0)
    assert(v.magnitude_sq() == 9.0)
}
