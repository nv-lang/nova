// Plan 124.8 — positive: methods on value-record.
module plan124_8.value_record_method_ok

type Vec3 value {
    x f64
    y f64
    z f64
}

fn Vec3.new(a f64, b f64, c f64) -> Vec3 =>
    { x: a, y: b, z: c }

fn Vec3 @magnitude_sq() -> f64 =>
    @x * @x + @y * @y + @z * @z

test "method on value-record works" {
    ro v = Vec3.new(1.0, 2.0, 2.0)
    assert(v.magnitude_sq() == 9.0)
}
