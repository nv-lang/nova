// Plan 124.8 [M-124.8-tuple-mut-field-write-codegen] — positive:
// tuple field write + method call read sequence — verifies that field
// mutation is visible через method-pointer receiver.
module plan124_8.tuple_mut_field_method_call_ok

type Vec2(x f64, y f64)

fn Vec2 @magnitude_sq() -> f64 =>
    @x * @x + @y * @y

test "mut tuple field write then method read picks up new value" {
    mut v = Vec2(x: 3.0, y: 4.0)
    assert(v.magnitude_sq() == 25.0)
    v.x = 5.0
    v.y = 12.0
    assert(v.magnitude_sq() == 169.0)
}
