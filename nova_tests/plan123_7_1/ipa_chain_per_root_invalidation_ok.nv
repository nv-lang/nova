// Plan 123.7.1 T4.1 (V4.1 per-root): chain cache survives writes
// to UNRELATED root fields.

module nova_tests.plan123_7_1

type Inner {
    ro v int
}

type Outer3 {
    ro inner Inner
    mut tag int
}

fn Outer3 mut @sum_with_tag_bump() -> int {
    // V4 conservative: @tag = ... → skips chain cache for @inner.v.
    // V4.1 per-root: @tag write doesn't touch @inner subtree →
    // chain @inner.v survives.
    ro a = @inner.v + @inner.v
    @tag = @tag + 1
    a + @inner.v + @inner.v
}

fn Outer3.new(v int, t int) -> Outer3 {
    Outer3 { inner: Inner { v }, tag: t }
}

test "V4.1 per-root: chain survives unrelated root write" {
    mut o = Outer3.new(5, 0)
    ro r = o.sum_with_tag_bump()
    // 4 reads of @inner.v=5 → 20.
    assert(r == 20)
}
