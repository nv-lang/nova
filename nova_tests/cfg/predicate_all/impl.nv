// Plan 42.16 Ф.1: peer с #cfg операторами — вложенные || && !.
// (target_os = win || linux || macos) && !target_os = freebsd =
//   "одна из 3 поддерживаемых OS" AND "не freebsd" = true на всех 3.
// Проверяет precedence + скобки: группа || внутри &&, унарный !.

#cfg((target_os = "windows" || target_os = "linux" || target_os = "macos") && !target_os = "freebsd")
module predicate_all.impl

export fn gated_value() -> int =>
    99
