// EXPECT_COMPILE_ERROR D162
//
// Plan 100.4.5 (D162): failable fn + consume + explicit consume на success-path
// но НЕТ errdefer → D162-uncovered-error-path (throw before commit leaks).

module nova_tests.plan100_4_5.neg_failable_consume_explicit_only_no_errdefer

type Connection consume { fd int }

fn Connection consume @disconnect() -> () { () }

fn connect() -> Connection => { fd: 1 }

// ❌ failable + consume + explicit но НЕТ errdefer
fn process() Fail -> () {
    consume c = connect()
    c.disconnect()   // happens-IF-no-throw; throw earlier leaks c
}

test "failable + consume + explicit-only без errdefer — D162 error" {
    process()
}
