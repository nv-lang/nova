// Plan 100.4.5 (D162): infallible function + consume binding + explicit
// commit. D162 не fires когда нет Fail в sig (только failable functions
// требуют errdefer cover error-path).

module nova_tests.plan100_4_5.consume_no_fail_just_commit_ok

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }

fn begin() -> Transaction => { id: 1 }

fn process() -> () {
    consume tx = begin()
    tx.commit()   // no Fail in sig, no D162 enforcement
}

test "infallible fn + consume — D162 не fires" {
    process()
}
