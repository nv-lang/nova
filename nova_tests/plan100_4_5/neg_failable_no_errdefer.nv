// EXPECT_COMPILE_ERROR D162-uncovered-error-path
//
// Plan 100.4.5 (D162): failable function с consume binding но БЕЗ errdefer —
// error D162-uncovered-error-path. На throw consume будет leaked.

module nova_tests.plan100_4_5.neg_failable_no_errdefer

type Transaction consume {
    id int,
}

fn Transaction consume @commit() -> () { () }
fn Transaction consume @rollback() -> () { () }

fn begin() -> Transaction => { id: 1 }

// ❌ failable + consume + НЕТ errdefer
fn process() Fail -> () {
    consume tx = begin()
    tx.commit()   // D162-uncovered-error-path: throw before commit leaks tx
}

test "failable fn без errdefer cover — D162 error" {
    process()
}
