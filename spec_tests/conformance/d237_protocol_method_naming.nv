// D237 — Protocol naming convention: protocol name = capitalized method name.
// Norm (spec/decisions/02-types.md §D237, Plan 137): prelude protocols are named so
// that the protocol's identifier is the capitalized form of its single @-method:
//   `Equal`   ⟺ method `@equal`
//   `Compare` ⟺ method `@compare`
// The Plan-137 rename amend fixed the post-rename names: `Equal.@equal`, `Compare.@compare`
// (and `Equal`'s default-body form `@equal => @compare(other) == 0`, D183 amend).
// This test exercises the POS, runtime-observable side of the convention: a user type
// implementing the renamed methods under their D237 spellings is satisfied, and the
// `@equal` method drives the ==/!= operators. Both renamed protocols are covered:
//   • `@equal` (Equal) — directly drives ==/!= ; the METHOD BODY decides equality.
//   • `@compare` (Compare) — callable as a method AND, written together with the
//     `Equal` default-body form `@equal => @compare(other) == 0`, drives ==/!= too.
// Part of the SINGLE `spec_tests.conformance` folder-module; D-prefixed unique type names
// avoid duplicate-top-level-name clashes.
module spec_tests.conformance

// (1) Renamed method `@equal` (the `Equal` protocol method per D237's table).
// Implementing it directly synthesizes the ==/!= operators. `@equal` deliberately
// ignores `tag` so we observe the METHOD BODY — not pointer/struct identity — decides ==.
type D237Keyed {
    k int
    tag int
}

fn D237Keyed @equal(other D237Keyed) -> bool => @k == other.k

// (2) Renamed method `@compare` (the `Compare` protocol method per D237's table),
// paired with the `Equal` default-body spelling `@equal => @compare(other) == 0`.
// Both post-D237 method names appear; `@compare` is callable directly and `@equal`
// (defined via @compare) drives ==/!=.
type D237Money {
    cents int
}

fn D237Money @compare(other D237Money) -> int =>
    if @cents < other.cents { -1 }
    else if @cents > other.cents { 1 }
    else { 0 }

fn D237Money @equal(other D237Money) -> bool => @compare(other) == 0

test "renamed `@equal` method (Equal) drives ==/!= ; body decides equality (D237)" {
    ro a = D237Keyed { k: 5, tag: 100 }
    ro b = D237Keyed { k: 5, tag: 999 }
    ro c = D237Keyed { k: 6, tag: 100 }
    assert(a == b)        // same k, tag ignored by @equal body
    assert(!(a == c))     // different k
    assert(a != c)        // != is the synthesized negation of @equal
    assert(!(a != b))
}

test "renamed `@compare` method (Compare) is callable and orders correctly (D237)" {
    ro a = D237Money { cents: 250 }
    ro b = D237Money { cents: 999 }
    ro c = D237Money { cents: 250 }
    assert(a.compare(b) < 0)     // 250 < 999
    assert(b.compare(a) > 0)     // 999 > 250
    assert(a.compare(c) == 0)    // 250 == 250
}

test "`@equal` defined via `@compare(other) == 0` drives ==/!= (D237 + D183 default body)" {
    ro a = D237Money { cents: 250 }
    ro b = D237Money { cents: 250 }
    ro c = D237Money { cents: 999 }
    assert(a == b)        // @compare == 0 → equal
    assert(a != c)        // @compare != 0 → not equal
    assert(!(a == c))
    assert(!(b != a))
}
