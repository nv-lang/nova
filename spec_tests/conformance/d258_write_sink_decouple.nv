// D258 — Write-sink protocol: decouple Display/Debug from the concrete StringBuilder.
// Norm (spec/decisions/02-types.md §D258, Plan 152.7.1): a thin sink protocol `Write`
// with the single method `mut @write(s str) -> ()` is introduced; `Display.@display`
// and `Debug.@debug` take a `Write` sink (NOT a concrete `StringBuilder`), and
// `StringBuilder` satisfies `Write` via its `@write` method. The decoupling is
// runtime-observable: a user type's `@display(mut w Write)` body — which knows ONLY
// `w.write(...)` — is sink-agnostic, so it yields the SAME text whether driven by
// (a) the implicit interpolation sink (`"${x}"`) or (b) an explicitly-constructed
// `StringBuilder` passed as the `Write` argument (`x.display(sb)`). The latter is the
// load-bearing D258 angle: `StringBuilder` is accepted where a `Write` is expected,
// proving the parameter is the protocol, not the concrete sink.
// Part of the SINGLE `spec_tests.conformance` folder-module; D-prefixed unique type
// names avoid duplicate-top-level-name clashes.
module spec_tests.conformance

// User type with a MANUAL @display written against the `Write` sink protocol (D258).
// The body never names `StringBuilder` — it only calls `w.write(...)`, so it is
// sink-agnostic by construction. This is exactly the decoupling D258 introduces.
type D258Pair { lo int, hi int }

fn D258Pair @display(mut w Write) -> () {
    w.write("[")
    w.write(str.from(@lo))
    w.write("..")
    w.write(str.from(@hi))
    w.write("]")
}

test "Display.@display routes through the Write sink — interpolation drives `w.write` (D258)" {
    ro p = D258Pair { lo: 3, hi: 9 }
    // `"${p}"` mounts the implicit sink and drives the SAME @display body.
    assert("${p}" == "[3..9]")
    ro q = D258Pair { lo: 0, hi: 0 }
    assert("${q}" == "[0..0]")
}

test "StringBuilder satisfies Write — same @display body driven by an explicit sink (D258)" {
    ro p = D258Pair { lo: 3, hi: 9 }
    // Build a concrete StringBuilder and pass IT where a `Write` is expected.
    // This compiles only because `StringBuilder` satisfies `Write` (via `@write`),
    // and `@display`'s parameter is the `Write` protocol — the D258 decoupling.
    consume sb = StringBuilder.new()
    p.display(sb)
    ro got = sb.into_str()
    // Identical to the interpolation result above ⇒ sink-agnostic body.
    assert(got == "[3..9]")
    assert(got == "${p}")
}

test "Write.@write appends in order — StringBuilder is a faithful Write sink (D258)" {
    // Drive the Write protocol method directly on the concrete sink: each `@write`
    // appends its argument in order, matching the byte-sink delegation in the norm.
    consume sb = StringBuilder.new()
    sb.write("a")
    sb.write("bc")
    sb.write("")
    sb.write("d")
    assert(sb.into_str() == "abcd")
}
