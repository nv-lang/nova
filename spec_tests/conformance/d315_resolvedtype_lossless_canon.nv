// D315 — `ResolvedType` is the SINGLE canonical carrier of type identity: it carries the
// FULL semantic identity (resolved identity, generic-args, Scalar{width,signed,wide_default},
// effects, the 3 mutability axes, pointer-modifier fidelity). `type_ref_to_c` is retired in
// favour of ONE lowering (`resolved_type_to_c`). The observable consequence pinned here:
// width/sign is LOSSLESS — `Vec[u32]` and `Vec[u8]` do NOT mis-mangle into a shared
// `nova_int`-erased carrier (the very `Vec[u32]` mis-mangling class D315 kills at the root),
// and an alias (`int`≡`i64`) canonicalizes so semantically-equal types stay value-equal.
// Spec: spec/decisions/02-types.md:13215 (D315). Part of the SINGLE `spec_tests.conformance`
// folder-module (one CU). D-prefixed names avoid clashes across D-files.
module spec_tests.conformance

test "distinct Vec element widths do NOT collapse — u32 and u8 stay lossless (D315)" {
    mut a []u32 = [1, 2, 3]
    assert(a[0] == 1)
    assert(a[2] == 3)
    mut b []u8 = [4, 5]
    assert(b[0] == 4)
    assert(b[1] == 5)
    // Both Vecs coexist in one CU; if `Vec[u32]`/`Vec[u8]` mis-mangled into a shared
    // nova_int-erased carrier (the D315 drift class), element values would corrupt.
    assert(a.len() == 3)
    assert(b.len() == 2)
}

test "top-of-width u32 element round-trips, not sign-flipped or truncated (D315)" {
    mut a []u32 = [4294967295, 0]   // u32::MAX then 0
    assert(a[0] == 4294967295)      // unsigned 32-bit max preserved (signed-collapse → -1)
    assert(a[1] == 0)
    assert(a[0] > a[1])
}

test "alias canonicalizes — int and i64 are the SAME canonical ResolvedType (D315)" {
    ro x int = 5
    ro y i64 = x        // `int` alias normalized to `i64` carrier — assignable, no width drift
    assert(x == y)      // semantically-equal types → structurally-equal carrier → value-equal
    assert(y == 5)
}