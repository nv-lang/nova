// D32 — Parameter-passing semantics. Records (managed heap) pass BY REFERENCE: a `mut`
// record param means field-mutations inside the function are VISIBLE to the caller. Primitives
// (`int`, …) pass BY VALUE in a register: a `mut` primitive param is a local copy whose
// reassignment is NOT visible to the caller. Matches the two spec examples verbatim:
// `fn deposit(mut acc Account, amount) { acc.balance += amount }` (visible) and
// `fn weird(mut x int) { x = 999 }` (NOT visible). Spec: spec/decisions/02-types.md:2372 (D32).
// Single `spec_tests.conformance` folder-module; D-prefixed names avoid clashes.
module spec_tests.conformance

// Managed-heap record (reference category): passed by reference.
type D32Account {
    balance int
}

// `mut` record param — mutation through the param is visible to the caller (by reference).
fn d32_deposit(mut acc D32Account, amount int) {
    acc.balance += amount
}

// `mut` primitive param — local copy; reassignment is NOT visible to the caller (by value).
fn d32_bump(mut x int) {
    x = 999
}

test "mut record param: caller sees the field mutation (D32, by reference)" {
    mut acc = D32Account { balance: 100 }
    d32_deposit(acc, 50)
    // The record lives on the managed heap and is passed by reference, so the deposit
    // performed inside d32_deposit is observable here.
    assert(acc.balance == 150)
}

test "mut primitive param: caller does NOT see the reassignment (D32, by value)" {
    mut n = 5
    d32_bump(n)
    // `int` is passed by value in a register; d32_bump mutated only its local copy.
    assert(n == 5)
}

test "the two passing modes differ on the SAME call sequence (D32 contrast)" {
    mut acc = D32Account { balance: 10 }
    mut k = 10
    d32_deposit(acc, 5)   // reference: visible
    d32_bump(k)           // value: not visible
    assert(acc.balance == 15)
    assert(k == 10)
}
