// D129 — `int` is an ALIAS for `i64` (64-bit SIGNED integer). Both map to the C-type
// `nova_int` (typedef int64_t). The absence of codegen distinction is INTENTIONAL — a
// bootstrap-invariant, NOT a collapse-bug (contrast D128 char/int, where distinction IS
// needed). This test pins the SIGNED arithmetic semantics and the int ≡ i64 value-equivalence.
module spec_tests.conformance

test "int is SIGNED: negative literals compare and add as signed (D129)" {
    ro a int = -5
    ro b int = 3
    assert(a < b)              // signed: -5 < 3 = true (unsigned would be false)
    assert(a + b == -2)        // signed: -5 + 3 = -2
}

test "int and i64 are interchangeable by value (D129 alias)" {
    ro a int = -5
    ro c i64 = -5
    assert(a == c)             // int ≡ i64 — same nova_int, same value
}
