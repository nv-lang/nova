// 40_detach.nv — D50 `detach { body }` fire-and-forget primitive.
//
// Spec: detach запускает body как fiber переживающий caller'а, привязан
// к глобальному supervisor'у (default LogAndDrop). Требует эффекта Detach
// в сигнатуре.
//
// Bootstrap default-handler = SyncDetach: body исполняется inline в
// потоке caller'а. Этого достаточно чтобы проверить наблюдаемые side-effects
// и совместимость с capture-семантикой.

module spec.detach_test

type Counter {
    mut val int
}

fn make_counter(v int) -> Counter => Counter { val: v }

// ================================================================
// SECTION 1: базовое исполнение
// ================================================================

test "detach: body executes (mutation visible)" {
    let mut x = 0
    detach {
        x = 42
    }
    assert(x == 42)
}

test "detach: empty body is no-op" {
    let mut touched = false
    detach { touched = true }
    assert(touched)
}

test "detach: trailing expr value is discarded (fire-and-forget)" {
    let mut log = 0
    detach {
        log = 7
        99   // discarded
    }
    assert(log == 7)
}

// ================================================================
// SECTION 2: capture
// ================================================================

test "detach: captures immutable int" {
    let n = 21
    let mut result = 0
    detach { result = n * 2 }
    assert(result == 42)
}

test "detach: captures multiple vars" {
    let a = 3
    let b = 5
    let mut c = 0
    detach { c = a * a + b * b }
    assert(c == 34)
}

test "detach: mutates captured record field" {
    let counter = make_counter(10)
    detach {
        counter.val = counter.val + 5
    }
    assert(counter.val == 15)
}

// ================================================================
// SECTION 3: detach + control flow
// ================================================================

test "detach with if inside" {
    let n = 5
    let mut tag = 0
    detach {
        if n > 0 {
            tag = 1
        } else {
            tag = -1
        }
    }
    assert(tag == 1)
}

test "detach with while inside" {
    let mut acc = 0
    detach {
        let mut i = 1
        while i <= 5 {
            acc += i
            i += 1
        }
    }
    assert(acc == 15)
}

// ================================================================
// SECTION 4: detach внутри supervised — НЕ участвует в scope queue
// ================================================================

test "detach inside supervised: runs but not part of scope schedule" {
    // detach живёт мимо scope. В bootstrap-SyncDetach он исполняется inline
    // в той точке где встречен — то есть до того как supervised закроется.
    // Пишем порядок выполнения через encoded log.
    let mut log = 0
    supervised {
        log = log * 10 + 1   // before any spawn
        detach {
            log = log * 10 + 2   // inline before spawn queue runs
        }
        spawn {
            log = log * 10 + 3
            Time.sleep(0)
            log = log * 10 + 5
        }
        spawn {
            log = log * 10 + 4
            Time.sleep(0)
            log = log * 10 + 6
        }
    }
    // Order: 1 (sync), 2 (detach inline), then supervised runs queue:
    //   spawn A: 3, yield → spawn B: 4, yield → A: 5 → B: 6
    // Encoded: 1,2,3,4,5,6 → 123456
    assert(log == 123456)
}

// ================================================================
// SECTION 5: nested detach
// ================================================================

test "detach inside detach: both run inline" {
    let mut order = 0
    detach {
        order = order * 10 + 1
        detach {
            order = order * 10 + 2
        }
        order = order * 10 + 3
    }
    // 1, 2 (inner detach inline), 3 → 123
    assert(order == 123)
}

test "detach: multiple detaches preserve sequential order" {
    let mut log = 0
    detach { log = log * 10 + 1 }
    detach { log = log * 10 + 2 }
    detach { log = log * 10 + 3 }
    assert(log == 123)
}

// ================================================================
// SECTION 6: detach + records, arrays
// ================================================================

test "detach mutates array via captured ref" {
    let mut sum = 0
    let xs = [10, 20, 30]
    detach {
        let mut i = 0
        while i < 3 {
            sum += xs[i]
            i += 1
        }
    }
    assert(sum == 60)
}

test "detach can be used outside any scope (unlike spawn-without-supervised)" {
    // detach по спеке D50 не требует scope. Spawn вне supervised — legacy
    // (по спеке должна быть compile error). Detach же привязан к глобальному
    // supervisor'у, поэтому валиден везде где вызывается функция с эффектом
    // Detach в сигнатуре. В bootstrap'е эффект-проверка отключена, так что
    // detach просто работает где угодно.
    let mut x = 100
    detach { x = x + 1 }
    detach { x = x * 2 }
    assert(x == 202)
}
