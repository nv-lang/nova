// 52_cancel_scope.nv — D75 manual structured cancellation.
//
// `cancel_scope { tok => body }` — supervised-scope с first-class
// CancelToken'ом. Через tok.cancel() можно изнутри (или, в production —
// извне через bind) принудительно валить scope: остальные fiber'ы
// на следующем yield-point бросят "scope cancelled" (механизм D71
// cancel_requested), scope-runner re-throw'ит на main flow.
//
// Возможности token (D75):
//   - tok.cancel()        — пометить scope как cancelled (idempotent)
//   - tok.is_cancelled()  — проверка флага без yield
//   - tok.bind(other)     — связать с родительским kill-switch
//                            (cancel(other) → cancel(self))

module spec.cancel_scope_test

// ================================================================
// SECTION 1: cancel_scope без вызова cancel ≡ supervised
// ================================================================

test "cancel_scope без cancel — все fiber'ы выполняются" {
    let mut sum = 0
    cancel_scope { tok =>
        spawn { sum += 1 }
        spawn { sum += 2 }
        spawn { sum += 4 }
    }
    assert(sum == 7)
}

test "cancel_scope: is_cancelled false по умолчанию" {
    let mut got_false = false
    cancel_scope { tok =>
        spawn {
            let cancelled = tok.is_cancelled()
            if !cancelled {
                got_false = true
            }
        }
    }
    assert(got_false)
}

// ================================================================
// SECTION 2: tok.cancel() изнутри — отмена peer-fiber'ов
// ================================================================

test "tok.cancel() изнутри — peer на следующем yield не выполняется" {
    // FIFO: spawn0 первый, делает cancel; spawn1 на yield видит cancel и throw.
    // throw в spawn1 поймает spawn-entry fail-frame; peer_completed не
    // успеет выставиться. Note: re-throw на main приходит как nova_throw
    // (без user handler — design D71 cooperative cancellation), поэтому
    // оборачиваем в with Fail чтобы тест не abort'нулся.
    let mut peer_completed = false
    with Fail = handler Fail {
        fail(_msg) {
            return ()
        }
    } {
        cancel_scope { tok =>
            spawn { tok.cancel() }
            spawn {
                Time.sleep(0)            // первый yield — cancel detected
                peer_completed = true    // не должно
            }
        }
    }
    assert(!peer_completed)
}

// ================================================================
// SECTION 3: повторный cancel — idempotent
// ================================================================

test "double cancel — idempotent, no panic" {
    let mut hits = 0
    cancel_scope { tok =>
        spawn {
            tok.cancel()
            tok.cancel()       // второй — no-op
            hits += 1
        }
    }
    assert(hits == 1)
}

// ================================================================
// SECTION 4: is_cancelled() меняется после cancel()
// ================================================================

test "is_cancelled() reflects cancel state within same fiber" {
    let mut before = false
    let mut after = false
    cancel_scope { tok =>
        spawn {
            before = tok.is_cancelled()    // false
            tok.cancel()
            after = tok.is_cancelled()     // true
        }
    }
    assert(!before)
    assert(after)
}

// ================================================================
// SECTION 5: bind — каскадная отмена
// ================================================================

test "bind: cancel parent — child.is_cancelled() observable без yield" {
    // Без yield нельзя триггернуть scope-cancel-throw, поэтому проверяем
    // is_cancelled() сразу после parent.cancel() — каскад уже сработал.
    let mut child_was_cancelled = false
    cancel_scope { parent =>
        spawn {
            cancel_scope { child =>
                child.bind(parent)
                spawn {
                    parent.cancel()
                    // Без yield — мы остаёмся на этом fiber'е.
                    child_was_cancelled = child.is_cancelled()
                }
            }
        }
    }
    assert(child_was_cancelled)
}
