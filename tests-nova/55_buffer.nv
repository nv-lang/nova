// 55_buffer.nv — Q-buffer: mutable byte accumulator для строк и сырых данных.
//
// Buffer унифицирует bytes-buffer и string-builder в один тип. API:
//   Buffer.new(), Buffer.with_capacity(n), Buffer.from(s str), Buffer.from(b []byte)
//   buf.add_str(s), buf.add_bytes(b), buf.add_byte(byte), buf.add_char(cp)
//   buf.len(), buf.capacity(), buf.clone()
//   buf.into() -> []byte (consume)
//   buf.try_into() -> str (Fail при невалидном UTF-8) — consume
//   buf.into_str_unchecked() -> str (без проверки) — consume
//
// После consume любой add_* → runtime panic "buffer consumed".

module spec.buffer

// ================================================================
// SECTION 1: создание + базовая аккумуляция
// ================================================================

test "Buffer.new() — empty buffer" {
    let buf = Buffer.new()
    assert(buf.len() == 0)
    assert(buf.capacity() >= 16)   // initial capacity 16
}

test "Buffer.with_capacity(64) — explicit capacity" {
    let buf = Buffer.with_capacity(64)
    assert(buf.len() == 0)
    assert(buf.capacity() >= 64)
}

test "Buffer.from(s) — copy of string bytes" {
    let buf = Buffer.from("hello")
    assert(buf.len() == 5)
}

test "add_str — accumulate strings" {
    let mut buf = Buffer.new()
    buf.add_str("hello")
    buf.add_str(" ")
    buf.add_str("world")
    assert(buf.len() == 11)
}

test "add_byte — single byte" {
    let mut buf = Buffer.new()
    buf.add_byte(65)    // 'A'
    buf.add_byte(66)    // 'B'
    buf.add_byte(67)    // 'C'
    assert(buf.len() == 3)
}

// ================================================================
// SECTION 2: финализация в str через try_into
// ================================================================

test "try_into — valid UTF-8 returns string" {
    let mut buf = Buffer.new()
    buf.add_str("hello world")
    let s = buf.try_into()
    assert(s == "hello world")
}

test "try_into — accumulate then finalize" {
    let mut buf = Buffer.new()
    let mut i = 0
    while i < 10 {
        buf.add_str("x")
        i = i + 1
    }
    let s = buf.try_into()
    assert(s == "xxxxxxxxxx")
}

test "into_str_unchecked — same content, no validation" {
    let mut buf = Buffer.new()
    buf.add_str("hello")
    let s = buf.into_str_unchecked()
    assert(s == "hello")
}

// ================================================================
// SECTION 3: финализация в []byte через into
// ================================================================

test "into() returns []byte with same content" {
    let mut buf = Buffer.new()
    buf.add_byte(72)    // 'H'
    buf.add_byte(105)   // 'i'
    let bytes = buf.into()
    assert(bytes[0] == 72)
    assert(bytes[1] == 105)
}

// ================================================================
// SECTION 4: грow strategy — capacity увеличивается
// ================================================================

test "capacity grows past initial 16" {
    let mut buf = Buffer.new()
    let initial_cap = buf.capacity()
    let mut i = 0
    while i < 100 {
        buf.add_byte(65)
        i = i + 1
    }
    assert(buf.len() == 100)
    assert(buf.capacity() > initial_cap)
}

// ================================================================
// SECTION 5: clone — independent snapshot
// ================================================================

test "clone — independent buffer" {
    let mut buf1 = Buffer.new()
    buf1.add_str("hello")
    let mut buf2 = buf1.clone()
    buf2.add_str(" world")
    assert(buf1.len() == 5)        // оригинал не изменился
    assert(buf2.len() == 11)       // клон вырос
}

// ================================================================
// SECTION 6: add_char UTF-8 encoding
// ================================================================

test "add_char ASCII (1 byte)" {
    let mut buf = Buffer.new()
    buf.add_char(65)        // 'A' — 1 byte
    assert(buf.len() == 1)
}

test "add_char Cyrillic (2 bytes)" {
    let mut buf = Buffer.new()
    buf.add_char(1040)      // 'А' (Cyrillic) — 2 bytes UTF-8
    assert(buf.len() == 2)
}

test "add_char emoji (4 bytes)" {
    let mut buf = Buffer.new()
    buf.add_char(128512)    // 😀 — 4 bytes UTF-8
    assert(buf.len() == 4)
}

// ================================================================
// SECTION 7: hot-loop pattern — много add_str
// ================================================================

test "hot-loop accumulation (1000 add_str)" {
    let mut buf = Buffer.with_capacity(2048)
    let mut i = 0
    while i < 1000 {
        buf.add_str("x")
        i = i + 1
    }
    assert(buf.len() == 1000)
    let s = buf.try_into()
    assert(s.len == 1000)
}
