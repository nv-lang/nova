// 15_trailing_block.nv — trailing-block syntax (D43).
//
// f(args) { body } — блок-аргумент за () вызова. Это НЕ лямбда (лямбда —
// строго `=> expr`), а самостоятельная грамматика.

module spec.trailing_block

fn run(body fn() -> int) -> int => body()

fn run_with(x int, body fn(int) -> int) -> int => body(x)

fn run_two(a int, b int, body fn(int, int) -> int) -> int => body(a, b)

test "trailing-block без параметров" {
    let v = run() {
        let x = 10
        x + 5
    }
    assert(v == 15)
}

test "trailing-block с одним параметром" {
    let v = run_with(7) { n =>
        n * n
    }
    assert(v == 49)
}

test "trailing-block с несколькими параметрами" {
    let v = run_two(3, 4) { (a, b) =>
        a * a + b * b
    }
    assert(v == 25)
}

test "trailing-block с let'ами внутри" {
    let v = run() {
        let a = 5
        let b = 10
        let c = a * b
        c + 1
    }
    assert(v == 51)
}

test "trailing-block с if внутри" {
    let v = run_with(5) { n =>
        if n > 0 {
            n * 2
        } else {
            0
        }
    }
    assert(v == 10)
}
