// 26_match_advanced.nv — продвинутые match-паттерны.
//
// 08_pattern_matching.nv покрыл базу. Здесь — глубокая вложенность,
// match по строкам/bool/tuple, комбинации Option/Result.

module spec.match_adv

test "match по строке" {
    let cmd = "stop"
    let r = match cmd {
        "start" => 1
        "stop"  => 2
        "pause" => 3
        _       => 0
    }
    assert(r == 2)
}

test "match по bool" {
    let r = match true {
        true  => "yes"
        false => "no"
    }
    assert(r == "yes")
}

test "match с literal-pattern в первой позиции" {
    let p = (1, 2, 3)
    let s = match p {
        (1, _, c) => c
        (_, _, _) => 0
    }
    assert(s == 3)
}

test "вложенный tuple-pattern" {
    let nested = ((1, 2), (3, 4))
    let r = match nested {
        ((a, b), (c, d)) => a + b + c + d
    }
    assert(r == 10)
}

test "глубоко вложенный Option" {
    let x = Some(Some(Some(42)))
    let v = match x {
        Some(Some(Some(n))) => n
        _                    => -1
    }
    assert(v == 42)
}

test "Result с Option payload" {
    let x = Ok(Some(7))
    let v = match x {
        Ok(Some(n)) => n
        Ok(None)    => 0
        Err(_)      => -1
    }
    assert(v == 7)
}

test "Option-Option None во внутренней позиции" {
    let x = Some(None)
    let v = match x {
        Some(Some(n)) => n
        Some(None)    => -2
        None          => -3
    }
    assert(v == -2)
}

test "guards в комбинации с tuple-pattern" {
    let p = (10, 20)
    let r = match p {
        (a, b) if a > b => "first"
        (a, b) if a < b => "second"
        _                => "equal"
    }
    assert(r == "second")
}

test "guards с reference на bound name" {
    let n = 7
    let r = match n {
        x if x < 0  => "neg"
        x if x == 0 => "zero"
        x if x < 10 => "small"
        _           => "big"
    }
    assert(r == "small")
}

test "match в let RHS" {
    let opt = Some(5)
    let v = match opt {
        Some(n) => n * 2
        None    => 0
    }
    assert(v == 10)
}

test "match в условии if" {
    let x = Ok(42)
    let valid = match x {
        Ok(n)  => n > 0
        Err(_) => false
    }
    assert(valid)
}

test "wildcard остаётся last (исчерпывающий)" {
    let n = 100
    let kind = match n {
        0  => "zero"
        1  => "one"
        _  => "many"
    }
    assert(kind == "many")
}
