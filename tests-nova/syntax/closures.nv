// 21_closures.nv — лямбды, closures, функции как значения.
//
// В 05_functions.nv покрыты только базовые лямбды. Здесь — захват
// окружения, возврат функции, передача функции как параметра.

module nova_tests.syntax.closures

fn make_adder(n int) -> fn(int) -> int {
    (x) => x + n
}

fn apply_twice(f fn(int) -> int, x int) -> int {
    f(f(x))
}

fn compose(f fn(int) -> int, g fn(int) -> int) -> fn(int) -> int {
    (x) => f(g(x))
}

test "closure захватывает параметр функции" {
    let add5 = make_adder(5)
    let add10 = make_adder(10)
    assert(add5(3) == 8)
    assert(add10(3) == 13)
}

test "независимые closure'ы не влияют друг на друга" {
    let a = make_adder(1)
    let b = make_adder(100)
    assert(a(0) == 1)
    assert(b(0) == 100)
    assert(a(0) == 1)
}

test "функция как параметр" {
    let r = apply_twice((x) => x * 2, 3)
    assert(r == 12)
}

test "lambda inline на let" {
    let sq = (x) => x * x
    assert(sq(7) == 49)
    assert(sq(0) == 0)
}

test "композиция функций" {
    let inc = (x) => x + 1
    let dbl = (x) => x * 2
    let f = compose(inc, dbl)
    assert(f(3) == 7)
}

test "closure захватывает локальную let" {
    let factor = 3
    let mul = (x) => x * factor
    assert(mul(4) == 12)
}

test "closure возвращается из block" {
    let f = {
        let n = 42
        (x) => x + n
    }
    assert(f(8) == 50)
}
