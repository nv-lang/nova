// bitwise.nv — D-operators (spec/03-syntax.md): bit-and, bit-or,
// bit-xor, shift-left, shift-right.

module nova_tests.types.bitwise

// ================================================================
// SECTION 1: AND `&`
// ================================================================

test "bit-and: basic" {
    assert((0xF0 & 0x0F) == 0)
    assert((0xFF & 0x0F) == 0x0F)
    assert((0xAB & 0xCD) == 0x89)
}

test "bit-and: zero is identity for nonexistent bits" {
    assert((42 & 0) == 0)
    assert((0 & 42) == 0)
}

test "bit-and: all-ones identity" {
    assert((0x12345678 & -1) == 0x12345678)
}

// ================================================================
// SECTION 2: OR `|`
// ================================================================

test "bit-or: basic" {
    assert((0xF0 | 0x0F) == 0xFF)
    assert((0x55 | 0xAA) == 0xFF)
    assert((0x12 | 0x34) == 0x36)
}

test "bit-or: zero is identity" {
    assert((42 | 0) == 42)
    assert((0 | 42) == 42)
}

// ================================================================
// SECTION 3: XOR `^`
// ================================================================

test "bit-xor: basic" {
    assert((0xFF ^ 0xF0) == 0x0F)
    assert((0xAA ^ 0x55) == 0xFF)
    assert((0xFF ^ 0xFF) == 0)
}

test "bit-xor: self-inverse" {
    let v = 0xDEAD
    assert((v ^ v) == 0)
}

test "bit-xor: identity with zero" {
    assert((42 ^ 0) == 42)
}

// ================================================================
// SECTION 4: shift-left `<<`
// ================================================================

test "shl: basic" {
    assert((1 << 0) == 1)
    assert((1 << 1) == 2)
    assert((1 << 4) == 16)
    assert((1 << 8) == 256)
}

test "shl: arbitrary value" {
    assert((3 << 4) == 48)         // 0b11 << 4 = 0b110000
    assert((0xAB << 8) == 0xAB00)
}

// ================================================================
// SECTION 5: shift-right `>>`
// ================================================================

test "shr: basic" {
    assert((256 >> 8) == 1)
    assert((48 >> 4) == 3)
    assert((0xAB00 >> 8) == 0xAB)
}

test "shr: zero" {
    assert((0 >> 5) == 0)
}

// ================================================================
// SECTION 6: Precedence
// ================================================================
// Spec D-operators: |  <  ^  <  &  <  shift  <  +  <  *

test "precedence: + binds tighter than |" {
    // 1 | 2 + 4 = 1 | (2+4) = 1 | 6 = 7
    assert((1 | 2 + 4) == 7)
}

test "precedence: + binds tighter than shift" {
    // Spec D-operators: + (level 11) > shift (level 10).
    // 1 + 1 << 2 = (1 + 1) << 2 = 2 << 2 = 8
    assert((1 + 1 << 2) == 8)
}

test "precedence: & binds tighter than |" {
    // 0xF0 | 0x0F & 0x33 = 0xF0 | (0x0F & 0x33) = 0xF0 | 0x03 = 0xF3
    assert((0xF0 | 0x0F & 0x33) == 0xF3)
}

test "precedence: ^ binds tighter than |" {
    // 0xF0 | 0x0F ^ 0x55 = 0xF0 | (0x0F ^ 0x55) = 0xF0 | 0x5A = 0xFA
    assert((0xF0 | 0x0F ^ 0x55) == 0xFA)
}

test "precedence: & binds tighter than ^" {
    // 0xF0 ^ 0xFF & 0x33 = 0xF0 ^ (0xFF & 0x33) = 0xF0 ^ 0x33 = 0xC3
    assert((0xF0 ^ 0xFF & 0x33) == 0xC3)
}

// ================================================================
// SECTION 7: типичные паттерны (CRC, hash, masking)
// ================================================================

test "byte mask via & 0xFF" {
    let v = 0x12345678
    assert((v & 0xFF) == 0x78)
}

test "extract high byte via >> + &" {
    let v = 0x12345678
    assert(((v >> 24) & 0xFF) == 0x12)
}

test "set bit via |" {
    let mut flags = 0
    flags = flags | 0x04
    flags = flags | 0x10
    assert(flags == 0x14)
}

test "toggle bit via ^" {
    let mut v = 0xFF
    v = v ^ 0x0F
    assert(v == 0xF0)
    v = v ^ 0x0F
    assert(v == 0xFF)
}

test "is even via & 1" {
    assert((42 & 1) == 0)
    assert((43 & 1) == 1)
}
