// 43_supervised_errors.nv — определение ошибок в supervised/spawn.
//
// Спецификация (D50): «один fiber бросил error → scope отменяет
// остальных, перевыбрасывает ошибку наружу». В bootstrap-codegen
// (D71) cancellation propagation НЕ реализована.
//
// Этот файл документирует:
//   1. Что РАБОТАЕТ — обычный pattern через mut-флаг для ошибок
//      бизнес-логики.
//   2. Что НЕ РАБОТАЕТ — `?` оператор и `throw` через границу
//      fiber'а в bootstrap'е (longjmp через границы fiber-стека
//      небезопасен — поэтому fail-frame'ов внутри spawn-body нет).
//   3. Как обнаружить ошибку завершения spawn — через явный
//      mut-флаг "did_succeed" / "had_error" (Go-style).

module spec.supervised_errors

// Простая ad-hoc структура для агрегации статуса fiber'а — не Result
// (prelude занят), просто record с success-флагом.
type FiberStatus {
    ok bool
    value int
    error_msg str
}

fn ok_status(v int) -> FiberStatus => FiberStatus { ok: true, value: v, error_msg: "" }
fn err_status(msg str) -> FiberStatus => FiberStatus { ok: false, value: 0, error_msg: msg }

// ================================================================
// SECTION 1: error-flag pattern — рекомендованный bootstrap-способ
// ================================================================

test "supervised: explicit error-flag pattern (Go-style)" {
    // Каждый spawn пишет в собственный mut-флаг. После scope main
    // агрегирует флаги в общий "did any fail".
    let mut a_ok = true
    let mut b_ok = true
    let mut a_val = 0
    let mut b_val = 0
    supervised {
        spawn {
            // Симулируем validated computation.
            let input = 10
            if input > 0 {
                a_val = input * 2   // success path
            } else {
                a_ok = false        // error path
            }
        }
        spawn {
            let input = -5
            if input > 0 {
                b_val = input * 2
            } else {
                b_ok = false
            }
        }
    }
    let any_failed = !a_ok || !b_ok
    assert(any_failed)         // b пометил себя как failed
    assert(a_ok)
    assert(!b_ok)
    assert(a_val == 20)
    assert(b_val == 0)
}

test "supervised: aggregate FiberStatus across spawns" {
    // Каждый fiber пишет FiberStatus в свою ячейку. После scope-exit
    // main собирает их.
    let mut r1 = ok_status(0)
    let mut r2 = ok_status(0)
    supervised {
        spawn {
            let x = 7
            if x > 0 {
                r1 = ok_status(x * x)   // 49
            } else {
                r1 = err_status("non-positive input")
            }
        }
        spawn {
            let y = 0
            if y > 0 {
                r2 = ok_status(y * y)
            } else {
                r2 = err_status("non-positive input")
            }
        }
    }
    assert(r1.ok)
    assert(r1.value == 49)
    assert(!r2.ok)
    assert(r2.error_msg == "non-positive input")
}

test "supervised: counter of failed fibers" {
    let mut errors = 0
    let mut successes = 0
    supervised {
        let mut i = 0
        while i < 10 {
            let cur = i
            spawn {
                // Чётные считаем "успехом", нечётные — "ошибкой".
                if cur % 2 == 0 {
                    successes += 1
                } else {
                    errors += 1
                }
            }
            i += 1
        }
    }
    assert(successes == 5)   // 0, 2, 4, 6, 8
    assert(errors == 5)      // 1, 3, 5, 7, 9
}

// ================================================================
// SECTION 2: Result через ? — работает на main-flow внутри supervised body
// ================================================================

fn parse_positive(s str) -> Result {
    if s == "ok" { return Ok(42) }
    Err("not 'ok'")
}

fn use_parse(s str) -> Result {
    let v = parse_positive(s)?       // ? на Result работает в обычном коде
    Ok(v + 1)
}

test "supervised body: Result via match works on main-flow" {
    // Result + match на main-flow внутри supervised — обычный код.
    let mut got_err = false
    let mut got_val = 0
    supervised {
        let r = use_parse("ok")
        let v = match r {
            Ok(n)  => n
            Err(_) => -1
        }
        if v < 0 { got_err = true } else { got_val = v }
    }
    assert(!got_err)
    assert(got_val == 43)
}

test "supervised body: Result match — error path" {
    let mut got_err = false
    supervised {
        let r = use_parse("bad")
        let v = match r {
            Ok(_)  => 0
            Err(_) => -1
        }
        if v < 0 { got_err = true }
    }
    assert(got_err)
}

// ================================================================
// SECTION 3: error early-exit через флаг + skip остальных шагов
// ================================================================

test "supervised: early-stop pattern via shared error flag" {
    // Pattern: каждый spawn перед работой проверяет shared флаг
    // `aborted`. Первый, кто встретит ошибку, ставит aborted = true,
    // остальные skip'ают. (Это manual cancel, не язык-уровень.)
    let mut aborted = false
    let mut work_done = 0

    supervised {
        spawn {
            if !aborted {
                let bad_input = -1
                if bad_input < 0 {
                    aborted = true   // ошибка → tell others
                } else {
                    work_done += 1
                }
            }
        }
        spawn {
            // Этот spawn запустится ПОСЛЕ первого (FIFO, без yield).
            // К моменту запуска aborted уже true → skip.
            if !aborted {
                work_done += 1   // не выполнится
            }
        }
        spawn {
            if !aborted {
                work_done += 1   // не выполнится
            }
        }
    }
    assert(aborted)
    assert(work_done == 0)   // первый fiber аборт'нул, остальные пропустили
}

// ================================================================
// SECTION 4: ограничения bootstrap'а (документация)
// ================================================================

// СЛЕДУЮЩИЕ pattern'ы НЕ РАБОТАЮТ в bootstrap'е. Закомментированы
// чтобы тестовый файл компилировался; описаны как открытые задачи.
//
// ЧЕГО НЕ ХВАТАЕТ:
//
// (A) `throw` внутри spawn-body НЕ ловится `with Fail` снаружи scope.
//     Причина: longjmp через границу fiber-стека (mco_resume) — UB.
//     Spec D50: «scope отменяет остальных, перевыбрасывает» —
//     требует cancellation propagation, не реализовано.
//
//     // НЕ РАБОТАЕТ:
//     // with Fail = (msg) => caught = true {
//     //     supervised {
//     //         spawn { throw "from fiber" }   // ← abort, не catch
//     //     }
//     // }
//
// (B) `?` оператор внутри spawn-body — fiber выходит с error, но
//     scope НЕ сигнализирует caller'у. Текущий codegen для ?
//     делает longjmp в нижестоящий fail-frame, что fiber-unsafe.
//
//     // НЕ РАБОТАЕТ для определения ошибки в spawn:
//     // supervised {
//     //     spawn { let v = divide(10, 0)? }   // ← UB
//     // }
//
// (C) Авто-cancellation остальных spawn'ов scope'а при ошибке
//     одного — нужно cancel-channel в NovaFiberQueue. Не сделано.
//
// Способ обнаружить ошибку из spawn в bootstrap'е — только явный
// mut-флаг (см. Section 1, 3). Это эквивалент Go-style "errgroup"
// без пересылки error через границу goroutine.

test "doc: error-flag is the ONLY way to detect spawn failures (bootstrap)" {
    // Этот тест существует чтобы зафиксировать текущее ограничение.
    let mut spawn_completed = false
    supervised {
        spawn {
            // Делаем что-то, что МОГЛО бы fail'нуться.
            let n = 42
            if n > 0 {
                spawn_completed = true
            }
            // Если бы был throw — мы бы НЕ установили spawn_completed.
        }
    }
    // Проверка успеха = проверка что флаг был установлен.
    assert(spawn_completed)
}
