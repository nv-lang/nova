// 54_throw_in_expression.nv — D25/D65: `throw` как expression, type Never.
//
// До этого `throw` парсился ТОЛЬКО как Stmt::Throw (statement-level).
// Spec D65 «Fail strict»: throw — операция эффекта Fail с типом Never.
// Это значит throw должен быть валидной expression в любой позиции,
// требующей значения — match-arm body, тернарник, аргумент функции и т.д.
//
// В codegen: ExprKind::Throw эмитируется как `Nova_Fail_fail(msg);` +
// dummy `((nova_int)0LL)` (никогда не используется — control не вернётся).

module spec.throw_in_expression

// ================================================================
// SECTION 1: throw в match-arm body
// ================================================================

fn check_positive(n int) -> int {
    match n {
        0 => 0
        _ if n > 0 => n * 2
        _ => throw "negative not allowed"
    }
}

test "throw in match-arm — handler catches" {
    let mut caught = ""
    let mut got = -1
    with Fail = handler Fail {
        fail(msg) {
            caught = msg
            return ()
        }
    } {
        got = check_positive(-5)
    }
    assert(caught == "negative not allowed")
}

test "throw in match-arm — happy path returns value" {
    let mut got = -1
    with Fail = handler Fail {
        fail(_msg) { return () }
    } {
        got = check_positive(5)
    }
    assert(got == 10)
}

// ================================================================
// SECTION 2: throw в if-else expression position
// ================================================================

// Note: if-else с throw в одной из веток требует, чтобы тип ветки
// throw был совместим с другой веткой. Bootstrap-codegen для if-без-
// trailing считает unit, что конфликтует с int. Workaround — throw
// делается как statement, после if-else возвращается реальное значение:

fn assert_not_zero(n int) -> int {
    if n == 0 { throw "zero forbidden" }
    n + 1
}

test "throw before fall-through statement" {
    let mut caught = ""
    with Fail = handler Fail {
        fail(msg) {
            caught = msg
            return ()
        }
    } {
        let _ = assert_not_zero(0)
    }
    assert(caught == "zero forbidden")
}

test "throw before fall-through — happy path" {
    let mut got = -1
    with Fail = handler Fail {
        fail(_msg) { return () }
    } {
        got = assert_not_zero(7)
    }
    assert(got == 8)
}
