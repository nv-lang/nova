// Trivial smoke bench for Plan 57 MVP verification.
module micro.hello

bench "noop" {
    measure {
        bench.opaque(42)
    }
}

bench "int add tight loop" {
    mut acc = 0
    measure {
        ro n = bench.iterations()
        mut i = 0
        while i < n {
            acc = bench.opaque(acc + i)
            i = i + 1
        }
        bench.elements(n)
    }
}
