// Plan 57 corpus 05: channel runtime + select multiplexing.
// Measures channel send/recv codegen + select codegen.

fn producer(tx ChanWriter[int], n int) -> () {
    mut i = 0
    while i < n {
        tx.send(i)
        i = i + 1
    }
    tx.close()
}

fn consumer(rx ChanReader[int]) -> int {
    mut sum = 0
    while Some(v) = rx.recv() {
        sum = sum + v
    }
    sum
}

fn dual_select() -> int {
    ro (tx_a, rx_a) = Channel.new(10)
    ro (tx_b, rx_b) = Channel.new(10)
    supervised {
        spawn { producer(tx_a, 5) }
        spawn { producer(tx_b, 5) }
    }
    mut total = 0
    loop {
        select {
            msg <- rx_a => {
                if Some(v) = msg { total = total + v } else { break }
            }
            msg <- rx_b => {
                if Some(v) = msg { total = total + v } else { break }
            }
        }
    }
    total
}

fn main() Io -> () {
    ro (tx, rx) = Channel.new(100)
    supervised {
        spawn { producer(tx, 100) }
    }
    ro s = consumer(rx)
    println(str.from(s))

    ro d = dual_select()
    println(str.from(d))
}
