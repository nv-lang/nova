{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "lib": ["ES2020"],
        "outDir": "./out",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "declaration": true,
        "resolveJsonModule": true
    },
    "include": [
        "client/**/*.ts",
        "tests/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "out",
        ".vscodeignore"
    ]
}
